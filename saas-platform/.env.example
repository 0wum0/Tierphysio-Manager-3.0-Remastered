APP_NAME="TheraPano"
APP_ENV=production
APP_DEBUG=false

# therapano.de  = Marketing/Landing/Login/Register (platform domain)
# app.therapano.de = Die Praxis-Software (app domain, nur mit Session)
PLATFORM_URL=https://therapano.de
APP_URL=https://app.therapano.de
APP_KEY=

# SaaS-Plattform Datenbank
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=therapano_saas
DB_USERNAME=dein_datenbankbenutzer
DB_PASSWORD=dein_datenbankpasswort

# Tenant-Datenbanken (gleicher MySQL-Server)
TENANT_DB_HOST=localhost
TENANT_DB_PORT=3306
TENANT_DB_USERNAME=dein_datenbankbenutzer
TENANT_DB_PASSWORD=dein_datenbankpasswort
TENANT_DB_PREFIX=therapano_tenant_

# Pfad zur Praxissoftware (für automatische Instanz-Erstellung)
PRACTICE_SOFTWARE_PATH=/var/www/therapano
PRACTICE_SOFTWARE_URL=https://app.therapano.de

# Session
# SESSION_DOMAIN muss mit Punkt-Prefix gesetzt werden damit der Cookie
# domain-übergreifend zwischen therapano.de und app.therapano.de gilt.
SESSION_LIFETIME=43200
SESSION_SECURE=true
SESSION_DOMAIN=.therapano.de

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@therapano.de
MAIL_FROM_NAME="TheraPano"

# Lizenz-Token Signierungsgeheimnis (mind. 32 Zeichen)
LICENSE_SECRET=aendere_mich_zu_einem_langen_geheimnis_32chars

APP_LOCALE=de
INSTALLED=false

