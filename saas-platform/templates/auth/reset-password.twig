<!DOCTYPE html>
<html lang="de" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neues Passwort setzen – TheraPano</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root { --tp-primary: #2563eb; --tp-primary-dark: #1d4ed8; }
        body {
            font-family: 'Inter', sans-serif; background: #0f172a;
            min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 1.5rem;
        }
        body::before {
            content: ''; position: fixed; inset: 0; pointer-events: none;
            background: radial-gradient(ellipse 70% 60% at 20% 30%, rgba(37,99,235,.12) 0%, transparent 60%);
        }
        .auth-wrap { width: 100%; max-width: 440px; position: relative; z-index: 1; }
        .auth-brand { text-align: center; margin-bottom: 2rem; }
        .auth-brand .logo { display: inline-flex; align-items: center; gap: .5rem; font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; margin-bottom: .5rem; }
        .auth-brand .logo span { color: var(--tp-primary); }
        .auth-brand p { color: #64748b; font-size: .875rem; margin: 0; }
        .auth-card { background: #1e293b; border: 1px solid #334155; border-radius: 1.25rem; padding: 2.25rem; }
        .auth-card h4 { color: #fff; font-weight: 700; font-size: 1.25rem; margin-bottom: .5rem; }
        .auth-card .sub { color: #64748b; font-size: .875rem; margin-bottom: 1.75rem; line-height: 1.6; }
        .form-label { color: #94a3b8; font-size: .8rem; font-weight: 600; letter-spacing: .03em; text-transform: uppercase; }
        .form-control { background: #0f172a; border-color: #334155; color: #e2e8f0; padding: .75rem 1rem; border-radius: .625rem; }
        .form-control:focus { background: #0f172a; border-color: var(--tp-primary); color: #e2e8f0; box-shadow: 0 0 0 3px rgba(37,99,235,.15); }
        .form-control::placeholder { color: #475569; }
        .btn-submit { background: var(--tp-primary); border: none; color: #fff; width: 100%; padding: .875rem; border-radius: .625rem; font-weight: 600; font-size: .95rem; transition: background .15s; display: flex; align-items: center; justify-content: center; gap: .5rem; }
        .btn-submit:hover { background: var(--tp-primary-dark); }
        .alert { border-radius: .625rem; font-size: .875rem; }
        .alert-danger { background: rgba(127,29,29,.3); border-color: #991b1b; color: #fca5a5; }
        .pw-strength { height: 4px; border-radius: 2px; margin-top: .5rem; transition: width .3s, background .3s; background: #334155; }
        .pw-hint { font-size: .75rem; color: #64748b; margin-top: .35rem; }
    </style>
</head>
<body>
<div class="auth-wrap">
    <div class="auth-brand">
        <a href="/" class="logo">Thera<span>Pano</span></a>
        <p>Die Praxis-Software für Tierphysiotherapeuten</p>
    </div>

    <div class="auth-card">
        <h4><i class="bi bi-lock me-2" style="color:var(--tp-primary);"></i>Neues Passwort setzen</h4>
        <p class="sub">Wählen Sie ein sicheres Passwort mit mindestens 8 Zeichen.</p>

        {% if flash_error %}
            <div class="alert alert-danger mb-3">
                <i class="bi bi-exclamation-triangle me-1"></i> {{ flash_error }}
            </div>
        {% endif %}

        <form method="POST" action="/reset-password" id="resetForm">
            {{ csrf_field()|raw }}
            <input type="hidden" name="token" value="{{ token|e }}">

            <div class="mb-3">
                <label class="form-label">Neues Passwort</label>
                <input
                    type="password"
                    name="password"
                    id="pw"
                    class="form-control"
                    placeholder="Mindestens 8 Zeichen"
                    autocomplete="new-password"
                    required
                    minlength="8"
                    autofocus
                >
                <div class="pw-strength" id="pwStrength" style="width:0;"></div>
                <div class="pw-hint" id="pwHint"></div>
            </div>
            <div class="mb-4">
                <label class="form-label">Passwort bestätigen</label>
                <input
                    type="password"
                    name="password_confirm"
                    id="pwConfirm"
                    class="form-control"
                    placeholder="Passwort wiederholen"
                    autocomplete="new-password"
                    required
                >
                <div class="pw-hint" id="matchHint"></div>
            </div>
            <button type="submit" class="btn-submit">
                <i class="bi bi-check-lg"></i> Passwort speichern
            </button>
        </form>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const pw = document.getElementById('pw');
    const bar = document.getElementById('pwStrength');
    const hint = document.getElementById('pwHint');
    const confirm = document.getElementById('pwConfirm');
    const matchHint = document.getElementById('matchHint');

    pw.addEventListener('input', () => {
        const v = pw.value;
        let score = 0;
        if (v.length >= 8) score++;
        if (/[A-Z]/.test(v)) score++;
        if (/[0-9]/.test(v)) score++;
        if (/[^A-Za-z0-9]/.test(v)) score++;
        const colors = ['#ef4444','#f59e0b','#22c55e','#16a34a'];
        const labels = ['Schwach','Mittel','Stark','Sehr stark'];
        bar.style.width = (score * 25) + '%';
        bar.style.background = colors[score - 1] ?? '#334155';
        hint.textContent = score > 0 ? labels[score - 1] : '';
        hint.style.color = colors[score - 1] ?? '#64748b';
    });

    confirm.addEventListener('input', () => {
        if (confirm.value && confirm.value !== pw.value) {
            matchHint.textContent = 'Passwörter stimmen nicht überein';
            matchHint.style.color = '#f87171';
        } else if (confirm.value) {
            matchHint.textContent = 'Passwörter stimmen überein ✓';
            matchHint.style.color = '#34d399';
        } else {
            matchHint.textContent = '';
        }
    });

    document.getElementById('resetForm').addEventListener('submit', e => {
        if (pw.value !== confirm.value) {
            e.preventDefault();
            matchHint.textContent = 'Passwörter stimmen nicht überein';
            matchHint.style.color = '#f87171';
        }
    });
</script>
</body>
</html>
