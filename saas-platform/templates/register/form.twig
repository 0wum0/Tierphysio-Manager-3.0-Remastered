{% extends 'layouts/landing.twig' %}

{% block content %}
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
        <div class="col-lg-7">

        <div class="text-center mb-4">
            <h1 class="fw-bold text-white">Jetzt registrieren</h1>
            <p class="text-secondary">Tarif: <strong class="text-white">{{ plan.name }}</strong> –
                {{ plan.price_month|number_format(2,',','.') }} €/Monat</p>
        </div>

        <div class="card">
            <div class="card-body p-4">
                <form method="POST" action="/register">
                    {{ csrf_field()|raw }}
                    <input type="hidden" name="plan_slug" value="{{ plan.slug }}">

                    <h6 class="text-secondary mb-3" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;">Betriebsart</h6>
                    <div class="row g-2 mb-4">
                        <div class="col-sm-6">
                            <label id="lbl-therapeut" style="cursor:pointer;border:2px solid #4f7cff;border-radius:10px;padding:.9rem 1rem;display:flex;align-items:center;gap:.65rem;background:rgba(79,124,255,0.08);width:100%;" onclick="selectRegType('therapeut')">
                                <input type="radio" name="practice_type" value="therapeut" checked style="accent-color:#4f7cff;flex-shrink:0;">
                                <div>
                                    <div style="font-weight:600;font-size:.85rem;">&#x1F3E5; Tierphysiotherapie</div>
                                    <div style="font-size:.72rem;color:#94a3b8;margin-top:2px;">Praxis &middot; Patienten &middot; Behandlungen</div>
                                </div>
                            </label>
                        </div>
                        <div class="col-sm-6">
                            <label id="lbl-trainer" style="cursor:pointer;border:2px solid rgba(255,255,255,0.15);border-radius:10px;padding:.9rem 1rem;display:flex;align-items:center;gap:.65rem;width:100%;" onclick="selectRegType('trainer')">
                                <input type="radio" name="practice_type" value="trainer" style="accent-color:#4f7cff;flex-shrink:0;">
                                <div>
                                    <div style="font-weight:600;font-size:.85rem;">&#x1F415; Hundeschule / Training</div>
                                    <div style="font-size:.72rem;color:#94a3b8;margin-top:2px;">Schule &middot; Hunde &middot; Halter &middot; Training</div>
                                </div>
                            </label>
                        </div>
                    </div>

                    <hr style="border-color:#334155;">
                    <h6 class="text-secondary mb-3 mt-4" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;">Ihre Praxis / Schule</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <label class="form-label" id="lbl-practice-name">Praxisname *</label>
                            <input type="text" name="practice_name" class="form-control" required placeholder="Tierphysiotherapie Muster" id="inp-practice-name">
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Ihr Name *</label>
                            <input type="text" name="owner_name" class="form-control" required placeholder="Max Mustermann">
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Telefon</label>
                            <input type="tel" name="phone" class="form-control" placeholder="+49 ...">
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">PLZ & Ort</label>
                            <div class="input-group">
                                <input type="text" name="zip" class="form-control" placeholder="PLZ" style="max-width:100px;">
                                <input type="text" name="city" class="form-control" placeholder="Ort">
                            </div>
                        </div>
                        <div class="col-sm-8">
                            <label class="form-label">Straße</label>
                            <input type="text" name="address" class="form-control" placeholder="Musterstraße 1">
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label">Land</label>
                            <select name="country" class="form-select">
                                <option value="DE">Deutschland</option>
                                <option value="AT">Österreich</option>
                                <option value="CH">Schweiz</option>
                            </select>
                        </div>
                    </div>

                    <hr style="border-color:#334155;">
                    <h6 class="text-secondary mb-3 mt-4" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;">Ihr Konto</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <label class="form-label">E-Mail-Adresse *</label>
                            <input type="email" name="email" class="form-control" required placeholder="info@praxis.de">
                            <div class="form-text" style="color:#64748b;">Diese E-Mail wird Ihr Login-Name.</div>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Passwort * (min. 8 Zeichen)</label>
                            <input type="password" name="password" class="form-control" required minlength="8" placeholder="••••••••">
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Abrechnungszyklus</label>
                            <select name="billing_cycle" class="form-select">
                                <option value="monthly">Monatlich ({{ plan.price_month|number_format(2,',','.') }} €/Monat)</option>
                                <option value="yearly">Jährlich ({{ plan.price_year|number_format(2,',','.') }} €/Jahr)</option>
                            </select>
                        </div>
                    </div>

                    <hr style="border-color:#334155;">
                    <h6 class="text-secondary mb-3 mt-4" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;">Rechtliche Zustimmungen</h6>
                    <div class="mb-4">
                        {% for doc in legal_docs %}
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="legal_{{ doc.slug }}" id="legal_{{ doc.slug }}" required>
                            <label class="form-check-label" for="legal_{{ doc.slug }}" style="font-size:.875rem;">
                                Ich stimme der
                                <a href="/legal/{{ doc.slug }}" target="_blank" class="text-primary">{{ doc.title }}</a>
                                (v{{ doc.version }}) zu. *
                            </label>
                        </div>
                        {% endfor %}
                    </div>

                    {# Default-Methode: Stripe wenn aktiviert, sonst manual.
                       Pro Kachel werden Border + Background je nach Default unterschiedlich gerendert,
                       damit ohne JS bereits die richtige Vorauswahl sichtbar ist. #}
                    {% set default_method = stripe_enabled ? 'stripe' : 'manual' %}
                    {% if stripe_enabled or paypal_enabled %}
                    <hr style="border-color:#334155;">
                    <h6 class="text-secondary mb-3 mt-4" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;">Zahlungsmethode</h6>
                    <div class="row g-2 mb-4" id="payment-methods">
                        <div class="col-sm-4">
                            <label class="pay-option" onclick="selectPayment('manual')" id="pm-manual" style="cursor:pointer;border:2px solid {{ default_method == 'manual' ? '#4f7cff' : 'rgba(255,255,255,0.15)' }};border-radius:10px;padding:.75rem;display:flex;flex-direction:column;align-items:center;gap:.35rem;{% if default_method == 'manual' %}background:rgba(79,124,255,0.08);{% endif %}width:100%;text-align:center;">
                                <input type="radio" name="payment_method" value="manual"{% if default_method == 'manual' %} checked{% endif %} style="display:none;">
                                <i class="bi bi-file-earmark-text" style="font-size:1.4rem;color:#7dd3fc;"></i>
                                <div style="font-size:.8rem;font-weight:600;color:#e2e8f0;">Auf Rechnung</div>
                                <div style="font-size:.68rem;color:#64748b;">Manuell / Überweisung</div>
                            </label>
                        </div>
                        {% if stripe_enabled %}
                        <div class="col-sm-4">
                            <label class="pay-option" onclick="selectPayment('stripe')" id="pm-stripe" style="cursor:pointer;border:2px solid {{ default_method == 'stripe' ? '#4f7cff' : 'rgba(255,255,255,0.15)' }};border-radius:10px;padding:.75rem;display:flex;flex-direction:column;align-items:center;gap:.35rem;{% if default_method == 'stripe' %}background:rgba(79,124,255,0.08);{% endif %}width:100%;text-align:center;">
                                <input type="radio" name="payment_method" value="stripe"{% if default_method == 'stripe' %} checked{% endif %} style="display:none;">
                                <svg width="32" height="14" viewBox="0 0 60 25" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin:.15rem 0;">
                                    <path d="M4.5 9.5c0-1.2.9-1.7 2.4-1.7 2.1 0 4.8.7 6.9 1.9V3.4C11.6 2.5 9 2 6.5 2 2.7 2 0 4 0 9.7c0 9.2 12.1 7.7 12.1 11.7 0 1.4-1.2 1.9-2.8 1.9-2.4 0-5.5-.9-8-2.4v6.5c2.7 1.2 5.5 1.7 8 1.7 6 0 10.1-3 10.1-8.5-.2-9.9-12.9-8.1-12.9-11.1z" fill="#6772E5"/>
                                    <path d="M24 8.5l-.4-2H18v17.5h5.9v-9.3c1.4-1.9 3.8-1.5 4.5-1.3V8.1c-.8-.2-3.6-.7-4.4.4z" fill="#6772E5"/>
                                    <path d="M35.5 2l-5.9 1.3v4.8h-3v4.8h3v8.6c0 3.5 2.1 4.8 5.7 4.8 1.5 0 3.3-.5 4.3-1.1v-4.8c-.8.4-4.1 1.2-4.1-1.2v-6.3H39V8.1h-3.5V2z" fill="#6772E5"/>
                                    <path d="M40 8.1h5.9V26H40z" fill="#6772E5"/>
                                    <path d="M42.9 6.3c1.9 0 3.4-1.5 3.4-3.2S44.8 0 42.9 0 39.5 1.4 39.5 3.1s1.5 3.2 3.4 3.2z" fill="#6772E5"/>
                                    <path d="M57.4 14.8L63 8.1h-7l-3.4 4.8V0h-5.9v26h5.9v-5l1.1-1.5 3.8 6.5H63l-5.6-10.2z" fill="#6772E5"/>
                                </svg>
                                <div style="font-size:.8rem;font-weight:600;color:#e2e8f0;">Stripe</div>
                                <div style="font-size:.68rem;color:#64748b;">Karte &middot; SEPA &middot; Link</div>
                            </label>
                        </div>
                        {% endif %}
                        {% if paypal_enabled %}
                        <div class="col-sm-4">
                            <label class="pay-option" onclick="selectPayment('paypal')" id="pm-paypal" style="cursor:pointer;border:2px solid rgba(255,255,255,0.15);border-radius:10px;padding:.75rem;display:flex;flex-direction:column;align-items:center;gap:.35rem;width:100%;text-align:center;">
                                <input type="radio" name="payment_method" value="paypal" style="display:none;">
                                <svg width="32" height="20" viewBox="0 0 24 24" fill="#009cde" xmlns="http://www.w3.org/2000/svg" style="margin:.15rem 0;">
                                    <path d="M7.3 21.6H5.1l.4-2.6H7c.5 0 .8.1 1 .3.2.2.3.4.3.7 0 .4-.1.8-.4 1-.2.4-.6.6-1 .6zM20.3 3.6c-.3-1.3-1-2.3-1.9-3C17.5.2 16.1 0 14.4 0H8.7c-.5 0-.9.3-1 .8L5.6 13.8c-.1.3.1.6.4.7H9l.8-5.2-.1.4c.1-.5.5-.8 1-.8h2.1c4.2 0 7.4-1.7 8.4-6.6v-.3c-.2-.2-.2-.2 0-.4z"/>
                                    <path d="M20.3 3.6c-.1.3-.2.5-.3.8-1.1 5.5-4.8 7.4-9.5 7.4H8.3c-.6 0-1.1.4-1.2 1L5.9 20c-.1.3.1.6.4.7H9c.4 0 .8-.3.9-.7l.1-.3.7-4.5.1-.3c.1-.4.5-.7.9-.7h.6c3.7 0 6.6-1.5 7.4-5.8.4-1.8.2-3.3-.7-4.4-.2-.2-.5-.2-.7-.4z"/>
                                </svg>
                                <div style="font-size:.8rem;font-weight:600;color:#e2e8f0;">PayPal</div>
                                <div style="font-size:.68rem;color:#64748b;">Abo &middot; Wiederkehrend</div>
                            </label>
                        </div>
                        {% endif %}
                    </div>
                    {% else %}
                    <input type="hidden" name="payment_method" value="manual">
                    {% endif %}

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" id="submit-btn">
                        <i class="bi bi-rocket-takeoff me-2"></i><span id="submit-label">{% if default_method == 'stripe' %}Weiter zu Stripe →{% else %}Jetzt Konto erstellen{% endif %}</span>
                    </button>

                    <p class="text-center text-secondary mt-3 mb-0" style="font-size:.8rem;">
                        <i class="bi bi-shield-lock me-1"></i>
                        Ihre Daten werden DSGVO-konform auf EU-Servern gespeichert.
                    </p>
                </form>
<script>
function selectPayment(method) {
    document.querySelectorAll('.pay-option').forEach(function(el) {
        el.style.border = '2px solid rgba(255,255,255,0.15)';
        el.style.background = '';
    });
    var selected = document.getElementById('pm-' + method);
    if (selected) {
        selected.style.border = '2px solid #4f7cff';
        selected.style.background = 'rgba(79,124,255,0.08)';
    }
    var radio = document.querySelector('input[name="payment_method"][value="' + method + '"]');
    if (radio) radio.checked = true;
    var lbl = document.getElementById('submit-label');
    if (lbl) {
        if (method === 'stripe') lbl.textContent = 'Weiter zu Stripe →';
        else if (method === 'paypal') lbl.textContent = 'Weiter zu PayPal →';
        else lbl.textContent = 'Jetzt Konto erstellen';
    }
}
</script>
<script>
function selectRegType(type) {
    var lt = document.getElementById('lbl-therapeut');
    var lr = document.getElementById('lbl-trainer');
    var ln = document.getElementById('lbl-practice-name');
    var ip = document.getElementById('inp-practice-name');
    if (!lt || !lr) return;
    if (type === 'therapeut') {
        lt.style.border = '2px solid #4f7cff';
        lt.style.background = 'rgba(79,124,255,0.08)';
        lr.style.border = '2px solid rgba(255,255,255,0.15)';
        lr.style.background = '';
        if (ln) ln.textContent = 'Praxisname *';
        if (ip) ip.placeholder = 'Tierphysiotherapie Muster';
    } else {
        lr.style.border = '2px solid #4f7cff';
        lr.style.background = 'rgba(79,124,255,0.08)';
        lt.style.border = '2px solid rgba(255,255,255,0.15)';
        lt.style.background = '';
        if (ln) ln.textContent = 'Name der Hundeschule *';
        if (ip) ip.placeholder = 'Hundeschule Muster';
    }
}
</script>
            </div>
        </div>

        <div class="text-center mt-3">
            <a href="/register" class="text-secondary" style="font-size:.8rem;">Anderen Tarif wählen</a>
        </div>
        </div>
        </div>
    </div>
</section>
{% endblock %}
