<!DOCTYPE html>
<html lang="de" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ page_title ?? 'Tierphysio SaaS' }}{% endblock %} – {{ app_name }}</title>
    <meta name="robots" content="noindex, nofollow">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --saas-primary: #2563eb;
            --saas-primary-hover: #1d4ed8;
            --saas-sidebar-width: 260px;
        }
        [data-bs-theme="dark"] {
            --bs-body-bg: #0f172a;
            --bs-body-color: #e2e8f0;
            --bs-card-bg: #1e293b;
            --bs-border-color: #334155;
        }
        body { font-family: 'Inter', sans-serif; }

        /* Sidebar */
        .sidebar {
            width: var(--saas-sidebar-width);
            min-height: 100vh;
            background: #1e293b;
            border-right: 1px solid #334155;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            display: flex; flex-direction: column;
            z-index: 1000;
            transition: transform .3s ease;
        }
        .sidebar-brand {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid #334155;
            text-decoration: none;
        }
        .sidebar-brand h5 {
            color: #fff;
            font-weight: 700;
            margin: 0;
            font-size: 1rem;
        }
        .sidebar-brand span { color: var(--saas-primary); }
        .sidebar-nav { flex: 1; padding: 1rem 0; overflow-y: auto; }
        .sidebar-section {
            padding: .25rem 1rem .25rem;
            font-size: .7rem;
            font-weight: 600;
            letter-spacing: .08em;
            color: #64748b;
            text-transform: uppercase;
            margin-top: .75rem;
        }
        .sidebar-link {
            display: flex;
            align-items: center;
            gap: .75rem;
            padding: .5rem 1.5rem;
            color: #94a3b8;
            text-decoration: none;
            font-size: .875rem;
            transition: all .15s;
            border-left: 3px solid transparent;
        }
        .sidebar-link:hover, .sidebar-link.active {
            color: #fff;
            background: rgba(255,255,255,.05);
        }
        .sidebar-link.active { border-left-color: var(--saas-primary); color: #fff; }
        .sidebar-link i { font-size: 1rem; width: 1.25rem; text-align: center; }
        .sidebar-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid #334155;
            font-size: .8rem;
            color: #64748b;
        }

        /* Main content */
        .main-content {
            margin-left: var(--saas-sidebar-width);
            min-height: 100vh;
            display: flex; flex-direction: column;
        }
        .topbar {
            background: #1e293b;
            border-bottom: 1px solid #334155;
            padding: .75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky; top: 0;
            z-index: 999;
        }
        .page-content { padding: 1.5rem; flex: 1; }

        /* Cards */
        .card { border: 1px solid #334155; background: #1e293b; }
        .card-header { background: rgba(255,255,255,.03); border-bottom: 1px solid #334155; }

        /* Stat cards */
        .stat-card { border-radius: .75rem; padding: 1.25rem 1.5rem; }
        .stat-value { font-size: 2rem; font-weight: 700; line-height: 1; }
        .stat-label { font-size: .8rem; color: #94a3b8; margin-top: .25rem; }

        /* Badges */
        .badge-active    { background: #064e3b; color: #6ee7b7; }
        .badge-trial     { background: #2e1065; color: #c4b5fd; }
        .badge-pending   { background: #3b1a08; color: #fdba74; }
        .badge-suspended { background: #1f1635; color: #a78bfa; }
        .badge-cancelled { background: #1c1c1c; color: #94a3b8; }
        .badge-paused    { background: #0c2a4a; color: #7dd3fc; }

        /* Table */
        .table { color: #e2e8f0; }
        .table thead th { color: #94a3b8; border-color: #334155; font-weight: 500; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; }
        .table td { border-color: #1e293b; vertical-align: middle; }
        .table tbody tr:hover { background: rgba(255,255,255,.02); }

        /* Forms */
        .form-control, .form-select {
            background: #0f172a;
            border-color: #334155;
            color: #e2e8f0;
        }
        .form-control:focus, .form-select:focus {
            background: #0f172a;
            border-color: var(--saas-primary);
            color: #e2e8f0;
            box-shadow: 0 0 0 3px rgba(37,99,235,.15);
        }
        .form-label { color: #94a3b8; font-size: .875rem; font-weight: 500; }

        /* Alerts */
        .alert { border-radius: .5rem; }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .main-content { margin-left: 0; }
        }
    </style>
    {% block styles %}{% endblock %}
</head>
<body>

{% block body %}
<div class="sidebar" id="sidebar">
    <a href="/admin" class="sidebar-brand">
        <h5>Thera<span>Pano</span></h5>
        <small style="color:#64748b;font-size:.7rem;">Verwaltungsplattform</small>
    </a>

    <nav class="sidebar-nav">
        <div class="sidebar-section">Übersicht</div>
        <a href="/admin" class="sidebar-link {% if active_nav == 'dashboard' %}active{% endif %}">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="sidebar-section">Verwaltung</div>
        <a href="/admin/tenants" class="sidebar-link {% if active_nav == 'tenants' %}active{% endif %}">
            <i class="bi bi-building"></i> Praxen
        </a>
        <a href="/admin/plans" class="sidebar-link {% if active_nav == 'plans' %}active{% endif %}">
            <i class="bi bi-collection"></i> Abo-Pläne
        </a>
        <a href="/admin/invoices" class="sidebar-link {% if active_nav == 'invoices' %}active{% endif %}">
            <i class="bi bi-receipt"></i> Rechnungen
        </a>
        <a href="/admin/migration" class="sidebar-link {% if active_nav == 'migration' %}active{% endif %}">
            <i class="bi bi-database-up"></i> Daten-Import
        </a>

        <div class="sidebar-section">Rechtliches</div>
        <a href="/admin/legal" class="sidebar-link {% if active_nav == 'legal' %}active{% endif %}">
            <i class="bi bi-file-earmark-text"></i> Dokumente
        </a>

        <div class="sidebar-section">System</div>
        <a href="/admin/settings" class="sidebar-link {% if active_nav == 'settings' %}active{% endif %}">
            <i class="bi bi-gear"></i> Einstellungen
        </a>
        <a href="/admin/feedback" class="sidebar-link {% if active_nav == 'feedback' %}active{% endif %}">
            <i class="bi bi-chat-square-text"></i> Feedback
            {# badge injected by JS #}
        </a>
        <a href="/admin/notifications" class="sidebar-link {% if active_nav == 'notifications' %}active{% endif %}" id="sidebar-notif-link">
            <i class="bi bi-bell"></i> Benachrichtigungen
            <span class="ms-auto badge bg-primary" id="sidebar-notif-count" style="display:none;font-size:.65rem;"></span>
        </a>
        <a href="/admin/updates" class="sidebar-link {% if active_nav == 'updates' %}active{% endif %}" id="sidebar-update-link">
            <i class="bi bi-arrow-repeat"></i> Updates
            <span class="ms-auto badge" id="sidebar-update-badge" style="display:none;font-size:.65rem;background:#22c55e;color:#fff;">NEU</span>
        </a>
        <a href="/admin/logout" class="sidebar-link" style="color:#f87171;margin-top:auto;">
            <i class="bi bi-box-arrow-left"></i> Abmelden
        </a>
    </nav>

    <div class="sidebar-footer">
        <div style="display:flex;align-items:center;gap:.5rem;">
            <div style="width:1.75rem;height:1.75rem;background:var(--saas-primary);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;color:#fff;flex-shrink:0;">
                {{ (auth_user ?? 'A')|slice(0,1)|upper }}
            </div>
            <div>
                <div style="color:#e2e8f0;font-size:.8rem;font-weight:600;">{{ auth_user ?? 'Admin' }}</div>
                <div style="color:#475569;font-size:.7rem;">{{ auth_role ?? '' }}</div>
            </div>
        </div>
    </div>
</div>

<div class="main-content">
    <div class="topbar">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-sm btn-outline-secondary d-md-none" onclick="document.getElementById('sidebar').classList.toggle('open')">
                <i class="bi bi-list"></i>
            </button>
            <h6 class="mb-0 fw-semibold">{{ page_title ?? '' }}</h6>
        </div>
        <div class="d-flex align-items-center gap-2">

            {# ── Update-Badge ───────────────────────────────────── #}
            <a href="/admin/updates" id="topbar-update-btn" class="btn btn-sm btn-outline-secondary position-relative" style="display:none;" title="Update verfügbar">
                <i class="bi bi-arrow-repeat"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill" style="background:#22c55e;font-size:.6rem;">NEU</span>
            </a>

            {# ── Benachrichtigungs-Glocke ────────────────────────── #}
            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary position-relative" id="notifDropdownBtn" data-bs-toggle="dropdown" aria-expanded="false" title="Benachrichtigungen">
                    <i class="bi bi-bell"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notif-badge" style="font-size:.6rem;display:none;"></span>
                </button>
                <div class="dropdown-menu dropdown-menu-end p-0" style="width:340px;background:#1e293b;border:1px solid #334155;border-radius:.75rem;overflow:hidden;" id="notif-dropdown">
                    <div style="padding:.75rem 1rem;border-bottom:1px solid #334155;display:flex;align-items:center;justify-content:space-between;">
                        <span style="font-weight:600;font-size:.875rem;color:#e2e8f0;">Benachrichtigungen</span>
                        <a href="/admin/notifications" style="font-size:.75rem;color:#60a5fa;">Alle anzeigen</a>
                    </div>
                    <div id="notif-list" style="max-height:320px;overflow-y:auto;">
                        <div style="padding:2rem;text-align:center;color:#475569;font-size:.8rem;">
                            <i class="bi bi-bell-slash" style="font-size:1.5rem;display:block;margin-bottom:.5rem;"></i>Keine neuen Benachrichtigungen
                        </div>
                    </div>
                    <div style="padding:.5rem 1rem;border-top:1px solid #334155;" id="notif-footer" style="display:none;">
                        <form method="POST" action="/admin/notifications/mark-all-read" style="margin:0;">
                            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                            <button type="submit" class="btn btn-sm btn-outline-secondary w-100" style="font-size:.75rem;"><i class="bi bi-check2-all me-1"></i>Alle als gelesen markieren</button>
                        </form>
                    </div>
                </div>
            </div>

            {# ── Schnellzugriff Einstellungen ─────────────────────── #}
            <a href="/admin/settings" class="btn btn-sm btn-outline-secondary" title="Einstellungen">
                <i class="bi bi-gear"></i>
            </a>

            <span class="badge" style="background:rgba(37,99,235,.2);color:#60a5fa;border:1px solid rgba(37,99,235,.3);">{{ auth_role ?? '' }}</span>
        </div>
    </div>

    <div class="page-content">
        {% if flash_success %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>{{ flash_success }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endif %}
        {% if flash_error %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>{{ flash_error }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endif %}
        {% if flash_info %}
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="bi bi-info-circle me-2"></i>{{ flash_info }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endif %}

        {% block content %}{% endblock %}
    </div>
</div>
{% endblock %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block scripts %}{% endblock %}

<script>
// ── Benachrichtigungs-Polling ─────────────────────────────────────────────
const NOTIF_ICONS = {
    new_tenant:   'bi-building-add',
    payment:      'bi-credit-card-2-front',
    overdue:      'bi-exclamation-triangle',
    trial_expiry: 'bi-hourglass-split',
    system_update:'bi-arrow-repeat',
};

async function loadNotifications() {
    try {
        const res  = await fetch('/admin/notifications/api/unread', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        if (!res.ok) return;
        const data = await res.json();

        const badge       = document.getElementById('notif-badge');
        const sidebarCount= document.getElementById('sidebar-notif-count');
        const list        = document.getElementById('notif-list');
        const footer      = document.getElementById('notif-footer');

        if (data.count > 0) {
            badge.textContent  = data.count > 99 ? '99+' : data.count;
            badge.style.display = '';
            if (sidebarCount) { sidebarCount.textContent = data.count; sidebarCount.style.display = ''; }

            if (list && data.items && data.items.length > 0) {
                list.innerHTML = data.items.map(n => {
                    const icon = NOTIF_ICONS[n.type] ?? 'bi-bell';
                    const time = new Date(n.created_at).toLocaleString('de-DE', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
                    return `<div style="padding:.75rem 1rem;border-bottom:1px solid #0f172a;display:flex;gap:.75rem;align-items:flex-start;">
                        <div style="width:2rem;height:2rem;border-radius:.4rem;background:rgba(37,99,235,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#60a5fa;font-size:.85rem;">
                            <i class="bi ${icon}"></i>
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:.8rem;font-weight:600;color:#e2e8f0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${n.title}</div>
                            <div style="font-size:.72rem;color:#64748b;margin-top:.1rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${n.message}</div>
                            <div style="font-size:.68rem;color:#475569;margin-top:.2rem;">${time}</div>
                        </div>
                    </div>`;
                }).join('');
                if (footer) footer.style.display = '';
            }
        } else {
            badge.style.display = 'none';
            if (sidebarCount) sidebarCount.style.display = 'none';
            if (list) list.innerHTML = '<div style="padding:2rem;text-align:center;color:#475569;font-size:.8rem;"><i class="bi bi-bell-slash" style="font-size:1.5rem;display:block;margin-bottom:.5rem;"></i>Keine neuen Benachrichtigungen</div>';
            if (footer) footer.style.display = 'none';
        }
    } catch (e) {}
}

// ── Update-Check ──────────────────────────────────────────────────────────
async function checkForUpdate() {
    try {
        const res  = await fetch('/admin/updates/check', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        if (!res.ok) return;
        const data = await res.json();
        if (data.has_update) {
            const btn   = document.getElementById('topbar-update-btn');
            const badge = document.getElementById('sidebar-update-badge');
            if (btn)   btn.style.display = '';
            if (badge) badge.style.display = '';
        }
    } catch (e) {}
}

// Sofort + alle 60s Benachrichtigungen laden
loadNotifications();
setInterval(loadNotifications, 60000);

// Update-Check einmal beim Laden (mit Verzögerung)
setTimeout(checkForUpdate, 4000);
</script>
</body>
</html>
