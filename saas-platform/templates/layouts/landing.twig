<!DOCTYPE html>
<html lang="de" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ page_title ?? 'TheraPano' }}{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}TheraPano – Die Praxis-Software für Tierphysiotherapeuten. Mehr Zeit fürs Tier, weniger Zeit am Schreibtisch.{% endblock %}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
        :root {
            --tp-primary: #2563eb;
            --tp-primary-dark: #1d4ed8;
            --tp-accent: #7c3aed;
            --tp-surface: #1e293b;
            --tp-border: #334155;
            --tp-text: #e2e8f0;
            --tp-muted: #94a3b8;
            --tp-bg: #0f172a;
        }
        * { box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--tp-bg);
            color: var(--tp-text);
            margin: 0;
        }

        /* Navbar */
        .tp-nav {
            position: sticky; top: 0; z-index: 1000;
            background: rgba(15,23,42,.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(51,65,85,.6);
            padding: .875rem 0;
        }
        .tp-nav .brand { font-weight: 800; font-size: 1.25rem; color: #fff; text-decoration: none; }
        .tp-nav .brand span { color: var(--tp-primary); }
        .tp-nav-actions { display: flex; gap: .75rem; align-items: center; }

        /* Buttons */
        .btn-tp-primary {
            background: var(--tp-primary); color: #fff; border: none;
            padding: .6rem 1.5rem; border-radius: .5rem; font-weight: 600; font-size: .9rem;
            text-decoration: none; display: inline-flex; align-items: center; gap: .5rem;
            transition: background .15s, transform .1s;
        }
        .btn-tp-primary:hover { background: var(--tp-primary-dark); color: #fff; transform: translateY(-1px); }
        .btn-tp-outline {
            background: transparent; color: var(--tp-text); border: 1px solid var(--tp-border);
            padding: .6rem 1.5rem; border-radius: .5rem; font-weight: 500; font-size: .9rem;
            text-decoration: none; display: inline-flex; align-items: center; gap: .5rem;
            transition: border-color .15s, color .15s;
        }
        .btn-tp-outline:hover { border-color: var(--tp-primary); color: var(--tp-primary); }
        .btn-tp-lg {
            padding: .875rem 2.5rem; font-size: 1rem; border-radius: .625rem;
        }

        /* Flash */
        .flash-container { position: fixed; top: 80px; right: 1.5rem; z-index: 9999; min-width: 320px; }

        /* Footer */
        .tp-footer {
            background: #0a0f1e;
            border-top: 1px solid var(--tp-border);
            padding: 3rem 0 1.5rem;
            color: var(--tp-muted);
            font-size: .875rem;
        }
        .tp-footer a { color: var(--tp-muted); text-decoration: none; }
        .tp-footer a:hover { color: var(--tp-text); }
        .tp-footer .brand { font-weight: 800; font-size: 1.1rem; color: #fff; }
        .tp-footer .brand span { color: var(--tp-primary); }

        {% block styles %}{% endblock %}
    </style>
</head>
<body>
<script>document.body.classList.add('js-ready');</script>

<!-- Navbar -->
<nav class="tp-nav">
    <div class="container d-flex align-items-center justify-content-between">
        <a href="/" class="brand">Thera<span>Pano</span></a>

        <div class="tp-nav-actions">
            <a href="#features" class="btn-tp-outline d-none d-md-inline-flex">Funktionen</a>
            <a href="#pricing" class="btn-tp-outline d-none d-md-inline-flex">Preise</a>
            <a href="/demo" class="btn-tp-outline d-none d-md-inline-flex" style="color:#a78bfa;border-color:rgba(124,58,237,.4);"><i class="bi bi-play-circle-fill"></i> Demo</a>
            <a href="/login" class="btn-tp-outline d-none d-sm-inline-flex">Anmelden</a>
            <a href="/register" class="btn-tp-primary">Kostenlos testen</a>
        </div>
    </div>
</nav>

<!-- Flash messages -->
{% if flash_success or flash_error %}
<div class="flash-container">
    {% if flash_success %}
        <div class="alert alert-success alert-dismissible fade show shadow-lg" role="alert">
            <i class="bi bi-check-circle me-2"></i>{{ flash_success }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endif %}
    {% if flash_error %}
        <div class="alert alert-danger alert-dismissible fade show shadow-lg" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>{{ flash_error }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endif %}
</div>
{% endif %}

<main>
    {% block content %}{% endblock %}
</main>

<!-- Footer -->
<footer class="tp-footer">
    <div class="container">
        <div class="row g-4 mb-4">
            <div class="col-lg-4">
                <div class="brand mb-2">Thera<span>Pano</span></div>
                <p style="color:var(--tp-muted);font-size:.85rem;line-height:1.6;">
                    Mehr Zeit fürs Tier, weniger Zeit am Schreibtisch.<br>
                    Die Praxis-Software für Tierphysiotherapeuten.
                </p>
            </div>
            <div class="col-lg-2 col-6">
                <div style="font-weight:600;color:var(--tp-text);margin-bottom:.75rem;font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;">Produkt</div>
                <div class="d-flex flex-column gap-2">
                    <a href="#features">Features</a>
                    <a href="#pricing">Preise</a>
                    <a href="/register">Registrieren</a>
                </div>
            </div>
            <div class="col-lg-2 col-6">
                <div style="font-weight:600;color:var(--tp-text);margin-bottom:.75rem;font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;">Rechtliches</div>
                <div class="d-flex flex-column gap-2">
                    <a href="/impressum">Impressum</a>
                    <a href="/datenschutz">Datenschutz</a>
                    <a href="/legal/agb">AGB</a>
                    <a href="/legal/av-vertrag">AVV</a>
                </div>
            </div>
            <div class="col-lg-4">
                <div style="font-weight:600;color:var(--tp-text);margin-bottom:.75rem;font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;">Sicherheit &amp; Compliance</div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge" style="background:#064e3b;color:#6ee7b7;font-weight:500;padding:.4rem .75rem;">DSGVO-konform</span>
                    <span class="badge" style="background:#0c2a4a;color:#7dd3fc;font-weight:500;padding:.4rem .75rem;">EU-Hosting</span>
                    <span class="badge" style="background:#1f1635;color:#a78bfa;font-weight:500;padding:.4rem .75rem;">SSL-verschlüsselt</span>
                </div>
            </div>
        </div>
        <hr style="border-color:var(--tp-border);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2" style="font-size:.8rem;">
            <span>&copy; {{ "now"|date("Y") }} TheraPano &ndash; Alle Rechte vorbehalten</span>
            <span>Made with <i class="bi bi-heart-fill" style="color:#ef4444;font-size:.7rem;"></i> in Deutschland</span>
        </div>
    </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>
