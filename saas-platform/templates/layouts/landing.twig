<!DOCTYPE html>
<html lang="de" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ page_title ?? 'TheraPano' }}{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}TheraPano – Die Premium Praxis-Software für Tierphysiotherapeuten.{% endblock %}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
        :root {
            --tp-bg: #030712;
            --tp-nav-bg: rgba(3, 7, 18, 0.9);
            --tp-primary: #3b82f6;
            --tp-border: rgba(255, 255, 255, 0.1);
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--tp-bg);
            color: #f8fafc;
            margin: 0;
            overflow-x: hidden;
            line-height: 1.6;
        }
        .tp-nav {
            position: sticky; top: 0; z-index: 1000;
            background: var(--tp-nav-bg);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--tp-border);
            padding: 1rem 0;
        }
        .tp-nav .brand { 
            font-family: 'Outfit', sans-serif;
            font-weight: 800; font-size: 1.5rem; color: #fff; text-decoration: none; 
            letter-spacing: -0.02em;
        }
        .tp-nav .brand span { color: var(--tp-primary); }
        
        .nav-link-custom {
            color: #94a3b8;
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            transition: color 0.2s;
        }
        .nav-link-custom:hover { color: #fff; }

        .btn-nav-primary {
            background: var(--tp-primary);
            color: white;
            padding: 0.6rem 1.25rem;
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.85rem;
            text-decoration: none;
            transition: transform 0.2s;
        }
        .btn-nav-primary:hover { transform: scale(1.03); color: white; }

        .btn-nav-outline {
            border: 1px solid var(--tp-border);
            color: #fff;
            padding: 0.6rem 1.25rem;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.85rem;
            text-decoration: none;
        }
    </style>
    {% block styles %}{% endblock %}
</head>
<body>

<nav class="tp-nav">
    <div class="container d-flex align-items-center justify-content-between">
        <a href="/" class="brand">Thera<span>Pano</span></a>

        <div class="d-flex align-items-center gap-4">
            <div class="d-none d-lg-flex gap-4">
                <a href="#features" class="nav-link-custom">Funktionen</a>
                <a href="#pricing" class="nav-link-custom">Preise</a>
                <a href="#faq" class="nav-link-custom">FAQ</a>
            </div>
            <div class="d-flex gap-2">
                <a href="/login" class="btn-nav-outline d-none d-sm-inline-flex">Login</a>
                <a href="/register" class="btn-nav-primary">Kostenlos testen</a>
            </div>
        </div>
    </div>
</nav>

{% if flash_success or flash_error %}
<div class="container mt-4">
    {% if flash_success %}<div class="alert alert-success">{{ flash_success }}</div>{% endif %}
    {% if flash_error %}<div class="alert alert-danger">{{ flash_error }}</div>{% endif %}
</div>
{% endif %}

<main>
    {% block content %}{% endblock %}
</main>

<footer class="py-5 mt-5" style="border-top: 1px solid var(--tp-border); background: #010409;">
    <div class="container text-center">
        <div class="brand mb-4">Thera<span>Pano</span></div>
        <div class="d-flex justify-content-center gap-4 mb-4">
            <a href="/impressum" class="nav-link-custom">Impressum</a>
            <a href="/datenschutz" class="nav-link-custom">Datenschutz</a>
        </div>
        <p class="text-muted small">&copy; {{ "now"|date("Y") }} TheraPano. Alle Rechte vorbehalten.</p>
    </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>
