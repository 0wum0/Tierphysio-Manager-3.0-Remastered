<!DOCTYPE html>
<html lang="de" data-bs-theme="dark">
<head>
            --tp-primary-dark: #1d4ed8;
            --tp-accent: #7c3aed;
            --tp-surface: #1e293b;
            --tp-border: #334155;
            --tp-text: #e2e8f0;
            --tp-muted: #94a3b8;
            --tp-bg: #0f172a;
        }
        * { box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: #0a0f1e;
            border-top: 1px solid var(--tp-border);
            padding: 3rem 0 1.5rem;
            color: var(--tp-muted);
            font-size: .875rem;
        }
        .tp-footer a { color: var(--tp-muted); text-decoration: none; }
        .tp-footer a:hover { color: var(--tp-text); }
        .tp-footer .brand { font-weight: 800; font-size: 1.1rem; color: #fff; }
        .tp-footer .brand span { color: var(--tp-primary); }

    </style>
    {% block styles %}{% endblock %}
    <script>
        (function () {
            try {
                var stored = localStorage.getItem('tp_theme');
                if (stored === 'light' || stored === 'dark') {
                    document.documentElement.setAttribute('data-bs-theme', stored);
                }
            } catch (e) {}
        })();
    </script>
</head>
<body>
<script>document.body.classList.add('js-ready');</script>

<!-- Navbar -->
<nav class="tp-nav">
    <div class="container d-flex align-items-center justify-content-between">
        <a href="/" class="brand">Thera<span>Pano</span></a>

        <div class="tp-nav-actions">
            <a href="#features" class="btn-tp-outline d-none d-md-inline-flex">Funktionen</a>
            <a href="#modules" class="btn-tp-outline d-none d-md-inline-flex">Module</a>
            <a href="#pricing" class="btn-tp-outline d-none d-md-inline-flex">Preise</a>
            <a href="#faq" class="btn-tp-outline d-none d-md-inline-flex">FAQ</a>
            <button type="button" id="themeToggle" class="btn-tp-outline d-none d-sm-inline-flex" aria-label="Theme wechseln">
                <i class="bi bi-moon-stars-fill"></i> Theme
            </button>
            <a href="/demo" class="btn-tp-outline d-none d-md-inline-flex" style="color:#a78bfa;border-color:rgba(124,58,237,.4);"><i class="bi bi-play-circle-fill"></i> Demo</a>
            <a href="/login" class="btn-tp-outline d-none d-sm-inline-flex">Anmelden</a>
            <a href="/register" class="btn-tp-primary">Kostenlos testen</a>
        </div>
    </div>
</nav>

<!-- Flash messages -->
{% if flash_success or flash_error %}
<div class="flash-container">
    {% if flash_success %}
        <div class="alert alert-success alert-dismissible fade show shadow-lg" role="alert">
            <i class="bi bi-check-circle me-2"></i>{{ flash_success }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endif %}
    {% if flash_error %}
        <div class="alert alert-danger alert-dismissible fade show shadow-lg" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>{{ flash_error }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endif %}
</div>
{% endif %}

<main>
    {% block content %}{% endblock %}
</main>

<!-- Footer -->
<footer class="tp-footer">
    <div class="container">
        <div class="row g-4 mb-4">
            <div class="col-lg-4">
                <div class="brand mb-2">Thera<span>Pano</span></div>
                <p style="color:var(--tp-muted);font-size:.85rem;line-height:1.6;">
                    Mehr Zeit fürs Tier, weniger Zeit am Schreibtisch.<br>
                    Die Praxis-Software für Tierphysiotherapeuten.
                </p>
            </div>
            <div class="col-lg-2 col-6">
                <div style="font-weight:600;color:var(--tp-text);margin-bottom:.75rem;font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;">Produkt</div>
                <div class="d-flex flex-column gap-2">
                    <a href="#features">Features</a>
                    <a href="#pricing">Preise</a>
                    <a href="/register">Registrieren</a>
                </div>
            </div>
            <div class="col-lg-2 col-6">
                <div style="font-weight:600;color:var(--tp-text);margin-bottom:.75rem;font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;">Rechtliches</div>
                <div class="d-flex flex-column gap-2">
                    <a href="/impressum">Impressum</a>
                    <a href="/datenschutz">Datenschutz</a>
                    <a href="/legal/agb">AGB</a>
                    <a href="/legal/av-vertrag">AVV</a>
                </div>
            </div>
            <div class="col-lg-4">
                <div style="font-weight:600;color:var(--tp-text);margin-bottom:.75rem;font-size:.8rem;text-transform:uppercase;letter-spacing:.06em;">Sicherheit &amp; Compliance</div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge" style="background:#064e3b;color:#6ee7b7;font-weight:500;padding:.4rem .75rem;">DSGVO-konform</span>
                    <span class="badge" style="background:#0c2a4a;color:#7dd3fc;font-weight:500;padding:.4rem .75rem;">EU-Hosting</span>
                    <span class="badge" style="background:#1f1635;color:#a78bfa;font-weight:500;padding:.4rem .75rem;">SSL-verschlüsselt</span>
                </div>
            </div>
        </div>
        <hr style="border-color:var(--tp-border);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2" style="font-size:.8rem;">
            <span>&copy; {{ "now"|date("Y") }} TheraPano &ndash; Alle Rechte vorbehalten</span>
            <span>Made with <i class="bi bi-heart-fill" style="color:#ef4444;font-size:.7rem;"></i> in Deutschland</span>
        </div>
    </div>
</footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>
