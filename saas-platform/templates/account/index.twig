{% extends 'layouts/public.twig' %}

{% block title %}Mein Konto{% endblock %}

{% block styles %}
<style>
    .account-hero {
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        border-bottom: 1px solid #1e293b;
        padding: 2.5rem 0 2rem;
    }
    .status-badge {
        font-size: .75rem;
        font-weight: 600;
        padding: .3rem .75rem;
        border-radius: 50px;
    }
    .status-trial    { background: rgba(234,179,8,.15);  color: #eab308; }
    .status-active   { background: rgba(34,197,94,.15);  color: #22c55e; }
    .status-suspended{ background: rgba(239,68,68,.15);  color: #ef4444; }
    .status-cancelled{ background: rgba(100,116,139,.15);color: #64748b; }
    .section-card {
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 12px;
        padding: 1.75rem;
        margin-bottom: 1.5rem;
    }
    .section-card h5 {
        font-size: 1rem;
        font-weight: 600;
        color: #f1f5f9;
        margin-bottom: 1.25rem;
        padding-bottom: .75rem;
        border-bottom: 1px solid #334155;
        display: flex;
        align-items: center;
        gap: .5rem;
    }
    .app-link-card {
        background: linear-gradient(135deg, rgba(37,99,235,.2), rgba(124,58,237,.2));
        border: 1px solid rgba(37,99,235,.4);
        border-radius: 12px;
        padding: 1.75rem;
        margin-bottom: 1.5rem;
        text-align: center;
    }
    .plan-card {
        background: #0f172a;
        border: 2px solid #334155;
        border-radius: 10px;
        padding: 1.25rem;
        cursor: pointer;
        transition: border-color .2s, background .2s;
    }
    .plan-card:hover  { border-color: #2563eb; background: rgba(37,99,235,.07); }
    .plan-card.active { border-color: #2563eb; background: rgba(37,99,235,.1); }
    .plan-card .price { font-size: 1.5rem; font-weight: 700; color: #fff; }
    .plan-card .name  { font-size: .9rem; font-weight: 600; color: #94a3b8; }
</style>
{% endblock %}

{% block content %}
{# ── Hero ── #}
<div class="account-hero">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <h1 class="h3 fw-bold text-white mb-1">
                    <i class="bi bi-person-circle me-2" style="color:#2563eb"></i>
                    {{ tenant.owner_name }}
                </h1>
                <p class="mb-0" style="color:#94a3b8">{{ tenant.practice_name }}</p>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="status-badge status-{{ tenant.status }}">
                    {% if tenant.status == 'trial' %}Testphase
                    {% elseif tenant.status == 'active' %}Aktiv
                    {% elseif tenant.status == 'suspended' %}Gesperrt
                    {% else %}{{ tenant.status }}{% endif %}
                </span>
                {% if tenant.trial_ends_at and tenant.status == 'trial' %}
                    <small style="color:#64748b">
                        Endet {{ tenant.trial_ends_at|date('d.m.Y') }}
                    </small>
                {% endif %}
                <a href="/logout" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-box-arrow-right me-1"></i>Abmelden
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container py-4">

    {# ── App-Link ── #}
    {% if app_url %}
    <div class="app-link-card">
        <i class="bi bi-grid-3x3-gap-fill" style="font-size:2rem;color:#2563eb;display:block;margin-bottom:.75rem"></i>
        <h5 class="text-white fw-bold mb-1">Zur Praxis-Software</h5>
        <p style="color:#94a3b8;font-size:.9rem" class="mb-3">
            Öffne deine persönliche TheraPano-Praxis-Oberfläche
        </p>
        <a href="{{ app_url }}" class="btn btn-primary px-4" target="_blank">
            <i class="bi bi-box-arrow-up-right me-2"></i>App öffnen
        </a>
    </div>
    {% endif %}

    <div class="row g-4">

        {# ── Linke Spalte ── #}
        <div class="col-lg-7">

            {# Kontodaten #}
            <div class="section-card">
                <h5><i class="bi bi-person-gear" style="color:#2563eb"></i> Kontodaten</h5>
                <form method="POST" action="/account/update">
                    <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Praxisname *</label>
                            <input type="text" name="practice_name" class="form-control"
                                   value="{{ tenant.practice_name }}" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ihr Name *</label>
                            <input type="text" name="owner_name" class="form-control"
                                   value="{{ tenant.owner_name }}" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-Mail</label>
                            <input type="email" class="form-control"
                                   value="{{ tenant.email }}" disabled>
                            <small style="color:#64748b">E-Mail kann nicht geändert werden</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="text" name="phone" class="form-control"
                                   value="{{ tenant.phone }}">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Adresse</label>
                            <input type="text" name="address" class="form-control"
                                   value="{{ tenant.address }}">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">PLZ</label>
                            <input type="text" name="zip" class="form-control"
                                   value="{{ tenant.zip }}">
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Stadt</label>
                            <input type="text" name="city" class="form-control"
                                   value="{{ tenant.city }}">
                        </div>
                    </div>
                    <div class="mt-3 text-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Speichern
                        </button>
                    </div>
                </form>
            </div>

            {# Passwort ändern #}
            <div class="section-card">
                <h5><i class="bi bi-shield-lock" style="color:#2563eb"></i> Passwort ändern</h5>
                <form method="POST" action="/account/password">
                    <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Aktuelles Passwort</label>
                            <input type="password" name="current_password" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Neues Passwort</label>
                            <input type="password" name="new_password" class="form-control"
                                   minlength="8" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Passwort bestätigen</label>
                            <input type="password" name="confirm_password" class="form-control"
                                   minlength="8" required>
                        </div>
                    </div>
                    <div class="mt-3 text-end">
                        <button type="submit" class="btn btn-outline-primary">
                            <i class="bi bi-key me-1"></i>Passwort ändern
                        </button>
                    </div>
                </form>
            </div>

        </div>

        {# ── Rechte Spalte ── #}
        <div class="col-lg-5">

            {# Aktuelles Abo #}
            <div class="section-card">
                <h5><i class="bi bi-receipt" style="color:#2563eb"></i> Aktuelles Abo</h5>
                {% if subscription %}
                    <div class="d-flex justify-content-between mb-2">
                        <span style="color:#94a3b8">Plan</span>
                        <strong class="text-white">{{ subscription.plan_name ?? tenant.plan_name }}</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span style="color:#94a3b8">Status</span>
                        <span class="status-badge status-{{ subscription.status }}">{{ subscription.status }}</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span style="color:#94a3b8">Abrechnungszyklus</span>
                        <span class="text-white">
                            {{ subscription.billing_cycle == 'yearly' ? 'Jährlich' : 'Monatlich' }}
                        </span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span style="color:#94a3b8">Betrag</span>
                        <strong class="text-white">{{ subscription.amount|number_format(2, ',', '.') }} € / {{ subscription.billing_cycle == 'yearly' ? 'Jahr' : 'Monat' }}</strong>
                    </div>
                    {% if subscription.ends_at %}
                    <div class="d-flex justify-content-between">
                        <span style="color:#94a3b8">Läuft bis</span>
                        <span class="text-white">{{ subscription.ends_at|date('d.m.Y') }}</span>
                    </div>
                    {% endif %}
                {% else %}
                    <p style="color:#64748b" class="mb-0">Kein aktives Abo gefunden.</p>
                {% endif %}
            </div>

            {# Plan wechseln #}
            {% if plans %}
            <div class="section-card">
                <h5><i class="bi bi-arrow-up-circle" style="color:#2563eb"></i> Plan wechseln</h5>
                <form method="POST" action="/account/plan">
                    <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                    <input type="hidden" name="plan_slug" id="selected_plan_slug"
                           value="{{ tenant.plan_slug }}">
                    <div class="d-flex flex-column gap-2 mb-3">
                        {% for plan in plans %}
                        <div class="plan-card {% if plan.slug == tenant.plan_slug %}active{% endif %}"
                             onclick="selectPlan('{{ plan.slug }}', this)">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="name">{{ plan.name }}</div>
                                    <div style="font-size:.8rem;color:#64748b">{{ plan.description ?? '' }}</div>
                                </div>
                                <div class="price">{{ plan.price_month|number_format(2,',','.') }}€<span style="font-size:.85rem;color:#64748b">/mo</span></div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-arrow-repeat me-1"></i>Plan wechseln
                    </button>
                </form>
            </div>
            {% endif %}

            {# Konto-Infos #}
            <div class="section-card">
                <h5><i class="bi bi-info-circle" style="color:#2563eb"></i> Konto-Informationen</h5>
                <div class="d-flex justify-content-between mb-2">
                    <span style="color:#94a3b8">Konto-ID</span>
                    <code style="color:#94a3b8;font-size:.8rem">{{ tenant.tid }}</code>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span style="color:#94a3b8">Registriert am</span>
                    <span class="text-white">{{ tenant.created_at|date('d.m.Y') }}</span>
                </div>
                {% if tenant.last_login_at %}
                <div class="d-flex justify-content-between">
                    <span style="color:#94a3b8">Letzter Login</span>
                    <span class="text-white">{{ tenant.last_login_at|date('d.m.Y H:i') }}</span>
                </div>
                {% endif %}
            </div>

        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function selectPlan(slug, el) {
    document.querySelectorAll('.plan-card').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('selected_plan_slug').value = slug;
}
</script>
{% endblock %}
