{% extends 'layouts/landing.twig' %}

{% block title %}TheraPano – Premium Praxissoftware für Tiertherapeuten & Hundeschulen{% endblock %}

{% block styles %}
<link rel="stylesheet" href="/css/landing.css?v=20260413-ux2">
<style>
    /* Hard override to ensure visible layout update even with stale cache */
    .feature-stage .bento-grid { gap: 1.4rem !important; }
    .feature-stage .bento {
        border: 2px solid rgba(59,130,246,.55) !important;
        border-radius: 20px !important;
        padding: 1.7rem !important;
        text-align: center !important;
        background: linear-gradient(160deg, rgba(37,99,235,.28), rgba(124,58,237,.22), rgba(15,23,42,.95)) !important;
        transform: none !important;
    }
    .feature-stage .bento h3 { font-size: 1.22rem !important; margin-bottom: .7rem !important; }
    .feature-stage .bento p { font-size: 1rem !important; max-width: 40ch !important; margin: 0 auto !important; }
</style>
{% endblock %}

{% block content %}
{# conflict-safe landing snapshot: premium centered layout #}
<section class="hero hero-premium" id="top">
    <div class="blob-wrap" aria-hidden="true">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
    </div>

    <div class="container hero-shell">
        <div class="hero-intro anim-fadeup">
            <span class="hero-kicker">THERAPANO SIGNATURE EXPERIENCE</span>
            <h1>Die <span class="gradient-text">einzigartige</span> Plattform für Tiertherapie & Hundetraining.</h1>
            <p>
                Ein durchgängiges Premium-System für Praxis, Reha und Hundeschule:
                Patientenmanagement, Terminlogik, Befunde, Abrechnung, Portal, Teamsteuerung,
                mobile Workflows und Automationen – visuell modern, fachlich vollständig.
            </p>
            <div class="hero-actions">
                <a href="/register" class="btn-tp-primary btn-tp-lg"><i class="bi bi-stars"></i> 14 Tage gratis starten</a>
                <a href="/demo" class="btn-tp-outline btn-tp-lg"><i class="bi bi-play-circle"></i> Live-Demo ansehen</a>
            </div>
        </div>

        <div class="hero-panel anim-fadeup anim-delay-2">
            <div class="panel-top">
                <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                <span class="panel-label">Praxis Command Center</span>
            </div>
            <div class="panel-grid">
                <div class="metric"><span>Termine heute</span><strong data-count="17">0</strong></div>
                <div class="metric"><span>Aktive Fälle</span><strong data-count="146">0</strong></div>
                <div class="metric"><span>Neue Intake-Formulare</span><strong data-count="6">0</strong></div>
                <div class="metric"><span>Automatisierte Erinnerungen</span><strong data-count="34">0</strong></div>
            </div>
            <div class="focus-card">
                <small>Nächster Kundenkontakt</small>
                <h6>🐕 Milo · Gangbildanalyse + Trainingsplan</h6>
                <p>11:00 Uhr · 45 Min · im Besitzerportal bestätigt</p>
                <div class="mockup-progress"><span class="mockup-progress-fill"></span></div>
            </div>
        </div>
    </div>
</section>

<section class="brand-strip">
    <div class="container">
        <div class="strip-grid">
            <span>🐾 Für Tierphysiotherapeuten</span>
            <span>🦮 Für Hundeschulen</span>
            <span>🐴 Für Pferdetherapeuten</span>
            <span>🏥 Für Reha-Zentren</span>
            <span>🚐 Für mobile Praxen</span>
        </div>
    </div>
</section>

<section class="feature-stage" id="features">
    <div class="container">
        <div class="section-head reveal text-center">
            <span class="section-label">Kompletter Funktionskatalog</span>
            <h2 class="section-title">Alles drin – ohne Tool-Chaos, ohne Medienbruch</h2>
            <p class="section-sub mx-auto">
                Basierend auf den realen Modulen deiner Plattform: von Patienten- und Besitzerverwaltung über Kalender,
                Befunde, Rechnungen, Mahnungen und Kommunikation bis zu Owner-Portal, Mobile API, Therapy Care Pro,
                Steuerexport und intelligenten Automationen.
            </p>
        </div>

        <div class="bento-grid">
            <article class="bento bento-large reveal">
                <h3>🧠 Praxis-Kern</h3>
                <p>Patienten, Besitzer, Akten, Anamnese, Befunde, Verlauf, Medien und strukturierte Therapiedokumentation – komplett digital und jederzeit abrufbar.</p>
            </article>
            <article class="bento reveal transition-delay-1"><h3>📅 Termin-Engine</h3><p>Kalender, Warteliste, Statuslogik, Google-Sync, Erinnerungen & Follow-up.</p></article>
            <article class="bento reveal transition-delay-2"><h3>🧾 Umsatz-Flow</h3><p>Rechnungen, Mahnungen, Zahlstatus, Ausgaben und steuerrelevante Exporte.</p></article>
            <article class="bento reveal transition-delay-3"><h3>🏠 Besitzerportal</h3><p>Termine, Rechnungen, Befunde, Nachrichten und Übungsfreigaben für Tierhalter.</p></article>
            <article class="bento reveal"><h3>📱 Mobile App/API</h3><p>Volle Prozesse mobil: Patienten, Termine, Rechnungen, Befunde, Nachrichten, Dashboards.</p></article>
            <article class="bento reveal transition-delay-1"><h3>🎓 Übungen & Hausaufgaben</h3><p>Trainingspläne, Vorlagen, Fortschritt, PDF-Export und Rückmeldungen.</p></article>
            <article class="bento reveal transition-delay-2"><h3>📈 Therapy Care Pro</h3><p>Fortschrittskategorien, Berichte, Bibliothek, Naturheilkunde, Reminder-Queue.</p></article>
            <article class="bento reveal transition-delay-3"><h3>🧩 Plugin-Ökosystem</h3><p>Bulk-Mail, Intake, Owner-Portal, Kalender-Erweiterungen und modulare Erweiterbarkeit.</p></article>
            <article class="bento reveal"><h3>🔒 Compliance & Sicherheit</h3><p>DSGVO-orientierte Prozesse, Rollen, Zugriffssteuerung, Dokumentation, sichere Kommunikation.</p></article>
        </div>
    </div>
</section>

<section class="audience-section" id="modules">
    <div class="container">
        <div class="section-head text-center reveal">
            <span class="section-label">Passend für jede Arbeitsweise</span>
            <h2 class="section-title">Tiertherapie + Hundeschule: Eine Oberfläche, zwei perfekte Workflows</h2>
        </div>

        <div class="audience-grid">
            <article class="aud-card reveal-left">
                <h3>Für Tiertherapeuten</h3>
                <p>Dokumentation, Verlauf, Befundqualität, Behandlungshistorie, Abrechnung und Nachsorge in einem klinisch klaren Prozess.</p>
                <div class="mini-tags"><span>Verlaufsdoku</span><span>Befundlogik</span><span>Rechnung & Mahnung</span></div>
            </article>
            <article class="aud-card reveal-right">
                <h3>Für Hundeschulen & Trainer</h3>
                <p>Trainingseinheiten, Teilnehmerverwaltung, Hausaufgabenpläne, Kundenkommunikation und Fortschrittsfeedback professionell bündeln.</p>
                <div class="mini-tags"><span>Trainingspläne</span><span>Kurslogik</span><span>Kundenportal</span></div>
            </article>
        </div>
    </div>
</section>

<section class="pricing" id="pricing">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <div class="section-label">Preise</div>
            <h2 class="section-title">Skalierbar vom Solo-Profi bis zur Premium-Praxis</h2>
            <p class="section-sub mx-auto">14 Tage kostenlos, kein Risiko, sofort einsatzbereit.</p>
        </div>

        {% if plans is defined and plans|length > 0 %}
            <div class="row g-4 justify-content-center">
                {% for plan in plans %}
                    <div class="col-md-6 col-lg-4 reveal transition-delay-{{ loop.index }}">
                        <div class="price-card {% if loop.index == 2 %}featured{% endif %}">
                            {% if loop.index == 2 %}<span class="featured-badge">Empfohlen</span>{% endif %}
                            <div class="price-name">{{ plan.name }}</div>
                            <div class="price-amount">{{ plan.price_month ?? '29' }}€ <span>/ Monat</span></div>
                            <div class="price-desc">{{ plan.description ?? 'Ideal für Ihren Einsatzbereich' }}</div>
                            <hr class="price-divider">
                            <ul class="price-features">
                                {% set features = plan.features ? plan.features|json_decode : [] %}
                                {% for feature in features %}
                                    <li><i class="bi bi-check-circle-fill"></i> {{ feature }}</li>
                                {% else %}
                                    <li><i class="bi bi-check-circle-fill"></i> Patienten, Termine, Befunde, Rechnungen</li>
                                    <li><i class="bi bi-check-circle-fill"></i> Portal + mobile Workflows</li>
                                    <li><i class="bi bi-check-circle-fill"></i> Automationen & Erinnerungen</li>
                                {% endfor %}
                            </ul>
                            <a href="/register/{{ plan.slug }}" class="{% if loop.index == 2 %}btn-tp-primary{% else %}btn-tp-outline{% endif %}" style="display:flex;justify-content:center;">Jetzt starten</a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

<section class="faq-section" id="faq">
    <div class="container">
        <div class="section-head text-center reveal">
            <span class="section-label">FAQ</span>
            <h2 class="section-title">Schnelle Antworten</h2>
        </div>
        <div class="faq-grid">
            <article class="faq-item reveal"><h4>Ist die Plattform wirklich für Hundeschulen nutzbar?</h4><p>Ja – mit Trainingsplänen, Kommunikationsmodulen, Owner-Portal und Fortschrittslogik ist sie explizit dafür geeignet.</p></article>
            <article class="faq-item reveal transition-delay-1"><h4>Kann ich Teammitglieder granular steuern?</h4><p>Ja. Rollen- und Zugriffsmodelle unterstützen unterschiedliche Verantwortlichkeiten im Team.</p></article>
            <article class="faq-item reveal transition-delay-2"><h4>Wie schnell ist der Start?</h4><p>In wenigen Minuten. Registrieren, Grunddaten setzen, direkt produktiv arbeiten.</p></article>
            <article class="faq-item reveal transition-delay-3"><h4>Kann ich später skalieren?</h4><p>Ja. Tarife und Funktionsumfang sind auf Wachstum und Mehrbenutzerbetrieb ausgerichtet.</p></article>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="cta-ring"></div>
    <div class="cta-ring ring-2"></div>
    <div class="container text-center reveal">
        <span class="section-label" style="justify-content:center;display:flex;">Jetzt durchstarten</span>
        <h2 class="cta-title">Deine unverwechselbare digitale Praxis beginnt hier.</h2>
        <p class="cta-sub">Premium-Auftritt, vollständige Prozesse, begeisterte Kunden.</p>
        <div class="hero-actions" style="justify-content:center;">
            <a href="/register" class="btn-tp-primary btn-tp-lg"><i class="bi bi-rocket-takeoff"></i> Kostenlos testen</a>
            <a href="/demo" class="btn-tp-outline btn-tp-lg"><i class="bi bi-play-circle-fill"></i> Demo öffnen</a>
        </div>
    </div>
</section>
{% endblock %}

{% block scripts %}
<script src="/js/landing.js?v=20260413-ux2" defer></script>
{% endblock %}
