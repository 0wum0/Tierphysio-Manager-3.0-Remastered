<!-- ═══════════════════════════════════════════════════════════════
     FEATURES
════════════════════════════════════════════════════════════════ -->
<section class="features" id="features">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <div class="section-label">Funktionen</div>
            <h2 class="section-title">Alles, was Ihre Praxis braucht</h2>
            <p class="section-sub mx-auto">
                Von der Patientenakte bis zur automatischen Rechnung –
                TheraPano deckt den kompletten Praxisalltag digital ab.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4 reveal transition-delay-1">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(37,99,235,.15);">🐾</div>
                    <h5>Patientenverwaltung</h5>
                    <p>Vollständige digitale Akten für alle Tiere inkl. Fotos, Besitzerinformationen, Impfstatus und lückenloser Behandlungshistorie.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 reveal transition-delay-2">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(124,58,237,.15);">📅</div>
                    <h5>Intelligenter Terminkalender</h5>
                    <p>Übersichtlicher Wochenplan, automatische Erinnerungen per E-Mail, Konfliktwarnung und optionaler Google-Calendar-Abgleich.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 reveal transition-delay-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(16,185,129,.15);">🧾</div>
                    <h5>Rechnungsstellung</h5>
                    <p>Rechnungen mit einem Klick erstellen, als PDF per E-Mail versenden und Zahlungseingang automatisch verfolgen.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 reveal transition-delay-1">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(245,158,11,.15);">📋</div>
                    <h5>Digitale Befundbögen</h5>
                    <p>Strukturierte Untersuchungsformulare für Erst- und Folgebehandlungen – digital ausfüllen, unterschreiben und archivieren.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 reveal transition-delay-2">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(239,68,68,.15);">📱</div>
                    <h5>TheraPano Android-App</h5>
                    <p>Die native App für unterwegs – Patienten, Termine und Nachrichten immer in der Hosentasche. Kostenlos für alle Tarife.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 reveal transition-delay-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(14,165,233,.15);">🔒</div>
                    <h5>DSGVO &amp; Datensicherheit</h5>
                    <p>Server in Deutschland, vollständiger Auftragsverarbeitungsvertrag, TLS-Verschlüsselung und tägliche Datensicherungen.</p>
                </div>
            </div>
        </div>
    </div>
</section>

