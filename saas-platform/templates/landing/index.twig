{% extends 'layouts/landing.twig' %}

{% block title %}TheraPano – Premium Praxis-Software für Tierherapie & Hundeschulen{% endblock %}

{% block styles %}
<link rel="stylesheet" href="/css/landing.css?v={{ "now"|date("U") }}">
{% endblock %}

{% block content %}
<!-- HERO SECTION -->
<section class="hero">
    <div class="container text-center">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <span class="section-kicker reveal-hidden">Die Zukunft der Tiertherapie</span>
                <h1 class="section-title reveal-hidden" style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05;">
                    Vom Praxistalltag zum <br>
                    <span class="gradient-text">High-Performance Cockpit.</span>
                </h1>
                <p class="mx-auto mb-5 reveal-hidden" style="max-width: 750px; font-size: 1.25rem; color: var(--lp-muted);">
                    TheraPano bündelt klinische Dokumentation, Patientenentwicklung und Praxismanagement in einer einzigen, hochintelligenten Plattform. Maßgeschneidert für Tierherapeuten und Hundeschulen.
                </p>
                <div class="d-flex justify-content-center gap-3 reveal-hidden">
                    <a href="/register" class="btn-nav-primary px-5 py-3 h5 mb-0">Jetzt kostenlos starten</a>
                    <a href="/demo" class="btn-nav-outline px-5 py-3 h5 mb-0">Live-Demo erleben</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- BRAND STRIP -->
<section class="brand-strip py-4 border-top border-bottom" style="background: rgba(0,0,0,0.2);">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-around gap-4 text-muted small fw-bold text-uppercase" style="letter-spacing: 0.1em;">
            <span>🐾 Tierphysio</span>
            <span>🦮 Hundeschulen</span>
            <span>🐴 Pferdetherapie</span>
            <span>🏥 Reha-Zentren</span>
            <span>🚐 Mobile Praxen</span>
        </div>
    </div>
</section>

<!-- SECTION: DAS COCKPIT (One-Stop Action) -->
<section class="py-5 mt-5">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 reveal-hidden">
                <span class="section-kicker">Das Schaltzentrum</span>
                <h2 class="section-title">Alles Erledigt. <br><span class="gradient-text">Ohne die Akte zu verlassen.</span></h2>
                <p class="text-muted mb-4">
                    In TheraPano ist die Patientenakte keine statische Liste, sondern dein interaktives Dashboard. Alle administrativen Aufgaben erledigst du direkt im Workflow.
                </p>
                <div class="row g-4 mt-2">
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-receipt text-primary h4"></i>
                            <div>
                                <h6 class="mb-1">Direkt-Abrechnung</h6>
                                <p class="small text-muted">Erstelle GoBD-konforme Rechnungen mit einem Klick aus dem Behandlungsprotokoll.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-calendar-plus text-primary h4"></i>
                            <div>
                                <h6 class="mb-1">Schnell-Termine</h6>
                                <p class="small text-muted">Buche Folgetermine sofort in der Akte. Synchronisiert in Echtzeit mit deinem Kalender.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-file-earmark-medical text-primary h4"></i>
                            <div>
                                <h6 class="mb-1">Tierarztberichte</h6>
                                <p class="small text-muted">Generiere automatisierte Verlaufsberichte für überweisende Tierärzte direkt aus dem Log.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-heart-pulse text-primary h4"></i>
                            <div>
                                <h6 class="mb-1">Theracare Integration</h6>
                                <p class="small text-muted">Überwache den Fortschritt (TCP) und passe Therapiepläne dynamisch an.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="glass-card reveal-hidden overflow-hidden p-0">
                    <div class="p-4 border-bottom border-white border-opacity-10 d-flex justify-content-between align-items-center bg-white bg-opacity-5">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle bg-success" style="width: 10px; height: 10px; box-shadow: 0 0 10px #198754;"></div>
                            <span class="fw-bold small">AKTIVER PATIENT: MILO</span>
                        </div>
                        <div class="btn-group">
                            <button class="btn btn-sm btn-outline-light opacity-50"><i class="bi bi-receipt"></i></button>
                            <button class="btn btn-sm btn-outline-light opacity-50"><i class="bi bi-calendar"></i></button>
                            <button class="btn btn-sm btn-outline-light opacity-50"><i class="bi bi-file-pdf"></i></button>
                        </div>
                    </div>
                    <div class="p-4" style="height: 300px; background: linear-gradient(135deg, rgba(59,130,246,0.05), transparent);">
                        <!-- Visual Timeline Simulation -->
                        <div class="mb-3 p-3 rounded-3 bg-white bg-opacity-5 border border-white border-opacity-10">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="small fw-bold">Behandlung: Physio</span>
                                <span class="small opacity-50">14:30</span>
                            </div>
                            <p class="small text-muted mb-0">Status auf "Schmerzfrei" gesetzt nach erfolgreichem Unterwasser-Laufband-Training.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SECTION: BUSINESS INTELLIGENCE (Forecast) -->
<section class="py-5" style="background: rgba(255,255,255,0.01);">
    <div class="container py-5">
        <div class="row g-5 align-items-center">
            <div class="col-lg-5 order-lg-2 reveal-hidden">
                <span class="section-kicker">Wirtschaftlichkeit</span>
                <h2 class="section-title">Die Jahresprognose. <br><span class="gradient-text">Planung mit Weitblick.</span></h2>
                <p class="text-muted">
                    TheraPano analysiert deine Umsatztrends und liefert dir eine präzise **Jahresprognose**. So weißt du heute schon, wie sich dein Business entwickelt.
                </p>
                <ul class="feature-list mt-4">
                    <li><i class="bi bi-graph-up-arrow"></i> <div><strong>Forecast-Algorithmus:</strong> Hochrechnung basierend auf Terminen und historischen Daten.</div></li>
                    <li><i class="bi bi-pie-chart"></i> <div><strong>Einnahmen-Mix:</strong> Detaillierte Analyse nach Behandlungsarten und Therapeuten.</div></li>
                    <li><i class="bi bi-cash-stack"></i> <div><strong>Liquiditäts-Check:</strong> Übersicht über offene Forderungen, Mahnungen und Praxisausgaben (Expenses).</div></li>
                </ul>
            </div>
            <div class="col-lg-7 order-lg-1">
                <div class="glass-card reveal-hidden p-5" style="border-color: rgba(59, 130, 246, 0.2);">
                    <div class="row align-items-end g-3 mb-4">
                        <div class="col" style="height: 60px; background: rgba(59, 130, 246, 0.1); border-radius: 8px;"></div>
                        <div class="col" style="height: 90px; background: rgba(59, 130, 246, 0.2); border-radius: 8px;"></div>
                        <div class="col" style="height: 140px; background: var(--lp-primary); border-radius: 8px; box-shadow: 0 0 20px var(--lp-primary);"></div>
                        <div class="col" style="height: 110px; background: rgba(59, 130, 246, 0.4); border-radius: 8px;"></div>
                        <div class="col" style="height: 160px; background: rgba(59, 130, 246, 0.6); border-radius: 8px;"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small opacity-50">PROGNOSE ENDE 2026</div>
                            <div class="h3 fw-bold mb-0">+14.2% Wachstum</div>
                        </div>
                        <i class="bi bi-shield-fill-check h2 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SECTION: THERACARE (TCP) -->
<section class="py-5">
    <div class="container py-5 text-center reveal-hidden">
        <span class="section-kicker">Therapeutische Tiefe</span>
        <h2 class="section-title">Theracare (TCP). <br><span class="gradient-text">Fortschritt visualisiert.</span></h2>
        <p class="text-muted mx-auto mb-5" style="max-width: 800px;">
            Hinter Theracare (Therapy Care Progress) verbirgt sich ein mächtiges Analysetool. Dokumentiere nicht nur, sondern zeige deinen Kunden schwarz auf weiß, wie sich die Lebensqualität ihres Tieres verbessert.
        </p>
        <div class="row g-4 text-start">
            <div class="col-md-4">
                <div class="glass-card">
                    <h5 class="mb-3"><i class="bi bi-bezier2 me-2 text-primary"></i> Verlaufsgrafiken</h5>
                    <p class="small text-muted">Visualisierte Parameterübersicht über Schmerz-Inzidenz, Beweglichkeit und Belastbarkeit im Zeitverlauf.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card">
                    <h5 class="mb-3"><i class="bi bi-flower3 me-2 text-primary"></i> Naturheilkunde-Log</h5>
                    <p class="small text-muted">Lückenlose Historie aller naturheilkundlichen Interventionen – von Bachblüten bis zur Phytotherapie.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card">
                    <h5 class="mb-3"><i class="bi bi-file-earmark-check me-2 text-primary"></i> Therapieberichte</h5>
                    <p class="small text-muted">Per Klick exportierbare Berichte, die als Grundlage für Tierarztbriefe oder Versicherungsanträge dienen.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SECTION: BETA APPS -->
<section class="py-5" style="background: linear-gradient(180deg, transparent, rgba(124, 58, 237, 0.03), transparent);">
    <div class="container py-5">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6 reveal-hidden">
                <span class="section-kicker">Native Experience</span>
                <h2 class="section-title">TheraPano für <br><span class="gradient-text">alle deine Geräte.</span></h2>
                <p class="text-muted mb-4">
                    Unsere nativen Anwendungen befinden sich in der finalen Entwicklungsphase. Als Beta-User hast du die Chance, die Zukunft deiner Praxissoftware aktiv mitzugestalten.
                </p>
                <div class="row g-3">
                    <div class="col-6"><div class="app-platform-card"><i class="bi bi-windows h4 mb-2 d-block"></i> Windows <span class="beta-badge">BETA</span></div></div>
                    <div class="col-6"><div class="app-platform-card"><i class="bi bi-apple h4 mb-2 d-block"></i> macOS <span class="beta-badge">BETA</span></div></div>
                    <div class="col-6"><div class="app-platform-card"><i class="bi bi-google-play h4 mb-2 d-block"></i> Android <span class="beta-badge">BETA</span></div></div>
                    <div class="col-6"><div class="app-platform-card"><i class="bi bi-phone h4 mb-2 d-block"></i> iOS <span class="beta-badge">BETA</span></div></div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="glass-card reveal-hidden p-5 text-center">
                    <i class="bi bi-cloud-check display-3 text-primary mb-3"></i>
                    <h4>Real-Time Sync</h4>
                    <p class="text-muted">Deine Daten werden in Millisekunden zwischen Tablet, Smartphone und Browser synchronisiert.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- MASSIVE FAQ SECTION -->
<section class="py-5" id="faq">
    <div class="container py-5">
        <div class="text-center mb-5 reveal-hidden">
            <span class="section-kicker">Detail-Wissen</span>
            <h2 class="section-title">Häufige Fragen & <span class="gradient-text">Detail-Antworten.</span></h2>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-10">
                
                <h4 class="faq-group-title reveal-hidden">🚀 Einstieg & Arbeitsalltag</h4>
                <div class="faq-item reveal-hidden">
                    <button class="faq-question">Wie erstelle ich eine Rechnung direkt aus der Akte? <i class="bi bi-plus"></i></button>
                    <div class="faq-answer">
                        Über die Schnell-Aktion "Rechnung" in der Patienten-Akte. TheraPano übernimmt automatisch alle unberechneten Termine und Befunde dieses Patienten in einen Rechnungsentwurf. Du prüfst nur noch kurz den GoBD-Status und sendest die Rechnung direkt per E-Mail oder druckst sie aus.
                    </div>
                </div>
                <div class="faq-item reveal-hidden">
                    <button class="faq-question">Was ist das Theracare (TCP) Modul? <i class="bi bi-plus"></i></button>
                    <div class="faq-answer">
                        TCP steht für Therapy Care Progress. Es ist ein spezialisiertes Modul zur Visualisierung von Heilungsverläufen. Du kannst Schmerz-Scores, Beweglichkeitsparameter und Vitalwerte grafisch darstellen. Dies ist besonders wertvoll für die Kommunikation mit Tierhaltern, um Fortschritte objektiv belegbar zu machen.
                    </div>
                </div>

                <h4 class="faq-group-title mt-5 reveal-hidden">💰 Finanzen & Rechtssicherheit</h4>
                <div class="faq-item reveal-hidden">
                    <button class="faq-question">Ist TheraPano wirklich GoBD-konform? <i class="bi bi-plus"></i></button>
                    <div class="faq-answer">
                        Ja. Wir haben eine dedizierte GoBD-Infrastruktur implementiert. Das bedeutet unter anderem: Rechnungen können nach dem Festschreiben nicht mehr einfach gelöscht werden. Stattdessen gibt es ein revisionssicheres Stornosystem mit korrekten Korrekturbelegen und Belegnummernkreisen, die lückenlos dokumentiert werden.
                    </div>
                </div>
                <div class="faq-item reveal-hidden">
                    <button class="faq-question">Wie funktioniert das automatisierte Mahnwesen? <i class="bi bi-plus"></i></button>
                    <div class="faq-answer">
                        Das System überwacht die Zahlungsziele deiner Rechnungen. Bei Überschreitung schlägt TheraPano automatisch die nächste Stufe vor: Von der freundlichen Zahlungserinnerung bis zur 1. und 2. Mahnung. Alle Vorlagen sind rechtlich geprüft und können mit einem Klick versendet werden.
                    </div>
                </div>
                <div class="faq-item reveal-hidden">
                    <button class="faq-question">Wie genau ist die Jahresprognose? <i class="bi bi-plus"></i></button>
                    <div class="faq-answer">
                        Die Prognose basiert auf einem statistischen Modell, das deine durchschnittlichen Monatsumsätze, die aktuelle Termindichte im Kalender und saisonale Trends (z.B. Ferienzeiten) einbezieht. Je mehr Daten du im System hast, desto präziser wird die Vorhersage deines Praxiserfolgs.
                    </div>
                </div>

                <h4 class="faq-group-title mt-5 reveal-hidden">🔒 Sicherheit & Technik</h4>
                <div class="faq-item reveal-hidden">
                    <button class="faq-question">Wie sind meine Daten voneinander getrennt? <i class="bi bi-plus"></i></button>
                    <div class="faq-answer">
                        TheraPano nutzt eine echte Multi-Tenant-Architektur. Das bedeutet, dass jeder Kunde technisch isolierte Datenbestände hat. Deine Patientendaten, Finanzen und Dokumente sind durch strikte Präfixe und Zugriffsfilter von den Daten anderer Praxen getrennt – für maximale Datensicherheit.
                    </div>
                </div>
                <div class="faq-item reveal-hidden">
                    <button class="faq-question">Was bedeutet der Beta-Status der Apps? <i class="bi bi-plus"></i></button>
                    <div class="faq-answer">
                        Die native Anwendungen für Windows, Mac, iOS und Android befinden sich in der letzten Testphase. Sie sind voll funktionsfähig und synchronisieren sich mit der Cloud, erhalten aber derzeit noch wöchentliche Updates zur Optimierung der Performance und UI. Als Cloud-Nutzer hast du sofortigen Zugriff auf alle Beta-Versionen.
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

<!-- PRICING SECTION -->
<section class="py-5" id="pricing">
    <div class="container py-5 text-center reveal-hidden">
        <span class="section-kicker">Deine Wahl</span>
        <h2 class="section-title">Einfache <span class="gradient-text">Preispläne.</span></h2>
        <div class="row g-4 mt-4 justify-content-center">
            {% if plans is defined %}
                {% for plan in plans %}
                    <div class="col-md-6 col-lg-4 d-flex">
                        <div class="glass-card w-100 p-5 d-flex flex-column {% if plan.is_featured %}border-primary{% endif %}">
                            <h3 class="h4 mb-3">{{ plan.name }}</h3>
                            <div class="h2 fw-bold mb-4">{{ (plan.price_month is defined and plan.price_month) ? plan.price_month : '0' }}€ <small class="h6 opacity-50">/mtl</small></div>
                            <ul class="list-unstyled text-start flex-grow-1 text-muted small mb-5">
                                {% set features = plan.features ? plan.features|json_decode : [] %}
                                {% for f in features %}
                                    <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i> {{ f }}</li>
                                {% endfor %}
                            </ul>
                            <a href="/register/{{ plan.slug }}" class="btn-nav-primary w-100 py-3">Jetzt starten</a>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</section>

<section class="py-5 text-center reveal-hidden">
    <div class="container py-5">
        <h2 class="section-title h1 mb-4">Bereit für den <br><span class="gradient-text">nächsten Schritt?</span></h2>
        <p class="text-muted mb-5 mx-auto" style="max-width: 600px;">Teste TheraPano 14 Tage lang völlig unverbindlich mit vollem Funktionsumfang.</p>
        <a href="/register" class="btn-nav-primary btn-lg px-5 py-3 h4">Kostenlos testen</a>
    </div>
</section>
{% endblock %}

{% block scripts %}
<script src="/js/landing.js?v={{ "now"|date("U") }}" defer></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const faqs = document.querySelectorAll('.faq-question');
        faqs.forEach(q => {
            q.addEventListener('click', () => {
                const item = q.parentElement;
                item.classList.toggle('active');
                const icon = q.querySelector('i');
                icon.classList.toggle('bi-plus');
                icon.classList.toggle('bi-dash');
                
                const answer = item.querySelector('.faq-answer');
                if (item.classList.contains('active')) {
                    gsap.from(answer, { opacity: 0, y: -10, duration: 0.4 });
                }
            });
        });
    });
</script>
{% endblock %}
