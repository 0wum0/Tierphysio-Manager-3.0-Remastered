{% extends 'layouts/landing.twig' %}

{% block title %}TheraPano – Premium Praxissoftware für Tierherapie & Hundeschulen{% endblock %}

{% block styles %}
<link rel="stylesheet" href="/css/landing.css?v={{ "now"|date("U") }}">
{% endblock %}

{% block content %}
<section class="hero">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7 hero-intro">
                <h1 data-gsap="skew-up">Die <span class="gradient-text">einzigartige</span> Plattform für Tiertherapie & Hundetraining.</h1>
                <p data-gsap="fade-up">
                    Ein durchgängiges Premium-System für deine Praxis: 
                    Patientenmanagement, Termine, digitale Befunde und Abrechnung. 
                    Modern, sicher und 100% maßgeschneidert auf deinen Workflow.
                </p>
                <div class="d-flex gap-3 hero-actions" data-gsap="fade-up">
                    <a href="/register" class="btn-nav-primary px-4 py-3 h5 mb-0">Jetzt kostenlos starten</a>
                    <a href="/demo" class="btn-nav-outline px-4 py-3 h5 mb-0">Demo ansehen</a>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="glass-card" data-gsap="float">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="badge bg-primary px-3 py-2">LIVE MONITOR</span>
                        <div class="d-flex gap-2">
                            <span class="rounded-circle bg-danger" style="width: 8px; height: 8px;"></span>
                            <span class="rounded-circle bg-success" style="width: 8px; height: 8px;"></span>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="metric-box">
                                <small class="text-muted d-block text-uppercase">Termine</small>
                                <span class="h2 fw-bold mb-0">17</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="metric-box">
                                <small class="text-muted d-block text-uppercase">Neue Fälle</small>
                                <span class="h2 fw-bold mb-0">146</span>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--lp-border);">
                        <h6 class="mb-1 fw-bold">🐕 Milo · Gangbildanalyse</h6>
                        <small class="text-muted">11:00 Uhr · Status: Bestätigt</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="brand-strip py-4 border-top border-bottom" style="background: rgba(0,0,0,0.2);">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-around gap-4 text-muted small fw-bold text-uppercase" style="letter-spacing: 0.1em;">
            <span>🐾 Tierphysio</span>
            <span>🦮 Hundeschulen</span>
            <span>🐴 Pferdetherapie</span>
            <span>🏥 Reha-Zentren</span>
            <span>🚐 Mobile Praxen</span>
        </div>
    </div>
</section>

<section class="py-5" id="features">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="section-title h1 mb-4">Alles drin – ohne Tool-Chaos, <span class="gradient-text">ohne Medienbruch</span></h2>
            <p class="text-muted mx-auto" style="max-width: 800px;">
                Vom Patientenmanagement bis zur Abrechnung: Deine Module greifen nahtlos ineinander für deinen Workflow der Zukunft.
            </p>
        </div>

        <div class="bento-grid">
            <article class="bento-item large">
                <div class="mb-3 d-flex justify-content-between align-items-center">
                    <span class="badge bg-primary">MODUL_01</span>
                </div>
                <h3>🧠 Praxis-Kern</h3>
                <p>Patientenbesitzer, Akten, Anamnese, Befunde, Verlauf und Medien – alles zentral und digital dokumentiert.</p>
            </article>
            <article class="bento-item medium">
                <h3>📅 Termin-Engine</h3>
                <p>Intelligenter Kalender, Warteliste, Google-Sync und automatisierte Terminerinnerungen.</p>
            </article>
            <article class="bento-item small">
                <h3>🧾 Umsatz-Flow</h3>
                <p>Rechnungen, Mahnungen und Steuerexporte.</p>
            </article>
            <article class="bento-item small">
                <h3>🏠 Besitzerportal</h3>
                <p>Self-Service für Tierhalter.</p>
            </article>
            <article class="bento-item medium">
                <h3>📱 Mobile App/API</h3>
                <p>Mobil arbeiten auf Tablet und Smartphone.</p>
            </article>
            <article class="bento-item medium">
                <h3>🎓 Übungen & Pläne</h3>
                <p>Übungsbibliothek für Patientenbesitzer.</p>
            </article>
            <article class="bento-item small">
                <h3>📈 Analytics Pro</h3>
                <p>Praxis-Metriken im Blick.</p>
            </article>
            <article class="bento-item small">
                <h3>🧩 Plugins</h3>
                <p>Erweiterbarkeit ohne Grenzen.</p>
            </article>
            <article class="bento-item medium">
                <h3>🔒 Compliance</h3>
                <p>DSGVO-konform und sicher gehostet.</p>
            </article>
        </div>
    </div>
</section>

<section class="py-5" id="modules">
    <div class="container py-5 text-center">
        <div class="row g-4 justify-content-center">
            <div class="col-md-5">
                <div class="glass-card h-100 p-5">
                    <h2 class="h3 mb-3">Für Tiertherapeuten</h2>
                    <p class="text-muted small">Präzise Dokumentation, Verlaufsgraphen und klinische Befundung – alles DSGVO-konform.</p>
                    <div class="d-flex flex-wrap gap-2 justify-content-center mt-3">
                        <span class="badge bg-dark border">Verlaufsdoku</span>
                        <span class="badge bg-dark border">Befundlogik</span>
                    </div>
                </div>
            </div>
            <div class="col-md-5">
                <div class="glass-card h-100 p-5">
                    <h2 class="h3 mb-3">Für Hundeschulen</h2>
                    <p class="text-muted small">Kursverwaltung, Teilnehmerlisten und direktes Feedback an die Besitzer professionell bündeln.</p>
                    <div class="d-flex flex-wrap gap-2 justify-content-center mt-3">
                        <span class="badge bg-dark border">Trainingspläne</span>
                        <span class="badge bg-dark border">Kurslogik</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" id="pricing">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="section-title h1 mb-4">Skalierbare Tarife <span class="gradient-text">für jede Praxisgröße</span></h2>
            <p class="text-muted">Starten Sie mit 14 Tagen kostenfreiem Test. Keine Kreditkarte erforderlich.</p>
        </div>

        <div class="row g-4 justify-content-center">
            {% if plans is defined and plans|length > 0 %}
                {% for plan in plans %}
                    <div class="col-md-6 col-lg-4">
                        <div class="glass-card price-card {% if plan.is_featured %}featured{% endif %} h-100 d-flex flex-column p-5">
                            {% if plan.is_featured %}
                                <div class="position-absolute top-0 end-0 m-3 px-3 py-1 bg-primary text-white small fw-bold rounded-pill">BELIEBTESTE WAHL</div>
                            {% endif %}
                            <h3 class="h5 mb-3">{{ plan.name }}</h3>
                            <div class="price-amount mb-2">{{ (plan.price_month is defined and plan.price_month) ? plan.price_month : '0' }}€<small class="h6 text-muted">/mtl</small></div>
                            <p class="text-muted small mb-4">{{ plan.description }}</p>
                            <hr class="border-secondary opacity-25">
                            <ul class="list-unstyled text-muted mb-5 text-start flex-grow-1">
                                {% set features = plan.features ? plan.features|json_decode : [] %}
                                {% for feature in features %}
                                    <li class="mb-3 d-flex align-items-start small">
                                        <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                        <span>{{ feature }}</span>
                                    </li>
                                {% endfor %}
                            </ul>
                            <a href="{{ path_for('register_plan', {slug: plan.slug}) }}" class="{% if plan.is_featured %}btn-nav-primary{% else %}btn-nav-outline{% endif %} w-100 py-3">Jetzt starten</a>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</section>

<section class="py-5" id="faq">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="section-title h2">Häufige Fragen</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="glass-card p-4">
                    <h4 class="h6 fw-bold">Ist es für Hundeschulen geeignet?</h4>
                    <p class="text-muted small mb-0">Ja, wir bieten spezielle Module für Trainingspläne und Kundenkommunikation.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="glass-card p-4">
                    <h4 class="h6 fw-bold">Wie sicher sind meine Daten?</h4>
                    <p class="text-muted small mb-0">Ihre Daten werden verschlüsselt und auf deutschen Servern gehostet (DSGVO-konform).</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 text-center">
    <div class="container py-5">
        <h2 class="section-title h1 mb-4">Starte jetzt digital durch.</h2>
        <a href="/register" class="btn-nav-primary btn-lg px-5 py-3">Kostenlos testen</a>
    </div>
</section>
{% endblock %}

{% block scripts %}
<script src="/js/landing.js?v={{ "now"|date("U") }}" defer></script>
{% endblock %}
