{% extends 'layouts/landing.twig' %}

{% block title %}TheraPano – Die Praxis-Software für Tierphysiotherapeuten{% endblock %}

{% block styles %}
<style>
@keyframes fadeUp{from{opacity:0;transform:translateY(32px)}to{opacity:1;transform:none}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
@keyframes pulse-glow{0%,100%{box-shadow:0 0 0 0 rgba(37,99,235,.4)}50%{box-shadow:0 0 32px 8px rgba(37,99,235,.15)}}
@keyframes shimmer{0%{background-position:-200% center}100%{background-position:200% center}}
@keyframes blob1{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(40px,-30px) scale(1.08)}66%{transform:translate(-20px,20px) scale(.95)}}
@keyframes blob2{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(-40px,20px) scale(1.05)}66%{transform:translate(30px,-30px) scale(.97)}}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.anim-fadeup{opacity:1}
.js-ready .anim-fadeup{opacity:0;animation:fadeUp .7s ease both}
.js-ready .anim-delay-1{animation-delay:.1s}.js-ready .anim-delay-2{animation-delay:.22s}.js-ready .anim-delay-3{animation-delay:.34s}.js-ready .anim-delay-4{animation-delay:.46s}
@media(prefers-reduced-motion:reduce){.js-ready .anim-fadeup{opacity:1;animation:none}}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease}
.reveal-left{opacity:0;transform:translateX(-28px);transition:opacity .65s ease,transform .65s ease}
.reveal-right{opacity:0;transform:translateX(28px);transition:opacity .65s ease,transform .65s ease}
.reveal.visible,.reveal-left.visible,.reveal-right.visible{opacity:1;transform:none}
.transition-delay-1{transition-delay:.1s!important}.transition-delay-2{transition-delay:.2s!important}.transition-delay-3{transition-delay:.3s!important}.transition-delay-4{transition-delay:.45s!important}.transition-delay-5{transition-delay:.6s!important}
.blob-wrap{position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:0}
.blob{position:absolute;border-radius:50%;filter:blur(80px);opacity:.55}
.blob-1{width:600px;height:600px;background:radial-gradient(circle,rgba(37,99,235,.35),transparent 70%);top:-100px;left:-100px;animation:blob1 12s ease-in-out infinite}
.blob-2{width:500px;height:500px;background:radial-gradient(circle,rgba(124,58,237,.3),transparent 70%);bottom:-80px;right:-60px;animation:blob2 14s ease-in-out infinite}
.blob-3{width:350px;height:350px;background:radial-gradient(circle,rgba(16,185,129,.18),transparent 70%);top:40%;left:40%;animation:blob1 18s ease-in-out infinite reverse}
.hero{position:relative;overflow:hidden;padding:7rem 0 6rem;background:linear-gradient(160deg,#080e1f 0%,#0f172a 50%,#0a0f1e 100%)}
.hero-badge{display:inline-flex;align-items:center;gap:.5rem;background:rgba(37,99,235,.12);border:1px solid rgba(37,99,235,.4);color:#93c5fd;padding:.35rem 1.1rem;border-radius:2rem;font-size:.78rem;font-weight:700;letter-spacing:.04em;margin-bottom:1.75rem;cursor:default;transition:background .2s}
.hero-badge:hover{background:rgba(37,99,235,.22)}
.hero-badge .badge-dot{width:6px;height:6px;background:#22c55e;border-radius:50%;animation:pulse-glow 2s ease infinite}
.hero h1{font-size:clamp(2.4rem,5.5vw,4rem);font-weight:900;line-height:1.08;letter-spacing:-.02em;background:linear-gradient(130deg,#fff 0%,#bfdbfe 45%,#c4b5fd 80%,#f9a8d4 100%);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:shimmer 5s linear infinite;margin-bottom:1.5rem}
.hero-sub{font-size:1.15rem;color:#94a3b8;line-height:1.75;max-width:560px;margin-bottom:2.75rem}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap}
.hero-stats{display:flex;gap:2.5rem;flex-wrap:wrap;margin-top:4rem;padding-top:2.5rem;border-top:1px solid rgba(51,65,85,.5)}
.hero-stat-val{font-size:1.9rem;font-weight:900;color:#fff;line-height:1}
.hero-stat-lbl{font-size:.78rem;color:#64748b;margin-top:.2rem}
.hero-visual{position:relative;display:flex;justify-content:center;align-items:center}
.mockup-wrap{position:relative;animation:float 6s ease-in-out infinite}
.mockup-wrap::before{content:'';position:absolute;inset:-2px;border-radius:1.4rem;background:linear-gradient(135deg,rgba(37,99,235,.5),rgba(124,58,237,.4),transparent);z-index:-1;filter:blur(16px);opacity:.6}
.mockup-card{background:rgba(30,41,59,.95);border:1px solid rgba(51,65,85,.8);border-radius:1.25rem;padding:1.5rem;width:100%;max-width:460px;box-shadow:0 40px 80px rgba(0,0,0,.6),0 0 0 1px rgba(255,255,255,.04);backdrop-filter:blur(12px)}
.mockup-topbar{display:flex;align-items:center;gap:.6rem;margin-bottom:1.25rem;padding-bottom:1rem;border-bottom:1px solid rgba(51,65,85,.6)}
.mockup-dot{width:10px;height:10px;border-radius:50%}
.mockup-title{font-size:.78rem;font-weight:600;color:#94a3b8;margin-left:auto}
.mockup-row{display:flex;justify-content:space-between;align-items:center;background:rgba(255,255,255,.03);border-radius:.5rem;padding:.7rem 1rem;margin-bottom:.4rem;font-size:.8rem;transition:background .15s;cursor:default}
.mockup-row:hover{background:rgba(255,255,255,.06)}
.mockup-row .label{color:#64748b;display:flex;align-items:center;gap:.5rem}
.mockup-row .val{color:#e2e8f0;font-weight:700}
.mockup-badge{font-size:.68rem;padding:.2rem .6rem;border-radius:1rem;font-weight:700}
.mockup-progress{height:4px;border-radius:2px;background:rgba(51,65,85,.6);overflow:hidden;margin-top:.3rem}
.mockup-progress-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,#2563eb,#7c3aed);width:0;transition:width 1s ease}
.trust-bar{padding:2.5rem 0;background:#090e1c;border-top:1px solid rgba(51,65,85,.4);border-bottom:1px solid rgba(51,65,85,.4);overflow:hidden}
.trust-track{display:flex;gap:3rem;align-items:center;animation:marquee 20s linear infinite;white-space:nowrap}
.trust-item{font-size:.85rem;font-weight:700;color:rgba(148,163,184,.4);letter-spacing:.05em;text-transform:uppercase;flex-shrink:0}
.section-label{font-size:.72rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:#3b82f6;margin-bottom:.875rem}
.section-title{font-size:clamp(1.75rem,3.5vw,2.75rem);font-weight:900;color:#fff;line-height:1.15;margin-bottom:1rem;letter-spacing:-.02em}
.section-sub{color:#64748b;max-width:520px;line-height:1.75;font-size:.975rem}
.features{padding:6rem 0;background:linear-gradient(180deg,#090e1c 0%,#0b1120 100%)}
.feature-card{background:rgba(30,41,59,.6);border:1px solid rgba(51,65,85,.7);border-radius:1.125rem;padding:1.875rem;height:100%;transition:border-color .25s,transform .25s,box-shadow .25s;position:relative;overflow:hidden}
.feature-card::after{content:'';position:absolute;inset:0;border-radius:1.125rem;background:linear-gradient(135deg,rgba(37,99,235,.06),transparent);opacity:0;transition:opacity .25s}
.feature-card:hover{border-color:rgba(59,130,246,.5);transform:translateY(-4px);box-shadow:0 16px 40px rgba(0,0,0,.3)}
.feature-card:hover::after{opacity:1}
.feature-icon{width:52px;height:52px;border-radius:.875rem;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:1.375rem}
.feature-card h5{font-weight:800;font-size:1.05rem;color:#f1f5f9;margin-bottom:.625rem}
.feature-card p{font-size:.875rem;color:#64748b;line-height:1.7;margin:0}
.demo-section{padding:5rem 0;background:linear-gradient(135deg,rgba(37,99,235,.08) 0%,rgba(124,58,237,.06) 100%);border-top:1px solid rgba(37,99,235,.15);border-bottom:1px solid rgba(124,58,237,.15);position:relative;overflow:hidden}
.demo-screen{background:rgba(15,23,42,.9);border:1px solid rgba(51,65,85,.7);border-radius:1rem;overflow:hidden;box-shadow:0 32px 64px rgba(0,0,0,.5)}
.demo-screen-bar{background:rgba(30,41,59,.9);padding:.6rem 1rem;display:flex;align-items:center;gap:.5rem;border-bottom:1px solid rgba(51,65,85,.6)}
.demo-screen-dot{width:8px;height:8px;border-radius:50%}
.demo-row{display:flex;align-items:center;gap:.75rem;padding:.625rem 1rem;border-bottom:1px solid rgba(51,65,85,.3);font-size:.775rem}
.demo-row:last-child{border-bottom:none}
.demo-time{color:#3b82f6;font-weight:700;min-width:40px}
.demo-name{color:#e2e8f0;font-weight:600}
.demo-type{color:#64748b;flex:1}
.pricing{padding:6rem 0;background:#0a0f1e}
.price-card{background:rgba(30,41,59,.7);border:1px solid rgba(51,65,85,.7);border-radius:1.25rem;padding:2.25rem 2rem;height:100%;position:relative;overflow:hidden;transition:transform .25s,box-shadow .25s,border-color .25s}
.price-card:hover{transform:translateY(-5px);box-shadow:0 24px 56px rgba(0,0,0,.4)}
.price-card.featured{border-color:rgba(37,99,235,.6);background:linear-gradient(145deg,rgba(37,99,235,.1),rgba(30,41,59,.9))}
.price-card.featured:hover{box-shadow:0 24px 56px rgba(37,99,235,.2)}
.featured-badge{position:absolute;top:1.25rem;right:1.25rem;background:linear-gradient(135deg,#2563eb,#7c3aed);color:#fff;font-size:.68rem;font-weight:800;padding:.3rem .75rem;border-radius:1rem;letter-spacing:.04em}
.price-name{font-size:.75rem;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:#64748b;margin-bottom:.75rem}
.price-amount{font-size:2.75rem;font-weight:900;color:#fff;line-height:1;margin-bottom:.25rem}
.price-amount span{font-size:1rem;font-weight:400;color:#64748b}
.price-desc{font-size:.875rem;color:#64748b;margin:.875rem 0 1.75rem;line-height:1.6}
.price-divider{border:none;border-top:1px solid rgba(51,65,85,.6);margin:0 0 1.5rem}
.price-features{list-style:none;padding:0;margin:0 0 2rem}
.price-features li{display:flex;align-items:flex-start;gap:.625rem;font-size:.875rem;color:#94a3b8;padding:.45rem 0}
.price-features li i{color:#22c55e;flex-shrink:0;margin-top:.15rem}
.testimonials{padding:6rem 0;background:#090e1c}
.testi-card{background:rgba(30,41,59,.6);border:1px solid rgba(51,65,85,.6);border-radius:1.125rem;padding:1.875rem;height:100%;transition:transform .25s,border-color .25s}
.testi-card:hover{transform:translateY(-3px);border-color:rgba(59,130,246,.4)}
.testi-stars{color:#f59e0b;font-size:.875rem;margin-bottom:1rem}
.testi-text{color:#cbd5e1;font-size:.9rem;line-height:1.7;margin-bottom:1.5rem;font-style:italic}
.testi-author{display:flex;align-items:center;gap:.875rem}
.testi-avatar{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.9rem;color:#fff;flex-shrink:0}
.testi-name{font-weight:700;font-size:.875rem;color:#f1f5f9}
.testi-role{font-size:.775rem;color:#64748b}
.cta-section{padding:7rem 0;position:relative;overflow:hidden;background:linear-gradient(160deg,#0a0f1e 0%,#0d1528 100%)}
.cta-section::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 90% 70% at 50% 50%,rgba(37,99,235,.12) 0%,transparent 70%);pointer-events:none}
.cta-ring{position:absolute;border-radius:50%;border:1px solid rgba(37,99,235,.12);top:50%;left:50%;transform:translate(-50%,-50%)}
</style>
{% endblock %}

{% block content %}

