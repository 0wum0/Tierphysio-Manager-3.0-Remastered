{% extends 'layouts/landing.twig' %}

{% block title %}TheraPano – Praxis-Software für Tierphysiotherapeuten{% endblock %}

{% block styles %}
<style>
    /* Hero */
    .hero {
        position: relative;
        overflow: hidden;
        padding: 6rem 0 5rem;
        background: linear-gradient(135deg, #0f172a 0%, #0c1526 50%, #0f172a 100%);
    }
    .hero::before {
        content: '';
        position: absolute; inset: 0;
        background:
            radial-gradient(ellipse 80% 60% at 20% 40%, rgba(37,99,235,.15) 0%, transparent 60%),
            radial-gradient(ellipse 60% 50% at 80% 70%, rgba(124,58,237,.12) 0%, transparent 60%);
        pointer-events: none;
    }
    .hero-badge {
        display: inline-flex; align-items: center; gap: .5rem;
        background: rgba(37,99,235,.15); border: 1px solid rgba(37,99,235,.35);
        color: #93c5fd; padding: .35rem 1rem; border-radius: 2rem;
        font-size: .8rem; font-weight: 600; letter-spacing: .03em;
        margin-bottom: 1.5rem;
    }
    .hero h1 {
        font-size: clamp(2.2rem, 5vw, 3.75rem);
        font-weight: 900; line-height: 1.1;
        background: linear-gradient(135deg, #fff 0%, #93c5fd 60%, #a78bfa 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 1.25rem;
    }
    .hero-sub {
        font-size: 1.15rem; color: #94a3b8; line-height: 1.7;
        max-width: 560px; margin-bottom: 2.5rem;
    }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    .hero-stats {
        display: flex; gap: 2.5rem; flex-wrap: wrap;
        margin-top: 4rem; padding-top: 2.5rem;
        border-top: 1px solid rgba(51,65,85,.6);
    }
    .hero-stat-val { font-size: 1.75rem; font-weight: 800; color: #fff; }
    .hero-stat-lbl { font-size: .8rem; color: #64748b; margin-top: .1rem; }

    /* App preview mockup */
    .hero-visual {
        position: relative;
        display: flex; justify-content: center; align-items: center;
    }
    .mockup-card {
        background: var(--tp-surface);
        border: 1px solid var(--tp-border);
        border-radius: 1.25rem;
        padding: 1.5rem;
        width: 100%; max-width: 480px;
        box-shadow: 0 40px 80px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.04);
    }
    .mockup-topbar {
        display: flex; align-items: center; gap: .75rem;
        margin-bottom: 1.25rem; padding-bottom: 1rem;
        border-bottom: 1px solid var(--tp-border);
    }
    .mockup-dot { width: 10px; height: 10px; border-radius: 50%; }
    .mockup-title { font-size: .85rem; font-weight: 600; color: #fff; margin-left: auto; }
    .mockup-row {
        display: flex; justify-content: space-between; align-items: center;
        background: rgba(255,255,255,.03); border-radius: .5rem;
        padding: .75rem 1rem; margin-bottom: .5rem;
        font-size: .8rem;
    }
    .mockup-row .label { color: #64748b; }
    .mockup-row .val { color: #e2e8f0; font-weight: 600; }
    .mockup-badge {
        font-size: .7rem; padding: .2rem .6rem; border-radius: 1rem; font-weight: 600;
    }

    /* Features */
    .features { padding: 5rem 0; background: #0b1120; }
    .section-label {
        font-size: .75rem; font-weight: 700; letter-spacing: .1em;
        text-transform: uppercase; color: var(--tp-primary); margin-bottom: .75rem;
    }
    .section-title {
        font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 800;
        color: #fff; margin-bottom: 1rem;
    }
    .section-sub { color: #64748b; max-width: 500px; line-height: 1.7; }

    .feature-card {
        background: var(--tp-surface); border: 1px solid var(--tp-border);
        border-radius: 1rem; padding: 1.75rem;
        transition: border-color .2s, transform .2s;
        height: 100%;
    }
    .feature-card:hover { border-color: rgba(37,99,235,.5); transform: translateY(-2px); }
    .feature-icon {
        width: 48px; height: 48px; border-radius: .75rem;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; margin-bottom: 1.25rem;
    }
    .feature-card h5 { font-weight: 700; font-size: 1rem; color: #fff; margin-bottom: .5rem; }
    .feature-card p { font-size: .875rem; color: #64748b; line-height: 1.65; margin: 0; }

    /* Pricing */
    .pricing { padding: 5rem 0; }
    .price-card {
        background: var(--tp-surface); border: 1px solid var(--tp-border);
        border-radius: 1.25rem; padding: 2rem 1.75rem;
        transition: border-color .2s, transform .2s; height: 100%;
        position: relative; overflow: hidden;
    }
    .price-card.featured {
        border-color: var(--tp-primary);
        background: linear-gradient(135deg, rgba(37,99,235,.12), var(--tp-surface));
    }
    .price-card.featured::before {
        content: 'Beliebteste Wahl';
        position: absolute; top: 1rem; right: -2rem;
        background: var(--tp-primary); color: #fff; font-size: .7rem; font-weight: 700;
        padding: .3rem 3rem; transform: rotate(40deg); letter-spacing: .05em;
    }
    .price-card:hover { transform: translateY(-3px); }
    .price-name { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--tp-muted); margin-bottom: .5rem; }
    .price-amount { font-size: 2.5rem; font-weight: 900; color: #fff; line-height: 1; }
    .price-amount span { font-size: 1rem; font-weight: 400; color: #64748b; }
    .price-desc { font-size: .85rem; color: #64748b; margin: .75rem 0 1.5rem; }
    .price-features { list-style: none; padding: 0; margin: 0 0 2rem; }
    .price-features li {
        display: flex; align-items: flex-start; gap: .6rem;
        font-size: .875rem; color: #94a3b8; padding: .4rem 0;
    }
    .price-features li i { color: #22c55e; flex-shrink: 0; margin-top: .1rem; }

    /* CTA */
    .cta-section {
        padding: 5rem 0;
        background: linear-gradient(135deg, rgba(37,99,235,.15) 0%, rgba(124,58,237,.1) 100%);
        border-top: 1px solid rgba(37,99,235,.2);
        border-bottom: 1px solid rgba(37,99,235,.2);
    }
</style>
{% endblock %}

{% block content %}

<!-- ── Hero ─────────────────────────────────────────────────────────────── -->
<section class="hero">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6" data-aos="fade-right">
                <div class="hero-badge">
                    <i class="bi bi-stars"></i> Neu: Terminkalender-Sync mit Google Calendar
                </div>
                <h1>Mehr Zeit fürs Tier, weniger Zeit am Schreibtisch.</h1>
                <p class="hero-sub">
                    TheraPano ist die All-in-One Praxis-Software für Tierphysiotherapeuten.
                    Patienten, Termine, Rechnungen und Befunde – alles an einem Ort.
                </p>
                <div class="hero-actions">
                    <a href="/register" class="btn-tp-primary btn-tp-lg">
                        <i class="bi bi-rocket-takeoff"></i> 14 Tage kostenlos testen
                    </a>
                    <a href="#features" class="btn-tp-outline btn-tp-lg">
                        <i class="bi bi-play-circle"></i> Features ansehen
                    </a>
                </div>
                <div class="hero-stats">
                    <div>
                        <div class="hero-stat-val">500+</div>
                        <div class="hero-stat-lbl">Praxen nutzen TheraPano</div>
                    </div>
                    <div>
                        <div class="hero-stat-val">98%</div>
                        <div class="hero-stat-lbl">Kundenzufriedenheit</div>
                    </div>
                    <div>
                        <div class="hero-stat-val">0€</div>
                        <div class="hero-stat-lbl">Einrichtungskosten</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-visual">
                    <div class="mockup-card">
                        <div class="mockup-topbar">
                            <div class="mockup-dot" style="background:#ef4444;"></div>
                            <div class="mockup-dot" style="background:#f59e0b;"></div>
                            <div class="mockup-dot" style="background:#22c55e;"></div>
                            <div class="mockup-title">app.therapano.de – Dashboard</div>
                        </div>
                        <div style="font-size:.75rem;color:#64748b;margin-bottom:.75rem;text-transform:uppercase;letter-spacing:.06em;font-weight:600;">Heutige Übersicht</div>
                        <div class="mockup-row">
                            <span class="label"><i class="bi bi-calendar-check me-2"></i>Termine heute</span>
                            <span class="val">8</span>
                        </div>
                        <div class="mockup-row">
                            <span class="label"><i class="bi bi-paw-fill me-2"></i>Aktive Patienten</span>
                            <span class="val">142</span>
                        </div>
                        <div class="mockup-row">
                            <span class="label"><i class="bi bi-receipt me-2"></i>Offene Rechnungen</span>
                            <span class="val" style="color:#f59e0b;">3 offen</span>
                        </div>
                        <div class="mockup-row">
                            <span class="label"><i class="bi bi-gift me-2"></i>Geburtstage</span>
                            <span class="mockup-badge" style="background:#064e3b;color:#6ee7b7;">2 heute 🎂</span>
                        </div>
                        <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid var(--tp-border);">
                            <div style="font-size:.75rem;color:#64748b;margin-bottom:.5rem;">Nächster Termin</div>
                            <div style="display:flex;align-items:center;gap:.75rem;">
                                <div style="width:4px;height:40px;background:var(--tp-primary);border-radius:4px;"></div>
                                <div>
                                    <div style="font-size:.875rem;font-weight:600;color:#fff;">Layla – Labrador</div>
                                    <div style="font-size:.75rem;color:#64748b;">10:30 Uhr · Erstbehandlung</div>
                                </div>
                                <span class="mockup-badge ms-auto" style="background:#0c2a4a;color:#7dd3fc;">Bestätigt</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── Features ──────────────────────────────────────────────────────────── -->
<section class="features" id="features">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Features</div>
            <h2 class="section-title">Alles, was Ihre Praxis braucht</h2>
            <p class="section-sub mx-auto">Von der Patientenakte bis zur Rechnung – TheraPano deckt den kompletten Praxisalltag ab.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(37,99,235,.15);">
                        <i class="bi bi-paw-fill" style="color:#60a5fa;"></i>
                    </div>
                    <h5>Patientenverwaltung</h5>
                    <p>Vollständige Akten für alle Patienten inkl. Besitzerinformationen, Fotos und Behandlungshistorie.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(124,58,237,.15);">
                        <i class="bi bi-calendar3" style="color:#a78bfa;"></i>
                    </div>
                    <h5>Terminkalender</h5>
                    <p>Übersichtlicher Kalender mit Google-Calendar-Sync, Erinnerungen und Terminbestätigungen per E-Mail.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(16,185,129,.15);">
                        <i class="bi bi-receipt" style="color:#34d399;"></i>
                    </div>
                    <h5>Rechnungsstellung</h5>
                    <p>Rechnungen auf Knopfdruck erstellen, als PDF versenden und Zahlungsstatus verfolgen.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(245,158,11,.15);">
                        <i class="bi bi-clipboard2-pulse" style="color:#fbbf24;"></i>
                    </div>
                    <h5>Befundbogen</h5>
                    <p>Strukturierte Befundbögen für Erst- und Folgeuntersuchungen – digital ausfüllen und archivieren.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(239,68,68,.15);">
                        <i class="bi bi-phone" style="color:#f87171;"></i>
                    </div>
                    <h5>TheraPano App</h5>
                    <p>Die native Android-App für unterwegs – Patienten, Termine und Nachrichten immer dabei.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(14,165,233,.15);">
                        <i class="bi bi-shield-lock" style="color:#38bdf8;"></i>
                    </div>
                    <h5>DSGVO &amp; Datenschutz</h5>
                    <p>EU-Hosting, vollständiger AVV-Vertrag, verschlüsselte Verbindungen und regelmäßige Backups.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── Pricing ───────────────────────────────────────────────────────────── -->
<section class="pricing" id="pricing">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-label">Preise</div>
            <h2 class="section-title">Transparent & fair</h2>
            <p class="section-sub mx-auto">Keine versteckten Kosten. 14 Tage kostenlos testen, kein Kreditkarte erforderlich.</p>
        </div>

        {% if plans is defined and plans|length > 0 %}
        <div class="row g-4 justify-content-center">
            {% for plan in plans %}
            <div class="col-md-6 col-lg-4">
                <div class="price-card {% if loop.index == 2 %}featured{% endif %}">
                    <div class="price-name">{{ plan.name }}</div>
                    <div class="price-amount">
                        {{ plan.price_month ?? '29' }}€
                        <span>/ Monat</span>
                    </div>
                    <div class="price-desc">{{ plan.description ?? 'Ideal für Ihre Praxis' }}</div>

                    <ul class="price-features">
                        {% set features = plan.features ? plan.features|json_decode : [] %}
                        {% for feature in features %}
                        <li><i class="bi bi-check-circle-fill"></i> {{ feature }}</li>
                        {% else %}
                        <li><i class="bi bi-check-circle-fill"></i> Unbegrenzte Patienten</li>
                        <li><i class="bi bi-check-circle-fill"></i> Terminkalender</li>
                        <li><i class="bi bi-check-circle-fill"></i> Rechnungsstellung</li>
                        <li><i class="bi bi-check-circle-fill"></i> DSGVO-konform</li>
                        <li><i class="bi bi-check-circle-fill"></i> E-Mail-Support</li>
                        {% endfor %}
                    </ul>

                    <a href="/register/{{ plan.slug }}" class="{% if loop.index == 2 %}btn-tp-primary{% else %}btn-tp-outline{% endif %} w-100 justify-content-center">
                        Jetzt starten
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <div class="row g-4 justify-content-center">
            <!-- Starter -->
            <div class="col-md-6 col-lg-4">
                <div class="price-card">
                    <div class="price-name">Starter</div>
                    <div class="price-amount">29€ <span>/ Monat</span></div>
                    <div class="price-desc">Für den Einstieg – alles Wichtige inklusive.</div>
                    <ul class="price-features">
                        <li><i class="bi bi-check-circle-fill"></i> Bis zu 100 Patienten</li>
                        <li><i class="bi bi-check-circle-fill"></i> Terminkalender</li>
                        <li><i class="bi bi-check-circle-fill"></i> Rechnungsstellung</li>
                        <li><i class="bi bi-check-circle-fill"></i> DSGVO-konform</li>
                        <li><i class="bi bi-check-circle-fill"></i> E-Mail-Support</li>
                    </ul>
                    <a href="/register/starter" class="btn-tp-outline w-100 justify-content-center">Jetzt starten</a>
                </div>
            </div>
            <!-- Pro -->
            <div class="col-md-6 col-lg-4">
                <div class="price-card featured">
                    <div class="price-name">Pro</div>
                    <div class="price-amount">59€ <span>/ Monat</span></div>
                    <div class="price-desc">Voller Funktionsumfang für wachsende Praxen.</div>
                    <ul class="price-features">
                        <li><i class="bi bi-check-circle-fill"></i> Unbegrenzte Patienten</li>
                        <li><i class="bi bi-check-circle-fill"></i> Google-Calendar-Sync</li>
                        <li><i class="bi bi-check-circle-fill"></i> Befundbögen</li>
                        <li><i class="bi bi-check-circle-fill"></i> Android-App</li>
                        <li><i class="bi bi-check-circle-fill"></i> Prioritäts-Support</li>
                    </ul>
                    <a href="/register/pro" class="btn-tp-primary w-100 justify-content-center">Jetzt starten</a>
                </div>
            </div>
            <!-- Enterprise -->
            <div class="col-md-6 col-lg-4">
                <div class="price-card">
                    <div class="price-name">Praxis+</div>
                    <div class="price-amount">99€ <span>/ Monat</span></div>
                    <div class="price-desc">Für größere Praxen mit mehreren Mitarbeitern.</div>
                    <ul class="price-features">
                        <li><i class="bi bi-check-circle-fill"></i> Alles aus Pro</li>
                        <li><i class="bi bi-check-circle-fill"></i> Bis zu 10 Mitarbeiter</li>
                        <li><i class="bi bi-check-circle-fill"></i> Massen-E-Mails</li>
                        <li><i class="bi bi-check-circle-fill"></i> Benutzerdefinierte Berichte</li>
                        <li><i class="bi bi-check-circle-fill"></i> Dedizierter Support</li>
                    </ul>
                    <a href="/register/praxis-plus" class="btn-tp-outline w-100 justify-content-center">Jetzt starten</a>
                </div>
            </div>
        </div>
        {% endif %}

        <div class="text-center mt-4" style="color:#64748b;font-size:.875rem;">
            <i class="bi bi-info-circle me-1"></i>
            Alle Pläne beinhalten 14 Tage kostenlosen Testzeitraum &bull; Keine Kreditkarte erforderlich &bull; Jederzeit kündbar
        </div>
    </div>
</section>

<!-- ── CTA ───────────────────────────────────────────────────────────────── -->
<section class="cta-section">
    <div class="container text-center">
        <h2 style="font-size:clamp(1.75rem,3vw,2.5rem);font-weight:800;color:#fff;margin-bottom:1rem;">
            Bereit für die digitale Praxis?
        </h2>
        <p style="color:#94a3b8;font-size:1.1rem;margin-bottom:2.5rem;max-width:500px;margin-inline:auto;">
            Starten Sie noch heute – kostenlos, ohne Kreditkarte, in 2 Minuten eingerichtet.
        </p>
        <a href="/register" class="btn-tp-primary btn-tp-lg me-3">
            <i class="bi bi-rocket-takeoff"></i> Kostenlos registrieren
        </a>
        <a href="/login" class="btn-tp-outline btn-tp-lg">
            <i class="bi bi-box-arrow-in-right"></i> Bereits Kunde? Anmelden
        </a>
    </div>
</section>

{% endblock %}
