{% extends 'layouts/landing.twig' %}

{% block title %}TheraPano – Premium Praxissoftware für Tierherapie & Hundeschulen{% endblock %}

{% block styles %}
<link rel="stylesheet" href="/css/landing.css?v={{ "now"|date("U") }}">
{% endblock %}

{% block content %}
<section class="hero">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7 hero-intro">
                <h1 data-gsap="skew-up">Die <span class="gradient-text">einzigartige</span> Plattform für Tiertherapie & Hundetraining.</h1>
                <p data-gsap="fade-up">
                    Ein durchgängiges Premium-System für deine Praxis: 
                    Patientenmanagement, Termine, digitale Befunde und Abrechnung. 
                    Modern, sicher und 100% maßgeschneidert auf deinen Workflow.
                </p>
                <div class="d-flex gap-3 hero-actions" data-gsap="fade-up">
                    <a href="/register" class="btn-nav-primary px-4 py-3 h5 mb-0">Jetzt kostenlos starten</a>
                    <a href="/demo" class="btn-nav-outline px-4 py-3 h5 mb-0">Demo ansehen</a>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="glass-card" data-gsap="float">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="badge bg-primary px-3 py-2">LIVE MONITOR</span>
                        <div class="d-flex gap-2">
                            <span class="rounded-circle bg-danger" style="width: 8px; height: 8px;"></span>
                            <span class="rounded-circle bg-success" style="width: 8px; height: 8px;"></span>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="metric-box">
                                <small class="text-muted d-block text-uppercase">Termine</small>
                                <span class="h2 fw-bold mb-0">17</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="metric-box">
                                <small class="text-muted d-block text-uppercase">Neue Fälle</small>
                                <span class="h2 fw-bold mb-0">146</span>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--lp-border);">
                        <h6 class="mb-1 fw-bold">🐕 Milo · Gangbildanalyse</h6>
                        <small class="text-muted">11:00 Uhr · Status: Bestätigt</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" id="features">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="section-title h1 mb-4">Alles drin – <span class="gradient-text">Null Kompromisse</span></h2>
            <p class="text-muted mx-auto" style="max-width: 700px;">Ein System, das alle Bereiche deiner Praxis digital bündelt.</p>
        </div>

        <div class="bento-grid">
            <article class="bento-item large">
                <h3>🧠 Praxis-Kern</h3>
                <p>Patientenbesitzer, Akten, Anamnese, Befunde, Verlauf und Medien – alles zentral und digital dokumentiert.</p>
            </article>
            <article class="bento-item medium">
                <h3>📅 Termin-Engine</h3>
                <p>Intelligenter Kalender, Warteliste, Google-Sync und automatisierte Terminerinnerungen.</p>
            </article>
            <article class="bento-item small">
                <h3>🧾 Umsatz-Flow</h3>
                <p>Rechnungen, Mahnungen und Steuerexporte.</p>
            </article>
            <article class="bento-item small">
                <h3>🏠 Besitzerportal</h3>
                <p>Kunden-Self-Service für Termine & Infos.</p>
            </article>
            <article class="bento-item medium">
                <h3>📱 Mobile App/API</h3>
                <p>Greife von überall sicher auf deine Praxisdaten zu – optimiert für Tablet und Smartphone.</p>
            </article>
            <article class="bento-item medium">
                <h3>🎓 Übungen</h3>
                <p>Hausaufgabenpläne und Übungsbibliothek für Patientenbesitzer.</p>
            </article>
            <article class="bento-item small">
                <h3>📈 Analytics</h3>
                <p>Praxis-Statistiken im Blick.</p>
            </article>
            <article class="bento-item small">
                <h3>🧩 Plugins</h3>
                <p>Modulare Erweiterbarkeit.</p>
            </article>
            <article class="bento-item medium">
                <h3>🔒 Compliance</h3>
                <p>100% DSGVO-konform, verschlüsselt und sicher in Deutschland gehostet.</p>
            </article>
        </div>
    </div>
</section>

<section class="py-5" id="modules">
    <div class="container py-5">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="glass-card h-100">
                    <h2 class="h3 mb-3">Für Tiertherapeuten</h2>
                    <p class="text-muted">Von der klinischen Befundung bis zum Behandlungsverlauf – präzise Tools für Physiotherapien und Reha-Zentren.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="glass-card h-100">
                    <h2 class="h3 mb-3">Für Hundeschulen</h2>
                    <p class="text-muted">Kursverwaltung, Teilnehmerlisten und direktes Feedback an die Besitzer für ein professionelles Trainingserlebnis.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" id="pricing">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="section-title h1 mb-4">Bereit für dein <span class="gradient-text">Wachstum</span></h2>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="glass-card price-card h-100">
                    <h3 class="h5 mb-3">Starter</h3>
                    <div class="price-amount mb-4">29€<small class="h6 text-muted">/mtl</small></div>
                    <ul class="list-unstyled text-muted mb-5 text-start">
                        <li class="mb-2"><i class="bi bi-check-circle text-primary me-2"></i> Alles im Blick</li>
                        <li class="mb-2"><i class="bi bi-check-circle text-primary me-2"></i> Patientenmanagement</li>
                    </ul>
                    <a href="/register" class="btn-nav-outline w-100">Jetzt starten</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card price-card featured h-100">
                    <h3 class="h5 mb-3">Pro</h3>
                    <div class="price-amount mb-4">49€<small class="h6 text-muted">/mtl</small></div>
                    <ul class="list-unstyled text-muted mb-5 text-start">
                        <li class="mb-2"><i class="bi bi-check-circle text-primary me-2"></i> Alle Features</li>
                        <li class="mb-2"><i class="bi bi-check-circle text-primary me-2"></i> Owner Portal</li>
                    </ul>
                    <a href="/register" class="btn-nav-primary w-100">Jetzt starten</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5" id="faq">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="section-title h2">Häufige Fragen</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="glass-card p-4">
                    <h4 class="h6 fw-bold">Ist es für Hundeschulen geeignet?</h4>
                    <p class="text-muted small mb-0">Ja, wir bieten spezielle Module für Trainingspläne und Kundenkommunikation.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="glass-card p-4">
                    <h4 class="h6 fw-bold">Wie sicher sind meine Daten?</h4>
                    <p class="text-muted small mb-0">Ihre Daten werden verschlüsselt und auf deutschen Servern gehostet (DSGVO-konform).</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 text-center">
    <div class="container py-5">
        <h2 class="section-title h1 mb-4">Starte jetzt digital durch.</h2>
        <a href="/register" class="btn-nav-primary btn-lg px-5 py-3">Kostenlos testen</a>
    </div>
</section>
{% endblock %}

{% block scripts %}
<script src="/js/landing.js?v={{ "now"|date("U") }}" defer></script>
{% endblock %}
