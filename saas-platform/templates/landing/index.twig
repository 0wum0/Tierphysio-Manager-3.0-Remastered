{% extends 'layouts/landing.twig' %}

{% block title %}TheraPano – Moderne Praxissoftware für Tiertherapeuten & Hundeschulen{% endblock %}

{% block styles %}
<link rel="stylesheet" href="/css/landing.css">
{% endblock %}

{% block content %}
<section class="hero" id="top">
    <div class="blob-wrap" aria-hidden="true">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
    </div>

    <div class="container hero-grid">
        <div class="hero-copy">
            <div class="hero-badge anim-fadeup">
                <span class="badge-dot"></span>
                Für Tierphysio, Osteopathie, Reha & Hundeschulen
            </div>
            <h1 class="anim-fadeup anim-delay-1">Die komplette Praxis- & Trainingsplattform für moderne Tiertherapeuten.</h1>
            <p class="hero-sub anim-fadeup anim-delay-2">
                TheraPano vereint Patientenakten, Terminplanung, Befunde, Rechnungen, Erinnerungen,
                Besitzerportal, mobile App, Teamverwaltung und Fachmodule in einem klaren Workflow –
                schnell, sicher und auf Wachstum ausgelegt.
            </p>
            <div class="hero-actions anim-fadeup anim-delay-3">
                <a href="/register" class="btn-tp-primary btn-tp-lg"><i class="bi bi-rocket-takeoff"></i> 14 Tage kostenlos testen</a>
                <a href="/demo" class="btn-tp-outline btn-tp-lg"><i class="bi bi-play-circle-fill"></i> Interaktive Demo</a>
            </div>
            <div class="hero-stats anim-fadeup anim-delay-4">
                <div><div class="hero-stat-val" data-count="120">0</div><div class="hero-stat-lbl">abgedeckte Praxis- & App-Funktionen</div></div>
                <div><div class="hero-stat-val" data-count="99" data-suffix="%">0%</div><div class="hero-stat-lbl">digitale Prozessabdeckung</div></div>
                <div><div class="hero-stat-val">0€</div><div class="hero-stat-lbl">Einrichtungsgebühr</div></div>
            </div>
        </div>

        <div class="hero-visual anim-fadeup anim-delay-2">
            <div class="mockup-card glass">
                <div class="mockup-topbar">
                    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
                    <span class="mockup-title">TheraPano · Tageszentrale</span>
                </div>
                <div class="mockup-list">
                    <div class="mockup-row"><span><i class="bi bi-people"></i> Aktive Besitzerkontakte</span><strong>318</strong></div>
                    <div class="mockup-row"><span><i class="bi bi-heart-pulse"></i> Laufende Therapiepläne</span><strong>74</strong></div>
                    <div class="mockup-row"><span><i class="bi bi-calendar2-week"></i> Termine heute</span><strong>15</strong></div>
                    <div class="mockup-row"><span><i class="bi bi-receipt-cutoff"></i> Offene Rechnungen</span><strong>9</strong></div>
                    <div class="mockup-row"><span><i class="bi bi-bell"></i> Automatische Erinnerungen</span><strong>27</strong></div>
                </div>
                <div class="mockup-focus">
                    <small>Nächster Slot</small>
                    <h6>🐕 Cooper · Laufanalyse & Trainingsanpassung</h6>
                    <p>10:30 Uhr · 45 Minuten · bestätigt im Besitzerportal</p>
                    <div class="mockup-progress"><span class="mockup-progress-fill"></span></div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="trust-bar" aria-label="Zielgruppen">
    <div class="trust-track" id="trustTrack">
        <span>🐕 Hundetherapie</span><span>·</span><span>🐴 Pferdetherapie</span><span>·</span><span>🐈 Katzenbehandlung</span><span>·</span>
        <span>🦮 Hundeschulen</span><span>·</span><span>🏥 Reha-Zentren</span><span>·</span><span>🚐 Mobile Therapeuten</span><span>·</span>
        <span>📚 Tiertrainer</span><span>·</span><span>🐕 Hundetherapie</span><span>·</span><span>🐴 Pferdetherapie</span><span>·</span>
        <span>🐈 Katzenbehandlung</span><span>·</span><span>🦮 Hundeschulen</span><span>·</span><span>🏥 Reha-Zentren</span><span>·</span>
    </div>
</section>

<section class="feature-pillars" id="features">
    <div class="container">
        <div class="section-head reveal">
            <span class="section-label">Komplette Plattform</span>
            <h2 class="section-title">Alle zentralen Funktionen deiner Praxis – in einem System</h2>
            <p class="section-sub">Vom Erstkontakt über Befund & Therapie bis Abrechnung, Nachsorge und Teamsteuerung: TheraPano bildet den vollständigen Praxisalltag für Tiertherapeuten und Hundetrainer digital ab.</p>
        </div>

        <div class="pillar-grid">
            <article class="pillar-card reveal transition-delay-1">
                <h3><i class="bi bi-person-vcard"></i> Patienten & Besitzer</h3>
                <ul>
                    <li>Digitale Patientenakte mit Verlauf, Medien & Dokumenten</li>
                    <li>Besitzerverwaltung mit Kontakt-Historie & Portalzugang</li>
                    <li>Anamnese, Befundbögen, Verlaufsdokumentation</li>
                    <li>Patienten-Onboarding & Intake-Prozesse</li>
                </ul>
            </article>
            <article class="pillar-card reveal transition-delay-2">
                <h3><i class="bi bi-calendar-event"></i> Termin & Auslastung</h3>
                <ul>
                    <li>Kalender mit Drag & Drop, Status und Warteliste</li>
                    <li>Automatische Erinnerungen & Follow-up-Logiken</li>
                    <li>Google-Kalender-Anbindung und Synchronisation</li>
                    <li>Team-Termine und Ressourcenplanung</li>
                </ul>
            </article>
            <article class="pillar-card reveal transition-delay-3">
                <h3><i class="bi bi-cash-stack"></i> Finanzen & Abrechnung</h3>
                <ul>
                    <li>Rechnungen, Mahnungen, Zahlungseingänge</li>
                    <li>Ausgabenmanagement & steuerrelevante Exporte</li>
                    <li>PDF-Export und E-Mail-Versand direkt aus dem System</li>
                    <li>Analysen zu Umsatz, offenen Posten und Trends</li>
                </ul>
            </article>
        </div>
    </div>
</section>

<section class="module-showcase" id="modules">
    <div class="container">
        <div class="section-head reveal text-center">
            <span class="section-label">Funktionsumfang im Detail</span>
            <h2 class="section-title">Ultra-umfangreich für jede Spezialisierung</h2>
        </div>

        <div class="module-grid">
            <div class="module-card reveal"><h4>📋 Befundwesen</h4><p>Erst- und Folgebefunde, PDF-Dokumente, Therapiehistorie und strukturierte Auswertung.</p></div>
            <div class="module-card reveal transition-delay-1"><h4>🧾 Rechnungen & Mahnwesen</h4><p>Angebot bis Mahnung mit Status, Versand, Historie und automatisierten Erinnerungen.</p></div>
            <div class="module-card reveal transition-delay-2"><h4>📨 Kommunikationszentrale</h4><p>Nachrichten-Threads, E-Mail-Anbindung, Team- und Besitzerkommunikation in einem Verlauf.</p></div>
            <div class="module-card reveal transition-delay-3"><h4>👥 Teamverwaltung</h4><p>Rollen, Benutzer, Profile, Berechtigungen und sichere Zugriffssteuerung pro Mitarbeitendem.</p></div>
            <div class="module-card reveal"><h4>📱 Mobile API & App</h4><p>Volle mobile Workflows für Termine, Patienten, Rechnungen, Befunde und Benachrichtigungen.</p></div>
            <div class="module-card reveal transition-delay-1"><h4>🏠 Besitzerportal</h4><p>Besitzer sehen Termine, Rechnungen, Befunde und erhalten Übungen/Hausaufgaben digital.</p></div>
            <div class="module-card reveal transition-delay-2"><h4>🎓 Hausaufgaben & Übungen</h4><p>Übungspläne, Vorlagen, PDF-Freigaben und Feedback-Schleifen für nachhaltigen Therapieerfolg.</p></div>
            <div class="module-card reveal transition-delay-3"><h4>📈 Therapy Care Pro</h4><p>Fortschritts-Tracking, Bibliotheken, Naturheilkunde, Berichte und automatische Erinnerungs-Queues.</p></div>
            <div class="module-card reveal"><h4>📤 Steuerexport Pro</h4><p>Steuer- und Audit-Exports mit nachvollziehbarer Finalisierung und Dokumentationspfad.</p></div>
            <div class="module-card reveal transition-delay-1"><h4>🔁 Automatisierungen</h4><p>Cron-basierte Erinnerungen, Geburtstage, Sync-Prozesse und systematische Routinejobs.</p></div>
            <div class="module-card reveal transition-delay-2"><h4>🧩 Plugin-fähig</h4><p>Erweiterbar um Fach-Module wie Intake, Portal, Bulk-Mail, Kalender-Addons und mehr.</p></div>
            <div class="module-card reveal transition-delay-3"><h4>🔒 Sicherheit & DSGVO</h4><p>Rollenkonzept, verschlüsselte Kommunikation, rechtliche Dokumente und nachvollziehbare Prozesse.</p></div>
        </div>
    </div>
</section>

<section class="audience-section">
    <div class="container">
        <div class="split-grid">
            <div class="split-card reveal-left">
                <span class="section-label">Für Tiertherapeuten</span>
                <h3>Praxisorganisation ohne Medienbrüche</h3>
                <p>Dokumentiere Therapien strukturiert, steuere Folgetermine, versende Rechnungen automatisiert und halte alle Patientendaten sicher an einem Ort.</p>
                <ul class="check-list">
                    <li>Fachgerechte Verlaufsdokumentation</li>
                    <li>Automatische Kommunikation mit Besitzern</li>
                    <li>Mehr Behandlungszeit statt Verwaltungsaufwand</li>
                </ul>
            </div>
            <div class="split-card reveal-right">
                <span class="section-label">Für Hundeschulen & Trainer</span>
                <h3>Training, Kurse & Betreuung zentral steuern</h3>
                <p>Verwalte Teilnehmer, dokumentiere Fortschritte, teile Trainingspläne digital und schaffe einen professionellen Kommunikationskanal mit Hundehaltern.</p>
                <ul class="check-list">
                    <li>Strukturierte Trainingspläne & Übungen</li>
                    <li>Termin- und Gruppenorganisation</li>
                    <li>Professionelle Kundenbindung via Portal</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="pricing" id="pricing">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <div class="section-label">Preise</div>
            <h2 class="section-title">Transparente Pakete für jede Praxisgröße</h2>
            <p class="section-sub mx-auto">Skalierbar vom Einzeltherapeuten bis zur großen Praxis mit Team und Spezialisierungen.</p>
        </div>

        {% if plans is defined and plans|length > 0 %}
            <div class="row g-4 justify-content-center">
                {% for plan in plans %}
                    <div class="col-md-6 col-lg-4 reveal transition-delay-{{ loop.index }}">
                        <div class="price-card {% if loop.index == 2 %}featured{% endif %}">
                            {% if loop.index == 2 %}<span class="featured-badge">Beliebtester Plan</span>{% endif %}
                            <div class="price-name">{{ plan.name }}</div>
                            <div class="price-amount">{{ plan.price_month ?? '29' }}€ <span>/ Monat</span></div>
                            <div class="price-desc">{{ plan.description ?? 'Ideal für Ihre Praxis' }}</div>
                            <hr class="price-divider">
                            <ul class="price-features">
                                {% set features = plan.features ? plan.features|json_decode : [] %}
                                {% for feature in features %}
                                    <li><i class="bi bi-check-circle-fill"></i> {{ feature }}</li>
                                {% else %}
                                    <li><i class="bi bi-check-circle-fill"></i> Unbegrenzte Patientenverwaltung</li>
                                    <li><i class="bi bi-check-circle-fill"></i> Kalender, Befunde, Rechnungen</li>
                                    <li><i class="bi bi-check-circle-fill"></i> Erinnerungen & Automationen</li>
                                    <li><i class="bi bi-check-circle-fill"></i> Mobile App & Besitzerportal</li>
                                {% endfor %}
                            </ul>
                            <a href="/register/{{ plan.slug }}" class="{% if loop.index == 2 %}btn-tp-primary{% else %}btn-tp-outline{% endif %}" style="display:flex;justify-content:center;">Jetzt starten</a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <p class="text-center mt-4 small-note reveal">14 Tage kostenlos · Keine Kreditkarte · DSGVO-konform · Sofort startklar</p>
    </div>
</section>

<section class="faq-section" id="faq">
    <div class="container">
        <div class="section-head reveal text-center">
            <span class="section-label">FAQ</span>
            <h2 class="section-title">Häufige Fragen</h2>
        </div>
        <div class="faq-grid">
            <article class="faq-item reveal"><h4>Ist TheraPano auch für Hundeschulen geeignet?</h4><p>Ja. Neben klassischer Therapie unterstützt TheraPano auch Trainingsworkflows, Übungspläne, Besitzerkommunikation und Terminorganisation für Hundetrainer.</p></article>
            <article class="faq-item reveal transition-delay-1"><h4>Kann ich mit mehreren Mitarbeitenden arbeiten?</h4><p>Ja. Rollen, Benutzerverwaltung und Teamfunktionen sind auf den parallelen Einsatz in Praxen und Trainingsbetrieben ausgelegt.</p></article>
            <article class="faq-item reveal transition-delay-2"><h4>Wie schnell kann ich starten?</h4><p>In wenigen Minuten. Account anlegen, Basisdaten erfassen und sofort mit Patienten, Terminen und Rechnungen loslegen.</p></article>
            <article class="faq-item reveal transition-delay-3"><h4>Bleiben meine Daten exportierbar?</h4><p>Ja. TheraPano unterstützt exportierbare Dokumente, PDFs und strukturierte Datenflüsse für transparente Prozesse.</p></article>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="cta-ring"></div>
    <div class="cta-ring ring-2"></div>
    <div class="container text-center reveal">
        <span class="section-label" style="justify-content:center;display:flex;">Jetzt modernisieren</span>
        <h2 class="cta-title">Mach aus deiner Praxis eine digitale Premium-Erfahrung.</h2>
        <p class="cta-sub">Mehr Struktur. Weniger Chaos. Bessere Betreuung für Tier & Besitzer.</p>
        <div class="hero-actions" style="justify-content:center;">
            <a href="/register" class="btn-tp-primary btn-tp-lg"><i class="bi bi-lightning-charge-fill"></i> Kostenlos registrieren</a>
            <a href="/demo" class="btn-tp-outline btn-tp-lg"><i class="bi bi-eye-fill"></i> Live-Demo ansehen</a>
        </div>
    </div>
</section>
{% endblock %}

{% block scripts %}
<script src="/js/landing.js" defer></script>
{% endblock %}
