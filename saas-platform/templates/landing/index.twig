<!-- ═══════════════════════════════════════════════════════════════
     PREISE
════════════════════════════════════════════════════════════════ -->
<section class="pricing" id="pricing">
    <div class="container">
        <div class="text-center mb-5 reveal">
            <div class="section-label">Preise</div>
            <h2 class="section-title">Transparent &amp; fair</h2>
            <p class="section-sub mx-auto">Keine versteckten Kosten. 14 Tage kostenlos testen, keine Kreditkarte erforderlich.</p>
        </div>

        {% if plans is defined and plans|length > 0 %}
        <div class="row g-4 justify-content-center">
            {% for plan in plans %}
            <div class="col-md-6 col-lg-4 reveal transition-delay-{{ loop.index }}">
                <div class="price-card {% if loop.index == 2 %}featured{% endif %}">
                    {% if loop.index == 2 %}<span class="featured-badge">⭐ Beliebtester</span>{% endif %}
                    <div class="price-name">{{ plan.name }}</div>
                    <div class="price-amount">{{ plan.price_month ?? '29' }}€ <span>/ Monat</span></div>
                    <div class="price-desc">{{ plan.description ?? 'Ideal für Ihre Praxis' }}</div>
                    <hr class="price-divider">
                    <ul class="price-features">
                        {% set features = plan.features ? plan.features|json_decode : [] %}
                        {% for feature in features %}
                        <li><i class="bi bi-check-circle-fill"></i> {{ feature }}</li>
                        {% else %}
                        <li><i class="bi bi-check-circle-fill"></i> Unbegrenzte Patienten</li>
                        <li><i class="bi bi-check-circle-fill"></i> Terminkalender</li>
                        <li><i class="bi bi-check-circle-fill"></i> Rechnungsstellung</li>
                        <li><i class="bi bi-check-circle-fill"></i> DSGVO-konform</li>
                        <li><i class="bi bi-check-circle-fill"></i> E-Mail-Support</li>
                        {% endfor %}
                    </ul>
                    <a href="/register/{{ plan.slug }}" class="{% if loop.index == 2 %}btn-tp-primary{% else %}btn-tp-outline{% endif %}" style="display:flex;justify-content:center;">
                        Jetzt starten
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <div class="row g-4 justify-content-center">
            <div class="col-md-6 col-lg-4 reveal transition-delay-1">
                <div class="price-card">
                    <div class="price-name">Starter</div>
                    <div class="price-amount">29€ <span>/ Monat</span></div>
                    <div class="price-desc">Für den Einstieg – alles Wichtige direkt inklusive.</div>
                    <hr class="price-divider">
                    <ul class="price-features">
                        <li><i class="bi bi-check-circle-fill"></i> Bis zu 100 Patienten</li>
                        <li><i class="bi bi-check-circle-fill"></i> Terminkalender</li>
                        <li><i class="bi bi-check-circle-fill"></i> Rechnungsstellung</li>
                        <li><i class="bi bi-check-circle-fill"></i> Android-App</li>
                        <li><i class="bi bi-check-circle-fill"></i> E-Mail-Support</li>
                    </ul>
                    <a href="/register/starter" class="btn-tp-outline" style="display:flex;justify-content:center;">Jetzt starten</a>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 reveal transition-delay-2">
                <div class="price-card featured">
                    <span class="featured-badge">⭐ Beliebtester</span>
                    <div class="price-name">Pro</div>
                    <div class="price-amount">59€ <span>/ Monat</span></div>
                    <div class="price-desc">Voller Funktionsumfang für wachsende Praxen.</div>
                    <hr class="price-divider">
                    <ul class="price-features">
                        <li><i class="bi bi-check-circle-fill"></i> Unbegrenzte Patienten</li>
                        <li><i class="bi bi-check-circle-fill"></i> Befundbögen &amp; Berichte</li>
                        <li><i class="bi bi-check-circle-fill"></i> Google-Calendar-Sync</li>
                        <li><i class="bi bi-check-circle-fill"></i> Android-App inklusive</li>
                        <li><i class="bi bi-check-circle-fill"></i> Prioritäts-Support</li>
                    </ul>
                    <a href="/register/pro" class="btn-tp-primary" style="display:flex;justify-content:center;">Jetzt starten</a>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 reveal transition-delay-3">
                <div class="price-card">
                    <div class="price-name">Praxis+</div>
                    <div class="price-amount">99€ <span>/ Monat</span></div>
                    <div class="price-desc">Für größere Praxen mit mehreren Mitarbeitenden.</div>
                    <hr class="price-divider">
                    <ul class="price-features">
                        <li><i class="bi bi-check-circle-fill"></i> Alles aus Pro</li>
