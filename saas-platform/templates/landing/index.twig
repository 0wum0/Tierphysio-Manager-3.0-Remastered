{% extends 'layouts/landing.twig' %}

{% block title %}TheraPano – Ultra-Premium Software für Tiertherapeuten{% endblock %}

{% block styles %}
<link rel="stylesheet" href="/css/landing.css?v=20260413-brutal">
{% endblock %}

{% block content %}
{# Hero Section with Cyber-Grid #}
<section class="hero" id="top">
    <div class="container hero-shell">
        <div class="row align-items-center">
            <div class="col-lg-7 hero-intro">
                <span class="hero-kicker" data-gsap="fade-in"><i class="bi bi-cpu"></i> Next-Gen Praxismanagement</span>
                <h1 data-gsap="skew-up">Die <span class="gradient-text">einzigartige</span> Plattform für Tiertherapie & Training.</h1>
                <p data-gsap="fade-up" data-gsap-delay="0.2">
                    Ein durchgängiges High-Tech-System für Praxis, Reha und Hundeschule. 
                    Begeistere deine Kunden mit einem digitalen Erlebnis der Extraklasse.
                </p>
                <div class="hero-actions" data-gsap="fade-up" data-gsap-delay="0.4">
                    <a href="/register" class="btn-tp-primary"><i class="bi bi-stars"></i> 14 Tage gratis starten</a>
                    <a href="/demo" class="btn-tp-outline"><i class="bi bi-play-circle"></i> Live-Demo ansehen</a>
                </div>
            </div>

            <div class="col-lg-5 d-none d-lg-block">
                <div class="glass-card hero-panel" data-gsap="float">
                    <div style="display:flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                        <span class="mono" style="font-size: 0.8rem; color: var(--lp-accent);">SYSTEM_STATUS: ACTIVE</span>
                        <div style="display:flex; gap: 0.5rem;">
                            <span style="width: 8px; height: 8px; background: #ef4444; border-radius: 50%;"></span>
                            <span style="width: 8px; height: 8px; background: #f59e0b; border-radius: 50%;"></span>
                            <span style="width: 8px; height: 8px; background: #22c55e; border-radius: 50%;"></span>
                        </div>
                    </div>
                    <div class="panel-grid">
                        <div class="glass-card" style="padding: 1rem; text-align: center;">
                            <small class="mono" style="font-size: 0.65rem;">Termine</small>
                            <div style="font-size: 1.5rem; font-weight: 800;" data-count="17">0</div>
                        </div>
                        <div class="glass-card" style="padding: 1rem; text-align: center;">
                            <small class="mono" style="font-size: 0.65rem;">Fälle</small>
                            <div style="font-size: 1.5rem; font-weight: 800;" data-count="146">0</div>
                        </div>
                    </div>
                    <div style="margin-top: 2rem; border-top: 1px solid var(--lp-border); padding-top: 1.5rem;">
                        <small class="mono" style="color: var(--lp-muted); font-size: 0.7rem;">NEXT_CONTACT</small>
                        <h6 style="font-family: var(--lp-font-header); margin: 0.5rem 0;">🐕 Milo · Gangbildanalyse</h6>
                        <p style="font-size: 0.85rem; color: var(--lp-muted);">11:00 Uhr · 45 Min</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="brand-strip">
    <div class="container">
        <div class="strip-grid">
            <span><i class="bi bi-shield-check"></i> Tierphysio</span>
            <span><i class="bi bi-lightning-charge"></i> Hundeschulen</span>
            <span><i class="bi bi-infinity"></i> Pferdetherapie</span>
            <span><i class="bi bi-command"></i> Reha-Zentren</span>
        </div>
    </div>
</section>

<section class="feature-stage py-5" id="features">
    <div class="container py-5">
        <div class="section-head text-center mb-5" data-gsap="reveal">
            <span class="hero-kicker">Core Intelligence</span>
            <h2 class="section-title">Alles drin – <span class="gradient-text">Null Kompromisse</span></h2>
            <p style="max-width: 700px; margin: 0 auto; color: var(--lp-muted);">
                Vom Patientenmanagement bis zur intelligenten Abrechnung: 
                Unsere Module greifen nahtlos ineinander für deinen Workflow der Zukunft.
            </p>
        </div>

        <div class="bento-grid">
            <article class="bento reveal" data-gsap="reveal">
                <div>
                    <i class="bi bi-layers-half" style="font-size: 2rem; color: var(--lp-accent);"></i>
                    <h3>Praxis-Kern</h3>
                    <p>Vollständige Patientenakten, Befunde und Verlauf – klinisch präzise dokumentiert.</p>
                </div>
                <div class="mono" style="font-size: 0.7rem; color: var(--lp-muted); opacity: 0.5;">MODULE // CORE_V3</div>
            </article>
            
            <article class="bento reveal" data-gsap="reveal">
                <h3>Termin-Engine</h3>
                <p>Kalender mit KI-Logik, Google-Sync und automatischer Warteliste.</p>
            </article>

            <article class="bento reveal" data-gsap="reveal">
                <h3>Umsatz-Flow</h3>
                <p>Digitaler Rechnungsversand, Mahnwesen und Exporte für den Steuerberater.</p>
            </article>

            <article class="bento reveal" data-gsap="reveal">
                <h3>Owner Portal</h3>
                <p>Deine Kunden haben Termine, Übungen und Rechnungen immer in der Tasche.</p>
            </article>

            <article class="bento reveal" data-gsap="reveal">
                <div>
                    <h3>Therapy Care Pro</h3>
                    <p>Strukturierte Übungspläne, Fortschrittsberichte und automatisierte Follow-ups.</p>
                </div>
            </article>

            <article class="bento reveal" data-gsap="reveal">
                <h3>Mobile API</h3>
                <p>Voller Zugriff auf deine Praxis-Daten, egal wo du dich gerade befindest.</p>
            </article>
        </div>
    </div>
</section>

<section class="audience-section py-5" id="modules">
    <div class="container py-5">
        <div class="section-head text-center mb-5" data-gsap="reveal">
            <h2 class="section-title">Maßgeschneiderte <span class="gradient-text">Workflows</span></h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6" data-gsap="reveal">
                <div class="glass-card h-100">
                    <h3 style="color: var(--lp-accent);">Für Tiertherapeuten</h3>
                    <p>Präzise Dokumentation, Verlaufsgraphen und klinische Befundung – alles DSGVO-konform und mobil abrufbar.</p>
                </div>
            </div>
            <div class="col-md-6" data-gsap="reveal">
                <div class="glass-card h-100">
                    <h3 style="color: var(--lp-secondary);">Für Hundeschulen</h3>
                    <p>Effiziente Kursverwaltung, Hausaufgaben-Pläne für Besitzer und direktes Fortschritts-Feedback via Portal.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="pricing py-5" id="pricing">
    <div class="container py-5">
        <div class="text-center mb-5" data-gsap="reveal">
            <span class="hero-kicker">Transparente Tarife</span>
            <h2 class="section-title">Bereit für dein <span class="gradient-text">Wachstum</span></h2>
        </div>

        <div class="row g-4 justify-content-center">
            {% if plans is defined and plans|length > 0 %}
                {% for plan in plans %}
                    <div class="col-md-6 col-lg-4" data-gsap="reveal">
                        <div class="price-card {% if loop.index == 2 %}featured{% endif %} h-100">
                            <div class="price-name mb-3">{{ plan.name }}</div>
                            <div class="price-amount mb-4">{{ plan.price_month ?? '29' }}€ <span style="font-size: 1rem; color: var(--lp-muted);">/ Monat</span></div>
                            <hr style="border-color: var(--lp-border);">
                            <ul class="list-unstyled mt-4 mb-5" style="display: grid; gap: 1rem;">
                                {% set features = plan.features ? plan.features|json_decode : [] %}
                                {% for feature in features %}
                                    <li style="color: var(--lp-muted); font-size: 0.9rem;"><i class="bi bi-check2-circle" style="color: var(--lp-accent); margin-right: 0.5rem;"></i> {{ feature }}</li>
                                {% else %}
                                    <li style="color: var(--lp-muted); font-size: 0.9rem;"><i class="bi bi-check2-circle" style="color: var(--lp-accent); margin-right: 0.5rem;"></i> Full Praxis Management</li>
                                    <li style="color: var(--lp-muted); font-size: 0.9rem;"><i class="bi bi-check2-circle" style="color: var(--lp-accent); margin-right: 0.5rem;"></i> Mobile Apps Included</li>
                                {% endfor %}
                            </ul>
                            <a href="/register/{{ plan.slug }}" class="{% if loop.index == 2 %}btn-tp-primary{% else %}btn-tp-outline{% endif %} w-100 justify-content-center">Start Experiment</a>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</section>

<section class="faq-section py-5" id="faq">
    <div class="container py-5">
        <div class="section-head text-center mb-5" data-gsap="reveal">
            <h2 class="section-title">Häufige <span class="gradient-text">Fragen</span></h2>
        </div>
        <div class="row g-4">
            <article class="col-md-6" data-gsap="reveal">
                <div class="glass-card">
                    <h4>Nutzbar für Hundeschulen?</h4>
                    <p style="color: var(--lp-muted);">Ja – mit speziellen Modulen für Trainingspläne und Kundenportal absolut perfekt geeignet.</p>
                </div>
            </article>
            <article class="col-md-6" data-gsap="reveal">
                <div class="glass-card">
                    <h4>Team-Steuerung möglich?</h4>
                    <p style="color: var(--lp-muted);">Ja. Granulare Rollen- und Rechteverwaltung für Mitarbeiter sind fester Bestandteil.</p>
                </div>
            </article>
            <article class="col-md-6" data-gsap="reveal">
                <div class="glass-card">
                    <h4>Wie schnell ist der Start?</h4>
                    <p style="color: var(--lp-muted);">In wenigen Minuten. Registrieren, Daten einpflegen und direkt produktiv loslegen.</p>
                </div>
            </article>
            <article class="col-md-6" data-gsap="reveal">
                <div class="glass-card">
                    <h4>Skalierbarkeit?</h4>
                    <p style="color: var(--lp-muted);">Die Plattform wächst mit dir – von der Solopraxis bis zum großen Reha-Zentrum.</p>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="cta-section py-5 text-center" style="background: radial-gradient(circle at top, var(--lp-primary-glow), transparent 60%);">
    <div class="container py-5">
        <h2 class="section-title mb-4" data-gsap="reveal">Starte jetzt in die <br><span class="gradient-text">digitale Ära</span> deiner Praxis.</h2>
        <p class="mb-5" style="color: var(--lp-muted); font-size: 1.1rem;" data-gsap="reveal">Über 500 Therapeuten vertrauen bereits auf TheraPano.</p>
        <div class="d-flex gap-3 justify-content-center" data-gsap="reveal">
            <a href="/register" class="btn-tp-primary btn-lg">Jetzt beitreten</a>
            <a href="/demo" class="btn-tp-outline btn-lg">Vorschau sehen</a>
        </div>
    </div>
</section>
{% endblock %}

{% block scripts %}
<script src="/js/landing.js?v=20260413-brutal" defer></script>
{% endblock %}
