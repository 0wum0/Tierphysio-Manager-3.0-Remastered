// ══════════════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════════════
let state;
let calYear, calMonth;

function loadState() {
    const saved = localStorage.getItem('therapano_demo');
    if (saved) { try { state = JSON.parse(saved); } catch(e) { state = JSON.parse(JSON.stringify(DEMO_DEFAULT)); } }
    else { state = JSON.parse(JSON.stringify(DEMO_DEFAULT)); }
    const now = new Date();
    calYear = now.getFullYear();
    calMonth = now.getMonth();
}
function saveState() { localStorage.setItem('therapano_demo', JSON.stringify(state)); }
function resetDemo() {
    if (!confirm('Demo-Daten zurücksetzen?')) return;
    localStorage.removeItem('therapano_demo');
    location.reload();
}

// ══════════════════════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════════════════════
const TIER_ICONS = {Hund:'🐕',Katze:'🐈',Pferd:'🐴',Kaninchen:'🐇',Vogel:'🦜',Sonstige:'🐾'};
function getPatient(id) { return state.patienten.find(p=>p.id==id); }
function getBesitzer(id) { return state.besitzer.find(b=>b.id==id); }
function fmtDate(d) { if(!d) return '–'; const p=d.split('-'); return p[2]+'.'+p[1]+'.'+p[0]; }
function todayStr() { return new Date().toISOString().slice(0,10); }
function statusBadge(s) {
    const m={aktiv:'badge-active',erledigt:'badge-done',storniert:'badge-cancelled',ausstehend:'badge-pending',bezahlt:'badge-active'};
    const l={aktiv:'Aktiv',erledigt:'Erledigt',storniert:'Storniert',ausstehend:'Ausstehend',bezahlt:'Bezahlt'};
    return `<span class="badge ${m[s]||'badge-pending'}">${l[s]||s}</span>`;
}

function toast(msg, type='success') {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    const icon = type==='success' ? '✅' : 'ℹ️';
    t.innerHTML = `<span>${icon}</span><span>${msg}</span>`;
    c.appendChild(t);
    setTimeout(() => t.remove(), 3500);
}

// ══════════════════════════════════════════════════════════════
// NAVIGATION
// ══════════════════════════════════════════════════════════════
const pageTitles = {dashboard:'Dashboard',termine:'Terminkalender',patienten:'Patienten',besitzer:'Besitzer',rechnungen:'Rechnungen',einstellungen:'Einstellungen'};

function showPage(name, btn) {
    document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
    document.getElementById('page-'+name).classList.add('active');
    document.querySelectorAll('.nav-link').forEach(l=>l.classList.remove('active'));
    if(btn) btn.classList.add('active');
    document.getElementById('pageTitle').textContent = pageTitles[name]||name;
    closeSidebar();
    renderPage(name);
}
function renderPage(name) {
    if(name==='dashboard') renderDashboard();
    else if(name==='termine') renderTermine();
    else if(name==='patienten') renderPatienten();
    else if(name==='besitzer') renderBesitzer();
    else if(name==='rechnungen') renderRechnungen();
}

function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('sidebarOverlay').classList.toggle('open');
}
function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('open');
}

// ══════════════════════════════════════════════════════════════
// DASHBOARD
// ══════════════════════════════════════════════════════════════
function renderDashboard() {
    const today = todayStr();
    const heuteTermine = state.termine.filter(t=>t.datum===today).sort((a,b)=>a.zeit.localeCompare(b.zeit));
    const tbody = document.getElementById('heute-termine');
    tbody.innerHTML = heuteTermine.map(t=>{
        const p = getPatient(t.patientId);
        const b = p ? getBesitzer(p.besitzerId) : null;
        return `<tr>
            <td><strong>${t.zeit}</strong></td>
            <td><span style="font-size:1.1rem;">${p?TIER_ICONS[p.tierart]:'🐾'}</span> ${p?p.name:'–'}</td>
            <td>${t.behandlung}</td>
            <td>${b?b.name:'–'}</td>
            <td>${statusBadge(t.status)}</td>
        </tr>`;
    }).join('') || '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:2rem;">Keine Termine heute</td></tr>';

    // Stats
    document.getElementById('stat-termine').textContent = heuteTermine.filter(t=>t.status!=='storniert').length;
    document.getElementById('stat-patienten').textContent = state.patienten.length;
    const bezahlt = state.rechnungen.filter(r=>r.status==='bezahlt').reduce((s,r)=>s+r.betrag,0);
    document.getElementById('stat-umsatz').textContent = bezahlt.toLocaleString('de-DE',{style:'currency',currency:'EUR',maximumFractionDigits:0});
    document.getElementById('stat-offen').textContent = state.rechnungen.filter(r=>r.status==='ausstehend').length;

    // Timeline
    const recentTermine = [...state.termine].filter(t=>t.status==='erledigt').slice(-4).reverse();
    document.getElementById('timeline').innerHTML = recentTermine.map(t=>{
        const p = getPatient(t.patientId);
        return `<div class="timeline-item"><div class="timeline-date">${fmtDate(t.datum)} · ${t.zeit}</div><div class="timeline-text">${p?TIER_ICONS[p.tierart]:''} <strong>${p?p.name:'–'}</strong> – ${t.behandlung} <span class="badge badge-done">Erledigt</span></div></div>`;
    }).join('') || '<div style="color:var(--muted);font-size:.85rem;">Keine abgeschlossenen Termine</div>';

    // Geburtstage
    const now = new Date();
    const weekEnd = new Date(); weekEnd.setDate(now.getDate()+7);
    const geburtstage = state.patienten.filter(p=>{
        if(!p.geburtstag) return false;
        const bd = new Date(p.geburtstag);
        const thisYear = new Date(now.getFullYear(), bd.getMonth(), bd.getDate());
        return thisYear >= now && thisYear <= weekEnd;
    });
    document.getElementById('geburtstage').innerHTML = geburtstage.length
        ? geburtstage.map(p=>`<div style="display:flex;align-items:center;gap:.75rem;padding:.6rem 0;border-bottom:1px solid var(--border);">
            <span style="font-size:1.5rem;">${TIER_ICONS[p.tierart]}</span>
            <div><div style="font-weight:600;">${p.name}</div><div style="font-size:.75rem;color:var(--muted);">${fmtDate(p.geburtstag)} 🎂</div></div>
          </div>`).join('')
        : '<div style="color:var(--muted);font-size:.85rem;padding:.5rem 0;">Keine Geburtstage diese Woche</div>';
}

// ══════════════════════════════════════════════════════════════
// KALENDER
// ══════════════════════════════════════════════════════════════
function renderTermine() {
    renderKalender();
    renderTerminListe();
}

function renderKalender() {
    const WOCHENTAGE = ['Mo','Di','Mi','Do','Fr','Sa','So'];
    const MONATE = ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'];
    document.getElementById('calMonthLabel').textContent = MONATE[calMonth] + ' ' + calYear;

    const grid = document.getElementById('calGrid');
    let html = WOCHENTAGE.map(d=>`<div class="cal-day-header">${d}</div>`).join('');

    const firstDay = new Date(calYear, calMonth, 1);
    const lastDay = new Date(calYear, calMonth+1, 0);
    let startDow = firstDay.getDay(); // 0=So
    startDow = startDow === 0 ? 6 : startDow - 1; // Mo=0

    const today = todayStr();

    for(let i=0; i<startDow; i++) {
        const d = new Date(calYear, calMonth, 1-startDow+i);
        html += `<div class="cal-day other-month"><div class="cal-day-num">${d.getDate()}</div></div>`;
    }
    for(let d=1; d<=lastDay.getDate(); d++) {
        const dateStr = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        const dayTermine = state.termine.filter(t=>t.datum===dateStr);
        const isToday = dateStr === today;
        const hasEvent = dayTermine.length > 0;
        let evHtml = dayTermine.slice(0,3).map(t=>{
            const p = getPatient(t.patientId);
            return `<div class="cal-event ${t.status==='erledigt'?'done':''}">${t.zeit} ${p?p.name:'–'}</div>`;
        }).join('');
        html += `<div class="cal-day ${isToday?'today':''} ${hasEvent?'has-event':''}" onclick="openNewTerminOnDate('${dateStr}')">
            <div class="cal-day-num">${d}</div>${evHtml}
        </div>`;
    }
    const remaining = (7 - ((startDow + lastDay.getDate()) % 7)) % 7;
    for(let i=1; i<=remaining; i++) html += `<div class="cal-day other-month"><div class="cal-day-num">${i}</div></div>`;
    grid.innerHTML = html;
}

function renderTerminListe() {
    const sorted = [...state.termine].sort((a,b)=>(a.datum+a.zeit).localeCompare(b.datum+b.zeit)).reverse().slice(0,20);
    document.getElementById('termin-liste').innerHTML = sorted.map(t=>{
        const p = getPatient(t.patientId);
        return `<tr>
            <td>${fmtDate(t.datum)}</td><td><strong>${t.zeit}</strong></td>
            <td>${p?TIER_ICONS[p.tierart]+' '+p.name:'–'}</td>
            <td>${t.behandlung}</td>
            <td>${statusBadge(t.status)}</td>
            <td><button class="btn btn-outline btn-sm" onclick="editTermin(${t.id})"><i class="bi bi-pencil"></i></button>
                <button class="btn btn-danger btn-sm ms-1" onclick="deleteTermin(${t.id})" style="margin-left:.25rem;"><i class="bi bi-trash"></i></button></td>
        </tr>`;
    }).join('');
}

function changeMonth(dir) {
    calMonth += dir;
    if(calMonth > 11) { calMonth=0; calYear++; }
    if(calMonth < 0) { calMonth=11; calYear--; }
    renderKalender();
}

// ══════════════════════════════════════════════════════════════
// PATIENTEN
// ══════════════════════════════════════════════════════════════
function renderPatienten(filter='') {
    const list = state.patienten.filter(p=>!filter||p.name.toLowerCase().includes(filter)||p.rasse.toLowerCase().includes(filter));
    document.getElementById('patienten-liste').innerHTML = list.map(p=>{
        const b = getBesitzer(p.besitzerId);
        return `<tr>
            <td><span style="font-size:1.2rem;">${TIER_ICONS[p.tierart]}</span> <strong>${p.name}</strong></td>
            <td>${p.tierart}</td><td>${p.rasse||'–'}</td>
            <td>${b?b.name:'–'}</td>
            <td>${fmtDate(p.letzterBesuch)}</td>
            <td><button class="btn btn-outline btn-sm" onclick="editPatient(${p.id})"><i class="bi bi-pencil"></i></button>
                <button class="btn btn-danger btn-sm" style="margin-left:.25rem;" onclick="deletePatient(${p.id})"><i class="bi bi-trash"></i></button></td>
        </tr>`;
    }).join('') || '<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:2rem;">Keine Patienten gefunden</td></tr>';
}

function filterPatienten() { renderPatienten(document.getElementById('patientenSearch').value.toLowerCase()); }

// ══════════════════════════════════════════════════════════════
// BESITZER
// ══════════════════════════════════════════════════════════════
function renderBesitzer(filter='') {
    const list = state.besitzer.filter(b=>!filter||b.name.toLowerCase().includes(filter)||b.email.toLowerCase().includes(filter));
    document.getElementById('besitzer-liste').innerHTML = list.map(b=>{
        const anzahl = state.patienten.filter(p=>p.besitzerId===b.id).length;
        return `<tr>
            <td><strong>${b.name}</strong></td>
            <td>${b.email}</td><td>${b.telefon||'–'}</td>
            <td><span class="badge badge-active">${anzahl} Tier${anzahl!==1?'e':''}</span></td>
            <td><button class="btn btn-outline btn-sm" onclick="editBesitzer(${b.id})"><i class="bi bi-pencil"></i></button>
                <button class="btn btn-danger btn-sm" style="margin-left:.25rem;" onclick="deleteBesitzer(${b.id})"><i class="bi bi-trash"></i></button></td>
        </tr>`;
    }).join('') || '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:2rem;">Keine Besitzer gefunden</td></tr>';
}
function filterBesitzer() { renderBesitzer(document.getElementById('besitzerSearch').value.toLowerCase()); }

// ══════════════════════════════════════════════════════════════
// RECHNUNGEN
// ══════════════════════════════════════════════════════════════
function renderRechnungen() {
    const bezahlt = state.rechnungen.filter(r=>r.status==='bezahlt').reduce((s,r)=>s+r.betrag,0);
    const offen = state.rechnungen.filter(r=>r.status==='ausstehend').reduce((s,r)=>s+r.betrag,0);
    document.getElementById('r-bezahlt-sum').textContent = bezahlt.toLocaleString('de-DE',{style:'currency',currency:'EUR'});
    document.getElementById('r-offen-sum').textContent = offen.toLocaleString('de-DE',{style:'currency',currency:'EUR'});
    document.getElementById('r-gesamt').textContent = state.rechnungen.length;

    const sorted = [...state.rechnungen].sort((a,b)=>b.datum.localeCompare(a.datum));
    document.getElementById('rechnungen-liste').innerHTML = sorted.map(r=>{
        const p = getPatient(r.patientId);
        const b = p ? getBesitzer(p.besitzerId) : null;
        return `<tr>
            <td><strong>${r.nr}</strong></td>
            <td>${p?TIER_ICONS[p.tierart]+' '+p.name:'–'} ${b?'<span style="color:var(--muted);font-size:.8rem;">/ '+b.name+'</span>':''}</td>
            <td><strong>${r.betrag.toLocaleString('de-DE',{style:'currency',currency:'EUR'})}</strong></td>
            <td>${fmtDate(r.datum)}</td>
            <td>${statusBadge(r.status)}</td>
            <td>
                ${r.status==='ausstehend'?`<button class="btn btn-success btn-sm" onclick="markBezahlt(${r.id})"><i class="bi bi-check-lg"></i></button>`:''}
                <button class="btn btn-danger btn-sm" style="margin-left:.25rem;" onclick="deleteRechnung(${r.id})"><i class="bi bi-trash"></i></button>
            </td>
        </tr>`;
    }).join('');
}

function markBezahlt(id) {
    const r = state.rechnungen.find(r=>r.id===id);
    if(r) { r.status='bezahlt'; saveState(); renderRechnungen(); toast('Rechnung als bezahlt markiert'); }
}
function deleteRechnung(id) {
    if(!confirm('Rechnung löschen?')) return;
    state.rechnungen = state.rechnungen.filter(r=>r.id!==id);
    saveState(); renderRechnungen(); toast('Rechnung gelöscht','info');
}

// ══════════════════════════════════════════════════════════════
// MODALS
// ══════════════════════════════════════════════════════════════
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function fillPatientSelect(selectId, selectedId=null) {
    const sel = document.getElementById(selectId);
    sel.innerHTML = state.patienten.map(p=>`<option value="${p.id}" ${p.id==selectedId?'selected':''}>${TIER_ICONS[p.tierart]} ${p.name} (${p.tierart})</option>`).join('');
}
function fillBesitzerSelect(selectId, selectedId=null) {
    const sel = document.getElementById(selectId);
    sel.innerHTML = state.besitzer.map(b=>`<option value="${b.id}" ${b.id==selectedId?'selected':''}>${b.name}</option>`).join('');
}

// ─── Termin ───────────────────────────────────────────────────
function openNewTermin() {
    document.getElementById('termin-edit-id').value='';
    document.getElementById('termin-modal-title').textContent='Neuer Termin';
    document.getElementById('t-datum').value = todayStr();
    document.getElementById('t-zeit').value = '09:00';
    document.getElementById('t-notiz').value = '';
    fillPatientSelect('t-patient');
    openModal('modal-termin');
}
function openNewTerminOnDate(dateStr) {
    openNewTermin();
    document.getElementById('t-datum').value = dateStr;
}
function editTermin(id) {
    const t = state.termine.find(t=>t.id===id);
    if(!t) return;
    document.getElementById('termin-edit-id').value = id;
    document.getElementById('termin-modal-title').textContent = 'Termin bearbeiten';
    document.getElementById('t-datum').value = t.datum;
    document.getElementById('t-zeit').value = t.zeit;
    document.getElementById('t-notiz').value = t.notiz||'';
    fillPatientSelect('t-patient', t.patientId);
    document.getElementById('t-behandlung').value = t.behandlung;
    openModal('modal-termin');
}
function saveTermin() {
    const editId = document.getElementById('termin-edit-id').value;
    const datum = document.getElementById('t-datum').value;
    const zeit = document.getElementById('t-zeit').value;
    const patientId = parseInt(document.getElementById('t-patient').value);
    const behandlung = document.getElementById('t-behandlung').value;
    const notiz = document.getElementById('t-notiz').value;
    if(!datum||!zeit) { toast('Bitte Datum und Uhrzeit eingeben','info'); return; }
    if(editId) {
        const t = state.termine.find(t=>t.id==editId);
        Object.assign(t,{datum,zeit,patientId,behandlung,notiz});
        toast('Termin aktualisiert');
    } else {
        state.termine.push({id:state.nextId.termin++,datum,zeit,patientId,behandlung,status:'aktiv',notiz});
        toast('Termin erstellt');
    }
    saveState(); closeModal('modal-termin'); renderPage(document.querySelector('.page.active').id.replace('page-',''));
}
function deleteTermin(id) {
    if(!confirm('Termin löschen?')) return;
    state.termine = state.termine.filter(t=>t.id!==id);
    saveState(); renderTermine(); toast('Termin gelöscht','info');
}

// ─── Patient ──────────────────────────────────────────────────
function openNewPatient() {
    document.getElementById('p-edit-id').value='';
    document.getElementById('patient-modal-title').textContent='Neuer Patient';
    ['p-name','p-rasse','p-diagnose'].forEach(id=>document.getElementById(id).value='');
    document.getElementById('p-geburtstag').value='';
    document.getElementById('p-gewicht').value='';
    fillBesitzerSelect('p-besitzer');
    openModal('modal-patient');
}
function editPatient(id) {
    const p = state.patienten.find(p=>p.id===id);
    if(!p) return;
    document.getElementById('p-edit-id').value=id;
    document.getElementById('patient-modal-title').textContent='Patient bearbeiten';
    document.getElementById('p-name').value=p.name;
    document.getElementById('p-rasse').value=p.rasse||'';
    document.getElementById('p-geburtstag').value=p.geburtstag||'';
    document.getElementById('p-gewicht').value=p.gewicht||'';
    document.getElementById('p-geschlecht').value=p.geschlecht||'Männlich';
    document.getElementById('p-tierart').value=p.tierart||'Hund';
    document.getElementById('p-diagnose').value=p.diagnose||'';
    fillBesitzerSelect('p-besitzer',p.besitzerId);
    openModal('modal-patient');
}
function savePatient() {
    const editId = document.getElementById('p-edit-id').value;
    const name = document.getElementById('p-name').value.trim();
    if(!name) { toast('Bitte Name eingeben','info'); return; }
    const data = {
        name, tierart:document.getElementById('p-tierart').value,
        rasse:document.getElementById('p-rasse').value,
        geschlecht:document.getElementById('p-geschlecht').value,
        geburtstag:document.getElementById('p-geburtstag').value,
        gewicht:parseFloat(document.getElementById('p-gewicht').value)||0,
        besitzerId:parseInt(document.getElementById('p-besitzer').value),
        diagnose:document.getElementById('p-diagnose').value,
        letzterBesuch:todayStr()
    };
    if(editId) { Object.assign(state.patienten.find(p=>p.id==editId), data); toast('Patient aktualisiert'); }
    else { state.patienten.push({id:state.nextId.patient++, ...data}); toast('Patient angelegt'); }
    saveState(); closeModal('modal-patient'); renderPatienten();
}
function deletePatient(id) {
    if(!confirm('Patient löschen?')) return;
    state.patienten = state.patienten.filter(p=>p.id!==id);
    saveState(); renderPatienten(); toast('Patient gelöscht','info');
}

// ─── Besitzer ─────────────────────────────────────────────────
function openNewBesitzer() {
    // Inline im Besitzer-Bereich — einfaches Prompt-basiertes Formular
    const name = prompt('Name des Besitzers:');
    if(!name) return;
    const email = prompt('E-Mail:') || '';
    const telefon = prompt('Telefon:') || '';
    state.besitzer.push({id:state.nextId.besitzer++,name,email,telefon,adresse:''});
    saveState(); renderBesitzer(); toast('Besitzer angelegt');
}
function editBesitzer(id) {
    const b = getBesitzer(id);
    if(!b) return;
    const name = prompt('Name:', b.name);
    if(!name) return;
    b.name = name;
    b.email = prompt('E-Mail:', b.email)||b.email;
    b.telefon = prompt('Telefon:', b.telefon)||b.telefon;
    saveState(); renderBesitzer(); toast('Besitzer aktualisiert');
}
function deleteBesitzer(id) {
    if(!confirm('Besitzer löschen?')) return;
    state.besitzer = state.besitzer.filter(b=>b.id!==id);
    saveState(); renderBesitzer(); toast('Besitzer gelöscht','info');
}

// ─── Rechnung ─────────────────────────────────────────────────
function openNewRechnung() {
    document.getElementById('r-datum').value = todayStr();
    document.getElementById('r-betrag').value = '';
    document.getElementById('r-leistung').value = '';
    fillPatientSelect('r-patient');
    openModal('modal-rechnung');
}
function saveRechnung() {
    const patientId = parseInt(document.getElementById('r-patient').value);
    const betrag = parseFloat(document.getElementById('r-betrag').value);
    const datum = document.getElementById('r-datum').value;
    const leistung = document.getElementById('r-leistung').value;
    if(!betrag||betrag<=0) { toast('Bitte gültigen Betrag eingeben','info'); return; }
    const nr = 'RE-'+new Date().getFullYear()+'-'+String(state.nextId.rechnung).padStart(3,'0');
    state.rechnungen.push({id:state.nextId.rechnung++,nr,patientId,betrag,datum,leistung,status:'ausstehend'});
    saveState(); closeModal('modal-rechnung'); renderRechnungen(); toast('Rechnung erstellt');
}

// Einstellungen
function saveSettings() { toast('Einstellungen lokal gespeichert'); }

// Close modals on overlay click
document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));

// Init
loadState();
renderDashboard();
</script>
</body>
</html>
