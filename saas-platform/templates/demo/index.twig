<script>
const DEF={besitzer:[{id:1,name:'Anna Bauer',email:'anna.bauer@mail.de',tel:'0176 11223344'},{id:2,name:'Klaus Hofmann',email:'k.hofmann@example.com',tel:'0152 98765432'},{id:3,name:'Sandra Klein',email:'sandra.klein@web.de',tel:'0170 33445566'},{id:4,name:'Peter Wagner',email:'p.wagner@gmx.de',tel:'0160 77889900'},{id:5,name:'Monika Schulz',email:'monika.schulz@t-online.de',tel:'0178 12345678'}],patienten:[{id:1,name:'Bella',ta:'Hund',rasse:'Labrador',ges:'Weiblich',geb:'2019-03-15',gew:28.5,bid:1,diag:'Huftdysplasie',lb:'2025-04-02',st:'aktiv'},{id:2,name:'Max',ta:'Hund',rasse:'Golden Retriever',ges:'Mannlich',geb:'2018-07-22',gew:32.0,bid:2,diag:'Kreuzbandriss re.',lb:'2025-04-05',st:'aktiv'},{id:3,name:'Luna',ta:'Katze',rasse:'Britisch Kurzhaar',ges:'Sterilisiert',geb:'2020-11-08',gew:4.2,bid:3,diag:'Wirbelsaulenprobleme',lb:'2025-03-28',st:'aktiv'},{id:4,name:'Rocky',ta:'Hund',rasse:'Rottweiler',ges:'Kastriert',geb:'2017-05-30',gew:45.0,bid:4,diag:'Spondylose LWS',lb:'2025-04-01',st:'aktiv'},{id:5,name:'Emma',ta:'Pferd',rasse:'Warmblut',ges:'Weiblich',geb:'2015-09-12',gew:520,bid:5,diag:'Ruckenprobleme',lb:'2025-03-30',st:'aktiv'},{id:6,name:'Balu',ta:'Hund',rasse:'Berner Sennenhund',ges:'Mannlich',geb:'2021-02-14',gew:38.0,bid:1,diag:'Ellenbogendysplasie',lb:'2025-04-03',st:'aktiv'},{id:7,name:'Mia',ta:'Katze',rasse:'Maine Coon',ges:'Weiblich',geb:'2022-06-20',gew:6.1,bid:2,diag:'Arthritis Vorderlauf',lb:'2025-04-04',st:'aktiv'}],termine:[{id:1,dat:'2025-04-07',zeit:'09:00',pid:1,beh:'Manuelle Therapie',st:'aktiv',not:'Fokus Hufte links'},{id:2,dat:'2025-04-07',zeit:'10:00',pid:2,beh:'Folgebehandlung',st:'aktiv',not:''},{id:3,dat:'2025-04-07',zeit:'11:00',pid:4,beh:'Elektrotherapie',st:'aktiv',not:'TENS 20min'},{id:4,dat:'2025-04-07',zeit:'13:30',pid:3,beh:'Massage',st:'erledigt',not:''},{id:5,dat:'2025-04-07',zeit:'14:30',pid:5,beh:'Laserbehandlung',st:'aktiv',not:''},{id:6,dat:'2025-04-07',zeit:'15:30',pid:6,beh:'Erstbehandlung',st:'aktiv',not:'Erstvorstellung'},{id:7,dat:'2025-04-07',zeit:'16:30',pid:7,beh:'Kontrolluntersuchung',st:'storniert',not:'Besitzer krank'},{id:8,dat:'2025-04-07',zeit:'17:00',pid:1,beh:'Hydrotherapie',st:'aktiv',not:'Aquatreadmill'},{id:9,dat:'2025-04-08',zeit:'09:00',pid:2,beh:'Manuelle Therapie',st:'aktiv',not:''},{id:10,dat:'2025-04-08',zeit:'10:30',pid:3,beh:'Folgebehandlung',st:'aktiv',not:''},{id:11,dat:'2025-04-03',zeit:'10:00',pid:1,beh:'Manuelle Therapie',st:'erledigt',not:''},{id:12,dat:'2025-04-02',zeit:'14:00',pid:6,beh:'Erstbehandlung',st:'erledigt',not:''}],rechnungen:[{id:1,nr:'RE-2025-001',pid:1,bet:85.00,dat:'2025-04-03',fae:'2025-04-17',lei:'Manuelle Therapie 60 min',st:'bezahlt'},{id:2,nr:'RE-2025-002',pid:2,bet:95.00,dat:'2025-04-05',fae:'2025-04-19',lei:'Folgebehandlung + Elektro',st:'bezahlt'},{id:3,nr:'RE-2025-003',pid:4,bet:75.00,dat:'2025-04-01',fae:'2025-04-15',lei:'Elektrotherapie 30 min',st:'bezahlt'},{id:4,nr:'RE-2025-004',pid:3,bet:65.00,dat:'2025-03-28',fae:'2025-04-11',lei:'Massage + Warme',st:'ausstehend'},{id:5,nr:'RE-2025-005',pid:5,bet:320.00,dat:'2025-03-30',fae:'2025-04-05',lei:'Behandlungspaket Pferd 4x',st:'ueberfaellig'},{id:6,nr:'RE-2025-006',pid:6,bet:95.00,dat:'2025-04-02',fae:'2025-04-16',lei:'Erstbehandlung + Befund',st:'bezahlt'},{id:7,nr:'RE-2025-007',pid:7,bet:295.00,dat:'2025-04-04',fae:'2025-04-18',lei:'Behandlungspaket 3x + Laser',st:'ausstehend'}],befunde:[{id:1,dat:'2025-04-03',pid:1,von:'Dr. Muller',diag:'Huftdysplasie bds., manuelle Therapie indiziert'},{id:2,dat:'2025-04-05',pid:2,von:'Dr. Muller',diag:'Post-OP Kreuzband: Reha Phase 2'},{id:3,dat:'2025-03-28',pid:3,von:'Dr. Muller',diag:'Bandscheibenvorfall LWS, konservativ'},{id:4,dat:'2025-04-01',pid:4,von:'Dr. Muller',diag:'Spondylose L4/L5, Elektrotherapie + Laser'}],nid:{t:13,p:8,b:6,r:8}};
const ICONS={Hund:'\uD83D\uDC15',Katze:'\uD83D\uDC08',Pferd:'\uD83D\uDC34',Kaninchen:'\uD83D\uDC07',Vogel:'\uD83D\uDDA4',Sonstige:'\uD83D\uDC3E'};
const MONTHS=['Januar','Februar','Marz','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'];
const WDAYS=['Mo','Di','Mi','Do','Fr','Sa','So'];
let S,CY,CM;
function loadS(){const s=localStorage.getItem('tp_demo3');if(s){try{S=JSON.parse(s);}catch(e){S=JSON.parse(JSON.stringify(DEF));}}else{S=JSON.parse(JSON.stringify(DEF));}const n=new Date();CY=n.getFullYear();CM=n.getMonth();}
function saveS(){localStorage.setItem('tp_demo3',JSON.stringify(S));}
function resetDemo(){if(!confirm('Demo zurucksetzen?'))return;localStorage.removeItem('tp_demo3');location.reload();}
function gP(id){return S.patienten.find(p=>p.id==id);}
function gB(id){return S.besitzer.find(b=>b.id==id);}
function fd(d){if(!d)return'-';const p=d.split('-');return p[2]+'.'+p[1]+'.'+p[0];}
function td(){return new Date().toISOString().slice(0,10);}
function mon(v){return v.toLocaleString('de-DE',{minimumFractionDigits:2,maximumFractionDigits:2})+' \u20AC';}
function bdg(s){const c={aktiv:'b-aktiv',erledigt:'b-erledigt',storniert:'b-storniert',ausstehend:'b-ausstehend',bezahlt:'b-bezahlt',ueberfaellig:'b-ueberfaellig'};const l={aktiv:'Aktiv',erledigt:'Erledigt',storniert:'Storniert',ausstehend:'Ausstehend',bezahlt:'Bezahlt',ueberfaellig:'\xDCberf\xe4llig'};return '<span class="sb '+(c[s]||'b-ausstehend')+'">'+(l[s]||s)+'</span>';}
function showPage(name,btn){document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));document.getElementById('page-'+name).classList.add('active');document.querySelectorAll('.snl').forEach(l=>l.classList.remove('active'));const nb=btn||document.getElementById('nav-'+name);if(nb)nb.classList.add('active');closeNav();renderPage(name);}
function renderPage(n){if(n==='dashboard')rDash();else if(n==='kalender')rKal();else if(n==='patienten')rPat();else if(n==='tierhalter')rTh();else if(n==='befunde')rBef();else if(n==='rechnungen')rRech();}
function toggleNav(){document.getElementById('appNav').classList.toggle('open');document.getElementById('navOv').classList.toggle('open');}
function closeNav(){document.getElementById('appNav').classList.remove('open');document.getElementById('navOv').classList.remove('open');}
function rDash(){
  const today=td();
  document.getElementById('dash-date').textContent=new Date().toLocaleDateString('de-DE',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  const ht=S.termine.filter(t=>t.dat===today&&t.st!=='storniert').sort((a,b)=>a.zeit.localeCompare(b.zeit));
  const nx=S.termine.filter(t=>t.dat>today&&t.st!=='storniert').sort((a,b)=>(a.dat+a.zeit).localeCompare(b.dat+b.zeit)).slice(0,4);
  document.getElementById('k-termine').textContent=ht.length;
  document.getElementById('k-patienten').textContent=S.patienten.length;
  const bz=S.rechnungen.filter(r=>r.st==='bezahlt').reduce((s,r)=>s+r.bet,0);
  document.getElementById('k-umsatz').textContent=mon(bz);
  const of=S.rechnungen.filter(r=>r.st==='ausstehend'||r.st==='ueberfaellig');
  document.getElementById('k-offen').textContent=of.length;
  document.getElementById('badge-offen').textContent=of.length;
  document.getElementById('act-of').textContent=S.rechnungen.filter(r=>r.st==='ausstehend').length;
  document.getElementById('act-ue').textContent=S.rechnungen.filter(r=>r.st==='ueberfaellig').length;
  document.getElementById('act-np').textContent=S.patienten.filter(p=>p.lb&&p.lb.slice(0,7)===today.slice(0,7)).length;
  document.getElementById('act-th').textContent=S.besitzer.length;
  let ah='';
  if(ht.length){ah+='<div class="px-3 py-2 d-flex align-items-center gap-2" style="border-bottom:1px solid var(--sa-border)"><span class="sb" style="background:rgba(79,124,255,.2);color:#93c5fd;">Heute</span><span style="font-size:.75rem;color:var(--sa-muted);">'+new Date().toLocaleDateString('de-DE')+'</span><span style="margin-left:auto;font-size:.72rem;color:var(--sa-muted);">'+ht.length+' Termine</span></div>';ht.forEach(t=>{const p=gP(t.pid);const b=p?gB(p.bid):null;ah+='<div class="ac"><div class="adb" style="background:rgba(79,124,255,.12);border:1.5px solid rgba(79,124,255,.35);"><div class="day" style="color:#4f7cff;">'+t.zeit.slice(0,2)+'</div><div class="mon" style="color:#4f7cff;opacity:.8;">'+t.zeit.slice(3)+'</div></div><div class="ai flex-grow-1"><div class="nm">'+(p?ICONS[p.ta]+' '+p.name:'-')+'</div><div class="mt">'+t.beh+(b?' \u00b7 '+b.name:'')+'</div></div><div class="ast">'+bdg(t.st)+'</div></div>';});}
  if(nx.length){ah+='<div class="px-3 py-2 d-flex align-items-center gap-2" style="border-top:1px solid var(--sa-border);border-bottom:1px solid var(--sa-border)"><span class="sb" style="background:rgba(100,115,130,.2);color:#94a3b8;">Kommend</span><span style="font-size:.75rem;color:var(--sa-muted);">nachste '+nx.length+' Termine</span></div>';nx.forEach(t=>{const p=gP(t.pid);const b=p?gB(p.bid):null;const d=t.dat.split('-');ah+='<div class="ac"><div class="adb" style="background:rgba(100,115,130,.1);border:1px solid rgba(100,115,130,.3);"><div class="day" style="color:#94a3b8;">'+d[2]+'</div><div class="dow" style="color:#94a3b8;">'+new Date(t.dat+'T00:00:00').toLocaleDateString('de-DE',{weekday:'short'})+'</div></div><div class="ai flex-grow-1"><div class="nm">'+(p?ICONS[p.ta]+' '+p.name:'-')+'</div><div class="mt">'+t.zeit+' Uhr \u00b7 '+t.beh+(b?' \u00b7 '+b.name:'')+'</div></div><div class="ast">'+bdg(t.st)+'</div></div>';});}
  if(!ah)ah='<div class="pcnt" style="color:var(--sa-muted);font-size:.85rem;text-align:center;padding:2rem;">Keine anstehenden Termine</div>';
  document.getElementById('appt-list').innerHTML=ah;
  const now=new Date();const we=new Date();we.setDate(now.getDate()+7);
  const bd=S.patienten.filter(p=>{if(!p.geb)return false;const d=new Date(p.geb);const ty=new Date(now.getFullYear(),d.getMonth(),d.getDate());return ty>=now&&ty<=we;});
  document.getElementById('dash-bdays').innerHTML=bd.length?bd.map(p=>'<div style="display:flex;align-items:center;gap:.65rem;padding:.5rem 0;border-bottom:1px solid var(--sa-border);"><span style="font-size:1.3rem;">'+ICONS[p.ta]+'</span><div><div style="font-weight:700;">'+p.name+'</div><div style="font-size:.72rem;color:var(--sa-muted);">'+fd(p.geb)+' \uD83C\uDF82</div></div></div>').join(''):'<div style="color:var(--sa-muted);font-size:.83rem;">Keine Geburtstage diese Woche</div>';
  const rc=S.termine.filter(t=>t.st==='erledigt').slice(-5).reverse();
  document.getElementById('dash-tl').innerHTML=rc.map(t=>{const p=gP(t.pid);return'<div class="tl-it"><div class="tl-dt">'+fd(t.dat)+' \u00b7 '+t.zeit+' Uhr</div><div class="tl-tx">'+(p?ICONS[p.ta]:'')+' <strong>'+(p?p.name:'-')+'</strong> \u00b7 '+t.beh+' '+bdg('erledigt')+'</div></div>';}).join('')||'<div style="color:var(--sa-muted);font-size:.83rem;">Keine abgeschlossenen Termine</div>';
}
function rKal(){
  document.getElementById('calLbl').textContent=MONTHS[CM]+' '+CY;
  const g=document.getElementById('calGrid');let h=WDAYS.map(d=>'<div class="cal-dh">'+d+'</div>').join('');
  const first=new Date(CY,CM,1);const last=new Date(CY,CM+1,0);let dow=first.getDay();dow=dow===0?6:dow-1;
  const today=td();
  for(let i=0;i<dow;i++){const d=new Date(CY,CM,1-dow+i);h+='<div class="cal-day om"><div class="cal-dn">'+d.getDate()+'</div></div>';}
  for(let d=1;d<=last.getDate();d++){const ds=CY+'-'+String(CM+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');const dt=S.termine.filter(t=>t.dat===ds);h+='<div class="cal-day '+(ds===today?'today':'')+'" onclick="openTerminDate(\''+ds+'\')"><div class="cal-dn">'+d+'</div>'+dt.slice(0,3).map(t=>{const p=gP(t.pid);return'<div class="cal-ev '+(t.st==='erledigt'?'done':t.st==='storniert'?'can':'')+'">'+t.zeit+' '+(p?p.name:'?')+'</div>';}).join('')+'</div>';}
  const rem=(7-((dow+last.getDate())%7))%7;for(let i=1;i<=rem;i++)h+='<div class="cal-day om"><div class="cal-dn">'+i+'</div></div>';
  g.innerHTML=h;
  const sl=[...S.termine].sort((a,b)=>(a.dat+a.zeit).localeCompare(b.dat+b.zeit)).reverse().slice(0,25);
  document.getElementById('termin-tbl').innerHTML=sl.map(t=>{const p=gP(t.pid);return'<tr><td>'+fd(t.dat)+'</td><td><strong>'+t.zeit+'</strong></td><td>'+(p?ICONS[p.ta]+' '+p.name:'-')+'</td><td>'+t.beh+'</td><td>'+bdg(t.st)+'</td><td style="display:flex;gap:.25rem;"><button class="btn-p btn-out btn-sm" onclick="editT('+t.id+')"><i class="bi bi-pencil"></i></button><button class="btn-p btn-dng btn-sm" onclick="delT('+t.id+')"><i class="bi bi-trash"></i></button></td></tr>';}).join('');
}
function changeMonth(d){CM+=d;if(CM>11){CM=0;CY++;}if(CM<0){CM=11;CY--;}rKal();}
function rPat(f=''){const l=S.patienten.filter(p=>!f||p.name.toLowerCase().includes(f)||(p.rasse||'').toLowerCase().includes(f));document.getElementById('p-cnt-lbl').textContent=l.length+' Patient'+(l.length!==1?'en':'');document.getElementById('pat-tbl').innerHTML=l.map(p=>{const b=gB(p.bid);return'<tr><td><span style="font-size:1.1rem;margin-right:.4rem;">'+ICONS[p.ta]+'</span><strong>'+p.name+'</strong></td><td>'+p.ta+'</td><td>'+(p.rasse||'-')+'</td><td>'+(b?b.name:'-')+'</td><td>'+fd(p.lb)+'</td><td>'+bdg(p.st||'aktiv')+'</td><td style="display:flex;gap:.25rem;"><button class="btn-p btn-out btn-sm" onclick="editP('+p.id+')"><i class="bi bi-pencil"></i></button><button class="btn-p btn-dng btn-sm" onclick="delP('+p.id+')"><i class="bi bi-trash"></i></button></td></tr>';}).join('')||'<tr><td colspan="7" style="text-align:center;color:var(--sa-muted);padding:2rem;">Keine Patienten gefunden</td></tr>';}
function filtP(){rPat(document.getElementById('p-srch').value.toLowerCase());}
function rTh(){document.getElementById('th-cnt-lbl').textContent=S.besitzer.length+' Tierhalter';document.getElementById('th-tbl').innerHTML=S.besitzer.map(b=>{const a=S.patienten.filter(p=>p.bid===b.id).length;return'<tr><td><strong>'+b.name+'</strong></td><td>'+b.email+'</td><td>'+(b.tel||'-')+'</td><td><span class="sb b-aktiv">'+a+' Tier'+(a!==1?'e':'')+'</span></td><td style="display:flex;gap:.25rem;"><button class="btn-p btn-out btn-sm" onclick="editBes('+b.id+')"><i class="bi bi-pencil"></i></button><button class="btn-p btn-dng btn-sm" onclick="delBes('+b.id+')"><i class="bi bi-trash"></i></button></td></tr>';}).join('');}
function addThPrompt(){const n=prompt('Name:');if(!n)return;const e=prompt('E-Mail:')||'';const t=prompt('Telefon:')||'';S.besitzer.push({id:S.nid.b++,name:n,email:e,tel:t});saveS();rTh();toast('Tierhalter angelegt');}
function editBes(id){const b=gB(id);if(!b)return;const n=prompt('Name:',b.name);if(!n)return;b.name=n;b.email=prompt('E-Mail:',b.email)||b.email;b.tel=prompt('Telefon:',b.tel)||b.tel;saveS();rTh();toast('Tierhalter aktualisiert');}
function delBes(id){if(!confirm('Tierhalter loschen?'))return;S.besitzer=S.besitzer.filter(b=>b.id!==id);saveS();rTh();toast('Geloscht','inf');}
function rBef(){document.getElementById('bef-tbl').innerHTML=S.befunde.map(b=>{const p=gP(b.pid);return'<tr><td>'+fd(b.dat)+'</td><td>'+(p?ICONS[p.ta]+' '+p.name:'-')+'</td><td>'+b.von+'</td><td style="max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+b.diag+'</td><td><button class="btn-p btn-out btn-sm" onclick="toast(\'Nur in der echten App verfugbar\',\'inf\')"><i class="bi bi-eye"></i></button></td></tr>';}).join('');}
function rRech(){const bz=S.rechnungen.filter(r=>r.st==='bezahlt').reduce((s,r)=>s+r.bet,0);const au=S.rechnungen.filter(r=>r.st==='ausstehend').reduce((s,r)=>s+r.bet,0);const ue=S.rechnungen.filter(r=>r.st==='ueberfaellig').reduce((s,r)=>s+r.bet,0);document.getElementById('r-bez').textContent=mon(bz);document.getElementById('r-aus').textContent=mon(au);document.getElementById('r-ueb').textContent=mon(ue);document.getElementById('r-ges').textContent=S.rechnungen.length;const sl=[...S.rechnungen].sort((a,b)=>b.dat.localeCompare(a.dat));document.getElementById('rech-tbl').innerHTML=sl.map(r=>{const p=gP(r.pid);const b=p?gB(p.bid):null;return'<tr><td><strong>'+r.nr+'</strong></td><td>'+(p?ICONS[p.ta]+' '+p.name:'-')+(b?'<span style="color:var(--sa-muted);font-size:.75rem;"> / '+b.name+'</span>':'')+'</td><td><strong>'+mon(r.bet)+'</strong></td><td>'+fd(r.dat)+'</td><td>'+fd(r.fae)+'</td><td>'+bdg(r.st)+'</td><td style="display:flex;gap:.25rem;">'+(r.st!=='bezahlt'?'<button class="btn-p btn-suc btn-sm" onclick="markBez('+r.id+')"><i class="bi bi-check-lg"></i></button>':'')+'<button class="btn-p btn-dng btn-sm" onclick="delR('+r.id+')"><i class="bi bi-trash"></i></button></td></tr>';}).join('');}
function markBez(id){const r=S.rechnungen.find(r=>r.id===id);if(r){r.st='bezahlt';saveS();rRech();toast('Als bezahlt markiert');}}
function delR(id){if(!confirm('Rechnung loschen?'))return;S.rechnungen=S.rechnungen.filter(r=>r.id!==id);saveS();rRech();toast('Geloscht','inf');}
function openMod(id){if(id==='mod-termin'){document.getElementById('t-eid').value='';document.getElementById('t-mod-ttl').textContent='Neuer Termin';document.getElementById('t-dat').value=td();document.getElementById('t-zeit').value='09:00';document.getElementById('t-not').value='';fillPS('t-pat');}if(id==='mod-patient'){document.getElementById('p-eid').value='';document.getElementById('p-mod-ttl').textContent='Neuer Patient';['p-name','p-rasse','p-diag'].forEach(i=>document.getElementById(i).value='');document.getElementById('p-geb').value='';document.getElementById('p-gew').value='';fillBS('p-bes');}if(id==='mod-rechnung'){document.getElementById('r-dat').value=td();document.getElementById('r-bet').value='';document.getElementById('r-lei').value='';fillPS('r-pat');}document.getElementById(id).classList.add('open');}
function closeMod(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.modal-bg').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
function fillPS(sid,sv=null){document.getElementById(sid).innerHTML=S.patienten.map(p=>'<option value="'+p.id+'"'+(p.id==sv?' selected':'')+'>'+ICONS[p.ta]+' '+p.name+' ('+p.ta+')</option>').join('');}
function fillBS(sid,sv=null){document.getElementById(sid).innerHTML=S.besitzer.map(b=>'<option value="'+b.id+'"'+(b.id==sv?' selected':'')+'>'+b.name+'</option>').join('');}
function openTerminDate(d){document.getElementById('t-eid').value='';document.getElementById('t-mod-ttl').textContent='Neuer Termin';document.getElementById('t-dat').value=d;document.getElementById('t-zeit').value='09:00';document.getElementById('t-not').value='';fillPS('t-pat');document.getElementById('mod-termin').classList.add('open');}
function editT(id){const t=S.termine.find(t=>t.id===id);if(!t)return;document.getElementById('t-eid').value=id;document.getElementById('t-mod-ttl').textContent='Termin bearbeiten';document.getElementById('t-dat').value=t.dat;document.getElementById('t-zeit').value=t.zeit;document.getElementById('t-not').value=t.not||'';fillPS('t-pat',t.pid);document.getElementById('t-beh').value=t.beh;document.getElementById('mod-termin').classList.add('open');}
function saveTermin(){const eid=document.getElementById('t-eid').value;const dat=document.getElementById('t-dat').value;const zeit=document.getElementById('t-zeit').value;const pid=parseInt(document.getElementById('t-pat').value);const beh=document.getElementById('t-beh').value;const not=document.getElementById('t-not').value;if(!dat||!zeit){toast('Bitte Datum und Zeit eingeben','inf');return;}if(eid){Object.assign(S.termine.find(t=>t.id==eid),{dat,zeit,pid,beh,not});toast('Termin aktualisiert');}else{S.termine.push({id:S.nid.t++,dat,zeit,pid,beh,st:'aktiv',not});toast('Termin erstellt');}saveS();closeMod('mod-termin');const a=document.querySelector('.page.active');if(a)renderPage(a.id.replace('page-',''));}
function delT(id){if(!confirm('Termin loschen?'))return;S.termine=S.termine.filter(t=>t.id!==id);saveS();rKal();toast('Geloscht','inf');}
function editP(id){const p=S.patienten.find(p=>p.id===id);if(!p)return;document.getElementById('p-eid').value=id;document.getElementById('p-mod-ttl').textContent='Patient bearbeiten';document.getElementById('p-name').value=p.name;document.getElementById('p-rasse').value=p.rasse||'';document.getElementById('p-geb').value=p.geb||'';document.getElementById('p-gew').value=p.gew||'';document.getElementById('p-ges').value=p.ges||'Weiblich';document.getElementById('p-ta').value=p.ta||'Hund';document.getElementById('p-diag').value=p.diag||'';fillBS('p-bes',p.bid);document.getElementById('mod-patient').classList.add('open');}
function savePatient(){const eid=document.getElementById('p-eid').value;const name=document.getElementById('p-name').value.trim();if(!name){toast('Bitte Name eingeben','inf');return;}const d={name,ta:document.getElementById('p-ta').value,rasse:document.getElementById('p-rasse').value,ges:document.getElementById('p-ges').value,geb:document.getElementById('p-geb').value,gew:parseFloat(document.getElementById('p-gew').value)||0,bid:parseInt(document.getElementById('p-bes').value),diag:document.getElementById('p-diag').value,lb:td(),st:'aktiv'};if(eid){Object.assign(S.patienten.find(p=>p.id==eid),d);toast('Patient aktualisiert');}else{S.patienten.push({id:S.nid.p++,...d});toast('Patient angelegt');}saveS();closeMod('mod-patient');rPat();}
function delP(id){if(!confirm('Patient loschen?'))return;S.patienten=S.patienten.filter(p=>p.id!==id);saveS();rPat();toast('Geloscht','inf');}
function saveRech(){const pid=parseInt(document.getElementById('r-pat').value);const bet=parseFloat(document.getElementById('r-bet').value);const dat=document.getElementById('r-dat').value||td();const lei=document.getElementById('r-lei').value;if(!bet||bet<=0){toast('Bitte Betrag eingeben','inf');return;}const nr='RE-'+new Date().getFullYear()+'-'+String(S.nid.r).padStart(3,'0');const fae=new Date(dat);fae.setDate(fae.getDate()+14);S.rechnungen.push({id:S.nid.r++,nr,pid,bet,dat,fae:fae.toISOString().slice(0,10),lei,st:'ausstehend'});saveS();closeMod('mod-rechnung');rRech();toast('Rechnung erstellt');}
function toast(msg,type='suc'){const w=document.getElementById('twWrap');const t=document.createElement('div');t.className='tw-item '+type;t.innerHTML='<i class="bi bi-'+(type==='suc'?'check-circle-fill':'info-circle-fill')+'" style="color:'+(type==='suc'?'var(--sa-success)':'var(--sa-primary)')+';flex-shrink:0;"></i><span>'+msg+'</span>';w.appendChild(t);setTimeout(()=>t.remove(),3500);}
loadS();rDash();
</script>
</body>
</html>