{% extends 'layouts/base.twig' %}

{% block title %}Praxis Cronjobs - SaaS Admin{% endblock %}
 
{% block styles %}
<style>
    /* Premium Futuristic Dark Theme Overrides */
    :root {
        --glass-bg: rgba(30, 41, 59, 0.7);
        --glass-border: rgba(255, 255, 255, 0.08);
        --accent-glow: rgba(37, 99, 235, 0.3);
    }
 
    .page-content {
        background: radial-gradient(circle at top right, rgba(30, 41, 59, 0.5), transparent),
                    radial-gradient(circle at bottom left, rgba(15, 23, 42, 0.8), #0f172a);
    }
 
    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border);
        border-radius: 1rem;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        overflow: hidden;
    }
 
    .glass-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 40px 0 rgba(0, 0, 0, 0.45), 0 0 20px 0 var(--accent-glow);
    }
 
    .card-header-gradient {
        background: linear-gradient(90deg, rgba(37, 99, 235, 0.1), transparent);
        border-bottom: 1px solid var(--glass-border);
        padding: 1.25rem;
    }
 
    .hero-alert {
        background: linear-gradient(135deg, rgba(34, 197, 94, 0.1), rgba(21, 128, 61, 0.05));
        border: 1px solid rgba(34, 197, 94, 0.2);
        color: #86efac;
        border-radius: 1rem;
    }
 
    .instruction-card {
        border-left: 4px solid var(--saas-primary);
    }
 
    .step-number {
        width: 24px;
        height: 24px;
        background: var(--saas-primary);
        color: white;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: bold;
        margin-right: 0.75rem;
    }
 
    .code-box {
        background: rgba(15, 23, 42, 0.9) !important;
        border: 1px solid rgba(37, 99, 235, 0.3) !important;
        color: #94a3b8 !important;
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
    }
 
    .btn-glow {
        box-shadow: 0 0 15px rgba(37, 99, 235, 0.4);
    }
 
    .btn-glow:hover {
        box-shadow: 0 0 25px rgba(37, 99, 235, 0.6);
    }
 
    .table-dark-custom {
        --bs-table-bg: transparent;
        --bs-table-striped-bg: rgba(255, 255, 255, 0.02);
        --bs-table-hover-bg: rgba(37, 99, 235, 0.05);
    }
 
    .status-badge {
        padding: 0.5em 1em;
        border-radius: 2rem;
        font-weight: 500;
        letter-spacing: 0.02em;
    }
 
    /* Soften the amber/warning */
    .alert-soft-warning {
        background: rgba(245, 158, 11, 0.05);
        border: 1px solid rgba(245, 158, 11, 0.2);
        color: #fcd34d;
    }
 
    .neon-text-blue { text-shadow: 0 0 10px rgba(37, 99, 235, 0.5); color: #60a5fa; }
    .neon-text-green { text-shadow: 0 0 10px rgba(34, 197, 94, 0.5); color: #4ade80; }
</style>
{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <h1 class="h3 mb-4">Praxis Cronjobs</h1>
            
            <div class="alert alert-success d-flex align-items-center">
                <div class="me-3 fs-3">🚀</div>
                <div>
                    <strong>Zentrale Automatisierung aktiv!</strong><br>
                    Du musst ab sofort nur noch <strong>einen einzigen</strong> Cronjob in deinem Hostinger-Panel einrichten. Dieser übernimmt automatisch die Aufgaben für alle Praxen.
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <h1 class="h3 mb-4 fw-bold neon-text-blue">Praxis Cronjobs</h1>
            
            <div class="hero-alert p-4 mb-4 d-flex align-items-center">
                <div class="me-4 fs-1">🚀</div>
                <div>
                    <h5 class="mb-1 text-white fw-bold">Zentrale Automatisierung aktiv!</h5>
                    <p class="mb-0 opacity-75">
                        Du musst ab sofort nur noch <strong>einen einzigen</strong> Cronjob in deinem Hostinger-Panel einrichten. 
                        Dieser übernimmt automatisch die Aufgaben für alle Praxen.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="glass-card instruction-card h-100">
                <div class="card-header-gradient">
                    <h5 class="card-title mb-0 d-flex align-items-center">
                        <i class="bi bi-tools me-2 text-primary"></i> Hostinger Setup-Anleitung
                    </h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">Um alle Praxen automatisch zu verarbeiten, richte bitte folgenden Cronjob ein:</p>
                    
                    <div class="space-y-4">
                        <div class="d-flex mb-3">
                            <span class="step-number">1</span>
                            <span>Logge dich in dein <strong>Hostinger hPanel</strong> ein.</span>
                        </div>
                        <div class="d-flex mb-3">
                            <span class="step-number">2</span>
                            <span>Gehe zu <strong>Erweitert &rarr; Cronjobs</strong>.</span>
                        </div>
                        <div class="d-flex mb-3">
                            <span class="step-number">3</span>
                            <span>Wähle <strong>Custom</strong> (Benutzerdefiniert).</span>
                        </div>
                        <div class="d-flex mb-4">
                            <span class="step-number">4</span>
                            <div class="flex-grow-1">
                                <span>Trage unter <strong>Command</strong> folgendes ein:</span>
                                <div class="input-group mt-3">
                                    <input type="text" class="form-control code-box border-0" id="global-cron-cmd" value="php /home/u772175418/domains/therapano.de/public_html/saas-platform/cron/cron_runner.php" readonly>
                                    <button class="btn btn-primary btn-glow px-4" type="button" onclick="copyToClipboard('global-cron-cmd')">
                                        <i class="bi bi-clipboard me-1"></i> Kopieren
                                    </button>
                                </div>
                                <div class="mt-2 small text-muted">
                                    <i class="bi bi-info-circle me-1"></i> Falls dieser Pfad nicht funktioniert, verwende <code>/usr/local/bin/php</code>.
                                </div>
                            </div>
                        </div>
                        <div class="d-flex mb-3">
                            <span class="step-number">5</span>
                            <span>Stelle das Intervall auf <strong>Alle 10 Minuten</strong> (<code>*/10 * * * *</code>).</span>
                        </div>
                    </div>
                    
                    <div class="alert-soft-warning p-3 mt-4 mb-0 d-flex align-items-center rounded-3">
                        <i class="bi bi-shield-check fs-4 me-3 text-warning"></i>
                        <div>
                            <strong>Self-Healing:</strong> Dieser Script repariert automatisch Datenbankfehler 
                            (wie fehlende Spalten) in den Praxen.
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="glass-card h-100">
                <div class="card-header-gradient">
                    <h5 class="card-title mb-0 d-flex align-items-center">
                        <i class="bi bi-list-stars me-2 text-info"></i> Verwaltete Aufgaben
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="list-group list-group-flush bg-transparent">
                        <div class="list-group-item bg-transparent border-0 px-0 mb-2">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-3">🎂</span>
                                <div>
                                    <div class="fw-bold text-white">Geburtstage</div>
                                    <small class="text-muted">Täglich 08:00 Uhr</small>
                                </div>
                            </div>
                        </div>
                        <div class="list-group-item bg-transparent border-0 px-0 mb-2">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-3">📅</span>
                                <div>
                                    <div class="fw-bold text-white">Kalender-Erinn.</div>
                                    <small class="text-muted">Alle 15 Minuten</small>
                                </div>
                            </div>
                        </div>
                        <div class="list-group-item bg-transparent border-0 px-0 mb-2">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-3">🔄</span>
                                <div>
                                    <div class="fw-bold text-white">Google Sync</div>
                                    <small class="text-muted">Stündlich</small>
                                </div>
                            </div>
                        </div>
                        <div class="list-group-item bg-transparent border-0 px-0 mb-2">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-3">💉</span>
                                <div>
                                    <div class="fw-bold text-white">TherapyCare</div>
                                    <small class="text-muted">Alle 15 Minuten</small>
                                </div>
                            </div>
                        </div>
                        <div class="list-group-item bg-transparent border-0 px-0">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-3">🎉</span>
                                <div>
                                    <div class="fw-bold text-white">Feiertage</div>
                                    <small class="text-muted">Täglich 08:00 Uhr</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="glass-card">
                <div class="card-header-gradient d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0 d-flex align-items-center">
                        <i class="bi bi-building me-2 text-primary"></i> Registrierte Praxen
                    </h5>
                    <button type="button" class="btn btn-sm btn-outline-warning" onclick="migrateAllTenants()">
                        <i class="bi bi-database-up me-1"></i> Globales Datenbank-Update
                    </button>
                </div>
                <div class="card-body p-0">
                    {% if tenants is empty %}
                    <div class="p-4 text-center text-muted">
                        <i class="bi bi-search fs-2 d-block mb-2"></i>
                        Keine Praxen gefunden.
                    </div>
                    {% else %}
                    <div class="table-responsive">
                        <table class="table table-dark-custom table-hover mb-0 align-middle">
                            <thead class="bg-dark">
                                <tr>
                                    <th class="ps-4">Praxis Name</th>
                                    <th>Kontakt</th>
                                    <th>Version</th>
                                    <th>Status</th>
                                    <th class="pe-4 text-end">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for tenant in tenants %}
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-white">{{ tenant.practice_name }}</div>
                                        <small class="text-muted">ID: {{ tenant.id }}</small>
                                    </td>
                                    <td>
                                        <div class="small">{{ tenant.email }}</div>
                                    </td>
                                    <td>
                                        <span id="db-version-{{ tenant.id }}" class="status-badge bg-secondary opacity-75">v?</span>
                                    </td>
                                    <td>
                                        <span class="status-badge badge-active small">Aktiv</span>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <button type="button" class="btn btn-sm btn-outline-primary me-2" data-bs-toggle="modal" data-bs-target="#modal-{{ tenant.id }}">
                                            <i class="bi bi-gear"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetTenantVersion({{ tenant.id }}, 34)" title="Reset v34">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

{% for tenant in tenants %}
<!-- Modal für {{ tenant.practice_name }} -->
<div class="modal fade" id="modal-{{ tenant.id }}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content glass-card border-0">
            <div class="card-header-gradient d-flex justify-content-between align-items-center">
                <h5 class="modal-title text-white">Konfiguration: {{ tenant.practice_name }}</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="small text-muted text-uppercase fw-bold">Praxis E-Mail</label>
                        <div class="text-white">{{ tenant.email }}</div>
                    </div>
                    <div class="col-md-6">
                        <label class="small text-muted text-uppercase fw-bold">Tenant UUID</label>
                        <div class="text-white font-monospace small">{{ tenant.uuid }}</div>
                    </div>
                </div>
                
                <div class="p-3 rounded-3 bg-dark border border-secondary border-opacity-25 mb-4">
                    <h6 class="text-primary mb-3"><i class="bi bi-lightning-charge me-2"></i> Manueller Dispatcher-Zugriff</h6>
                    
                    <div class="mb-3">
                        <label class="form-label small text-muted">Sicherheits-Token</label>
                        <div class="input-group">
                            <input type="text" class="form-control code-box border-0" id="token-{{ tenant.id }}" placeholder="Token generieren...">
                            <button type="button" class="btn btn-secondary" onclick="generateToken('token-{{ tenant.id }}')">
                                <i class="bi bi-dice-5"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label small text-muted">Direkt-URL (Trigger)</label>
                        <div class="input-group">
                            <input type="text" class="form-control code-box border-0 text-truncate" id="url-{{ tenant.id }}" readonly>
                            <button type="button" class="btn btn-secondary" onclick="copyToClipboard('url-{{ tenant.id }}')">
                                <i class="bi bi-clipboard"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2 align-items-center">
                        <form action="/admin/praxis-cron/update-token" method="POST" class="m-0">
                            <input type="hidden" name="tenant_id" value="{{ tenant.id }}">
                            <input type="hidden" name="cron_job_key" value="dispatcher">
                            <input type="hidden" name="token" id="input-token-{{ tenant.id }}">
                            <button type="submit" class="btn btn-success btn-glow px-4">Speichern</button>
                        </form>
                        
                        <button type="button" class="btn btn-outline-info px-4" onclick="runCron({{ tenant.id }}, 'dispatcher')">
                            <i class="bi bi-play-circle me-1"></i> Testen
                        </button>
                    </div>
                    
                    <div id="result-{{ tenant.id }}" class="mt-3"></div>
                </div>
            </div>
            <div class="modal-footer border-0 p-4 pt-0">
                <button type="button" class="btn btn-outline-secondary w-100" data-bs-dismiss="modal">Schließen</button>
            </div>
        </div>
    </div>
</div>
{% endfor %}

<script>
function generateToken(inputId) {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
    let token = '';
    for (let i = 0; i < 40; i++) {
        token += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    document.getElementById(inputId).value = token;
    updateUrlsAndCmds();
}

function copyToClipboard(elementId) {
    const element = document.getElementById(elementId);
    element.select();
    document.execCommand('copy');
}

function runCron(tenantId, cronJobKey) {
    const resultDiv = document.getElementById('result-' + tenantId);
    resultDiv.innerHTML = '<span class="text-info">⏳ Dispatcher wird gestartet...</span>';

    fetch('/admin/praxis-cron/run-now?tenant_id=' + tenantId + '&cron_job_key=' + cronJobKey)
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            resultDiv.innerHTML = '<span class="text-success">✓ Erfolgreich (HTTP ' + data.http_code + ')</span>';
        } else {
            resultDiv.innerHTML = '<span class="text-danger">✗ Fehlgeschlagen: ' + (data.error || 'HTTP ' + data.http_code) + '</span>';
        }
    })
    .catch(error => {
        resultDiv.innerHTML = '<span class="text-danger">✗ Fehler: ' + error + '</span>';
    });
}

function updateUrlsAndCmds() {
    {% for tenant in tenants %}
    const token{{ tenant.id }} = document.getElementById('token-{{ tenant.id }}').value;
    const domain{{ tenant.id }} = 'app.therapano.de';
    const tid{{ tenant.id }} = '{{ tenant.tid|default('') }}';
    const url{{ tenant.id }} = 'https://' + domain{{ tenant.id }} + '/cron/dispatcher?tid=' + tid{{ tenant.id }} + '&token=' + token{{ tenant.id }};
    const cmd{{ tenant.id }} = '*/10 * * * * curl -s "' + url{{ tenant.id }} + '" > /dev/null 2>&1';

    document.getElementById('url-{{ tenant.id }}').value = url{{ tenant.id }};
    document.getElementById('cmd-{{ tenant.id }}').value = cmd{{ tenant.id }};
    document.getElementById('input-token-{{ tenant.id }}').value = token{{ tenant.id }};
    {% endfor %}
}

// Initialize on modal show
document.addEventListener('DOMContentLoaded', function() {
    {% for tenant in tenants %}
    document.getElementById('modal-{{ tenant.id }}').addEventListener('show.bs.modal', function() {
        // Load existing token from server via AJAX
        fetch('/admin/praxis-cron/get-token?tenant_id={{ tenant.id }}&cron_job_key=dispatcher')
        .then(response => response.json())
        .then(data => {
            if (data.success && data.token) {
                document.getElementById('token-{{ tenant.id }}').value = data.token;
                updateUrlsAndCmds();
            }
        })
        .catch(error => {
            console.error('Fehler beim Laden des Tokens:', error);
        });
    });
    {% endfor %}

    // Load database versions
    {% for tenant in tenants %}
    loadTenantVersion({{ tenant.id }});
    {% endfor %}
});

function loadTenantVersion(tenantId) {
    const versionBadge = document.getElementById('db-version-' + tenantId);
    if (!versionBadge) return;

    fetch('/admin/migration/tenant-version?tenant_id=' + tenantId, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (data.current_version === null) {
                versionBadge.textContent = 'N/A';
                versionBadge.className = 'badge bg-warning';
            } else if (data.is_up_to_date) {
                versionBadge.textContent = 'v' + data.current_version;
                versionBadge.className = 'badge bg-success';
            } else {
                versionBadge.textContent = 'v' + data.current_version + ' (neu: v' + data.latest_version + ')';
                versionBadge.className = 'badge bg-warning';
            }
        } else {
            versionBadge.textContent = 'Fehler';
            versionBadge.className = 'badge bg-danger';
        }
    })
    .catch(error => {
        versionBadge.textContent = 'Fehler';
        versionBadge.className = 'badge bg-danger';
    });
}

function migrateAllTenants() {
    const statusDiv = document.getElementById('migration-status');
    statusDiv.innerHTML = '<span class="text-info">⏳ Migration läuft...</span>';

    fetch('/admin/migration/migrate-all')
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            statusDiv.innerHTML = '<span class="text-success">✓ ' + data.message + '</span>';
            // Reload versions
            {% for tenant in tenants %}
            loadTenantVersion({{ tenant.id }});
            {% endfor %}
        } else {
            statusDiv.innerHTML = '<span class="text-danger">✗ ' + (data.error || data.message) + '</span>';
        }
    })
    .catch(error => {
        statusDiv.innerHTML = '<span class="text-danger">✗ Fehler: ' + error + '</span>';
    });
}

function resetTenantVersion(tenantId, targetVersion) {
    if (!confirm('Version wirklich auf v' + targetVersion + ' zurücksetzen?')) return;

    fetch('/admin/migration/reset-version?tenant_id=' + tenantId + '&target_version=' + targetVersion)
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            loadTenantVersion(tenantId);
        } else {
            alert('Fehler: ' + (data.error || data.message));
        }
    })
    .catch(error => {
        alert('Fehler: ' + error);
    });
}
</script>
{% endblock %}
