{% extends 'layouts/base.twig' %}
{% set active_nav = 'praxis_cron' %}

{% block title %}Praxis Cronjobs - SaaS Admin{% endblock %}

{% block content %}
<div class="row mb-4">
    <div class="col-12">
        <h4 class="fw-bold mb-3 text-primary"><i class="bi bi-clock-history me-2"></i>Praxis Cronjobs</h4>
        <div class="alert alert-success d-flex align-items-center gap-3">
            <i class="bi bi-rocket-takeoff fs-3 flex-shrink-0"></i>
            <div>
                <h6 class="mb-1 fw-bold">Zentrale Automatisierung aktiv!</h6>
                <p class="mb-0 fs-sm opacity-75">Du musst ab sofort nur noch <strong>einen einzigen</strong> Cronjob in deinem Hostinger-Panel einrichten. Dieser übernimmt automatisch die Aufgaben für alle Praxen.</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-start border-primary h-100">
                <div class="card-header px-4 py-3">
                    <h5 class="card-title mb-0 d-flex align-items-center">
                        <i class="bi bi-tools me-2 text-primary"></i>Hostinger Setup-Anleitung
                    </h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">Um alle Praxen automatisch zu verarbeiten, richte bitte folgenden Cronjob ein:</p>
                    
                    <div class="space-y-4">
                        <div class="d-flex mb-3 align-items-start gap-2">
                            <span class="ps-step-num">1</span>
                            <span>Logge dich in dein <strong>Hostinger hPanel</strong> ein.</span>
                        </div>
                        <div class="d-flex mb-3 align-items-start gap-2">
                            <span class="ps-step-num">2</span>
                            <span>Gehe zu <strong>Erweitert &rarr; Cronjobs</strong>.</span>
                        </div>
                        <div class="d-flex mb-3 align-items-start gap-2">
                            <span class="ps-step-num">3</span>
                            <span>Wähle <strong>Custom</strong> (Benutzerdefiniert).</span>
                        </div>
                        <div class="d-flex mb-4 align-items-start gap-2">
                            <span class="ps-step-num">4</span>
                            <div class="flex-grow-1">
                                <span>Trage unter <strong>Command</strong> folgendes ein:</span>
                                <div class="input-group mt-3">
                                    <input type="text" class="form-control font-monospace" id="global-cron-cmd" value="php /home/u772175418/domains/therapano.de/public_html/saas-platform/cron/cron_runner.php" readonly>
                                    <button class="btn btn-primary px-4" type="button" onclick="copyToClipboard('global-cron-cmd')">
                                        <i class="bi bi-clipboard me-1"></i> Kopieren
                                    </button>
                                </div>
                                <div class="mt-2 small text-muted">
                                    <i class="bi bi-info-circle me-1"></i> Falls dieser Pfad nicht funktioniert, verwende <code>/usr/local/bin/php</code>.
                                </div>
                            </div>
                        </div>
                        <div class="d-flex mb-3 align-items-start gap-2">
                            <span class="ps-step-num">5</span>
                            <span>Stelle das Intervall auf <strong>Alle 10 Minuten</strong> (<code>*/10 * * * *</code>).</span>
                        </div>
                    </div>
                    
                    <div class="alert alert-warning d-flex align-items-center gap-2 mt-4 mb-0">
                        <i class="bi bi-shield-check fs-4 me-3 text-warning"></i>
                        <div>
                            <strong>Self-Healing:</strong> Dieser Script repariert automatisch Datenbankfehler 
                            (wie fehlende Spalten) in den Praxen.
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header px-4 py-3">
                    <h5 class="card-title mb-0 d-flex align-items-center">
                        <i class="bi bi-list-stars me-2 text-info"></i>Verwaltete Aufgaben
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="list-group list-group-flush bg-transparent">
                        <div class="list-group-item bg-transparent border-0 px-0 mb-2">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-3">🎂</span>
                                <div>
                                    <div class="fw-bold text-white">Geburtstage</div>
                                    <small class="text-muted">Täglich 08:00 Uhr</small>
                                </div>
                            </div>
                        </div>
                        <div class="list-group-item bg-transparent border-0 px-0 mb-2">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-3">📅</span>
                                <div>
                                    <div class="fw-bold text-white">Kalender-Erinn.</div>
                                    <small class="text-muted">Alle 15 Minuten</small>
                                </div>
                            </div>
                        </div>
                        <div class="list-group-item bg-transparent border-0 px-0 mb-2">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-3">🔄</span>
                                <div>
                                    <div class="fw-bold text-white">Google Sync</div>
                                    <small class="text-muted">Stündlich</small>
                                </div>
                            </div>
                        </div>
                        <div class="list-group-item bg-transparent border-0 px-0 mb-2">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-3">💉</span>
                                <div>
                                    <div class="fw-bold text-white">TherapyCare</div>
                                    <small class="text-muted">Alle 15 Minuten</small>
                                </div>
                            </div>
                        </div>
                        <div class="list-group-item bg-transparent border-0 px-0">
                            <div class="d-flex align-items-center">
                                <span class="fs-4 me-3">🎉</span>
                                <div>
                                    <div class="fw-bold text-white">Feiertage</div>
                                    <small class="text-muted">Täglich 08:00 Uhr</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header px-4 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0 d-flex align-items-center">
                        <i class="bi bi-building me-2 text-primary"></i>Registrierte Praxen
                    </h5>
                </div>
                <div class="card-body p-0">
                    {% if tenants is empty %}
                    <div class="p-4 text-center text-muted">
                        <i class="bi bi-search fs-2 d-block mb-2"></i>
                        Keine Praxen gefunden.
                    </div>
                    {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="bg-dark">
                                <tr>
                                    <th class="ps-4">Praxis Name</th>
                                    <th>Kontakt</th>
                                    <th>Status</th>
                                    <th class="pe-4 text-end">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for tenant in tenants %}
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-white">{{ tenant.practice_name }}</div>
                                        <small class="text-muted">ID: {{ tenant.id }}</small>
                                    </td>
                                    <td>
                                        <div class="small">{{ tenant.email }}</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-success">Aktiv</span>
                                    </td>
                                    <td class="pe-4 text-end" id="tenant-actions-{{ tenant.id }}">
                                        <button type="button" class="btn btn-sm btn-outline-primary me-2" data-bs-toggle="modal" data-bs-target="#modal-{{ tenant.id }}" title="Konfiguration">
                                            <i class="bi bi-gear"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetTenantVersion({{ tenant.id }}, 34)" title="Reset v34">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

{% for tenant in tenants %}
<!-- Modal für {{ tenant.practice_name }} -->
<div class="modal fade" id="modal-{{ tenant.id }}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header px-4">
                <h5 class="modal-title text-white">Konfiguration: {{ tenant.practice_name }}</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 py-3">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="small text-muted text-uppercase fw-bold">Praxis E-Mail</label>
                        <div class="text-white">{{ tenant.email }}</div>
                    </div>
                    <div class="col-md-6">
                        <label class="small text-muted text-uppercase fw-bold">Tenant UUID</label>
                        <div class="text-white font-monospace small">{{ tenant.uuid }}</div>
                    </div>
                </div>
                
                <div class="p-3 rounded-3 bg-dark border border-secondary border-opacity-25 mb-4">
                    <h6 class="text-primary mb-3"><i class="bi bi-lightning-charge me-2"></i> Manueller Dispatcher-Zugriff</h6>
                    
                    <div class="mb-3">
                        <label class="form-label small text-muted">Sicherheits-Token</label>
                        <div class="input-group">
                            <input type="text" class="form-control font-monospace" id="token-{{ tenant.id }}" placeholder="Token generieren...">
                            <button type="button" class="btn btn-secondary" onclick="generateToken('token-{{ tenant.id }}')">
                                <i class="bi bi-dice-5"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label small text-muted">Direkt-URL (Trigger)</label>
                        <div class="input-group">
                            <input type="text" class="form-control font-monospace text-truncate" id="url-{{ tenant.id }}" readonly>
                            <button type="button" class="btn btn-secondary" onclick="copyToClipboard('url-{{ tenant.id }}')">
                                <i class="bi bi-clipboard"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2 align-items-center">
                        <form action="/admin/praxis-cron/update-token" method="POST" class="m-0">
                            <input type="hidden" name="tenant_id" value="{{ tenant.id }}">
                            <input type="hidden" name="cron_job_key" value="dispatcher">
                            <input type="hidden" name="token" id="input-token-{{ tenant.id }}">
                            <button type="submit" class="btn btn-success px-4">Speichern</button>
                        </form>
                        
                        <button type="button" class="btn btn-outline-info px-4" onclick="runCron({{ tenant.id }}, 'dispatcher')">
                            <i class="bi bi-play-circle me-1"></i> Testen
                        </button>
                    </div>
                    
                    <div id="result-{{ tenant.id }}" class="mt-3"></div>
                </div>
            </div>
            <div class="modal-footer border-0 p-4 pt-0">
                <button type="button" class="btn btn-outline-secondary w-100" data-bs-dismiss="modal">Schließen</button>
            </div>
        </div>
    </div>
</div>
{% endfor %}

<script>
function generateToken(inputId) {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
    let token = '';
    for (let i = 0; i < 40; i++) {
        token += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    document.getElementById(inputId).value = token;
    updateUrlsAndCmds();
}

function copyToClipboard(elementId) {
    const element = document.getElementById(elementId);
    element.select();
    document.execCommand('copy');
}

function runCron(tenantId, cronJobKey) {
    const resultDiv = document.getElementById('result-' + tenantId);
    resultDiv.innerHTML = '<span class="text-info">⏳ Dispatcher wird gestartet...</span>';

    fetch('/admin/praxis-cron/run-now?tenant_id=' + tenantId + '&cron_job_key=' + cronJobKey)
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            resultDiv.innerHTML = '<span class="text-success">✓ Erfolgreich (HTTP ' + data.http_code + ')</span>';
        } else {
            resultDiv.innerHTML = '<span class="text-danger">✗ Fehlgeschlagen: ' + (data.error || 'HTTP ' + data.http_code) + '</span>';
        }
    })
    .catch(error => {
        resultDiv.innerHTML = '<span class="text-danger">✗ Fehler: ' + error + '</span>';
    });
}

function updateUrlsAndCmds() {
    {% for tenant in tenants %}
    const tokenEl{{ tenant.id }} = document.getElementById('token-{{ tenant.id }}');
    if (tokenEl{{ tenant.id }}) {
        const token{{ tenant.id }} = tokenEl{{ tenant.id }}.value;
        const domain{{ tenant.id }} = 'app.therapano.de';
        const tid{{ tenant.id }} = '{{ tenant.tid|default('') }}';
        const url{{ tenant.id }} = 'https://' + domain{{ tenant.id }} + '/cron/dispatcher?tid=' + tid{{ tenant.id }} + '&token=' + token{{ tenant.id }};

        const urlInput{{ tenant.id }} = document.getElementById('url-{{ tenant.id }}');
        if (urlInput{{ tenant.id }}) urlInput{{ tenant.id }}.value = url{{ tenant.id }};

        const inputToken{{ tenant.id }} = document.getElementById('input-token-{{ tenant.id }}');
        if (inputToken{{ tenant.id }}) inputToken{{ tenant.id }}.value = token{{ tenant.id }};
    }
    {% endfor %}
}

// Initialize
document.addEventListener('DOMContentLoaded', function() {
    {% for tenant in tenants %}
    const modalEl{{ tenant.id }} = document.getElementById('modal-{{ tenant.id }}');
    if (modalEl{{ tenant.id }}) {
        modalEl{{ tenant.id }}.addEventListener('show.bs.modal', function() {
            // Load existing token from server via AJAX
            fetch('/admin/praxis-cron/get-token?tenant_id={{ tenant.id }}&cron_job_key=dispatcher')
            .then(response => response.json())
            .then(data => {
                if (data.success && data.token) {
                    document.getElementById('token-{{ tenant.id }}').value = data.token;
                    updateUrlsAndCmds();
                }
            })
            .catch(error => console.error('Token-Fehler:', error));
        });
    }
    {% endfor %}
});

function resetTenantVersion(tenantId, targetVersion) {
    if (!confirm('Version wirklich auf v' + targetVersion + ' zurücksetzen?')) return;

    fetch('/admin/migration/reset-version?tenant_id=' + tenantId + '&target_version=' + targetVersion)
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            loadTenantVersion(tenantId);
        } else {
            alert('Fehler: ' + (data.error || data.message));
        }
    })
    .catch(error => {
        alert('Fehler: ' + error);
    });
}
</script>
{% endblock %}
