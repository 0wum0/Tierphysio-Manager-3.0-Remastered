{# SYSTEM-HEALTH + AKTIVITÄTSPROTOKOLL                                       #}
{# ══════════════════════════════════════════════════════════════════════════ #}
<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="dash-card">
            <div class="dash-header">
                <div class="dash-title"><i class="bi bi-heart-pulse me-2" style="color:#6ee7b7;"></i>Systemstatus Prüfung</div>
                <button id="dash-health-btn" class="btn btn-sm btn-outline-success" style="font-size:.72rem;">
                    <i class="bi bi-arrow-clockwise me-1"></i>Alle prüfen
                </button>
            </div>
            <div id="dash-health-body" style="padding:1rem;">
                <div style="font-size:.8rem;color:#64748b;text-align:center;padding:.5rem 0;">
                    <i class="bi bi-shield-check me-1"></i>Auf "Alle prüfen" klicken um den Systemstatus aller aktiven Praxen zu laden.
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="dash-card h-100">
            <div class="dash-header">
                <div class="dash-title"><i class="bi bi-activity me-2" style="color:#60a5fa;"></i>Letzte Admin-Aktivitäten</div>
            </div>
            {% if recent_activity %}
            {% for act in recent_activity %}
            <div class="act-item">
                <div class="act-dot" style="background:{% if act.action starts with 'system' %}#60a5fa{% elseif act.action starts with 'tenant' %}#6ee7b7{% elseif act.action starts with 'payment' %}#fde68a{% else %}#94a3b8{% endif %};"></div>
                <div style="flex:1;min-width:0;">
                    <div style="color:#94a3b8;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ act.description ?? act.action }}</div>
                </div>
                <div style="font-size:.68rem;color:#475569;white-space:nowrap;flex-shrink:0;">{{ act.created_at|date('d.m H:i') }}</div>
            </div>
            {% endfor %}
            {% else %}
            <div style="padding:2rem;text-align:center;color:#475569;font-size:.8rem;">
                <i class="bi bi-journal" style="font-size:1.5rem;display:block;margin-bottom:.5rem;"></i>Noch keine Aktivitäten protokolliert.
            </div>
            {% endif %}
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════════════════════════════════ #}
{# TOP-KUNDEN + NEUESTES FEEDBACK                                            #}
{# ══════════════════════════════════════════════════════════════════════════ #}
<div class="row g-3">
    <div class="col-lg-6">
        <div class="dash-card">
            <div class="dash-header">
                <div class="dash-title"><i class="bi bi-trophy me-2" style="color:#fde68a;"></i>Top-Kunden nach Betrag</div>
            </div>
            {% for t in top_tenants %}
            <div style="padding:.6rem 1rem;border-bottom:1px solid #1f2d3d;display:flex;align-items:center;gap:.75rem;">
                <div style="width:1.6rem;height:1.6rem;border-radius:50%;background:linear-gradient(135deg,#6EA8FE,#a78bfa);display:flex;align-items:center;justify-content:center;font-size:.65rem;font-weight:700;color:#fff;flex-shrink:0;">
                    {{ loop.index }}
                </div>
                <div style="flex:1;min-width:0;">
                    <div style="font-size:.82rem;font-weight:600;color:#e2e8f0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ t.practice_name }}</div>
                    <div style="font-size:.7rem;color:#64748b;">{{ t.plan_name ?? '–' }} · {% if t.billing_cycle == 'yearly' %}Jährlich{% else %}Monatlich{% endif %}</div>
                </div>
                <div style="font-size:.9rem;font-weight:700;color:#fde68a;flex-shrink:0;">{{ t.amount ? t.amount|number_format(2,',','.') ~ ' €' : '–' }}</div>
            </div>
            {% else %}
            <div style="padding:2rem;text-align:center;color:#475569;font-size:.8rem;">Keine aktiven Abonnenten.</div>
            {% endfor %}
        </div>
    </div>

    <div class="col-lg-6">
        <div class="dash-card">
            <div class="dash-header">
                <div class="dash-title">
                    <i class="bi bi-chat-square-text me-2" style="color:#a78bfa;"></i>Neuestes Feedback
                    {% if stats.unread_feedback > 0 %}
                    <span class="badge ms-1" style="background:rgba(167,139,250,.2);color:#c4b5fd;font-size:.62rem;">{{ stats.unread_feedback }} ungelesen</span>
                    {% endif %}
                </div>
                <a href="/admin/feedback" class="btn btn-sm btn-outline-secondary" style="font-size:.72rem;">Alle →</a>
            </div>
            {% if recent_feedback %}
            {% for fb in recent_feedback %}
            {% set catClass = {'bug':'cat-bug','feature':'cat-feature','praise':'cat-praise','other':'cat-other'} %}
            {% set catDe    = {'bug':'Fehler','feature':'Wunsch','praise':'Lob','other':'Sonstiges'} %}
            {% set catIcon  = {'bug':'🐛','feature':'💡','praise':'⭐','other':'💬'} %}
            <div class="fb-item {% if not fb.is_read %}border-start border-3{% endif %}" style="{% if not fb.is_read %}border-color:#a78bfa !important;{% endif %}">
                <span style="font-size:1.05rem;">{{ catIcon[fb.category] ?? '💬' }}</span>
                <div style="flex:1;min-width:0;">
                    <div style="display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;">
                        <span style="font-size:.78rem;font-weight:600;color:#e2e8f0;">{{ fb.practice_name ?? 'Anonym' }}</span>
                        <span class="cat-badge {{ catClass[fb.category] ?? 'cat-other' }}">{{ catDe[fb.category] ?? fb.category }}</span>
                        {% if fb.rating %}<span style="font-size:.68rem;color:#fde68a;">{% for s in 1..fb.rating %}★{% endfor %}</span>{% endif %}
                    </div>
                    <div style="font-size:.78rem;color:#94a3b8;margin-top:.1rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{{ fb.message }}</div>
                    <div style="font-size:.67rem;color:#475569;margin-top:.15rem;">{{ fb.created_at|date('d.m.Y H:i') }}</div>
                </div>
            </div>
            {% endfor %}
            {% else %}
            <div style="padding:2rem;text-align:center;color:#475569;font-size:.8rem;">
                <i class="bi bi-chat-square" style="font-size:1.5rem;display:block;margin-bottom:.5rem;"></i>Noch kein Feedback eingegangen.
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
Chart.defaults.color = '#64748b';
Chart.defaults.borderColor = '#1f2d3d';
Chart.defaults.font.family = "'Inter', sans-serif";

const CHART_COLORS = ['#6EA8FE','#a78bfa','#6ee7b7','#fde68a','#f87171','#7dd3fc','#fdba74','#c4b5fd'];

// Umsatz-Verlauf (Prognose)
(function() {
    const labels = {{ revenue_chart.labels|json_encode|raw }};
    const data   = {{ revenue_chart.data|json_encode|raw }};
    new Chart(document.getElementById('revenueChart'), {
        type: 'line',
        data: {
            labels,
            datasets: [{
                label: 'Mögl. Monatsumsatz (€)',
                data,
                borderColor: '#6EA8FE',
                backgroundColor: 'rgba(110,168,254,.12)',
                borderWidth: 2.5,
                fill: true,
                tension: .35,
                pointRadius: 3,
                pointBackgroundColor: '#6EA8FE',
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { label: ctx => ' ' + ctx.parsed.y.toLocaleString('de-DE',{minimumFractionDigits:2}) + ' €' } }
            },
            scales: {
                x: { grid: { color: '#1f2d3d' }, ticks: { font: { size: 10 } } },
                y: { grid: { color: '#1f2d3d' }, ticks: { font: { size: 10 }, callback: v => v.toLocaleString('de-DE') + ' €' } }
            }
        }
    });
})();

// Neuregistrierungen
(function() {
    const labels = {{ reg_chart.labels|json_encode|raw }};
    const data   = {{ reg_chart.data|json_encode|raw }};
    new Chart(document.getElementById('regChart'), {
        type: 'bar',
        data: {
            labels,
            datasets: [{
                label: 'Neue Praxen',
                data,
                backgroundColor: 'rgba(110,231,183,.5)',
                borderColor: '#6ee7b7',
                borderWidth: 1.5,
                borderRadius: 4,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, ticks: { font: { size: 10 } } },
                y: { grid: { color: '#1f2d3d' }, ticks: { font: { size: 10 }, stepSize: 1 } }
            }
        }
    });
})();

// Plan Distribution Donut
(function() {
    const labels = {{ plan_distribution.labels|json_encode|raw }};
    const data   = {{ plan_distribution.data|json_encode|raw }};
    if (!labels.length) return;
    const chart = new Chart(document.getElementById('planDonut'), {
        type: 'doughnut',
        data: { labels, datasets: [{ data, backgroundColor: CHART_COLORS, borderWidth: 0, hoverOffset: 6 }] },
        options: {
            cutout: '70%',
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { label: ctx => ' ' + ctx.label + ': ' + ctx.parsed } }
            }
        }
    });
    // Color legend dots
    document.querySelectorAll('.donut-legend-dot').forEach(el => {
        el.style.color = CHART_COLORS[+el.dataset.idx] ?? '#94a3b8';
    });
})();

// Status Donut
(function() {
    const labels = {{ status_distribution.labels|json_encode|raw }};
    const data   = {{ status_distribution.data|json_encode|raw }};
    const colorMap = {active:'#6ee7b7',trial:'#c4b5fd',pending:'#fdba74',cancelled:'#94a3b8',paused:'#7dd3fc',suspended:'#fca5a5'};
    if (!labels.length) return;
    new Chart(document.getElementById('statusDonut'), {
        type: 'doughnut',
        data: {
            labels,
            datasets: [{ data, backgroundColor: labels.map(l => colorMap[l] ?? '#94a3b8'), borderWidth: 0, hoverOffset: 6 }]
        },
        options: {
            cutout: '70%',
            plugins: { legend: { display: false } }
        }
    });
})();

// Systemstatus-Prüfung
(function() {
    'use strict';
    const btn  = document.getElementById('dash-health-btn');
    const body = document.getElementById('dash-health-body');
    if (!btn || !body) return;

    btn.addEventListener('click', async () => {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Prüfe…';
        body.innerHTML = '<div style="font-size:.8rem;color:#64748b;text-align:center;padding:.5rem 0;"><span class="spinner-border spinner-border-sm me-2"></span>Prüfe alle aktiven Praxen…</div>';

        const rows = document.querySelectorAll('table tbody tr[data-tid]');
        let ids = [...new Set(Array.from(rows).map(r => r.dataset.tid).filter(Boolean))];

        if (!ids.length) {
            document.querySelectorAll('a[href^="/admin/tenants/"]').forEach(a => {
                const m = a.href.match(/\/admin\/tenants\/(\d+)$/);
                if (m) ids.push(m[1]);
            });
            ids = [...new Set(ids)].slice(0, 10);
        }

        if (!ids.length) {
            body.innerHTML = '<div style="font-size:.8rem;color:#64748b;text-align:center;padding:.5rem 0;">Keine Praxen auf dieser Seite gefunden.</div>';
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Alle prüfen';
            return;
        }

        const results = await Promise.allSettled(
            ids.map(id =>
                fetch('/admin/tenants/' + id + '/health-api', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.json()).then(d => ({ id, ...d }))
                    .catch(() => ({ id, status: 'error', issues: ['Anfrage fehlgeschlagen'], checks: {} }))
            )
        );

        const items    = results.map(r => r.status === 'fulfilled' ? r.value : { id: '?', status: 'error', issues: [], checks: {} });
        const ok       = items.filter(i => i.status === 'ok').length;
        const warn     = items.filter(i => i.status === 'warning').length;
        const critical = items.filter(i => i.status === 'critical' || i.status === 'error').length;

        const statusIcon = critical > 0 ? '🔴' : (warn > 0 ? '🟡' : '🟢');
        let html = `<div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
            <span style="font-size:1.4rem;">${statusIcon}</span>
            <span style="color:#6ee7b7;font-weight:600;">${ok} in Ordnung</span>
            ${warn > 0    ? `<span style="color:#fde68a;font-weight:600;">${warn} Warnung${warn > 1 ? 'en' : ''}</span>` : ''}
            ${critical > 0 ? `<span style="color:#fca5a5;font-weight:600;">${critical} Kritisch</span>` : ''}
            <span style="font-size:.72rem;color:#64748b;">${items.length} Praxen geprüft</span>
        </div><div class="row g-2">`;

        items.forEach(item => {
            const sc = item.status === 'ok' ? '#6ee7b7' : (item.status === 'warning' ? '#fde68a' : '#fca5a5');
            const si = item.status === 'ok' ? 'bi-check-circle-fill' : (item.status === 'warning' ? 'bi-exclamation-triangle-fill' : 'bi-x-circle-fill');
            const msg = item.issues?.length > 0 ? item.issues[0] : 'Alles in Ordnung';
            html += `<div class="col-md-3 col-sm-4 col-6">
                <a href="/admin/tenants/${item.id}" style="text-decoration:none;">
                    <div style="background:#0f172a;border:1px solid #334155;border-radius:.4rem;padding:.5rem .75rem;display:flex;align-items:center;gap:.5rem;">
                        <i class="bi ${si}" style="color:${sc};font-size:.85rem;flex-shrink:0;"></i>
                        <div style="min-width:0;">
                            <div style="font-size:.75rem;color:#e2e8f0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${item.tid || ('Praxis #' + item.id)}</div>
                            <div style="font-size:.65rem;color:${item.status === 'ok' ? '#6ee7b7' : '#94a3b8'};white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${msg}</div>
                        </div>
                    </div>
                </a>
            </div>`;
        });
        html += '</div>';
        body.innerHTML = html;
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Erneut prüfen';
    });
})();
</script>
{% endblock %}
