{% extends 'layouts/base.twig' %}
{% set active_nav = 'dashboard' %}

{% block content %}
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value text-white">{{ stats.total }}</div>
                    <div class="stat-label">Praxen gesamt</div>
                </div>
                <div style="font-size:2rem;color:#2563eb;"><i class="bi bi-building"></i></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value text-success">{{ stats.active }}</div>
                    <div class="stat-label">Aktive Praxen</div>
                </div>
                <div style="font-size:2rem;color:#10b981;"><i class="bi bi-check-circle"></i></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value text-primary">{{ stats.active_subscriptions }}</div>
                    <div class="stat-label">Aktive Abos</div>
                </div>
                <div style="font-size:2rem;color:#2563eb;"><i class="bi bi-credit-card"></i></div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card card">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-value text-warning">{{ stats.monthly_revenue|number_format(2, ',', '.') }} €</div>
                    <div class="stat-label">Monatl. Umsatz (aktiv)</div>
                </div>
                <div style="font-size:2rem;color:#f59e0b;"><i class="bi bi-currency-euro"></i></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card p-3 text-center">
            <div class="fw-bold" style="color:#fdba74;">{{ stats.pending }}</div>
            <div class="stat-label">Ausstehend</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card p-3 text-center">
            <div class="fw-bold" style="color:#7dd3fc;">{{ stats.paused }}</div>
            <div class="stat-label">Pausiert</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card p-3 text-center">
            <div class="fw-bold" style="color:#94a3b8;">{{ stats.cancelled }}</div>
            <div class="stat-label">Gekündigt</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between py-3 px-4">
        <span class="fw-semibold">Neueste Praxen</span>
        <a href="/admin/tenants" class="btn btn-sm btn-outline-primary">Alle anzeigen</a>
    </div>
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th class="px-4">Praxis</th>
                    <th>Therapeut</th>
                    <th>Plan</th>
                    <th>Status</th>
                    <th>Erstellt</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for tenant in recent_tenants %}
                <tr>
                    <td class="px-4 fw-medium">{{ tenant.practice_name }}</td>
                    <td class="text-secondary">{{ tenant.owner_name }}</td>
                    <td>
                        <span class="badge bg-secondary">{{ tenant.plan_name ?? 'N/A' }}</span>
                    </td>
                    <td>
                        {% set statusMap = {
                            'active': 'badge-active',
                            'pending': 'badge-pending',
                            'suspended': 'badge-suspended',
                            'cancelled': 'badge-cancelled',
                            'paused': 'badge-paused'
                        } %}
                        <span class="badge {{ statusMap[tenant.status] ?? 'bg-secondary' }}">{{ tenant.status }}</span>
                    </td>
                    <td class="text-secondary" style="font-size:.8rem;">{{ tenant.created_at|date('d.m.Y') }}</td>
                    <td>
                        <a href="/admin/tenants/{{ tenant.id }}" class="btn btn-xs btn-outline-secondary" style="font-size:.75rem;padding:.2rem .5rem;">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="6" class="text-center text-secondary px-4 py-4">Noch keine Praxen registriert.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
