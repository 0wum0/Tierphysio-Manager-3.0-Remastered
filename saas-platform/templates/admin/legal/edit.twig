{% extends 'layouts/base.twig' %}
{% set active_nav = 'legal' %}

{% block content %}
<div class="d-flex align-items-center mb-4">
    <a href="/admin/legal" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left me-1"></i>Zurück
    </a>
</div>

<div class="row justify-content-center">
<div class="col-lg-9">
<div class="card">
    <div class="card-header px-4 py-3">
        <span class="fw-semibold"><i class="bi bi-pencil me-2"></i>Dokument bearbeiten: {{ doc.title }}</span>
    </div>
    <div class="card-body px-4 py-4">
        <form method="POST" action="/admin/legal/{{ doc.id }}/edit">
            {{ csrf_field()|raw }}

            <div class="row g-3 mb-4">
                <div class="col-sm-8">
                    <label class="form-label">Titel *</label>
                    <input type="text" name="title" class="form-control" required value="{{ doc.title }}">
                </div>
                <div class="col-sm-2">
                    <label class="form-label">Version</label>
                    <input type="text" name="version" class="form-control" value="{{ doc.version }}" placeholder="1.0">
                </div>
                <div class="col-sm-2">
                    <label class="form-label">Slug</label>
                    <input type="text" class="form-control" value="{{ doc.slug }}" disabled>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Inhalt (Markdown)</label>
                <textarea name="content" class="form-control font-monospace" rows="25" style="font-size:.8rem;line-height:1.6;">{{ doc.content }}</textarea>
                <div class="form-text" style="color:#64748b;">
                    Markdown wird unterstützt: # Überschrift, ## Unterüberschrift, **Fett**, *Kursiv*, - Listen
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Speichern
                </button>
                <a href="/legal/{{ doc.slug }}" target="_blank" class="btn btn-outline-secondary">
                    <i class="bi bi-eye me-1"></i>Vorschau
                </a>
                <a href="/admin/legal" class="btn btn-outline-secondary ms-auto">Abbrechen</a>
            </div>
        </form>
    </div>
</div>
</div>
</div>
{% endblock %}
