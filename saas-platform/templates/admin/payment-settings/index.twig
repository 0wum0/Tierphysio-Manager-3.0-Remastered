{% extends 'layouts/base.twig' %}
{% set active_nav = 'payment_settings' %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-credit-card me-2"></i>Zahlungs-Einstellungen</h4>
        <div class="text-muted fs-xs mt-1">Stripe, PayPal &amp; Cronjobs konfigurieren</div>
    </div>
    <div class="d-flex gap-2">
        <a href="/admin/settings" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-gear me-1"></i>Allgemeine Einstellungen
        </a>
    </div>
</div>

{% if flash_success is defined and flash_success %}
<div class="alert alert-success mb-4 fs-sm">{{ flash_success|raw }}</div>
{% endif %}
{% if flash_error is defined and flash_error %}
<div class="alert alert-danger mb-4 fs-sm">{{ flash_error|raw }}</div>
{% endif %}

{# ─────────────────────────────────────────────────────────────────────────── #}
{# STRIPE                                                                       #}
{# ─────────────────────────────────────────────────────────────────────────── #}
<form method="POST" action="/admin/payment-settings/update">
    {{ csrf_field()|raw }}

    <div class="card mb-3">
        <div class="card-header px-4 py-3 d-flex align-items-center gap-3">
            <svg width="22" height="22" viewBox="0 0 60 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4.5 9.5c0-1.2.9-1.7 2.4-1.7 2.1 0 4.8.7 6.9 1.9V3.4C11.6 2.5 9 2 6.5 2 2.7 2 0 4 0 9.7c0 9.2 12.1 7.7 12.1 11.7 0 1.4-1.2 1.9-2.8 1.9-2.4 0-5.5-.9-8-2.4v6.5c2.7 1.2 5.5 1.7 8 1.7 6 0 10.1-3 10.1-8.5-.2-9.9-12.9-8.1-12.9-11.1z" fill="#6772E5"/>
                <path d="M24 8.5l-.4-2H18v17.5h5.9v-9.3c1.4-1.9 3.8-1.5 4.5-1.3V8.1c-.8-.2-3.6-.7-4.4.4z" fill="#6772E5"/>
                <path d="M35.5 2l-5.9 1.3v4.8h-3v4.8h3v8.6c0 3.5 2.1 4.8 5.7 4.8 1.5 0 3.3-.5 4.3-1.1v-4.8c-.8.4-4.1 1.2-4.1-1.2v-6.3H39V8.1h-3.5V2z" fill="#6772E5"/>
                <path d="M40 8.1h5.9V26H40z" fill="#6772E5"/>
                <path d="M42.9 6.3c1.9 0 3.4-1.5 3.4-3.2S44.8 0 42.9 0 39.5 1.4 39.5 3.1s1.5 3.2 3.4 3.2z" fill="#6772E5"/>
                <path d="M57.4 14.8L63 8.1h-7l-3.4 4.8V0h-5.9v26h5.9v-5l1.1-1.5 3.8 6.5H63l-5.6-10.2z" fill="#6772E5"/>
            </svg>
            <span class="fw-700">Stripe</span>
            <span class="badge {% if settings.stripe_enabled == '1' %}bg-success{% else %}bg-secondary{% endif %}" id="stripe-status-badge">
                {{ settings.stripe_enabled == '1' ? 'Aktiviert' : 'Deaktiviert' }}
            </span>
            <div class="ms-auto">
                <button type="button" class="btn btn-sm btn-outline-secondary ms-auto" onclick="testStripe()">
                    <i class="bi bi-plug me-1"></i>Verbindung testen
                </button>
            </div>
        </div>
        <div class="card-body px-4 py-3">

            {# ── Schritt-für-Schritt Anleitung ── #}
            <div class="mb-4">
                <div class="text-muted fs-xs fw-700 text-uppercase mb-3" style="letter-spacing:.06em;">
                    <i class="bi bi-list-check me-1"></i>Einrichtungsanleitung
                </div>
                <div class="d-flex gap-2">
                    <div class="fw-700">1</div>
                    <div class="text-muted fs-sm">
                        Gehe zu <a href="https://dashboard.stripe.com/register" target="_blank"><strong>dashboard.stripe.com</strong></a> und erstelle ein Konto (oder melde dich an).
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <div class="fw-700">2</div>
                    <div class="text-muted fs-sm">
                        Navigiere zu <strong>Entwickler → API-Schlüssel</strong>. Kopiere den <strong>Öffentlichen Schlüssel</strong> (<code>pk_live_...</code>) und den <strong>Geheimen Schlüssel</strong> (<code>sk_live_...</code>) in die Felder unten.<br>
                        <span class="text-warning">⚠ Für Tests verwende die Testmodus-Keys (<code>pk_test_...</code> / <code>sk_test_...</code>).</span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <div class="fw-700">3</div>
                    <div class="text-muted fs-sm">
                        Für automatische Webhooks: Navigiere zu <strong>Entwickler → Webhooks → Endpunkt hinzufügen</strong>.<br>
                        URL: <code>https://therapano.de/webhooks/stripe</code><br>
                        Events: <code>invoice.payment_succeeded</code>, <code>invoice.payment_failed</code>, <code>customer.subscription.deleted</code><br>
                        Kopiere das <strong>Webhook-Signing-Secret</strong> (<code>whsec_...</code>) unten ein.
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <div class="fw-700">4</div>
                    <div class="text-muted fs-sm">
                        Für <strong>Stripe Link</strong> (One-Click Checkout): Aktiviere Link in deinen <a href="https://dashboard.stripe.com/settings/payment_methods" target="_blank">Zahlungsmethoden-Einstellungen</a>. Kein zusätzlicher Code nötig — Stripe aktiviert es automatisch im Checkout.
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <div class="fw-700">5</div>
                    <div class="text-muted fs-sm">
                        Aktiviere Stripe unten und speichere. Klicke dann auf <strong>Verbindung testen</strong>.
                    </div>
                </div>
            </div>

            <hr class="my-4">

            <div class="row g-3">
                <div class="col-12">
                    <div class="form-check form-switch d-flex align-items-center gap-2">
                        <input class="form-check-input" type="checkbox" name="stripe_enabled" value="1" id="stripe-toggle"
                               {% if settings.stripe_enabled == '1' %}checked{% endif %}
                               onchange="document.getElementById('stripe-status-badge').textContent = this.checked ? 'Aktiviert' : 'Deaktiviert'; document.getElementById('stripe-status-badge').className = 'badge ' + (this.checked ? 'bg-success' : 'bg-secondary');">
                        <label class="form-check-label fw-600" for="stripe-toggle">Stripe aktivieren</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label text-muted fs-xs fw-600" for="stripe_public_key">Öffentlicher Schlüssel (Publishable Key)</label>
                        <input type="text" class="form-control font-monospace" id="stripe_public_key" name="stripe_public_key"
                               value="{{ settings.stripe_public_key ?? '' }}"
                               placeholder="pk_live_... oder pk_test_...">
                        <div class="form-text text-muted fs-xs">Beginnt mit <code>pk_live_</code> (Live) oder <code>pk_test_</code> (Test)</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label text-muted fs-xs fw-600" for="stripe_secret_key">Geheimer Schlüssel (Secret Key)</label>
                        <input type="password" class="form-control font-monospace" id="stripe_secret_key" name="stripe_secret_key"
                               value="{{ settings.stripe_secret_key ?? '' }}"
                               placeholder="sk_live_... oder sk_test_...">
                        <div class="form-text text-muted fs-xs">Niemals öffentlich teilen! Beginnt mit <code>sk_live_</code> oder <code>sk_test_</code></div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="mb-0">
                        <label class="form-label text-muted fs-xs fw-600" for="stripe_webhook_secret">Webhook Signing Secret</label>
                        <input type="password" class="form-control font-monospace" id="stripe_webhook_secret" name="stripe_webhook_secret"
                               value="{{ settings.stripe_webhook_secret ?? '' }}"
                               placeholder="whsec_...">
                        <div class="form-text text-muted fs-xs">
                            Webhook-Endpunkt: <code>https://therapano.de/webhooks/stripe</code> —
                            <a href="https://dashboard.stripe.com/webhooks" target="_blank">In Stripe Dashboard konfigurieren →</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="test-result" id="stripe-test-result"></div>
        </div>
    </div>

    {# ─────────────────────────────────────────────────────────────────────── #}
    {# PAYPAL                                                                   #}
    {# ─────────────────────────────────────────────────────────────────────── #}
    <div class="card mb-3">
        <div class="card-header px-4 py-3 d-flex align-items-center gap-3">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#009cde" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.3 21.6H5.1l.4-2.6H7c.5 0 .8.1 1 .3.2.2.3.4.3.7 0 .4-.1.8-.4 1-.2.4-.6.6-1 .6zM20.3 3.6c-.3-1.3-1-2.3-1.9-3C17.5.2 16.1 0 14.4 0H8.7c-.5 0-.9.3-1 .8L5.6 13.8c-.1.3.1.6.4.7H9l.8-5.2-.1.4c.1-.5.5-.8 1-.8h2.1c4.2 0 7.4-1.7 8.4-6.6v-.3c-.2-.2-.2-.2 0-.4z"/>
                <path d="M20.3 3.6c-.1.3-.2.5-.3.8-1.1 5.5-4.8 7.4-9.5 7.4H8.3c-.6 0-1.1.4-1.2 1L5.9 20c-.1.3.1.6.4.7H9c.4 0 .8-.3.9-.7l.1-.3.7-4.5.1-.3c.1-.4.5-.7.9-.7h.6c3.7 0 6.6-1.5 7.4-5.8.4-1.8.2-3.3-.7-4.4-.2-.2-.5-.2-.7-.4z"/>
            </svg>
            <span class="fw-700">PayPal</span>
            <span class="badge {% if settings.paypal_enabled == '1' %}bg-success{% else %}bg-secondary{% endif %}" id="paypal-status-badge">
                {{ settings.paypal_enabled == '1' ? 'Aktiviert' : 'Deaktiviert' }}
            </span>
            <div class="ms-auto">
                <button type="button" class="btn btn-sm btn-outline-secondary ms-auto" onclick="testPayPal()">
                    <i class="bi bi-plug me-1"></i>Verbindung testen
                </button>
            </div>
        </div>
        <div class="card-body px-4 py-3">

            <div class="mb-4">
                <div class="text-muted fs-xs fw-700 text-uppercase mb-3" style="letter-spacing:.06em;">
                    <i class="bi bi-list-check me-1"></i>Einrichtungsanleitung
                </div>
                <div class="d-flex gap-2">
                    <div class="fw-700">1</div>
                    <div class="text-muted fs-sm">
                        Gehe zu <a href="https://developer.paypal.com" target="_blank"><strong>developer.paypal.com</strong></a> und melde dich mit deinem PayPal-Geschäftskonto an.
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <div class="fw-700">2</div>
                    <div class="text-muted fs-sm">
                        Navigiere zu <strong>Apps & Credentials</strong> → <strong>Create App</strong>.<br>
                        Wähle <strong>Merchant</strong> als App-Typ. Kopiere <strong>Client ID</strong> und <strong>Client Secret</strong> aus deiner App.
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <div class="fw-700">3</div>
                    <div class="text-muted fs-sm">
                        <span class="text-warning">⚠ Sandbox-Modus</span> für Tests aktivieren — schalte ihn <strong>aus</strong> wenn du live gehst.<br>
                        Im Sandbox-Modus werden <strong>keine echten Zahlungen</strong> verarbeitet.
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <div class="fw-700">4</div>
                    <div class="text-muted fs-sm">
                        Stelle sicher, dass dein PayPal-Konto <strong>Subscriptions (Abonnements)</strong> unterstützt — dies erfordert ein verifiziertes Geschäftskonto.<br>
                        <a href="https://www.paypal.com/de/webapps/mpp/merchant" target="_blank">PayPal Geschäftskonto einrichten →</a>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <div class="fw-700">5</div>
                    <div class="text-muted fs-sm">
                        Return-URL (nach Zahlung): <code>https://therapano.de/register/payment-success</code>
                    </div>
                </div>
            </div>

            <hr class="my-4">

            <div class="row g-3">
                <div class="col-6">
                    <div class="form-check form-switch d-flex align-items-center gap-2">
                        <input class="form-check-input" type="checkbox" name="paypal_enabled" value="1" id="paypal-toggle"
                               {% if settings.paypal_enabled == '1' %}checked{% endif %}
                               onchange="document.getElementById('paypal-status-badge').textContent = this.checked ? 'Aktiviert' : 'Deaktiviert'; document.getElementById('paypal-status-badge').className = 'badge ' + (this.checked ? 'bg-success' : 'bg-secondary');">
                        <label class="form-check-label fw-600" for="paypal-toggle">PayPal aktivieren</label>
                    </div>
                </div>
                <div class="col-6">
                    <div class="form-check form-switch d-flex align-items-center gap-2">
                        <input class="form-check-input" type="checkbox" name="paypal_sandbox" value="1" id="paypal-sandbox"
                               {% if settings.paypal_sandbox != '0' %}checked{% endif %}>
                        <label class="form-check-label fw-600 text-warning" for="paypal-sandbox">Sandbox-Modus (Test)</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label text-muted fs-xs fw-600" for="paypal_client_id">Client ID</label>
                        <input type="text" class="form-control font-monospace" id="paypal_client_id" name="paypal_client_id"
                               value="{{ settings.paypal_client_id ?? '' }}"
                               placeholder="AaBbCcDd...">
                        <div class="form-text text-muted fs-xs">Aus dem PayPal Developer Dashboard kopieren</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-0">
                        <label class="form-label text-muted fs-xs fw-600" for="paypal_client_secret">Client Secret</label>
                        <input type="password" class="form-control font-monospace" id="paypal_client_secret" name="paypal_client_secret"
                               value="{{ settings.paypal_client_secret ?? '' }}"
                               placeholder="••••••••••••">
                        <div class="form-text text-muted fs-xs">Niemals öffentlich teilen!</div>
                    </div>
                </div>
            </div>
            <div class="test-result" id="paypal-test-result"></div>
        </div>
    </div>

    <div class="mb-4">
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg me-2"></i>Zahlungseinstellungen speichern
        </button>
    </div>
</form>

{# ─────────────────────────────────────────────────────────────────────────── #}
{# CRONJOBS                                                                     #}
{# ─────────────────────────────────────────────────────────────────────────── #}
<div class="card mb-3" id="cron">
    <div class="card-header px-4 py-3 d-flex align-items-center gap-3">
        <i class="bi bi-clock-history text-info"></i>
        <span class="fw-700">Cronjobs einrichten</span>
        {% if cron_status.last_run %}
        <span class="text-muted fs-xs ms-1">
            Letzter Lauf: <strong>{{ cron_status.last_run }}</strong>
            ({{ cron_status.last_mode }})
        </span>
        {% endif %}
        <div class="ms-auto d-flex gap-2">
            <form method="POST" action="/admin/payment-settings/cron/run">
                {{ csrf_field()|raw }}
                <input type="hidden" name="mode" value="hourly">
                <button class="btn btn-sm btn-outline-secondary" type="submit"><i class="bi bi-play me-1"></i>Stündlich</button>
            </form>
            <form method="POST" action="/admin/payment-settings/cron/run">
                {{ csrf_field()|raw }}
                <input type="hidden" name="mode" value="daily">
                <button class="btn btn-sm btn-outline-secondary" type="submit"><i class="bi bi-play me-1"></i>Täglich</button>
            </form>
        </div>
    </div>
    <div class="card-body px-4 py-3">

        {# Was macht der Cron? #}
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="code-block">
                    <div class="text-primary fs-xs fw-700 mb-2"><i class="bi bi-clock me-1"></i>Stündlich</div>
                    <ul class="mb-0 ps-3 text-muted" style="font-size:.78rem;line-height:1.8;">
                        <li>Trial-Ablauf prüfen → sperren</li>
                        <li>Erinnerung (3 Tage vor Ablauf)</li>
                        <li>Überfällige Zahlungen → past_due</li>
                        <li>Revenue-Snapshot speichern</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-4">
                <div class="code-block">
                    <div class="fs-xs fw-700 mb-2" style="color:#a78bfa;"><i class="bi bi-calendar3 me-1"></i>Täglich (zusätzlich)</div>
                    <ul class="mb-0 ps-3 text-muted" style="font-size:.78rem;line-height:1.8;">
                        <li>Alte Benachrichtigungen aufräumen</li>
                        <li>Feedback-Tages-Zusammenfassung</li>
                        <li>Stripe-Subscriptions synchronisieren</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-4">
                <div class="code-block">
                    <div class="text-success fs-xs fw-700 mb-2"><i class="bi bi-folder2 me-1"></i>Skript-Pfad</div>
                    <code class="fs-xs" style="word-break:break-all;">{{ cron_path }}</code>
                </div>
            </div>
        </div>

        {# Crontab Einrichtung #}
        <div class="text-muted fs-xs fw-700 text-uppercase mb-3" style="letter-spacing:.06em;">
            <i class="bi bi-terminal me-1"></i>Crontab konfigurieren (auf dem Server)
        </div>

        <div class="d-flex gap-2">
            <div class="fw-700">1</div>
            <div class="text-muted fs-sm">
                Per SSH auf den Server verbinden und den Crontab-Editor öffnen:<br>
                <code>crontab -e</code>
            </div>
        </div>
        <div class="d-flex gap-2">
            <div class="fw-700">2</div>
            <div class="text-muted fs-sm">
                Folgende Zeilen hinzufügen (Pfad ggf. anpassen):
            </div>
        </div>

        <div class="code-block mb-3">
            <span class="text-muted"># TheraPano SaaS — Stündlicher Cron (Trial, Zahlungen, Revenue-Snapshot)</span><br>
            <span class="text-primary">0 * * * * php {{ cron_path }} hourly >> /var/log/therapano_cron.log 2>&amp;1</span><br><br>
            <span class="text-muted"># TheraPano SaaS — Täglicher Cron um 08:00 Uhr (Aufräumen, Feedback, Stripe-Sync)</span><br>
            <span class="text-primary">0 8 * * * php {{ cron_path }} daily >> /var/log/therapano_cron.log 2>&amp;1</span>
        </div>

        <div class="d-flex gap-2">
            <div class="fw-700">3</div>
            <div class="text-muted fs-sm">
                Bei Hostinger / Shared Hosting: Gehe im hPanel zu <strong>Erweitert → Cron Jobs</strong>.<br>
                Trage dort ein:<br>
                <strong>Befehl:</strong> <code>php {{ cron_path }} hourly</code><br>
                <strong>Zeitplan:</strong> <code>0 * * * *</code> (jede Stunde)
            </div>
        </div>
        <div class="ps-step">
            <div class="ps-step-num">4</div>
            <div class="ps-step-content">
                Log-Datei prüfen: <code>tail -f /var/log/therapano_cron.log</code><br>
                Oder nutze die <strong>Manuell ausführen</strong>-Buttons oben rechts zum Testen.
            </div>
        </div>

        {# Letztes Log #}
        {% if cron_status.last_lines|length > 0 %}
        <hr class="my-4">
        <div class="text-muted fs-xs fw-700 text-uppercase mb-2" style="letter-spacing:.06em;">
            <i class="bi bi-journal-text me-1"></i>Letztes Log
        </div>
        <div class="code-block">
            {% for line in cron_status.last_lines %}
            {{ line|e }}<br>
            {% endfor %}
        </div>
        {% else %}
        <div class="text-muted fs-sm mt-3">
            <i class="bi bi-info-circle me-1"></i>
            Noch kein Log vorhanden. Führe den Cron einmal manuell aus oder warte auf den ersten automatischen Lauf.
        </div>
        {% endif %}

    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
async function testStripe() {
    const btn = event.target.closest('button');
    const res = document.getElementById('stripe-test-result');
    btn.disabled = true; btn.textContent = 'Teste…';
    res.style.display = 'none';
    try {
        const r = await fetch('/admin/payment-settings/test/stripe');
        const d = await r.json();
        res.className = 'test-result ' + (d.ok ? 'ok' : 'err');
        res.textContent = (d.ok ? '✓ ' : '✗ ') + d.message;
        res.style.display = 'block';
    } catch(e) {
        res.className = 'test-result err';
        res.textContent = '✗ Netzwerkfehler: ' + e.message;
        res.style.display = 'block';
    }
    btn.disabled = false; btn.innerHTML = '<i class="bi bi-plug me-1"></i>Verbindung testen';
}

async function testPayPal() {
    const btn = event.target.closest('button');
    const res = document.getElementById('paypal-test-result');
    btn.disabled = true; btn.textContent = 'Teste…';
    res.style.display = 'none';
    try {
        const r = await fetch('/admin/payment-settings/test/paypal');
        const d = await r.json();
        res.className = 'test-result ' + (d.ok ? 'ok' : 'err');
        res.textContent = (d.ok ? '✓ ' : '✗ ') + d.message;
        res.style.display = 'block';
    } catch(e) {
        res.className = 'test-result err';
        res.textContent = '✗ Netzwerkfehler: ' + e.message;
        res.style.display = 'block';
    }
    btn.disabled = false; btn.innerHTML = '<i class="bi bi-plug me-1"></i>Verbindung testen';
}
</script>
{% endblock %}
