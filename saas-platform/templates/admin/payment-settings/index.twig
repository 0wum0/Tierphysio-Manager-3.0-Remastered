{% extends 'layouts/base.twig' %}
{% set active_nav = 'payment_settings' %}

{% block styles %}
<style>
.ps-card{background:#0f172a;border:1px solid #1e293b;border-radius:.875rem;margin-bottom:1.5rem;}
.ps-card-header{padding:1rem 1.5rem;border-bottom:1px solid #1e293b;display:flex;align-items:center;gap:.75rem;}
.ps-card-header h3{margin:0;font-size:.95rem;font-weight:700;color:#e2e8f0;}
.ps-card-body{padding:1.5rem;}
.ps-badge{font-size:.65rem;padding:.2rem .55rem;border-radius:999px;font-weight:700;letter-spacing:.03em;}
.ps-badge-on{background:rgba(34,197,94,.15);color:#86efac;}
.ps-badge-off{background:rgba(100,116,139,.15);color:#94a3b8;}
.ps-toggle{position:relative;display:inline-flex;align-items:center;gap:.6rem;cursor:pointer;}
.ps-toggle input[type=checkbox]{width:2.5rem;height:1.35rem;appearance:none;background:#1e293b;border:1px solid #334155;border-radius:999px;cursor:pointer;transition:background .2s;flex-shrink:0;}
.ps-toggle input[type=checkbox]:checked{background:#6ea8fe;border-color:#6ea8fe;}
.ps-toggle input[type=checkbox]::after{content:'';position:absolute;top:50%;left:.18rem;transform:translateY(-50%);width:1rem;height:1rem;background:#fff;border-radius:50%;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.3);}
.ps-toggle input[type=checkbox]:checked::after{left:1.32rem;}
.ps-form-group{margin-bottom:1.25rem;}
.ps-label{display:block;font-size:.78rem;font-weight:600;color:#94a3b8;margin-bottom:.4rem;}
.ps-input{width:100%;background:#1e293b;border:1px solid #334155;border-radius:.5rem;padding:.55rem .875rem;color:#e2e8f0;font-size:.875rem;font-family:monospace;outline:none;transition:border-color .15s;}
.ps-input:focus{border-color:#6ea8fe;}
.ps-input.masked{letter-spacing:.15em;color:#64748b;}
.ps-input.masked:focus{letter-spacing:normal;color:#e2e8f0;}
.ps-hint{font-size:.72rem;color:#475569;margin-top:.3rem;line-height:1.5;}
.ps-hint a{color:#6ea8fe;text-decoration:none;}
.ps-hint a:hover{text-decoration:underline;}
.ps-step{display:flex;gap:.875rem;margin-bottom:1rem;align-items:flex-start;}
.ps-step-num{width:1.6rem;height:1.6rem;background:rgba(110,168,254,.15);border:1px solid #6ea8fe;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;color:#6ea8fe;flex-shrink:0;margin-top:.05rem;}
.ps-step-content{font-size:.82rem;color:#94a3b8;line-height:1.6;}
.ps-step-content strong{color:#e2e8f0;}
.ps-step-content code{background:#1e293b;border:1px solid #334155;border-radius:.3rem;padding:.1rem .35rem;font-family:monospace;font-size:.8rem;color:#7dd3fc;}
.ps-divider{border:none;border-top:1px solid #1e293b;margin:1.5rem 0;}
.cron-block{background:#0a0f1a;border:1px solid #1e293b;border-radius:.6rem;padding:1rem 1.25rem;font-family:monospace;font-size:.8rem;color:#7dd3fc;line-height:1.8;overflow-x:auto;}
.cron-block .comment{color:#475569;}
.cron-block .cmd{color:#86efac;}
.status-dot{width:.55rem;height:.55rem;border-radius:50%;display:inline-block;flex-shrink:0;}
.status-dot.green{background:#22c55e;box-shadow:0 0 6px #22c55e;}
.status-dot.red{background:#ef4444;}
.status-dot.gray{background:#475569;}
.test-btn{font-size:.78rem;padding:.3rem .75rem;border-radius:.4rem;border:1px solid #334155;background:transparent;color:#94a3b8;cursor:pointer;transition:all .15s;}
.test-btn:hover{border-color:#6ea8fe;color:#6ea8fe;}
.test-result{font-size:.78rem;margin-top:.5rem;padding:.4rem .75rem;border-radius:.4rem;display:none;}
.test-result.ok{background:rgba(34,197,94,.1);color:#86efac;border:1px solid rgba(34,197,94,.2);}
.test-result.err{background:rgba(239,68,68,.1);color:#fca5a5;border:1px solid rgba(239,68,68,.2);}
</style>
{% endblock %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-0 fw-bold" style="color:#e2e8f0;">💳 Zahlungs-Einstellungen</h4>
        <div style="font-size:.78rem;color:#475569;margin-top:.2rem;">Stripe, PayPal & Cronjobs konfigurieren</div>
    </div>
    <div class="d-flex gap-2">
        <a href="/admin/settings" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-gear me-1"></i>Allgemeine Einstellungen
        </a>
    </div>
</div>

{% if flash_success is defined and flash_success %}
<div class="alert alert-success mb-4" style="font-size:.85rem;">{{ flash_success|raw }}</div>
{% endif %}
{% if flash_error is defined and flash_error %}
<div class="alert alert-danger mb-4" style="font-size:.85rem;">{{ flash_error|raw }}</div>
{% endif %}

{# ─────────────────────────────────────────────────────────────────────────── #}
{# STRIPE                                                                       #}
{# ─────────────────────────────────────────────────────────────────────────── #}
<form method="POST" action="/admin/payment-settings/update">
    {{ csrf_field()|raw }}

    <div class="ps-card">
        <div class="ps-card-header">
            <svg width="22" height="22" viewBox="0 0 60 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4.5 9.5c0-1.2.9-1.7 2.4-1.7 2.1 0 4.8.7 6.9 1.9V3.4C11.6 2.5 9 2 6.5 2 2.7 2 0 4 0 9.7c0 9.2 12.1 7.7 12.1 11.7 0 1.4-1.2 1.9-2.8 1.9-2.4 0-5.5-.9-8-2.4v6.5c2.7 1.2 5.5 1.7 8 1.7 6 0 10.1-3 10.1-8.5-.2-9.9-12.9-8.1-12.9-11.1z" fill="#6772E5"/>
                <path d="M24 8.5l-.4-2H18v17.5h5.9v-9.3c1.4-1.9 3.8-1.5 4.5-1.3V8.1c-.8-.2-3.6-.7-4.4.4z" fill="#6772E5"/>
                <path d="M35.5 2l-5.9 1.3v4.8h-3v4.8h3v8.6c0 3.5 2.1 4.8 5.7 4.8 1.5 0 3.3-.5 4.3-1.1v-4.8c-.8.4-4.1 1.2-4.1-1.2v-6.3H39V8.1h-3.5V2z" fill="#6772E5"/>
                <path d="M40 8.1h5.9V26H40z" fill="#6772E5"/>
                <path d="M42.9 6.3c1.9 0 3.4-1.5 3.4-3.2S44.8 0 42.9 0 39.5 1.4 39.5 3.1s1.5 3.2 3.4 3.2z" fill="#6772E5"/>
                <path d="M57.4 14.8L63 8.1h-7l-3.4 4.8V0h-5.9v26h5.9v-5l1.1-1.5 3.8 6.5H63l-5.6-10.2z" fill="#6772E5"/>
            </svg>
            <h3>Stripe</h3>
            <span class="ps-badge {% if settings.stripe_enabled == '1' %}ps-badge-on{% else %}ps-badge-off{% endif %}" id="stripe-status-badge">
                {{ settings.stripe_enabled == '1' ? 'Aktiviert' : 'Deaktiviert' }}
            </span>
            <div class="ms-auto">
                <button type="button" class="test-btn" onclick="testStripe()">
                    <i class="bi bi-plug me-1"></i>Verbindung testen
                </button>
            </div>
        </div>
        <div class="ps-card-body">

            {# ── Schritt-für-Schritt Anleitung ── #}
            <div style="margin-bottom:1.5rem;">
                <div style="font-size:.8rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.875rem;">
                    📋 Einrichtungsanleitung
                </div>
                <div class="ps-step">
                    <div class="ps-step-num">1</div>
                    <div class="ps-step-content">
                        Gehe zu <a href="https://dashboard.stripe.com/register" target="_blank"><strong>dashboard.stripe.com</strong></a> und erstelle ein Konto (oder melde dich an).
                    </div>
                </div>
                <div class="ps-step">
                    <div class="ps-step-num">2</div>
                    <div class="ps-step-content">
                        Navigiere zu <strong>Entwickler → API-Schlüssel</strong>. Kopiere den <strong>Öffentlichen Schlüssel</strong> (<code>pk_live_...</code>) und den <strong>Geheimen Schlüssel</strong> (<code>sk_live_...</code>) in die Felder unten.<br>
                        <span style="color:#fde68a;">⚠ Für Tests verwende die Testmodus-Keys (<code>pk_test_...</code> / <code>sk_test_...</code>).</span>
                    </div>
                </div>
                <div class="ps-step">
                    <div class="ps-step-num">3</div>
                    <div class="ps-step-content">
                        Für automatische Webhooks: Navigiere zu <strong>Entwickler → Webhooks → Endpunkt hinzufügen</strong>.<br>
                        URL: <code>https://therapano.de/webhooks/stripe</code><br>
                        Events: <code>invoice.payment_succeeded</code>, <code>invoice.payment_failed</code>, <code>customer.subscription.deleted</code><br>
                        Kopiere das <strong>Webhook-Signing-Secret</strong> (<code>whsec_...</code>) unten ein.
                    </div>
                </div>
                <div class="ps-step">
                    <div class="ps-step-num">4</div>
                    <div class="ps-step-content">
                        Für <strong>Stripe Link</strong> (One-Click Checkout): Aktiviere Link in deinen <a href="https://dashboard.stripe.com/settings/payment_methods" target="_blank">Zahlungsmethoden-Einstellungen</a>. Kein zusätzlicher Code nötig — Stripe aktiviert es automatisch im Checkout.
                    </div>
                </div>
                <div class="ps-step">
                    <div class="ps-step-num">5</div>
                    <div class="ps-step-content">
                        Aktiviere Stripe unten und speichere. Klicke dann auf <strong>Verbindung testen</strong>.
                    </div>
                </div>
            </div>

            <hr class="ps-divider">

            <div class="row g-3">
                <div class="col-12">
                    <label class="ps-toggle">
                        <input type="checkbox" name="stripe_enabled" value="1" id="stripe-toggle"
                               {% if settings.stripe_enabled == '1' %}checked{% endif %}
                               onchange="document.getElementById('stripe-status-badge').textContent = this.checked ? 'Aktiviert' : 'Deaktiviert'; document.getElementById('stripe-status-badge').className = 'ps-badge ' + (this.checked ? 'ps-badge-on' : 'ps-badge-off');">
                        <span style="font-size:.85rem;font-weight:600;color:#e2e8f0;">Stripe aktivieren</span>
                    </label>
                </div>
                <div class="col-md-6">
                    <div class="ps-form-group">
                        <label class="ps-label" for="stripe_public_key">Öffentlicher Schlüssel (Publishable Key)</label>
                        <input type="text" class="ps-input" id="stripe_public_key" name="stripe_public_key"
                               value="{{ settings.stripe_public_key ?? '' }}"
                               placeholder="pk_live_... oder pk_test_...">
                        <div class="ps-hint">Beginnt mit <code>pk_live_</code> (Live) oder <code>pk_test_</code> (Test)</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="ps-form-group">
                        <label class="ps-label" for="stripe_secret_key">Geheimer Schlüssel (Secret Key)</label>
                        <input type="password" class="ps-input" id="stripe_secret_key" name="stripe_secret_key"
                               value="{{ settings.stripe_secret_key ?? '' }}"
                               placeholder="sk_live_... oder sk_test_...">
                        <div class="ps-hint">Niemals öffentlich teilen! Beginnt mit <code>sk_live_</code> oder <code>sk_test_</code></div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="ps-form-group" style="margin-bottom:0;">
                        <label class="ps-label" for="stripe_webhook_secret">Webhook Signing Secret</label>
                        <input type="password" class="ps-input" id="stripe_webhook_secret" name="stripe_webhook_secret"
                               value="{{ settings.stripe_webhook_secret ?? '' }}"
                               placeholder="whsec_...">
                        <div class="ps-hint">
                            Webhook-Endpunkt: <code>https://therapano.de/webhooks/stripe</code> —
                            <a href="https://dashboard.stripe.com/webhooks" target="_blank">In Stripe Dashboard konfigurieren →</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="test-result" id="stripe-test-result"></div>
        </div>
    </div>

    {# ─────────────────────────────────────────────────────────────────────── #}
    {# PAYPAL                                                                   #}
    {# ─────────────────────────────────────────────────────────────────────── #}
    <div class="ps-card">
        <div class="ps-card-header">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#009cde" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.3 21.6H5.1l.4-2.6H7c.5 0 .8.1 1 .3.2.2.3.4.3.7 0 .4-.1.8-.4 1-.2.4-.6.6-1 .6zM20.3 3.6c-.3-1.3-1-2.3-1.9-3C17.5.2 16.1 0 14.4 0H8.7c-.5 0-.9.3-1 .8L5.6 13.8c-.1.3.1.6.4.7H9l.8-5.2-.1.4c.1-.5.5-.8 1-.8h2.1c4.2 0 7.4-1.7 8.4-6.6v-.3c-.2-.2-.2-.2 0-.4z"/>
                <path d="M20.3 3.6c-.1.3-.2.5-.3.8-1.1 5.5-4.8 7.4-9.5 7.4H8.3c-.6 0-1.1.4-1.2 1L5.9 20c-.1.3.1.6.4.7H9c.4 0 .8-.3.9-.7l.1-.3.7-4.5.1-.3c.1-.4.5-.7.9-.7h.6c3.7 0 6.6-1.5 7.4-5.8.4-1.8.2-3.3-.7-4.4-.2-.2-.5-.2-.7-.4z"/>
            </svg>
            <h3>PayPal</h3>
            <span class="ps-badge {% if settings.paypal_enabled == '1' %}ps-badge-on{% else %}ps-badge-off{% endif %}" id="paypal-status-badge">
                {{ settings.paypal_enabled == '1' ? 'Aktiviert' : 'Deaktiviert' }}
            </span>
            <div class="ms-auto">
                <button type="button" class="test-btn" onclick="testPayPal()">
                    <i class="bi bi-plug me-1"></i>Verbindung testen
                </button>
            </div>
        </div>
        <div class="ps-card-body">

            <div style="margin-bottom:1.5rem;">
                <div style="font-size:.8rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.875rem;">
                    📋 Einrichtungsanleitung
                </div>
                <div class="ps-step">
                    <div class="ps-step-num">1</div>
                    <div class="ps-step-content">
                        Gehe zu <a href="https://developer.paypal.com" target="_blank"><strong>developer.paypal.com</strong></a> und melde dich mit deinem PayPal-Geschäftskonto an.
                    </div>
                </div>
                <div class="ps-step">
                    <div class="ps-step-num">2</div>
                    <div class="ps-step-content">
                        Navigiere zu <strong>Apps & Credentials</strong> → <strong>Create App</strong>.<br>
                        Wähle <strong>Merchant</strong> als App-Typ. Kopiere <strong>Client ID</strong> und <strong>Client Secret</strong> aus deiner App.
                    </div>
                </div>
                <div class="ps-step">
                    <div class="ps-step-num">3</div>
                    <div class="ps-step-content">
                        <span style="color:#fde68a;">⚠ Sandbox-Modus</span> für Tests aktivieren — schalte ihn <strong>aus</strong> wenn du live gehst.<br>
                        Im Sandbox-Modus werden <strong>keine echten Zahlungen</strong> verarbeitet.
                    </div>
                </div>
                <div class="ps-step">
                    <div class="ps-step-num">4</div>
                    <div class="ps-step-content">
                        Stelle sicher, dass dein PayPal-Konto <strong>Subscriptions (Abonnements)</strong> unterstützt — dies erfordert ein verifiziertes Geschäftskonto.<br>
                        <a href="https://www.paypal.com/de/webapps/mpp/merchant" target="_blank">PayPal Geschäftskonto einrichten →</a>
                    </div>
                </div>
                <div class="ps-step">
                    <div class="ps-step-num">5</div>
                    <div class="ps-step-content">
                        Return-URL (nach Zahlung): <code>https://therapano.de/register/payment-success</code>
                    </div>
                </div>
            </div>

            <hr class="ps-divider">

            <div class="row g-3">
                <div class="col-6">
                    <label class="ps-toggle">
                        <input type="checkbox" name="paypal_enabled" value="1" id="paypal-toggle"
                               {% if settings.paypal_enabled == '1' %}checked{% endif %}
                               onchange="document.getElementById('paypal-status-badge').textContent = this.checked ? 'Aktiviert' : 'Deaktiviert'; document.getElementById('paypal-status-badge').className = 'ps-badge ' + (this.checked ? 'ps-badge-on' : 'ps-badge-off');">
                        <span style="font-size:.85rem;font-weight:600;color:#e2e8f0;">PayPal aktivieren</span>
                    </label>
                </div>
                <div class="col-6">
                    <label class="ps-toggle">
                        <input type="checkbox" name="paypal_sandbox" value="1"
                               {% if settings.paypal_sandbox != '0' %}checked{% endif %}>
                        <span style="font-size:.85rem;font-weight:600;color:#fde68a;">Sandbox-Modus (Test)</span>
                    </label>
                </div>
                <div class="col-md-6">
                    <div class="ps-form-group">
                        <label class="ps-label" for="paypal_client_id">Client ID</label>
                        <input type="text" class="ps-input" id="paypal_client_id" name="paypal_client_id"
                               value="{{ settings.paypal_client_id ?? '' }}"
                               placeholder="AaBbCcDd...">
                        <div class="ps-hint">Aus dem PayPal Developer Dashboard kopieren</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="ps-form-group" style="margin-bottom:0;">
                        <label class="ps-label" for="paypal_client_secret">Client Secret</label>
                        <input type="password" class="ps-input" id="paypal_client_secret" name="paypal_client_secret"
                               value="{{ settings.paypal_client_secret ?? '' }}"
                               placeholder="••••••••••••">
                        <div class="ps-hint">Niemals öffentlich teilen!</div>
                    </div>
                </div>
            </div>
            <div class="test-result" id="paypal-test-result"></div>
        </div>
    </div>

    <div class="d-flex gap-2 mb-5">
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg me-2"></i>Zahlungseinstellungen speichern
        </button>
    </div>
</form>

{# ─────────────────────────────────────────────────────────────────────────── #}
{# CRONJOBS                                                                     #}
{# ─────────────────────────────────────────────────────────────────────────── #}
<div class="ps-card" id="cron">
    <div class="ps-card-header">
        <i class="bi bi-clock-history" style="font-size:1.1rem;color:#a78bfa;"></i>
        <h3>Cronjobs einrichten</h3>
        {% if cron_status.last_run %}
        <span style="font-size:.72rem;color:#64748b;margin-left:.5rem;">
            Letzter Lauf: <strong style="color:#94a3b8;">{{ cron_status.last_run }}</strong>
            ({{ cron_status.last_mode }})
        </span>
        {% endif %}
        <div class="ms-auto d-flex gap-2">
            <form method="POST" action="/admin/payment-settings/cron/run" style="margin:0;">
                {{ csrf_field()|raw }}
                <input type="hidden" name="mode" value="hourly">
                <button class="test-btn" type="submit">▶ Stündlich ausführen</button>
            </form>
            <form method="POST" action="/admin/payment-settings/cron/run" style="margin:0;">
                {{ csrf_field()|raw }}
                <input type="hidden" name="mode" value="daily">
                <button class="test-btn" type="submit">▶ Täglich ausführen</button>
            </form>
        </div>
    </div>
    <div class="ps-card-body">

        {# Was macht der Cron? #}
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div style="background:#0a0f1a;border:1px solid #1e293b;border-radius:.6rem;padding:1rem;">
                    <div style="font-size:.75rem;font-weight:700;color:#6ea8fe;margin-bottom:.5rem;">⏱ Stündlich</div>
                    <ul style="margin:0;padding-left:1.1rem;font-size:.78rem;color:#94a3b8;line-height:1.8;">
                        <li>Trial-Ablauf prüfen → sperren</li>
                        <li>Erinnerung (3 Tage vor Ablauf)</li>
                        <li>Überfällige Zahlungen → past_due</li>
                        <li>Revenue-Snapshot speichern</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-4">
                <div style="background:#0a0f1a;border:1px solid #1e293b;border-radius:.6rem;padding:1rem;">
                    <div style="font-size:.75rem;font-weight:700;color:#a78bfa;margin-bottom:.5rem;">📅 Täglich (zusätzlich)</div>
                    <ul style="margin:0;padding-left:1.1rem;font-size:.78rem;color:#94a3b8;line-height:1.8;">
                        <li>Alte Benachrichtigungen aufräumen</li>
                        <li>Feedback-Tages-Zusammenfassung</li>
                        <li>Stripe-Subscriptions synchronisieren</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-4">
                <div style="background:#0a0f1a;border:1px solid #1e293b;border-radius:.6rem;padding:1rem;">
                    <div style="font-size:.75rem;font-weight:700;color:#86efac;margin-bottom:.5rem;">📂 Skript-Pfad</div>
                    <code style="font-size:.72rem;color:#7dd3fc;word-break:break-all;line-height:1.6;">{{ cron_path }}</code>
                </div>
            </div>
        </div>

        {# Crontab Einrichtung #}
        <div style="font-size:.8rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.06em;margin-bottom:1rem;">
            📋 Crontab konfigurieren (auf dem Server)
        </div>

        <div class="ps-step">
            <div class="ps-step-num">1</div>
            <div class="ps-step-content">
                Per SSH auf den Server verbinden und den Crontab-Editor öffnen:<br>
                <code>crontab -e</code>
            </div>
        </div>
        <div class="ps-step">
            <div class="ps-step-num">2</div>
            <div class="ps-step-content">
                Folgende Zeilen hinzufügen (Pfad ggf. anpassen):
            </div>
        </div>

        <div class="cron-block mb-3">
            <span class="comment"># TheraPano SaaS — Stündlicher Cron (Trial, Zahlungen, Revenue-Snapshot)</span><br>
            <span class="cmd">0 * * * * php {{ cron_path }} hourly >> /var/log/therapano_cron.log 2>&1</span><br><br>
            <span class="comment"># TheraPano SaaS — Täglicher Cron um 08:00 Uhr (Aufräumen, Feedback, Stripe-Sync)</span><br>
            <span class="cmd">0 8 * * * php {{ cron_path }} daily >> /var/log/therapano_cron.log 2>&1</span>
        </div>

        <div class="ps-step">
            <div class="ps-step-num">3</div>
            <div class="ps-step-content">
                Bei Hostinger / Shared Hosting: Gehe im hPanel zu <strong>Erweitert → Cron Jobs</strong>.<br>
                Trage dort ein:<br>
                <strong>Befehl:</strong> <code>php {{ cron_path }} hourly</code><br>
                <strong>Zeitplan:</strong> <code>0 * * * *</code> (jede Stunde)
            </div>
        </div>
        <div class="ps-step">
            <div class="ps-step-num">4</div>
            <div class="ps-step-content">
                Log-Datei prüfen: <code>tail -f /var/log/therapano_cron.log</code><br>
                Oder nutze die <strong>Manuell ausführen</strong>-Buttons oben rechts zum Testen.
            </div>
        </div>

        {# Letztes Log #}
        {% if cron_status.last_lines|length > 0 %}
        <hr class="ps-divider">
        <div style="font-size:.8rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.75rem;">
            📄 Letztes Log
        </div>
        <div class="cron-block">
            {% for line in cron_status.last_lines %}
            {{ line|e }}<br>
            {% endfor %}
        </div>
        {% else %}
        <div style="margin-top:1rem;font-size:.8rem;color:#475569;">
            <i class="bi bi-info-circle me-1"></i>
            Noch kein Log vorhanden. Führe den Cron einmal manuell aus oder warte auf den ersten automatischen Lauf.
        </div>
        {% endif %}

    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
async function testStripe() {
    const btn = event.target.closest('button');
    const res = document.getElementById('stripe-test-result');
    btn.disabled = true; btn.textContent = 'Teste…';
    res.style.display = 'none';
    try {
        const r = await fetch('/admin/payment-settings/test/stripe');
        const d = await r.json();
        res.className = 'test-result ' + (d.ok ? 'ok' : 'err');
        res.textContent = (d.ok ? '✓ ' : '✗ ') + d.message;
        res.style.display = 'block';
    } catch(e) {
        res.className = 'test-result err';
        res.textContent = '✗ Netzwerkfehler: ' + e.message;
        res.style.display = 'block';
    }
    btn.disabled = false; btn.innerHTML = '<i class="bi bi-plug me-1"></i>Verbindung testen';
}

async function testPayPal() {
    const btn = event.target.closest('button');
    const res = document.getElementById('paypal-test-result');
    btn.disabled = true; btn.textContent = 'Teste…';
    res.style.display = 'none';
