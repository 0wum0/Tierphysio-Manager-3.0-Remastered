{% extends 'layouts/base.twig' %}

{% block content %}

{# ── Header ─────────────────────────────────────────────────────────── #}
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        {% if unread_count > 0 %}
        <span class="badge bg-primary ms-2">{{ unread_count }} ungelesen</span>
        {% endif %}
    </div>
    <div class="d-flex gap-2">
        {% if unread_count > 0 %}
        <form method="POST" action="/admin/notifications/mark-all-read">
            {{ csrf_field()|raw }}
            <button type="submit" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-check2-all me-1"></i>Alle gelesen
            </button>
        </form>
        {% endif %}
        <form method="POST" action="/admin/notifications/delete-read" onsubmit="return confirm('Alle gelesenen Benachrichtigungen löschen?')">
            {{ csrf_field()|raw }}
            <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash3 me-1"></i>Gelesene löschen
            </button>
        </form>
        <a href="/admin/notifications/activity-log" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-journal-text me-1"></i>Aktivitätsprotokoll
        </a>
    </div>
</div>

{# ── Liste ──────────────────────────────────────────────────────────── #}
{% if notifications is empty %}
<div class="text-center py-5 text-muted">
    <svg class="sa-icon sa-icon-3x d-block mx-auto mb-3 opacity-25"><use href="/sa/icons/sprite.svg#bell"></use></svg>
    <div class="fw-600">Keine Benachrichtigungen</div>
    <div class="fs-sm mt-1">Alles auf dem neuesten Stand.</div>
</div>
{% else %}

{% set typeIcons = {
    'new_tenant':   'bi-building-add',
    'payment':      'bi-credit-card-2-front',
    'overdue':      'bi-exclamation-triangle',
    'trial_expiry': 'bi-hourglass-split',
    'system_update':'bi-arrow-repeat',
} %}

{% for notif in notifications %}
<div class="notif-item {% if not notif.is_read %}unread{% endif %}" id="notif-{{ notif.id }}">
    <div class="notif-icon notif-type-{{ notif.type|default('default') }}">
        <i class="bi {{ typeIcons[notif.type] ?? 'bi-bell' }}"></i>
    </div>
    <div class="flex-grow-1 min-w-0">
        <div class="d-flex align-items-start justify-content-between gap-2">
            <div>
                <div class="{% if not notif.is_read %}fw-700{% else %}fw-500{% endif %} fs-sm">{{ notif.title }}</div>
                <div class="text-muted fs-xs mt-1">{{ notif.message }}</div>
            </div>
            <div class="d-flex align-items-center gap-1 flex-shrink-0">
                <span class="text-muted fs-xs text-nowrap">{{ notif.created_at|date('d.m.Y H:i') }}</span>
                {% if not notif.is_read %}
                <form method="POST" action="/admin/notifications/{{ notif.id }}/read">
                    {{ csrf_field()|raw }}
                    <button type="submit" class="btn btn-sm py-0 px-1 btn-outline-secondary" title="Als gelesen markieren">
                        <i class="bi bi-check2"></i>
                    </button>
                </form>
                {% endif %}
                <form method="POST" action="/admin/notifications/{{ notif.id }}/delete">
                    {{ csrf_field()|raw }}
                    <button type="submit" class="btn btn-sm py-0 px-1 btn-outline-danger" title="Löschen">
                        <i class="bi bi-x"></i>
                    </button>
                </form>
            </div>
        </div>
        {% if notif.data %}
        {% set data = notif.data|json_decode %}
        {% if data is not empty %}
        <div class="mt-1 d-flex gap-2 flex-wrap">
            {% for k, v in data %}
            <span class="badge text-muted fs-xs" style="background:#0f172a;border:1px solid #334155;">{{ k }}: {{ v }}</span>
            {% endfor %}
        </div>
        {% endif %}
        {% endif %}
    </div>
</div>
{% endfor %}
{% endif %}

{# ── Pagination ────────────────────────────────────────────────────── #}
{% if pagination.last_page > 1 %}
<nav class="mt-4 d-flex justify-content-between align-items-center">
    <span class="text-muted fs-sm">{{ pagination.total }} Benachrichtigungen</span>
    <ul class="pagination pagination-sm mb-0">
        {% if pagination.has_prev %}
        <li class="page-item"><a class="page-link" href="?page={{ pagination.page - 1 }}">‹</a></li>
        {% endif %}
        {% for p in 1..pagination.last_page %}
        <li class="page-item {% if p == pagination.page %}active{% endif %}">
            <a class="page-link" href="?page={{ p }}">{{ p }}</a>
        </li>
        {% endfor %}
        {% if pagination.has_next %}
        <li class="page-item"><a class="page-link" href="?page={{ pagination.page + 1 }}">›</a></li>
        {% endif %}
    </ul>
</nav>
{% endif %}

{% endblock %}
