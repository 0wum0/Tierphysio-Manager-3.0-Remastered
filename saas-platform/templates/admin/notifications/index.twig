{% extends 'layouts/base.twig' %}
{% set active_nav = 'notifications' %}

{% block styles %}
<style>
.notif-item { background:#1e293b; border:1px solid #334155; border-radius:.75rem; padding:1rem 1.25rem; margin-bottom:.5rem; transition:all .15s; display:flex; align-items:flex-start; gap:1rem; }
.notif-item:hover { border-color:#475569; background:#1e2d3d; }
.notif-item.unread { border-left:3px solid #2563eb; }
.notif-icon { width:2.5rem; height:2.5rem; border-radius:.5rem; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:1rem; }
.notif-type-new_tenant      { background:rgba(16,185,129,.12); color:#34d399; }
.notif-type-payment         { background:rgba(37,99,235,.12);  color:#60a5fa; }
.notif-type-overdue         { background:rgba(239,68,68,.12);  color:#f87171; }
.notif-type-trial_expiry    { background:rgba(245,158,11,.12); color:#fbbf24; }
.notif-type-system_update   { background:rgba(139,92,246,.12); color:#c4b5fd; }
.notif-type-default         { background:rgba(100,116,139,.12);color:#94a3b8; }
</style>
{% endblock %}

{% block content %}

{# ── Header ─────────────────────────────────────────────────────────── #}
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        {% if unread_count > 0 %}
        <span class="badge bg-primary ms-2">{{ unread_count }} ungelesen</span>
        {% endif %}
    </div>
    <div class="d-flex gap-2">
        {% if unread_count > 0 %}
        <form method="POST" action="/admin/notifications/mark-all-read">
            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
            <button type="submit" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-check2-all me-1"></i>Alle gelesen
            </button>
        </form>
        {% endif %}
        <form method="POST" action="/admin/notifications/delete-read" onsubmit="return confirm('Alle gelesenen Benachrichtigungen löschen?')">
            <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
            <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash3 me-1"></i>Gelesene löschen
            </button>
        </form>
        <a href="/admin/notifications/activity-log" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-journal-text me-1"></i>Aktivitätsprotokoll
        </a>
    </div>
</div>

{# ── Liste ──────────────────────────────────────────────────────────── #}
{% if notifications is empty %}
<div class="text-center py-5" style="color:#475569;">
    <i class="bi bi-bell-slash" style="font-size:3rem;opacity:.3;display:block;margin-bottom:.75rem;"></i>
    <div style="font-size:1rem;">Keine Benachrichtigungen</div>
    <div style="font-size:.875rem;margin-top:.25rem;">Alles auf dem neuesten Stand.</div>
</div>
{% else %}

{% set typeIcons = {
    'new_tenant':   'bi-building-add',
    'payment':      'bi-credit-card-2-front',
    'overdue':      'bi-exclamation-triangle',
    'trial_expiry': 'bi-hourglass-split',
    'system_update':'bi-arrow-repeat',
} %}

{% for notif in notifications %}
<div class="notif-item {% if not notif.is_read %}unread{% endif %}" id="notif-{{ notif.id }}">
    <div class="notif-icon notif-type-{{ notif.type|default('default') }}">
        <i class="bi {{ typeIcons[notif.type] ?? 'bi-bell' }}"></i>
    </div>
    <div class="flex-grow-1 min-w-0">
        <div class="d-flex align-items-start justify-content-between gap-2">
            <div>
                <div style="font-weight:{% if not notif.is_read %}700{% else %}500{% endif %};color:#e2e8f0;font-size:.9rem;">{{ notif.title }}</div>
                <div style="font-size:.8rem;color:#94a3b8;margin-top:.2rem;">{{ notif.message }}</div>
            </div>
            <div class="d-flex align-items-center gap-1 flex-shrink-0">
                <span style="font-size:.72rem;color:#475569;white-space:nowrap;">{{ notif.created_at|date('d.m.Y H:i') }}</span>
                {% if not notif.is_read %}
                <form method="POST" action="/admin/notifications/{{ notif.id }}/read" style="margin:0;">
                    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                    <button type="submit" class="btn btn-sm py-0 px-1 btn-outline-secondary" title="Als gelesen markieren">
                        <i class="bi bi-check2"></i>
                    </button>
                </form>
                {% endif %}
                <form method="POST" action="/admin/notifications/{{ notif.id }}/delete" style="margin:0;">
                    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                    <button type="submit" class="btn btn-sm py-0 px-1 btn-outline-danger" title="Löschen">
                        <i class="bi bi-x"></i>
                    </button>
                </form>
            </div>
        </div>
        {% if notif.data %}
        {% set data = notif.data|json_decode ?? {} %}
        {% if data %}
        <div class="mt-1 d-flex gap-2 flex-wrap">
            {% for k, v in data %}
            <span style="font-size:.72rem;background:#0f172a;border:1px solid #334155;border-radius:.3rem;padding:.1rem .4rem;color:#64748b;">{{ k }}: {{ v }}</span>
            {% endfor %}
        </div>
        {% endif %}
        {% endif %}
    </div>
</div>
{% endfor %}
{% endif %}

{# ── Pagination ────────────────────────────────────────────────────── #}
{% if pagination.last_page > 1 %}
<nav class="mt-4 d-flex justify-content-between align-items-center">
    <small class="text-secondary">{{ pagination.total }} Benachrichtigungen</small>
    <ul class="pagination pagination-sm mb-0">
        {% if pagination.has_prev %}
        <li class="page-item"><a class="page-link" href="?page={{ pagination.page - 1 }}">‹</a></li>
        {% endif %}
        {% for p in 1..pagination.last_page %}
        <li class="page-item {% if p == pagination.page %}active{% endif %}">
            <a class="page-link" href="?page={{ p }}">{{ p }}</a>
        </li>
        {% endfor %}
        {% if pagination.has_next %}
        <li class="page-item"><a class="page-link" href="?page={{ pagination.page + 1 }}">›</a></li>
        {% endif %}
    </ul>
</nav>
{% endif %}

{% endblock %}
