{% extends 'layouts/base.twig' %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-4">
    <a href="/admin/updates" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Zurück</a>
    <span class="text-muted fs-sm">Installiert: <strong>v{{ current }}</strong></span>
</div>

{% if releases is empty %}
<div class="text-center py-5 text-muted">
    <svg class="sa-icon sa-icon-3x d-block mx-auto mb-3 opacity-25"><use href="/sa/icons/sprite.svg#document-text"></use></svg>
    <div>Changelog nicht verfügbar – Update-Server nicht erreichbar.</div>
</div>
{% else %}
{% for release in releases %}
<div class="card mb-3{% if release.version == current %}" style="border-color:rgba(37,99,235,.4){% endif %}">
    <div class="card-body px-4 py-3">
        <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
            <div class="d-flex align-items-center gap-2">
                <span class="h5 mb-0 fw-800 {% if release.version == current %}text-primary{% endif %}">v{{ release.version }}</span>
                {% if release.version == current %}
                <span class="badge text-success" style="background:rgba(16,185,129,.15);border:1px solid rgba(16,185,129,.3);"><i class="bi bi-check-circle me-1"></i>Installiert</span>
                {% elseif release.prerelease %}
                <span class="badge bg-warning text-dark fs-xs">Beta</span>
                {% else %}
                <span class="badge text-primary fs-xs" style="background:rgba(37,99,235,.15);border:1px solid rgba(37,99,235,.3);">Stabil</span>
                {% endif %}
            </div>
            <div class="text-muted fs-sm">
                {% if release.published_at %}<i class="bi bi-calendar3 me-1"></i>{{ release.published_at|date('d.m.Y') }}{% endif %}
            </div>
        </div>
        {% if release.name and release.name != release.version %}
        <div class="text-muted fs-sm mt-1">{{ release.name }}</div>
        {% endif %}
        {% if release.body %}
        <div class="release-body">{{ release.body }}</div>
        {% else %}
        <div class="text-muted fs-sm mt-2 fst-italic">Keine Release Notes verfügbar.</div>
        {% endif %}
    </div>
</div>
{% endfor %}
{% endif %}

{% endblock %}
