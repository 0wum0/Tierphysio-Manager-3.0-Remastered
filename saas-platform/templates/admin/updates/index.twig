{% extends 'layouts/base.twig' %}

{% block content %}

<div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
    <span class="v-badge v-badge-current"><i class="bi bi-tag"></i>v{{ current }}</span>
    {% if available %}
        {% if available.version > current %}
        <span class="v-badge v-badge-new"><i class="bi bi-stars"></i>v{{ available.version }} verfügbar</span>
        {% else %}
        <span class="v-badge v-badge-uptodate"><i class="bi bi-check-circle"></i>Aktuell</span>
        {% endif %}
    {% else %}
    <span class="v-badge v-badge-uptodate"><i class="bi bi-wifi-off"></i>Update-Server nicht erreichbar</span>
    {% endif %}
    <div class="ms-auto d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary" id="checkUpdateBtn" onclick="checkUpdate()">
            <i class="bi bi-arrow-clockwise me-1"></i>Jetzt prüfen
        </button>
        <a href="/admin/updates/changelog" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-file-text me-1"></i>Changelog
        </a>
        <a href="/admin/updates/system-info" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-cpu me-1"></i>Systeminfo
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">

        {# ── Update-Box ──────────────────────────────────────────────── #}
        {% if available and available.version > current %}
        <div class="card mb-3" style="border-color:rgba(16,185,129,.3);">
            <div class="card-header px-4 py-3 text-success fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-stars me-2"></i>Neues Update verfügbar</div>
            <div class="card-body px-4 py-3">
            <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                <div>
                    <div class="h3 fw-700 mb-0 text-success">v{{ available.version }}</div>
                    <div class="text-muted fs-sm mt-1">
                        {% if available.published_at %}Veröffentlicht: {{ available.published_at|date('d.m.Y') }}{% endif %}
                        {% if available.prerelease %}<span class="badge bg-warning text-dark ms-2 fs-xs">Beta</span>{% endif %}
                    </div>
                </div>
                <div>
                    <span class="text-muted fs-sm">Kanal: <strong>{{ channel }}</strong></span>
                </div>
            </div>
            {% if available.body %}
            <div class="mb-3">
                <div class="text-muted fs-xs text-uppercase mb-2" style="letter-spacing:.06em;">Release Notes</div>
                <div class="release-body" style="max-height:200px;">{{ available.body }}</div>
            </div>
            {% endif %}
            <form method="POST" action="/admin/updates/apply" onsubmit="return confirm('Update auf v{{ available.version }} anwenden? Die Plattform wird kurz neu gestartet.')">
                {{ csrf_field()|raw }}
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-cloud-download me-1"></i>Update auf v{{ available.version }} anwenden
                </button>
                <a href="{{ available.html_url }}" target="_blank" class="btn btn-outline-secondary ms-2">
                    <i class="bi bi-github me-1"></i>Release ansehen
                </a>
            </form>
            </div>
        </div>
        {% else %}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-check-circle me-2"></i>Kein Update verfügbar</div>
            <div class="card-body px-4 py-3">
            <p class="text-muted fs-sm mb-3">Die installierte Version <strong>v{{ current }}</strong> ist aktuell.</p>
            <button class="btn btn-sm btn-outline-secondary" onclick="checkUpdate()">
                <i class="bi bi-arrow-clockwise me-1"></i>Erneut prüfen
            </button>
            </div>
        </div>
        {% endif %}

        {# ── Update-Verlauf ─────────────────────────────────────────── #}
        {% if update_log %}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-clock-history me-2"></i>Update-Verlauf</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Datum</th>
                            <th>Von</th>
                            <th>Nach</th>
                            <th>Kanal</th>
                            <th>Status</th>
                            <th>Admin</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set statusMap = {'success':'Erfolgreich','failed':'Fehlgeschlagen','rolled_back':'Zurückgerollt'} %}
                        {% set statusColor = {'success':'#34d399','failed':'#f87171','rolled_back':'#fbbf24'} %}
                        {% for entry in update_log %}
                        <tr>
                            <td class="text-muted text-nowrap fs-xs">{{ entry.performed_at|date('d.m.Y H:i') }}</td>
                            <td class="fs-sm">v{{ entry.from_version }}</td>
                            <td class="fs-sm fw-600 text-success">v{{ entry.to_version }}</td>
                            <td class="text-muted fs-sm">{{ entry.channel }}</td>
                            <td>
                                <span class="fs-xs fw-600 {% if entry.status == 'success' %}text-success{% elseif entry.status == 'failed' %}text-danger{% else %}text-warning{% endif %}">
                                    {{ statusMap[entry.status] ?? entry.status }}
                                </span>
                            </td>
                            <td class="text-muted fs-sm">{{ entry.performed_by }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}
    </div>

    <div class="col-lg-5">

        {# ── SaaS Platform DB-Migrationen ────────────────────────────── #}
        {% set dbm = db_migration ?? {} %}
        {% set pendingCount = dbm.pending ?? 0 %}
        <div class="card mb-3{% if pendingCount > 0 %} border-warning{% endif %}">
            <div class="card-header px-4 py-3 d-flex align-items-center gap-2 fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;">
                <i class="bi bi-database-gear {% if pendingCount > 0 %}text-warning{% else %}text-success{% endif %}"></i>
                Datenbank-Migrationen (Global)
                {% if pendingCount > 0 %}
                <span class="badge bg-warning text-dark">{{ pendingCount }} ausstehend</span>
                {% else %}
                <span class="badge text-success">Aktuell</span>
                {% endif %}
            </div>
            <div class="card-body px-4 py-3">

            {% if pendingCount > 0 %}
            <div class="alert alert-warning fs-sm">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>{{ pendingCount }} ausstehende Migration(en)</strong> müssen auf der Produktionsdatenbank angewandt werden. Dies behebt aktuelle 500-Fehler durch fehlende Spalten.
            </div>
            {% endif %}

            <div class="d-flex justify-content-between py-2 border-bottom fs-sm mb-2">
                <span class="text-muted">Angewandt</span>
                <span class="fw-500">{{ dbm.applied ?? 0 }} / {{ (dbm.applied ?? 0) + pendingCount }}</span>
            </div>

            {% if dbm.files is defined and dbm.files %}
            <div style="max-height:140px;overflow-y:auto;" class="mb-3">
                {% for f in dbm.files %}
                <div class="d-flex align-items-center gap-2 py-1 border-bottom fs-xs">
                    <i class="bi bi-{{ f.applied ? 'check-circle-fill text-success' : 'clock text-warning' }} flex-shrink-0"></i>
                    <span class="{{ f.applied ? 'text-muted' : 'text-warning' }} font-monospace">{{ f.filename }}</span>
                </div>
                {% endfor %}
            </div>
            {% endif %}

            <form method="POST" action="/admin/updates/run-db-migrations" class="mt-2"
                  onsubmit="return confirm('SaaS-Datenbank-Migrationen anwenden? Dies ändert die globale Datenbank (plans, subscriptions, …).')">
                {{ csrf_field()|raw }}
                <button type="submit" class="btn btn-sm w-100 {% if pendingCount > 0 %}btn-warning{% else %}btn-outline-secondary{% endif %}">
                    <i class="bi bi-database-fill-up me-1"></i>
                    {% if pendingCount > 0 %}{{ pendingCount }} Migration(en) anwenden{% else %}Migrationen prüfen / neu ausführen{% endif %}
                </button>
            </form>
            </div>
        </div>

        {# ── System-Übersicht ──────────────────────────────────────────── #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-info-circle me-2"></i>Systemübersicht</div>
            <div class="card-body px-4 py-3">
            {% set rows = [
                ['PHP-Version',      sysinfo.php_version],
                ['Betriebssystem',   sysinfo.os],
                ['Datenbank',        sysinfo.db_version],
                ['Webserver',        sysinfo.server_software],
                ['Zeitzone',         sysinfo.timezone],
                ['Memory Limit',     sysinfo.memory_limit],
                ['Max. Upload',      sysinfo.max_upload],
            ] %}
            {% for row in rows %}
            <div class="d-flex justify-content-between py-2 border-bottom fs-sm">
                <span class="text-muted">{{ row[0] }}</span>
                <span class="fw-500">{{ row[1] }}</span>
            </div>
            {% endfor %}
            {% if sysinfo.uptime != 'n/a' %}
            <div class="d-flex justify-content-between py-2 fs-sm">
                <span class="text-muted">Uptime</span>
                <span class="fw-500">{{ sysinfo.uptime }}</span>
            </div>
            {% endif %}
            </div>
        </div>

        {# ── Festplattenspeicher ───────────────────────────────────────────── #}
        {% if disk_total > 0 %}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-hdd me-2"></i>Festplattenspeicher</div>
            <div class="card-body px-4 py-3">
            {% set used = disk_total - disk_free %}
            {% set pct  = (used / disk_total * 100)|round %}
            <div class="d-flex justify-content-between mb-2 fs-sm">
                <span class="text-muted">Belegt: {{ (used / 1073741824)|round(1) }} GB</span>
                <span>Frei: {{ (disk_free / 1073741824)|round(1) }} GB</span>
            </div>
            <div class="progress" style="height:8px;">
                <div class="progress-bar {% if pct > 85 %}bg-danger{% elseif pct > 65 %}bg-warning{% else %}bg-success{% endif %}" style="width:{{ pct }}%"></div>
            </div>
            <div class="text-muted fs-xs mt-1">{{ pct }}% von {{ (disk_total / 1073741824)|round(1) }} GB belegt</div>
            </div>
        </div>
        {% endif %}

        {# ── PHP-Extensions ────────────────────────────────────────────────── #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-puzzle me-2"></i>PHP-Extensions</div>
            <div class="card-body px-4 py-3">
            <div class="row g-1">
                {% for ext, ok in extensions %}
                <div class="col-6">
                    <div class="fs-sm {{ ok ? 'text-success' : 'text-danger' }} py-1">
                        <i class="bi bi-{{ ok ? 'check-circle' : 'x-circle' }} me-1"></i>{{ ext }}
                    </div>
                </div>
                {% endfor %}
            </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
async function checkUpdate() {
    const btn = document.getElementById('checkUpdateBtn');
    btn.innerHTML = '<i class="bi bi-arrow-clockwise spin me-1"></i>Prüfe…';
    btn.disabled = true;
    try {
        const res  = await fetch('/admin/updates/check');
        const data = await res.json();
        if (data.has_update) {
            location.reload();
        } else {
            btn.innerHTML = '<i class="bi bi-check-circle me-1"></i>Aktuell';
            setTimeout(() => {
                btn.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Jetzt prüfen';
                btn.disabled = false;
            }, 3000);
        }
    } catch {
        btn.innerHTML = '<i class="bi bi-wifi-off me-1"></i>Fehler';
        btn.disabled = false;
    }
}
</script>
<style>.spin { animation: spin .8s linear infinite; } @keyframes spin { to { transform:rotate(360deg); } }</style>
{% endblock %}
