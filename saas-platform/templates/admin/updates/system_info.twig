{% extends 'layouts/base.twig' %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-4">
    <a href="/admin/updates" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Zurück</a>
    <button onclick="window.print()" class="btn btn-sm btn-outline-secondary"><i class="bi bi-printer me-1"></i>Drucken</button>
</div>

<div class="row g-4">
    <div class="col-lg-6">

        {# ── Plattform & PHP ──────────────────────────────────────────────── #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-code-slash me-2"></i>Plattform & PHP</div>
            <div class="card-body px-4 py-3">
            {% set rows = [
                ['Plattform-Version', sysinfo.platform_version],
                ['PHP-Version',       sysinfo.php_version],
                ['PHP SAPI',          sysinfo.php_sapi],
                ['Betriebssystem',    sysinfo.os],
                ['Webserver',         sysinfo.server_software],
                ['Zeitzone',          sysinfo.timezone],
            ] %}
            {% for row in rows %}
            <div class="d-flex justify-content-between py-2 border-bottom fs-sm">
                <span class="text-muted">{{ row[0] }}</span>
                <span class="font-monospace fw-500 fs-xs">{{ row[1] }}</span>
            </div>
            {% endfor %}
            </div>
        </div>

        {# ── PHP.ini ──────────────────────────────────────────────────────── #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-sliders me-2"></i>PHP-Konfiguration</div>
            <div class="card-body px-4 py-3">
            {% for key, val in php_ini %}
            <div class="d-flex justify-content-between py-2 border-bottom fs-sm">
                <span class="text-muted">{{ key }}</span>
                <span class="font-monospace fw-500 fs-xs">{{ val ?: 'n/a' }}</span>
            </div>
            {% endfor %}
            </div>
        </div>
    </div>

    <div class="col-lg-6">

        {# ── Datenbank & Server ──────────────────────────────────────────── #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-database me-2"></i>Datenbank & Server</div>
            <div class="card-body px-4 py-3">
            {% set rows2 = [
                ['MySQL-Version', sysinfo.db_version],
                ['Memory Limit',  sysinfo.memory_limit],
                ['Max. Upload',   sysinfo.max_upload],
                ['Composer Pkg',  sysinfo.composer_name],
            ] %}
            {% for row in rows2 %}
            <div class="d-flex justify-content-between py-2 border-bottom fs-sm">
                <span class="text-muted">{{ row[0] }}</span>
                <span class="font-monospace fw-500 fs-xs">{{ row[1] }}</span>
            </div>
            {% endfor %}
            {% if sysinfo.uptime != 'n/a' %}
            <div class="d-flex justify-content-between py-2 fs-sm">
                <span class="text-muted">Server-Uptime</span>
                <span class="font-monospace fw-500 fs-xs">{{ sysinfo.uptime }}</span>
            </div>
            {% endif %}
            </div>
        </div>

        {# ── Festplatte ────────────────────────────────────────────────────────── #}
        {% if disk_total > 0 %}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-hdd me-2"></i>Festplattenspeicher</div>
            <div class="card-body px-4 py-3">
            {% set used = disk_total - disk_free %}
            {% set pct  = (used / disk_total * 100)|round %}
            <div class="d-flex justify-content-between mb-3 fs-sm">
                <div><div class="text-muted">Belegt</div><div class="fw-500">{{ (used / 1073741824)|round(2) }} GB</div></div>
                <div class="text-center"><div class="text-muted">Frei</div><div class="fw-500 text-success">{{ (disk_free / 1073741824)|round(2) }} GB</div></div>
                <div class="text-end"><div class="text-muted">Gesamt</div><div class="fw-500">{{ (disk_total / 1073741824)|round(2) }} GB</div></div>
            </div>
            <div class="progress" style="height:10px;">
                <div class="progress-bar {% if pct > 85 %}bg-danger{% elseif pct > 65 %}bg-warning{% else %}bg-success{% endif %}" style="width:{{ pct }}%"></div>
            </div>
            <div class="text-muted fs-xs mt-1 text-end">{{ pct }}% belegt</div>
            </div>
        </div>
        {% endif %}

        {# ── PHP Extensions ──────────────────────────────────────────────────────── #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-puzzle me-2"></i>PHP-Extensions (Pflicht)</div>
            <div class="card-body px-4 py-3">
            <div class="d-flex flex-wrap gap-1 mb-2">
                {% for ext, ok in extensions %}
                <span class="badge {{ ok ? 'text-success' : 'text-danger' }} fs-xs fw-600" style="background:{{ ok ? 'rgba(16,185,129,.12)' : 'rgba(239,68,68,.12)' }};">
                    <i class="bi bi-{{ ok ? 'check-circle-fill' : 'x-circle-fill' }} me-1"></i>{{ ext }}
                </span>
                {% endfor %}
            </div>
            {% if not extensions|filter(v => not v)|length %}
            <div class="text-success fs-sm mt-2"><i class="bi bi-check-all me-1"></i>Alle erforderlichen Extensions vorhanden.</div>
            {% else %}
            <div class="text-danger fs-sm mt-2"><i class="bi bi-exclamation-triangle me-1"></i>Fehlende Extensions müssen installiert werden.</div>
            {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
