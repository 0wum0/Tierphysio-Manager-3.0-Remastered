{% extends 'layouts/base.twig' %}

{% block content %}
{# ── Stats row ── #}
<div class="row g-3 mb-3">
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body p-3">
                <div class="h3 fw-700 mb-0">{{ stats.total }}</div>
                <div class="text-muted fs-xs">Gesamt</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body p-3">
                <div class="h3 fw-700 mb-0" style="color:#a78bfa;">{{ stats.unread }}</div>
                <div class="text-muted fs-xs">Ungelesen</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body p-3">
                <div class="h3 fw-700 mb-0 text-danger">{{ stats.bug }}</div>
                <div class="text-muted fs-xs">🐛 Bugs</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body p-3">
                <div class="h3 fw-700 mb-0 text-success">{{ stats.praise }}</div>
                <div class="text-muted fs-xs">⭐ Lob</div>
            </div>
        </div>
    </div>
</div>

{# ── Filter bar ── #}
<div class="card mb-3">
    <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap py-2 px-3">
        <div class="d-flex gap-2 flex-wrap">
            <a href="/admin/feedback" class="btn btn-sm {% if filter == 'all' %}btn-primary{% else %}btn-outline-secondary{% endif %}">Alle</a>
            <a href="/admin/feedback?filter=unread" class="btn btn-sm {% if filter == 'unread' %}btn-primary{% else %}btn-outline-secondary{% endif %}">
                Ungelesen {% if stats.unread > 0 %}<span class="badge ms-1 bg-primary fs-nano">{{ stats.unread }}</span>{% endif %}
            </a>
            <a href="/admin/feedback?category=bug" class="btn btn-sm {% if category == 'bug' %}btn-danger{% else %}btn-outline-secondary{% endif %}">🐛 Bug</a>
            <a href="/admin/feedback?category=feature" class="btn btn-sm {% if category == 'feature' %}btn-primary{% else %}btn-outline-secondary{% endif %}">💡 Feature</a>
            <a href="/admin/feedback?category=praise" class="btn btn-sm {% if category == 'praise' %}btn-success{% else %}btn-outline-secondary{% endif %}">⭐ Lob</a>
            <a href="/admin/feedback?category=other" class="btn btn-sm {% if category == 'other' %}btn-secondary{% else %}btn-outline-secondary{% endif %}">💬 Sonstiges</a>
        </div>
        {% if stats.unread > 0 %}
        <form method="POST" action="/admin/feedback/mark-all-read" class="mb-0">
            {{ csrf_field()|raw }}
            <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-check2-all me-1"></i>Alle gelesen</button>
        </form>
        {% endif %}
    </div>
</div>

{# ── Table ── #}
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover table-sm mb-0">
            <thead>
                <tr>
                    <th class="px-3" style="width:30%">Von</th>
                    <th style="width:8%">Kat.</th>
                    <th style="width:8%">Bewertung</th>
                    <th>Nachricht</th>
                    <th style="width:10%">Plattform</th>
                    <th style="width:12%">Datum</th>
                    <th style="width:5%"></th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                <tr class="{% if not item.is_read %}table-active border-start border-3 border-primary{% endif %}">
                    <td class="px-4">
                        <div class="fw-600 fs-sm">{{ item.practice_name ?? item.tenant_name ?? 'Anonym' }}</div>
                        {% if item.email %}<div class="text-muted fs-xs">{{ item.email }}</div>{% endif %}
                    </td>
                    <td>
                        {% set catClass = {'bug':'cat-bug','feature':'cat-feature','praise':'cat-praise','other':'cat-other'} %}
                        {% set catIcon  = {'bug':'🐛','feature':'💡','praise':'⭐','other':'💬'} %}
                        <span class="cat-badge {{ catClass[item.category] ?? 'cat-other' }}">{{ catIcon[item.category] ?? '💬' }} {{ item.category }}</span>
                    </td>
                    <td>
                        {% if item.rating %}
                        <span class="text-warning fs-sm">{% for s in 1..item.rating %}★{% endfor %}<span class="text-muted">{% for s in 1..(5 - item.rating) %}★{% endfor %}</span></span>
                        {% else %}
                        <span class="text-muted">–</span>
                        {% endif %}
                    </td>
                    <td style="max-width:280px;">
                        <div class="text-muted fs-sm text-truncate">{{ item.message }}</div>
                    </td>
                    <td>
                        <span class="badge bg-secondary bg-opacity-50 fs-nano">{{ item.platform ?? 'web' }}</span>
                        {% if item.app_version %}<div class="text-muted fs-nano">v{{ item.app_version }}</div>{% endif %}
                    </td>
                    <td class="text-muted text-nowrap fs-sm">{{ item.created_at|date('d.m.Y') }}<br><span class="fs-xs">{{ item.created_at|date('H:i') }}</span></td>
                    <td>
                        <a href="/admin/feedback/{{ item.id }}" class="btn btn-sm btn-outline-secondary" title="Ansehen">
                            <svg class="sa-icon"><use href="/sa/icons/sprite.svg#eye"></use></svg>
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="7" class="text-center text-muted py-5">
                    <svg class="sa-icon sa-icon-3x mb-2 d-block mx-auto opacity-25"><use href="/sa/icons/sprite.svg#message-square"></use></svg>
                    Noch kein Feedback eingegangen.
                </td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if total_pages > 1 %}
    <div class="card-footer d-flex align-items-center justify-content-between py-2 px-4">
        <span class="text-muted fs-sm">{{ total }} Einträge gesamt</span>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                {% if page > 1 %}
                <li class="page-item"><a class="page-link" href="?page={{ page - 1 }}&filter={{ filter }}&category={{ category }}">‹</a></li>
                {% endif %}
                {% for p in 1..total_pages %}
                <li class="page-item {% if p == page %}active{% endif %}">
                    <a class="page-link" href="?page={{ p }}&filter={{ filter }}&category={{ category }}">{{ p }}</a>
                </li>
                {% endfor %}
                {% if page < total_pages %}
                <li class="page-item"><a class="page-link" href="?page={{ page + 1 }}&filter={{ filter }}&category={{ category }}">›</a></li>
                {% endif %}
            </ul>
        </nav>
    </div>
    {% endif %}
</div>
{% endblock %}
