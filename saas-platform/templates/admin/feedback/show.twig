{% extends 'layouts/base.twig' %}
{% set active_nav = 'feedback' %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a href="/admin/feedback" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Zurück</a>
            <h5 class="mb-0 fw-semibold">Feedback #{{ item.id }}</h5>
        </div>

        <div class="card mb-3">
            <div class="card-header py-3 px-4">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-2">
                        {% set catClass = {'bug':'cat-bug','feature':'cat-feature','praise':'cat-praise','other':'cat-other'} %}
                        {% set catIcon  = {'bug':'🐛','feature':'💡','praise':'⭐','other':'💬'} %}
                        <span class="badge {% if item.category == 'bug' %}bg-danger{% elseif item.category == 'feature' %}bg-primary{% elseif item.category == 'praise' %}bg-success{% else %}bg-secondary{% endif %}">
                            {{ catIcon[item.category] ?? '💬' }} {{ item.category|capitalize }}
                        </span>
                        {% if item.rating %}
                        <span style="color:#fde68a;">{{ '★'|repeat(item.rating) }}<span style="color:#334155;font-size:.85rem;">{{ '★'|repeat(5 - item.rating) }}</span></span>
                        {% endif %}
                    </div>
                    <span style="font-size:.78rem;color:#64748b;">{{ item.created_at|date('d.m.Y H:i') }}</span>
                </div>
            </div>
            <div class="card-body px-4 py-3">
                <div class="row g-3 mb-3" style="font-size:.83rem;">
                    <div class="col-sm-6">
                        <div style="color:#64748b;margin-bottom:.2rem;">Von</div>
                        <div style="color:#e2e8f0;font-weight:600;">{{ item.practice_name ?? item.tenant_name ?? 'Anonym' }}</div>
                        {% if item.tenant_email or item.email %}
                        <div style="color:#64748b;font-size:.75rem;">{{ item.tenant_email ?? item.email }}</div>
                        {% endif %}
                    </div>
                    <div class="col-sm-3">
                        <div style="color:#64748b;margin-bottom:.2rem;">Plattform</div>
                        <div style="color:#e2e8f0;">{{ item.platform ?? 'web' }}</div>
                    </div>
                    <div class="col-sm-3">
                        <div style="color:#64748b;margin-bottom:.2rem;">App Version</div>
                        <div style="color:#e2e8f0;">{{ item.app_version ?? '–' }}</div>
                    </div>
                </div>
                <hr style="border-color:#334155;">
                <div style="color:#94a3b8;line-height:1.7;white-space:pre-wrap;">{{ item.message }}</div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <form method="POST" action="/admin/feedback/{{ item.id }}/delete" onsubmit="return confirm('Feedback wirklich löschen?')">
                <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Löschen</button>
            </form>
        </div>
    </div>
</div>

<style>
.cat-badge{font-size:.65rem;padding:.15rem .45rem;border-radius:999px;font-weight:600;}
.cat-bug{background:rgba(239,68,68,.15);color:#fca5a5;}
.cat-feature{background:rgba(37,99,235,.15);color:#93c5fd;}
.cat-praise{background:rgba(16,185,129,.15);color:#6ee7b7;}
.cat-other{background:rgba(100,116,139,.15);color:#94a3b8;}
</style>
{% endblock %}
