{% extends 'layouts/base.twig' %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a href="/admin/feedback" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Zurück</a>
            <h5 class="mb-0 fw-semibold">Feedback #{{ item.id }}</h5>
        </div>

        <div class="card mb-3">
            <div class="card-header py-3 px-4">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-2">
                        {% set catClass = {'bug':'cat-bug','feature':'cat-feature','praise':'cat-praise','other':'cat-other'} %}
                        {% set catIcon  = {'bug':'🐛','feature':'💡','praise':'⭐','other':'💬'} %}
                        <span class="badge {% if item.category == 'bug' %}bg-danger{% elseif item.category == 'feature' %}bg-primary{% elseif item.category == 'praise' %}bg-success{% else %}bg-secondary{% endif %}">
                            {{ catIcon[item.category] ?? '💬' }} {{ item.category|capitalize }}
                        </span>
                        {% if item.rating %}
                        <span class="text-warning">{% for s in 1..item.rating %}★{% endfor %}<span class="text-muted">{% for s in 1..(5 - item.rating) %}★{% endfor %}</span></span>
                        {% endif %}
                    </div>
                    <span class="text-muted fs-sm">{{ item.created_at|date('d.m.Y H:i') }}</span>
                </div>
            </div>
            <div class="card-body px-4 py-3">
                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <div class="text-muted fs-xs mb-1">Von</div>
                        <div class="fw-600 fs-sm">{{ item.practice_name ?? item.tenant_name ?? 'Anonym' }}</div>
                        {% if item.tenant_email or item.email %}
                        <div class="text-muted fs-xs">{{ item.tenant_email ?? item.email }}</div>
                        {% endif %}
                    </div>
                    <div class="col-sm-3">
                        <div class="text-muted fs-xs mb-1">Plattform</div>
                        <div class="fs-sm">{{ item.platform ?? 'web' }}</div>
                    </div>
                    <div class="col-sm-3">
                        <div class="text-muted fs-xs mb-1">App Version</div>
                        <div class="fs-sm">{{ item.app_version ?? '–' }}</div>
                    </div>
                </div>
                <hr class="border-secondary">
                <div class="text-muted lh-lg" style="white-space:pre-wrap;">{{ item.message }}</div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <form method="POST" action="/admin/feedback/{{ item.id }}/delete" onsubmit="return confirm('Feedback wirklich löschen?')">
                <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Löschen</button>
            </form>
        </div>
    </div>
</div>

{% endblock %}
