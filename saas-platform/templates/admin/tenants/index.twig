{% extends 'layouts/base.twig' %}
{% set active_nav = 'tenants' %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <p class="text-secondary mb-0" style="font-size:.875rem;">{{ total }} Praxen insgesamt</p>
    </div>
    <div class="d-flex gap-2">
        <form method="GET" action="/admin/tenants" class="d-flex gap-2">
            <input type="text" name="q" value="{{ search }}" class="form-control form-control-sm" placeholder="Suche..." style="width:220px;">
            <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
            {% if search %}<a href="/admin/tenants" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x"></i></a>{% endif %}
        </form>
        <form method="POST" action="/admin/tenants/fix-storage" onsubmit="return confirm('Storage-Ordner für alle Praxen ohne Ordner anlegen?');">
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-sm btn-outline-warning" title="Fehlende Storage-Ordner für alle Mandanten anlegen">
                <i class="bi bi-folder-symlink me-1"></i>Storage reparieren
            </button>
        </form>
        <a href="/admin/tenants/create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Neue Praxis
        </a>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th class="px-4" style="width:40px;">#</th>
                    <th>Praxis</th>
                    <th>Therapeut / E-Mail</th>
                    <th>Plan</th>
                    <th>Status</th>
                    <th>Trial-Ende / Billing</th>
                    <th>Erstellt</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for tenant in tenants %}
                {% set statusMap = {
                    'active':             'badge-active',
                    'trial':              'badge-trial',
                    'trialing':           'badge-trial',
                    'pending':            'badge-pending',
                    'suspended':          'badge-suspended',
                    'cancelled':          'badge-cancelled',
                    'paused':             'badge-paused',
                    'past_due':           'bg-warning-lt text-warning',
                    'grace':              'bg-warning-lt text-warning',
                    'founders_discount':  'bg-success-lt text-success',
                } %}
                <tr>
                    <td class="px-4 text-secondary" style="font-size:.8rem;">{{ tenant.id }}</td>
                    <td>
                        <div class="fw-medium">
                            {{ tenant.practice_name }}
                            {% if tenant.is_founder %}
                            <span title="Early-Tester Founder ({{ tenant.grandfathered_price ?? '39'}}€/Monat)" style="display:inline-block;background:linear-gradient(135deg,#f59e0b,#d97706);color:#fff;border-radius:4px;font-size:.6rem;font-weight:700;padding:1px 5px;vertical-align:2px;letter-spacing:.03em;">★ FOUNDER</span>
                            {% endif %}
                        </div>
                        <div style="font-size:.75rem;color:#64748b;">{{ tenant.city }}{% if tenant.country %}, {{ tenant.country }}{% endif %}</div>
                    </td>
                    <td>
                        <div style="font-size:.875rem;">{{ tenant.owner_name }}</div>
                        <div style="font-size:.75rem;color:#64748b;">{{ tenant.email }}</div>
                    </td>
                    <td>
                        <span class="badge bg-secondary">{{ tenant.plan_name ?? '–' }}</span>
                        {% if tenant.grandfathered_price %}
                        <span class="badge bg-success-lt text-success fs-xxs" title="{{ tenant.grandfathered_reason }}">{{ tenant.grandfathered_price }}€</span>
                        {% endif %}
                    </td>
                    <td>
                        <span class="badge {{ statusMap[tenant.status] ?? 'bg-secondary' }}">{{ tenant.status }}</span>
                        {% if tenant.sub_status and tenant.sub_status != tenant.status %}
                        <span class="badge {{ statusMap[tenant.sub_status] ?? 'bg-secondary' }} fs-xxs">{{ tenant.sub_status }}</span>
                        {% endif %}
                    </td>
                    <td style="font-size:.75rem;">
                        {% if tenant.trial_ends_at %}
                            {% set trialEnd = tenant.trial_ends_at|date('U') %}
                            {% set now = 'now'|date('U') %}
                            {% if trialEnd < now %}
                            <span class="text-danger"><i class="bi bi-clock-history"></i> {{ tenant.trial_ends_at|date('d.m.Y') }}</span>
                            {% else %}
                            <span class="text-warning"><i class="bi bi-hourglass-split"></i> {{ tenant.trial_ends_at|date('d.m.Y') }}</span>
                            {% endif %}
                        {% elseif tenant.next_billing %}
                            <span class="text-muted"><i class="bi bi-calendar-check"></i> {{ tenant.next_billing|date('d.m.Y') }}</span>
                        {% else %}
                            <span class="text-muted">–</span>
                        {% endif %}
                        {% if tenant.last_login_at %}
                        <div class="text-muted" style="font-size:.7rem;" title="Letzter Login">↩ {{ tenant.last_login_at|date('d.m.Y') }}</div>
                        {% endif %}
                    </td>
                    <td class="text-secondary" style="font-size:.8rem;">{{ tenant.created_at|date('d.m.Y') }}</td>
                    <td>
                        <a href="/admin/tenants/{{ tenant.id }}" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="8" class="text-center text-secondary py-5">
                        <i class="bi bi-building d-block mb-2" style="font-size:2rem;"></i>
                        Noch keine Praxen vorhanden.
                        <a href="/admin/tenants/create" class="d-block mt-2">Erste Praxis erstellen</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pages > 1 %}
    <div class="card-footer d-flex justify-content-between align-items-center px-4 py-3">
        <span class="text-secondary" style="font-size:.8rem;">Seite {{ page }} von {{ pages }}</span>
        <div class="d-flex gap-1">
            {% if page > 1 %}
                <a href="/admin/tenants?page={{ page - 1 }}{% if search %}&q={{ search }}{% endif %}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-chevron-left"></i>
                </a>
            {% endif %}
            {% if page < pages %}
                <a href="/admin/tenants?page={{ page + 1 }}{% if search %}&q={{ search }}{% endif %}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-chevron-right"></i>
                </a>
            {% endif %}
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
