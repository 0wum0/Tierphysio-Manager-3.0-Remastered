{% extends 'layouts/base.twig' %}
{% set active_nav = 'tenants' %}

{% block content %}
{% set statusMap = {
    'active':    'badge-active',
    'trial':     'badge-trial',
    'pending':   'badge-pending',
    'suspended': 'badge-suspended',
    'cancelled': 'badge-cancelled',
    'paused':    'badge-paused'
} %}

<div class="d-flex align-items-center justify-content-between mb-4">
    <a href="/admin/tenants" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Zurück
    </a>
    <div class="d-flex gap-2">
        <a href="/admin/tenants/{{ tenant.id }}/edit" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-pencil me-1"></i>Bearbeiten
        </a>
        {% if tenant.status == 'pending' %}
        <form method="POST" action="/admin/tenants/{{ tenant.id }}/activate" class="d-inline">
            {{ csrf_field()|raw }}
            <button class="btn btn-sm btn-success"><i class="bi bi-check-circle me-1"></i>Aktivieren</button>
        </form>
        {% endif %}
        {% if tenant.status == 'active' or tenant.status == 'trial' or tenant.status == 'paused' %}
        <form method="POST" action="/admin/tenants/{{ tenant.id }}/suspend" class="d-inline" onsubmit="return confirm('Praxis wirklich sperren?')">
            {{ csrf_field()|raw }}
            <button class="btn btn-sm btn-warning"><i class="bi bi-pause-circle me-1"></i>Sperren</button>
        </form>
        {% endif %}
        {% if tenant.status == 'suspended' or tenant.status == 'paused' %}
        <form method="POST" action="/admin/tenants/{{ tenant.id }}/reactivate" class="d-inline">
            {{ csrf_field()|raw }}
            <button class="btn btn-sm btn-success"><i class="bi bi-play-circle me-1"></i>Reaktivieren</button>
        </form>
        {% endif %}
        {% if tenant.status != 'cancelled' %}
        <form method="POST" action="/admin/tenants/{{ tenant.id }}/cancel" class="d-inline" onsubmit="return confirm('Abo wirklich kündigen?')">
            {{ csrf_field()|raw }}
            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-x-circle me-1"></i>Kündigen</button>
        </form>
        {% endif %}
        {% if auth_role == 'superadmin' %}
        <form method="POST" action="/admin/tenants/{{ tenant.id }}/delete" class="d-inline" onsubmit="return confirm('Praxis ENDGÜLTIG löschen? Diese Aktion kann nicht rückgängig gemacht werden!')">
            {{ csrf_field()|raw }}
            <button class="btn btn-sm btn-danger"><i class="bi bi-trash me-1"></i>Löschen</button>
        </form>
        {% endif %}
    </div>
</div>

<div class="row g-3">
    {# Left column #}
    <div class="col-lg-8">
        {# Praxis-Info #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 d-flex align-items-center justify-content-between">
                <span class="fw-semibold">Praxis-Informationen</span>
                <span class="badge {{ statusMap[tenant.status] ?? 'bg-secondary' }}">{{ tenant.status }}</span>
            </div>
            <div class="card-body px-4 py-3">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="text-secondary" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">Praxisname</div>
                        <div class="fw-medium mt-1">{{ tenant.practice_name }}</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-secondary" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">Therapeut</div>
                        <div class="fw-medium mt-1">{{ tenant.owner_name }}</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-secondary" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">E-Mail</div>
                        <div class="mt-1"><a href="mailto:{{ tenant.email }}">{{ tenant.email }}</a></div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-secondary" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">Telefon</div>
                        <div class="mt-1">{{ tenant.phone ?: '–' }}</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-secondary" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">Adresse</div>
                        <div class="mt-1">
                            {% if tenant.address %}{{ tenant.address }}<br>{% endif %}
                            {% if tenant.zip or tenant.city %}{{ tenant.zip }} {{ tenant.city }}{% endif %}
                            {% if tenant.country %}<br><span class="badge bg-secondary">{{ tenant.country }}</span>{% endif %}
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-secondary" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">UUID</div>
                        <div class="mt-1 font-monospace" style="font-size:.75rem;color:#64748b;">{{ tenant.uuid }}</div>
                    </div>
                </div>
                {% if tenant.notes %}
                <hr style="border-color:#334155;">
                <div class="text-secondary" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">Notizen</div>
                <div class="mt-1" style="font-size:.875rem;">{{ tenant.notes }}</div>
                {% endif %}
            </div>
        </div>

        {# Subscription History #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3"><span class="fw-semibold">Abo-Verlauf</span></div>
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th class="px-4">Plan</th>
                            <th>Zyklus</th>
                            <th>Betrag</th>
                            <th>Status</th>
                            <th>Start</th>
                            <th>Ende</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for sub in all_subs %}
                        <tr>
                            <td class="px-4"><span class="badge bg-secondary">{{ sub.plan_name }}</span></td>
                            <td style="font-size:.8rem;">{{ sub.billing_cycle == 'monthly' ? 'Monatlich' : 'Jährlich' }}</td>
                            <td class="fw-medium">{{ sub.amount|number_format(2, ',', '.') }} {{ sub.currency }}</td>
                            <td>
                                {% set subStatus = {'active':'badge-active','cancelled':'badge-cancelled','past_due':'badge-pending','trialing':'badge-paused'} %}
                                <span class="badge {{ subStatus[sub.status] ?? 'bg-secondary' }}">{{ sub.status }}</span>
                            </td>
                            <td style="font-size:.8rem;">{{ sub.started_at|date('d.m.Y') }}</td>
                            <td style="font-size:.8rem;">{{ sub.ends_at ? sub.ends_at|date('d.m.Y') : '–' }}</td>
                        </tr>
                        {% else %}
                        <tr><td colspan="6" class="text-center text-secondary py-3 px-4">Kein Abo vorhanden.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# Right column #}
    <div class="col-lg-4">
        {# Current Plan #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3"><span class="fw-semibold">Aktueller Plan</span></div>
            <div class="card-body px-4">
                <div class="fw-bold fs-5 mb-1">{{ tenant.plan_name ?? '–' }}</div>
                <div class="text-secondary mb-2" style="font-size:.8rem;">{{ tenant.plan_slug ?? '' }}</div>
                {% if tenant.plan_features %}
                    {% set features = tenant.plan_features ? tenant.plan_features|json_decode : [] %}
                    <div class="d-flex flex-wrap gap-1 mt-2">
                        {% for f in features %}
                        <span class="badge bg-primary bg-opacity-25 text-primary" style="font-size:.7rem;">{{ f }}</span>
                        {% endfor %}
                    </div>
                {% endif %}
                <hr style="border-color:#334155;">
                <div class="text-secondary" style="font-size:.75rem;">Max. Benutzer</div>
                <div class="fw-medium">{{ tenant.max_users == -1 ? 'Unbegrenzt' : tenant.max_users }}</div>
            </div>
        </div>

        {# Infrastructure #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3"><span class="fw-semibold">Infrastruktur</span></div>
            <div class="card-body px-4">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary" style="font-size:.8rem;">Datenbank</span>
                    {% if tenant.db_created %}
                        <span class="text-success" style="font-size:.8rem;"><i class="bi bi-check-circle"></i> Erstellt</span>
                    {% else %}
                        <span class="text-warning" style="font-size:.8rem;"><i class="bi bi-clock"></i> Ausstehend</span>
                    {% endif %}
                </div>
                {% if tenant.db_name %}
                <div class="font-monospace text-secondary mb-3" style="font-size:.75rem;">{{ tenant.db_name }}</div>
                {% endif %}
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary" style="font-size:.8rem;">Admin-Benutzer</span>
                    {% if tenant.admin_created %}
                        <span class="text-success" style="font-size:.8rem;"><i class="bi bi-check-circle"></i> Erstellt</span>
                    {% else %}
                        <span class="text-warning" style="font-size:.8rem;"><i class="bi bi-clock"></i> Ausstehend</span>
                    {% endif %}
                </div>
                
                <hr style="border-color:#334155;">
                <form method="POST" action="/admin/tenants/{{ tenant.id }}/repair" onsubmit="return confirm('ACHTUNG: Dies erzwingt eine Neusynchronisation ALLER Datenbank-Tabellen für diese Praxis. Vorhandene Daten bleiben erhalten, aber die Struktur wird auf v48 aktualisiert. Fortfahren?')">
                    {{ csrf_field()|raw }}
                    <button type="submit" class="btn btn-sm btn-outline-warning w-100">
                        <i class="bi bi-tools me-1"></i>Tabellen reparieren
                    </button>
                </form>
            </div>
        </div>

        {# Lizenz & Nutzungsdauer #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3"><span class="fw-semibold">Lizenz & Nutzungsdauer</span></div>
            <div class="card-body px-4 py-3">
                {# Aktueller Trial-Status #}
                {% if tenant.trial_ends_at %}
                <div class="mb-3">
                    <div class="text-secondary mb-1" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;">Kostenlos bis</div>
                    {% if tenant.trial_ends_at starts with '2099' %}
                        <span class="badge" style="background:#7c3aed;font-size:.85rem;"><i class="bi bi-infinity me-1"></i>Lifetime-Lizenz</span>
                    {% else %}
                        <span class="fw-medium">{{ tenant.trial_ends_at|date('d.m.Y') }}</span>
                    {% endif %}
                </div>
                {% endif %}

                {# Lifetime vergeben #}
                <form method="POST" action="/admin/tenants/{{ tenant.id }}/set-trial" class="mb-3">
                    {{ csrf_field()|raw }}
                    <input type="hidden" name="trial_type" value="lifetime">
                    <button type="submit" class="btn btn-sm w-100" style="background:#7c3aed;color:#fff;border:none;">
                        <i class="bi bi-infinity me-1"></i>Lifetime-Lizenz vergeben
                    </button>
                </form>

                {# Custom Trial-Dauer #}
                <form method="POST" action="/admin/tenants/{{ tenant.id }}/set-trial">
                    {{ csrf_field()|raw }}
                    <input type="hidden" name="trial_type" value="days">
                    <div class="mb-2">
                        <label class="form-label" style="font-size:.75rem;color:#94a3b8;">Kostenlose Nutzung (Tage)</label>
                        <div class="input-group input-group-sm">
                            <input type="number" name="trial_days" class="form-control form-control-sm"
                                   style="background:#0f172a;border-color:#334155;color:#f1f5f9;"
                                   value="30" min="1" max="3650">
                            <button type="submit" class="btn btn-sm btn-outline-success">Vergeben</button>
                        </div>
                        <div class="mt-1" style="font-size:.7rem;color:#64748b;">z.B. 30 = 1 Monat, 365 = 1 Jahr</div>
                    </div>
                </form>
            </div>
        </div>

        {# Lizenz-Tokens #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 d-flex align-items-center justify-content-between">
                <span class="fw-semibold">Lizenz-Tokens</span>
                <form method="POST" action="/admin/tenants/{{ tenant.id }}/license">
                    {{ csrf_field()|raw }}
                    <button class="btn btn-xs btn-outline-primary" style="font-size:.75rem;padding:.2rem .6rem;">
                        <i class="bi bi-key me-1"></i>Neu ausstellen
                    </button>
                </form>
            </div>
            <div class="card-body px-4 py-3">
                {% if licenses %}
                {% for lic in licenses %}
                <div class="d-flex justify-content-between mb-1" style="font-size:.75rem;">
                    <span class="text-secondary">Ausgestellt {{ lic.issued_at|date('d.m.Y H:i') }}</span>
                    <span class="text-secondary">Läuft ab
                        {% if lic.expires_at starts with '2099' %}
                            <span style="color:#a78bfa;"><i class="bi bi-infinity"></i> Lifetime</span>
                        {% else %}
                            {{ lic.expires_at|date('d.m.Y') }}
                        {% endif %}
                    </span>
                </div>
                {% endfor %}
                {% else %}
                <div class="text-secondary" style="font-size:.8rem;">Keine aktiven Tokens.</div>
                {% endif %}
            </div>
        </div>

        {# Health Check #}
        {% if tenant.db_name %}
        <div class="card mb-3" id="health-card">
            <div class="card-header px-4 py-3 d-flex align-items-center justify-content-between">
                <span class="fw-semibold"><i class="bi bi-heart-pulse me-2 text-success"></i>System-Health</span>
                <button id="health-check-btn" class="btn btn-xs btn-outline-secondary" style="font-size:.75rem;padding:.2rem .6rem;">
                    <i class="bi bi-arrow-clockwise me-1"></i>Prüfen
                </button>
            </div>
            <div class="card-body px-4 py-3" id="health-body">
                <div style="font-size:.8rem;color:#64748b;text-align:center;padding:.5rem 0;">
                    <i class="bi bi-info-circle me-1"></i>Auf "Prüfen" klicken um Health-Status zu laden.
                </div>
            </div>
        </div>
        {% endif %}

        {# Feature Flags #}
        {% if tenant.db_name %}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 d-flex align-items-center justify-content-between">
                <span class="fw-semibold"><i class="bi bi-toggles me-2" style="color:#a78bfa;"></i>Feature-Flags</span>
                <a href="/admin/tenants/{{ tenant.id }}/activity" class="btn btn-xs btn-outline-secondary" style="font-size:.75rem;padding:.2rem .6rem;">
                    <i class="bi bi-clock-history me-1"></i>Aktivitätslog
                </a>
            </div>
            <div class="card-body px-4 py-2">
                {% if flags %}
                {% for feature, enabled in flags %}
                <div class="d-flex align-items-center justify-content-between py-2" style="border-bottom:1px solid #1e293b;">
                    <span style="font-size:.8rem;color:#cbd5e1;">{{ feature|replace({'_enabled': '', '_': ' '})|title }}</span>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input feature-toggle" type="checkbox"
                               data-tenant="{{ tenant.id }}"
                               data-feature="{{ feature }}"
                               {% if enabled %}checked{% endif %}
                               style="cursor:pointer;">
                    </div>
                </div>
                {% endfor %}
                {% else %}
                <div style="font-size:.8rem;color:#64748b;padding:.5rem 0;">Keine Feature-Flags verfügbar (DB noch nicht eingerichtet).</div>
                {% endif %}
            </div>
        </div>
        {% endif %}

        {# Meta #}
        <div class="card">
            <div class="card-body px-4 py-3" style="font-size:.8rem;color:#64748b;">
                <div class="d-flex justify-content-between mb-1">
                    <span>Erstellt</span><span>{{ tenant.created_at|date('d.m.Y H:i') }}</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Aktualisiert</span><span>{{ tenant.updated_at|date('d.m.Y H:i') }}</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    // ── Health Check ───────────────────────────────────────────────────────
    const btn    = document.getElementById('health-check-btn');
    const body   = document.getElementById('health-body');
    const tenantId = {{ tenant.id }};

    if (btn && body) {
        btn.addEventListener('click', async () => {
            btn.disabled = true;
            body.innerHTML = '<div style="text-align:center;padding:.75rem;font-size:.8rem;color:#64748b;"><span class="spinner-border spinner-border-sm me-2"></span>Prüfe…</div>';
            try {
                const res  = await fetch('/admin/tenants/' + tenantId + '/health-api', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                const data = await res.json();
                const statusColor = data.status === 'ok' ? '#6ee7b7' : (data.status === 'warning' ? '#fde68a' : '#fca5a5');
                const statusIcon  = data.status === 'ok' ? 'bi-check-circle-fill' : (data.status === 'warning' ? 'bi-exclamation-triangle-fill' : 'bi-x-circle-fill');
                let html = `<div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi ${statusIcon}" style="color:${statusColor};font-size:1.2rem;"></i>
                    <span class="fw-semibold" style="color:${statusColor};text-transform:uppercase;font-size:.75rem;">${data.status}</span>
                </div>`;
                // Individual checks
                if (data.checks) {
                    for (const [key, chk] of Object.entries(data.checks)) {
                        const ok   = chk.ok;
                        const icon = ok ? 'bi-check-circle text-success' : 'bi-x-circle text-danger';
                        const label = key.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase());
                        html += `<div class="d-flex justify-content-between align-items-center mb-1" style="font-size:.78rem;">
                            <span style="color:#94a3b8;">${label}</span>
                            <span><i class="bi ${icon}"></i></span>
                        </div>`;
                    }
                }
                // Issues list
                if (data.issues && data.issues.length > 0) {
                    html += '<hr style="border-color:#1e293b;margin:.5rem 0;">';
                    html += '<div style="font-size:.75rem;color:#f87171;">';
                    data.issues.forEach(i => { html += `<div><i class="bi bi-dot me-1"></i>${i}</div>`; });
                    html += '</div>';
                }
                body.innerHTML = html;
            } catch (e) {
                body.innerHTML = '<div style="font-size:.8rem;color:#f87171;">Fehler beim Laden des Health-Status.</div>';
            } finally {
                btn.disabled = false;
            }
        });
    }

    // ── Feature Flag Toggles ───────────────────────────────────────────────
    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content
                   || '{{ csrf_token() }}';

    document.querySelectorAll('.feature-toggle').forEach(toggle => {
        toggle.addEventListener('change', async function() {
            const feature = this.dataset.feature;
            const enabled = this.checked ? '1' : '0';
            const tid     = this.dataset.tenant;
            this.disabled = true;
            try {
                const body = new URLSearchParams({ feature, enabled, _csrf: csrfToken });
                await fetch('/admin/tenants/' + tid + '/features', {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: body.toString(),
                });
            } catch (e) {
                this.checked = !this.checked; // revert on error
            } finally {
                this.disabled = false;
            }
        });
    });
})();
</script>
{% endblock %}
