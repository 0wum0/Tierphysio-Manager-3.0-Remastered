{% extends 'layouts/base.twig' %}
{% set active_nav = 'revenue' %}

{% block styles %}
<style>
.kpi-card        { background:#1e293b; border:1px solid #334155; border-radius:.75rem; padding:1.25rem 1.5rem; height:100%; }
.kpi-label       { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#64748b; margin-bottom:.35rem; }
.kpi-value       { font-size:1.75rem; font-weight:800; letter-spacing:-.03em; color:#e2e8f0; line-height:1.1; }
.kpi-sub         { font-size:.75rem; color:#475569; margin-top:.35rem; }
.kpi-badge       { display:inline-block; font-size:.65rem; font-weight:700; padding:.15rem .5rem; border-radius:.25rem; margin-bottom:.4rem; }
.badge-paid      { background:rgba(52,211,153,.12); color:#34d399; border:1px solid rgba(52,211,153,.25); }
.badge-projected { background:rgba(96,165,250,.1);  color:#60a5fa; border:1px solid rgba(96,165,250,.2); }
.chart-card      { background:#1e293b; border:1px solid #334155; border-radius:.75rem; padding:1.25rem; }
.chart-title     { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#64748b; margin-bottom:1rem; }
.plan-bar        { height:8px; border-radius:4px; background:#334155; overflow:hidden; margin-top:.3rem; }
.plan-fill       { height:100%; border-radius:4px; }
.inv-row td      { font-size:.8rem; vertical-align:middle; }
.divider-label   { font-size:.65rem; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:#475569;
                   padding:.4rem 0; border-top:1px solid #334155; margin-top:.5rem; margin-bottom:.75rem; }
</style>
{% endblock %}

{% block content %}

{# ── Header ─────────────────────────────────────────────────────────────── #}
<div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
    <div>
        <h4 class="mb-0 fw-bold" style="color:#e2e8f0;">Umsatz-Übersicht</h4>
        <small style="color:#475569;">Nur tatsächlich eingegangene Zahlungen werden als Umsatz gezählt.</small>
    </div>
    <div class="ms-auto">
        <button class="btn btn-sm btn-outline-secondary" onclick="refreshKPIs()">
            <i class="bi bi-arrow-clockwise me-1"></i>Aktualisieren
        </button>
    </div>
</div>

{# ══════════════════════════════════════════════════════════════════════════ #}
{# SEKTION 1 – TATSÄCHLICHER UMSATZ (nur bezahlte Rechnungen)               #}
{# ══════════════════════════════════════════════════════════════════════════ #}
<div class="divider-label"><i class="bi bi-check-circle-fill me-1" style="color:#34d399;"></i>Tatsächlicher Umsatz – nur bezahlte Rechnungen</div>
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="kpi-card">
            <div class="kpi-badge badge-paid">Bezahlt</div>
            <div class="kpi-label">Umsatz diesen Monat</div>
            <div class="kpi-value" id="kpi-month" style="color:#34d399;">
                {{ month_rev|number_format(2, ',', '.') }} €
            </div>
            <div class="kpi-sub">Eingegangene Zahlungen im {{ "now"|date('F Y') }}</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="kpi-card">
            <div class="kpi-badge badge-paid">Bezahlt</div>
            <div class="kpi-label">Zahlende Kunden</div>
            <div class="kpi-value" id="kpi-active" style="color:#e2e8f0;">{{ active }}</div>
            <div class="kpi-sub">Aktive Abonnements · {{ churned }} Kündigungen diesen Monat</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="kpi-card">
            <div class="kpi-badge badge-paid">Bezahlt</div>
            <div class="kpi-label">Ø pro Kunde / Monat</div>
            <div class="kpi-value" id="kpi-arpu">{{ arpu|number_format(2, ',', '.') }} €</div>
            <div class="kpi-sub">Durchschnittlicher Betrag je zahlendem Kunden</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="kpi-card">
            <div class="kpi-badge" style="background:rgba(100,116,139,.12);color:#94a3b8;border:1px solid rgba(100,116,139,.2);">Analyse</div>
            <div class="kpi-label">Trial-zu-Kunde Quote</div>
            <div class="kpi-value" id="kpi-conv"
                 style="color:{% if conversion >= 20 %}#34d399{% elseif conversion >= 10 %}#fbbf24{% else %}#f87171{% endif %};">
                {{ conversion }} %
            </div>
            <div class="kpi-sub">{{ trials }} Testkonten aktiv · Berechnung: 90 Tage</div>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════════════════════════════════ #}
{# SEKTION 2 – MÖGLICHER UMSATZ (Prognose, noch nicht bezahlt)              #}
{# ══════════════════════════════════════════════════════════════════════════ #}
<div class="divider-label"><i class="bi bi-graph-up-arrow me-1" style="color:#60a5fa;"></i>Möglicher Umsatz – Prognose bei gleichbleibenden Abonnements</div>
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <div class="kpi-card" style="border-color:rgba(96,165,250,.25);">
            <div class="kpi-badge badge-projected">Prognose</div>
            <div class="kpi-label">Möglicher Monatsumsatz</div>
            <div class="kpi-value" id="kpi-mrr" style="color:#60a5fa;">
                {{ mrr|number_format(2, ',', '.') }} €
            </div>
            <div class="kpi-sub">Wenn alle {{ active }} aktiven Abos diesen Monat zahlen</div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="kpi-card" style="border-color:rgba(96,165,250,.25);">
            <div class="kpi-badge badge-projected">Prognose</div>
            <div class="kpi-label">Möglicher Jahresumsatz</div>
            <div class="kpi-value" id="kpi-arr" style="color:#60a5fa;">
                {{ arr|number_format(2, ',', '.') }} €
            </div>
            <div class="kpi-sub">Hochrechnung: Monatlicher Betrag × 12</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kpi-card" style="border-color:rgba(96,165,250,.15);background:rgba(96,165,250,.03);">
            <div class="kpi-label" style="color:#475569;">Hinweis</div>
            <p style="font-size:.8rem;color:#64748b;margin:0;line-height:1.6;">
                Die Prognosewerte basieren auf aktiven Abonnements und zeigen den <strong style="color:#94a3b8;">maximal möglichen Umsatz</strong>.
                Sie sind erst Umsatz, wenn die Zahlung tatsächlich eingegangen ist.
            </p>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════════════════════════════════ #}
{# SEKTION 3 – CHARTS & DETAILS                                              #}
{# ══════════════════════════════════════════════════════════════════════════ #}
<div class="divider-label"><i class="bi bi-bar-chart-line me-1"></i>Verlauf & Aufschlüsselung</div>
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="chart-card">
            <div class="chart-title"><i class="bi bi-bar-chart-line me-1"></i>Neukunden & Abgänge pro Monat (12 Monate)</div>
            <canvas id="tenantsChart" height="90"></canvas>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="chart-card h-100">
            <div class="chart-title"><i class="bi bi-pie-chart me-1"></i>Prognose nach Tarif</div>
            {% set totalMrr = mrr > 0 ? mrr : 1 %}
            {% for plan in by_plan %}
            {% set pct = (plan.mrr / totalMrr * 100)|round %}
            <div class="mb-3">
                <div class="d-flex justify-content-between" style="font-size:.8rem;">
                    <span style="color:#e2e8f0;font-weight:600;">{{ plan.plan_name }}</span>
                    <span style="color:#94a3b8;">{{ plan.sub_count }}×</span>
                </div>
                <div class="plan-bar">
                    <div class="plan-fill" style="width:{{ pct }}%;background:{% if loop.index == 1 %}#2563eb{% elseif loop.index == 2 %}#7c3aed{% elseif loop.index == 3 %}#059669{% else %}#d97706{% endif %};"></div>
                </div>
                <div style="font-size:.7rem;color:#475569;margin-top:.15rem;">
                    {{ plan.mrr|number_format(2, ',', '.') }} €/Mo möglich ({{ pct }}%)
                </div>
            </div>
            {% else %}
            <p style="color:#475569;font-size:.8rem;">Noch keine aktiven Abonnements.</p>
            {% endfor %}
        </div>
    </div>
</div>

{# ── Letzte bezahlte Rechnungen ──────────────────────────────────────────── #}
<div class="chart-card">
    <div class="chart-title"><i class="bi bi-receipt-cutoff me-1"></i>Zuletzt eingegangene Zahlungen (30 Tage)</div>
    {% if recent_paid %}
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th style="font-size:.7rem;color:#475569;font-weight:600;">Datum</th>
                    <th style="font-size:.7rem;color:#475569;font-weight:600;">Praxis</th>
                    <th style="font-size:.7rem;color:#475569;font-weight:600;">Betrag</th>
                    <th style="font-size:.7rem;color:#475569;font-weight:600;">Status</th>
                </tr>
            </thead>
            <tbody>
                {% for inv in recent_paid %}
                <tr class="inv-row">
                    <td style="color:#64748b;white-space:nowrap;">{{ inv.paid_at|date('d.m.Y') }}</td>
                    <td>
                        <a href="/admin/tenants/{{ inv.tenant_id }}" style="color:#60a5fa;text-decoration:none;">
                            {{ inv.practice_name }}
                        </a>
                    </td>
                    <td style="font-weight:700;color:#34d399;">{{ inv.total_amount|number_format(2, ',', '.') }} €</td>
                    <td>
                        <span class="kpi-badge badge-paid">Bezahlt</span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p style="color:#475569;font-size:.85rem;margin:.5rem 0 0;">
        <i class="bi bi-info-circle me-1"></i>Keine bezahlten Rechnungen in den letzten 30 Tagen.
        Zahlungen erscheinen hier sobald sie als <em>bezahlt</em> markiert sind.
    </p>
    {% endif %}
</div>

{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
(function() {
    'use strict';

    Chart.defaults.color = '#64748b';
    Chart.defaults.borderColor = '#334155';

    const ntLabels  = {{ new_tenants|map(r => r.month)|json_encode|raw }};
    const ntValues  = {{ new_tenants|map(r => r.count)|json_encode|raw }};
    const churnVals = {{ churn_data|map(r => r.count)|json_encode|raw }};

    new Chart(document.getElementById('tenantsChart'), {
        type: 'bar',
        data: {
            labels: ntLabels,
            datasets: [
                {
                    label: 'Neukunden',
                    data: ntValues,
                    backgroundColor: 'rgba(37,99,235,.75)',
                    borderRadius: 4,
                },
                {
                    label: 'Abgänge',
                    data: churnVals,
                    backgroundColor: 'rgba(248,113,113,.6)',
                    borderRadius: 4,
                }
            ]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 11 }, color: '#64748b' } }
            },
            scales: {
                x: { grid: { display: false } },
                y: { grid: { color: '#334155' }, ticks: { stepSize: 1 } }
            }
        }
    });

    window.refreshKPIs = async function() {
        try {
            const res = await fetch('/admin/revenue/api', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            if (!res.ok) return;
            const d   = await res.json();
            const fmt = v => Number(v).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            document.getElementById('kpi-mrr').textContent    = fmt(d.mrr)    + ' €';
            document.getElementById('kpi-arr').textContent    = fmt(d.arr)    + ' €';
            document.getElementById('kpi-active').textContent = d.active;
            document.getElementById('kpi-conv').textContent   = d.conversion  + ' %';
        } catch {}
    };
})();
</script>
{% endblock %}
