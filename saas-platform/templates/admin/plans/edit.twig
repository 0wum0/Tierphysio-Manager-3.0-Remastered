{% extends 'layouts/base.twig' %}
{% set active_nav = 'plans' %}

{% block content %}
<div class="d-flex align-items-center mb-4">
    <a href="/admin/plans" class="btn btn-sm btn-outline-secondary me-3">
        <i class="bi bi-arrow-left me-1"></i>Zurück
    </a>
</div>

<div class="row justify-content-center">
<div class="col-lg-7">
<div class="card">
    <div class="card-header px-4 py-3">
        <span class="fw-semibold"><i class="bi bi-collection me-2"></i>Plan bearbeiten: {{ plan.name }}</span>
    </div>
    <div class="card-body px-4 py-4">
        <form method="POST" action="/admin/plans/{{ plan.id }}/edit">
            {{ csrf_field()|raw }}

            <div class="row g-3 mb-4">
                <div class="col-sm-6">
                    <label class="form-label">Name *</label>
                    <input type="text" name="name" class="form-control" required value="{{ plan.name }}">
                </div>
                <div class="col-sm-6">
                    <label class="form-label">Slug</label>
                    <input type="text" class="form-control" value="{{ plan.slug }}" disabled>
                </div>
                <div class="col-12">
                    <label class="form-label">Beschreibung</label>
                    <textarea name="description" class="form-control" rows="2">{{ plan.description }}</textarea>
                </div>
                <div class="col-sm-4">
                    <label class="form-label">Preis / Monat (€)</label>
                    <input type="number" name="price_month" class="form-control" step="0.01" value="{{ plan.price_month }}">
                </div>
                <div class="col-sm-4">
                    <label class="form-label">Preis / Jahr (€)</label>
                    <input type="number" name="price_year" class="form-control" step="0.01" value="{{ plan.price_year }}">
                </div>
                <div class="col-sm-4">
                    <label class="form-label">Max. Benutzer (-1 = unbegrenzt)</label>
                    <input type="number" name="max_users" class="form-control" value="{{ plan.max_users }}">
                </div>
                <div class="col-sm-4">
                    <label class="form-label">Testzeitraum (Tage)</label>
                    <input type="number" name="trial_days" class="form-control" value="{{ plan.trial_days }}">
                </div>
                <div class="col-sm-6">
                    <label class="form-label" style="font-size:.75rem;color:#94a3b8;">Stripe Price ID (monatlich)</label>
                    <input type="text" name="stripe_price_id" class="form-control"
                           placeholder="price_1ABC…" value="{{ plan.stripe_price_id ?? '' }}">
                </div>
                <div class="col-sm-6">
                    <label class="form-label" style="font-size:.75rem;color:#94a3b8;">Stripe Price ID (jährlich)</label>
                    <input type="text" name="stripe_price_id_yearly" class="form-control"
                           placeholder="price_1DEF…" value="{{ plan.stripe_price_id_yearly ?? '' }}">
                </div>
                <div class="col-sm-6">
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" name="is_public" value="1" id="is_public"
                               {{ plan.is_public ? 'checked' : '' }}>
                        <label class="form-check-label" for="is_public">Öffentlich (im Registrierungsdialog)</label>
                    </div>
                </div>
            </div>

            <hr style="border-color:#334155;">
            <h6 class="text-secondary mb-3 mt-3" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;">Features (freigeschaltete Module)</h6>
            <div class="mb-3">
                <label class="form-label">Features</label>
                <div class="row g-2">
                    {% set allFeatures = {
                        'invoices':        'Rechnungen',
                        'appointments':    'Termine',
                        'patients':        'Patienten',
                        'owners':          'Besitzer',
                        'dashboard':       'Dashboard',
                        'waitlist':        'Warteliste',
                        'intake':          'Patientenanmeldung',
                        'staff':           'Mitarbeiterverwaltung',
                        'reports':         'Berichte',
                        'calendar':        'Kalender',
                        'google_sync':     'Google Sync',
                        'therapy_care':    'Therapie-Dokumentation',
                        'messaging':       'Nachrichten',
                        'file_uploads':    'Datei-Uploads',
                        'advanced_reports':'Erweiterte Berichte',
                        'owner_portal':    'Besitzer-Portal',
                        'reminders':       'Erinnerungen',
                        'premium_support': 'Premium Support',
                        'ai_features':     'KI-Features',
                        'premium':         'Premium'
                    } %}
                    {% for key, label in allFeatures %}
                    <div class="col-sm-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="features[]"
                                   value="{{ key }}" id="feat_{{ key }}"
                                   {% if key in features %}checked{% endif %}>
                            <label class="form-check-label" for="feat_{{ key }}" style="font-size:.85rem;">{{ label }}</label>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <hr style="border-color:#334155;">
            <div class="mb-4 mt-3">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" name="is_active" value="1" id="is_active"
                        {{ plan.is_active ? 'checked' : '' }}>
                    <label class="form-check-label" for="is_active">Plan aktiv (für Registrierung sichtbar)</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Speichern
                </button>
                <a href="/admin/plans" class="btn btn-outline-secondary">Abbrechen</a>
            </div>
        </form>
    </div>
</div>
</div>
</div>
{% endblock %}
