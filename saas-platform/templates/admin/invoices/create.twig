{% extends 'layouts/base.twig' %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-4">
    <a href="/admin/invoices" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Zurück</a>
</div>

<form method="POST" action="/admin/invoices" id="invoiceForm">
    {{ csrf_field()|raw }}

    <div class="row g-4">

        {# ── Linke Spalte ────────────────────────────────────────────── #}
        <div class="col-lg-8">

            {# Kundenauswahl #}
            <div class="card mb-3">
                <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-person-circle me-1"></i>Kunde</div>
                <div class="card-body px-4 py-3">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Kunde / Praxis <span class="text-danger">*</span></label>
                        <select name="tenant_id" class="form-select" required id="tenantSelect">
                            <option value="">— Kunden auswählen —</option>
                            {% for tenant in tenants %}
                            <option value="{{ tenant.id }}" {% if preselected == tenant.id %}selected{% endif %}>
                                {{ tenant.practice_name ?? tenant.owner_name }} ({{ tenant.email }})
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                </div>
            </div>

            {# Positionen #}
            <div class="card mb-3">
                <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-list-ul me-1"></i>Rechnungspositionen</div>
                <div class="card-body px-4 py-3">
                <div class="table-responsive">
                    <table class="table mb-3" id="positionsTable">
                        <thead>
                            <tr>
                                <th style="width:40%">Beschreibung</th>
                                <th style="width:12%">Menge</th>
                                <th style="width:17%">Einzelpreis (€)</th>
                                <th style="width:13%">MwSt. (%)</th>
                                <th style="width:14%" class="text-end">Gesamt</th>
                                <th style="width:4%"></th>
                            </tr>
                        </thead>
                        <tbody id="positionsBody">
                            <tr class="pos-row">
                                <td><input type="text" name="position_description[]" class="form-control form-control-sm" placeholder="Leistungsbeschreibung…" required></td>
                                <td><input type="number" name="position_quantity[]" class="form-control form-control-sm pos-qty" value="1" min="0.01" step="0.01"></td>
                                <td><input type="number" name="position_price[]" class="form-control form-control-sm pos-price" value="0.00" min="0" step="0.01"></td>
                                <td>
                                    <select name="position_tax_rate[]" class="form-select form-select-sm pos-tax">
                                        <option value="0">0 % (stfr.)</option>
                                        <option value="7">7 %</option>
                                        <option value="19" selected>19 %</option>
                                    </select>
                                </td>
                                <td class="text-end pos-total text-nowrap fw-600">0,00 €</td>
                                <td><button type="button" class="btn btn-sm btn-outline-danger py-0 px-1 remove-pos" tabindex="-1"><i class="bi bi-trash3"></i></button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <button type="button" class="btn btn-sm btn-outline-primary" id="addPosition">
                    <i class="bi bi-plus-lg me-1"></i>Position hinzufügen
                </button>
                </div>
            </div>

            {# Notizen #}
            <div class="card mb-3">
                <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-chat-text me-1"></i>Hinweise &amp; Zahlungsbedingungen</div>
                <div class="card-body px-4 py-3">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Hinweis (erscheint auf der Rechnung)</label>
                        <textarea name="notes" class="form-control" rows="2" placeholder="z.B. Vielen Dank für Ihr Vertrauen…"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Zahlungsbedingungen</label>
                        <input type="text" name="payment_terms" class="form-control" placeholder="z.B. Zahlbar innerhalb 14 Tagen ohne Abzug">
                    </div>
                </div>
                </div>
            </div>
        </div>

        {# ── Rechte Spalte ───────────────────────────────────────────── #}
        <div class="col-lg-4">

            {# Rechnungsdetails #}
            <div class="card mb-3">
                <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-info-circle me-1"></i>Rechnungsdetails</div>
                <div class="card-body px-4 py-3">
                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label">Rechnungsnummer</label>
                        <input type="text" name="invoice_number" class="form-control" value="{{ next_number }}" required>
                    </div>
                    <div>
                        <label class="form-label">Status</label>
                        <select name="status" class="form-select">
                            <option value="draft">Entwurf</option>
                            <option value="open" selected>Offen</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Zahlungsart</label>
                        <select name="payment_method" class="form-select" id="paymentMethod">
                            <option value="rechnung" selected>Rechnung</option>
                            <option value="ueberweisung">Überweisung</option>
                            <option value="lastschrift">Lastschrift</option>
                            <option value="bar">Barzahlung (Quittung)</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Rechnungsdatum</label>
                        <input type="date" name="issue_date" class="form-control" value="{{ issue_date }}">
                    </div>
                    <div id="dueDateField">
                        <label class="form-label">Fälligkeitsdatum</label>
                        <input type="date" name="due_date" class="form-control" value="{{ due_date }}">
                    </div>
                </div>
                </div>
            </div>

            {# Summen #}
            <div class="card mb-3">
                <div class="card-body px-4 py-3">
                    <div class="d-flex justify-content-between border-bottom py-2 fs-sm"><span class="text-muted">Nettobetrag</span><span id="sumNet">0,00 €</span></div>
                    <div class="d-flex justify-content-between border-bottom py-2 fs-sm"><span class="text-muted">Mehrwertsteuer</span><span id="sumTax">0,00 €</span></div>
                    <div class="d-flex justify-content-between pt-3 fw-700 fs-md"><span>Gesamtbetrag</span><span id="sumGross" class="text-success">0,00 €</span></div>
                </div>
            </div>

            {# Aktionen #}
            <div class="card">
                <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-send me-1"></i>Aktionen</div>
                <div class="card-body px-4 py-3">
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" name="_send_email" value="1" id="sendEmailCheck">
                    <label class="form-check-label text-muted fs-sm" for="sendEmailCheck">
                        Rechnung direkt per E-Mail senden
                    </label>
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Rechnung erstellen
                    </button>
                    <a href="/admin/invoices" class="btn btn-outline-secondary">Abbrechen</a>
                </div>
                </div>
            </div>
        </div>
    </div>
</form>
{% endblock %}

{% block scripts %}
<script>
const fmt = v => new Intl.NumberFormat('de-DE',{minimumFractionDigits:2,maximumFractionDigits:2}).format(v) + ' €';

function calcRow(row) {
    const qty   = parseFloat(row.querySelector('.pos-qty').value.replace(',','.'))   || 0;
    const price = parseFloat(row.querySelector('.pos-price').value.replace(',','.')) || 0;
    const tax   = parseFloat(row.querySelector('.pos-tax').value)                    || 0;
    const gross = qty * price * (1 + tax / 100);
    row.querySelector('.pos-total').textContent = fmt(gross);
    return { net: qty * price, tax: qty * price * tax / 100, gross };
}

function recalcAll() {
    let net = 0, tax = 0, gross = 0;
    document.querySelectorAll('#positionsBody .pos-row').forEach(row => {
        const t = calcRow(row);
        net   += t.net;
        tax   += t.tax;
        gross += t.gross;
    });
    document.getElementById('sumNet').textContent   = fmt(net);
    document.getElementById('sumTax').textContent   = fmt(tax);
    document.getElementById('sumGross').textContent = fmt(gross);
}

document.getElementById('positionsBody').addEventListener('input', recalcAll);

document.getElementById('addPosition').addEventListener('click', () => {
    const tmpl = document.querySelector('#positionsBody .pos-row').cloneNode(true);
    tmpl.querySelectorAll('input').forEach(i => { if (i.type !== 'number' || i.classList.contains('pos-qty')) {} else { i.value = '0.00'; } });
    tmpl.querySelectorAll('input[type="text"]').forEach(i => i.value = '');
    tmpl.querySelector('.pos-qty').value   = '1';
    tmpl.querySelector('.pos-price').value = '0.00';
    tmpl.querySelector('.pos-total').textContent = '0,00 €';
    document.getElementById('positionsBody').appendChild(tmpl);
    tmpl.querySelector('input[type="text"]').focus();
});

document.getElementById('positionsBody').addEventListener('click', e => {
    const btn = e.target.closest('.remove-pos');
    if (!btn) return;
    const rows = document.querySelectorAll('#positionsBody .pos-row');
    if (rows.length <= 1) return;
    btn.closest('.pos-row').remove();
    recalcAll();
});

// Zahlungsart: Barzahlung → Fälligkeitsdatum ausblenden
document.getElementById('paymentMethod').addEventListener('change', function() {
    document.getElementById('dueDateField').style.display = this.value === 'bar' ? 'none' : '';
});

recalcAll();
</script>
{% endblock %}
