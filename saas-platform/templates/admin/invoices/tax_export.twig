{% extends 'layouts/base.twig' %}

{% block content %}

{# ── Filter ────────────────────────────────────────────────────────── #}
<div class="d-flex align-items-center justify-content-between mb-4">
    <a href="/admin/invoices" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Zurück</a>
</div>

<div class="card mb-3">
    <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;"><i class="bi bi-funnel me-1"></i>Zeitraum auswählen</div>
    <div class="card-body px-4 py-3">
    <form method="GET" action="/admin/invoices/tax-export" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Von</label>
            <input type="date" name="date_from" class="form-control" value="{{ date_from }}">
        </div>
        <div class="col-md-3">
            <label class="form-label">Bis</label>
            <input type="date" name="date_to" class="form-control" value="{{ date_to }}">
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-arrow-clockwise me-1"></i>Anzeigen
            </button>
            <a href="/admin/invoices/tax-export?date_from={{ date_from }}&date_to={{ date_to }}&format=csv"
               class="btn btn-success">
                <i class="bi bi-file-earmark-spreadsheet me-1"></i>CSV herunterladen
            </a>
        </div>
        <div class="col-md-3 d-flex gap-2">
            {# Schnellauswahl-Buttons #}
            <a href="/admin/invoices/tax-export?date_from={{ 'now'|date('Y') }}-01-01&date_to={{ 'now'|date('Y-m-d') }}" class="btn btn-sm btn-outline-secondary">Dieses Jahr</a>
            <a href="/admin/invoices/tax-export?date_from={{ 'now'|date('Y') }}-{{ 'now'|date('m') }}-01&date_to={{ 'now'|date('Y-m-d') }}" class="btn btn-sm btn-outline-secondary">Dieser Monat</a>
        </div>
    </form>
    </div>
</div>

{# ── Steuer-Zusammenfassung ────────────────────────────────────────── #}
{% if summary %}
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card mb-3">
            <div class="card-header px-4 py-3">
                <span class="fw-600 fs-sm">
                    <i class="bi bi-calculator me-1"></i>Steuer-Zusammenfassung für {{ date_from|date('d.m.Y') }} – {{ date_to|date('d.m.Y') }}
                </span>
            </div>
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Steuersatz</th>
                            <th class="text-end">Anzahl Rechnungen</th>
                            <th class="text-end">Nettobetrag</th>
                            <th class="text-end">Steuerbetrag</th>
                            <th class="text-end">Bruttobetrag</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in summary %}
                        <tr>
                            <td><strong>{{ row.tax_rate|number_format(0,',','.') }} %</strong></td>
                            <td class="text-end">{{ row.invoice_count }}</td>
                            <td class="text-end">{{ row.total_net|number_format(2,',','.') }} €</td>
                            <td class="text-end text-warning">{{ row.total_tax|number_format(2,',','.') }} €</td>
                            <td class="text-end"><strong>{{ row.total_gross|number_format(2,',','.') }} €</strong></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr class="fw-700 border-top">
                            <th>Gesamt</th>
                            <th class="text-end">{{ summary|map(r => r.invoice_count)|reduce((carry, v) => carry + v, 0) }}</th>
                            <th class="text-end">{{ summary|map(r => r.total_net)|reduce((carry, v) => carry + v, 0)|number_format(2,',','.') }} €</th>
                            <th class="text-end text-warning">{{ summary|map(r => r.total_tax)|reduce((carry, v) => carry + v, 0)|number_format(2,',','.') }} €</th>
                            <th class="text-end text-success">{{ summary|map(r => r.total_gross)|reduce((carry, v) => carry + v, 0)|number_format(2,',','.') }} €</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
{% endif %}

{# ── Einzelne Rechnungen ───────────────────────────────────────────── #}
<div class="card">
    <div class="card-header px-4 py-3 d-flex justify-content-between align-items-center">
        <span class="text-muted fs-sm">{{ invoices|length }} Rechnung(en) im Zeitraum</span>
        <a href="/admin/invoices/tax-export?date_from={{ date_from }}&date_to={{ date_to }}&format=csv" class="btn btn-sm btn-success">
            <i class="bi bi-download me-1"></i>CSV exportieren
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover table-sm mb-0">
            <thead class="fs-xs text-muted">
                <tr>
                    <th>Rechnungsnr.</th>
                    <th>Datum</th>
                    <th>Kunde</th>
                    <th>Status</th>
                    <th class="text-end">Netto (€)</th>
                    <th class="text-end">MwSt. (€)</th>
                    <th class="text-end">Brutto (€)</th>
                    <th>Bezahlt am</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for inv in invoices %}
                {% set statusLabels = {'draft':'Entwurf','open':'Offen','paid':'Bezahlt','overdue':'Überfällig','cancelled':'Storniert'} %}
                <tr>
                    <td class="px-4"><strong class="fs-sm">{{ inv.invoice_number }}</strong></td>
                    <td class="fs-sm text-nowrap">{{ inv.issue_date|date('d.m.Y') }}</td>
                    <td>
                        <div class="fs-sm">{{ inv.tenant_display }}</div>
                        <div class="text-muted fs-xs">{{ inv.tenant_email }}</div>
                    </td>
                    <td><span class="badge-inv badge-inv-{{ inv.status }}">{{ statusLabels[inv.status] ?? inv.status }}</span></td>
                    <td class="text-end fs-sm">{{ inv.total_net|number_format(2,',','.') }}</td>
                    <td class="text-end text-warning fs-sm">{{ inv.total_tax|number_format(2,',','.') }}</td>
                    <td class="text-end fw-600 fs-sm">{{ inv.total_gross|number_format(2,',','.') }}</td>
                    <td class="text-nowrap fs-sm">
                        {% if inv.paid_at %}
                            <span class="text-success">{{ inv.paid_at|date('d.m.Y') }}</span>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="/admin/invoices/{{ inv.id }}" class="btn btn-sm btn-outline-secondary">
                            <svg class="sa-icon"><use href="/sa/icons/sprite.svg#eye"></use></svg>
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="9" class="text-center py-5 text-muted">
                        <svg class="sa-icon sa-icon-3x d-block mx-auto mb-2 opacity-25"><use href="/sa/icons/sprite.svg#search"></use></svg>
                        Keine Rechnungen im gewählten Zeitraum.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}
