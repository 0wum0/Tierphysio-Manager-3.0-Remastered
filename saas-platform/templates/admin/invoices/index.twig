{% extends 'layouts/base.twig' %}
{% set active_nav = 'invoices' %}

{% block styles %}
<style>
.stat-card-inv { border-radius:.75rem; padding:1.25rem 1.5rem; border:1px solid #334155; }
.stat-value-lg { font-size:1.75rem; font-weight:800; line-height:1; }
.badge-inv { font-size:.7rem; padding:.25rem .6rem; border-radius:1rem; font-weight:700; }
.badge-draft    { background:#1e293b; color:#64748b; border:1px solid #334155; }
.badge-open     { background:#0c2a4a; color:#7dd3fc; }
.badge-paid     { background:#064e3b; color:#6ee7b7; }
.badge-overdue  { background:#3b1a08; color:#fb923c; }
.badge-cancelled{ background:#1c1c1c; color:#94a3b8; }
.inv-row td { font-size:.875rem; }
.inv-row:hover td { background:rgba(37,99,235,.04)!important; cursor:pointer; }
.chart-bar-wrap { height:6px; background:#1e293b; border-radius:3px; overflow:hidden; }
.chart-bar-fill { height:100%; border-radius:3px; transition:width .8s ease; }
</style>
{% endblock %}

{% block content %}

{# ── Stats ─────────────────────────────────────────────────────────── #}
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card-inv" style="background:linear-gradient(135deg,rgba(37,99,235,.12),#1e293b);">
            <div class="text-secondary mb-1" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.06em;">Monatsumsatz</div>
            <div class="stat-value-lg text-white">{{ stats.revenue_month|number_format(2,',','.') }} €</div>
            <div style="font-size:.75rem;color:#64748b;margin-top:.25rem;">Bezahlte Rechnungen</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card-inv" style="background:linear-gradient(135deg,rgba(16,185,129,.1),#1e293b);">
            <div class="text-secondary mb-1" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.06em;">Jahresumsatz</div>
            <div class="stat-value-lg" style="color:#34d399;">{{ stats.revenue_year|number_format(2,',','.') }} €</div>
            <div style="font-size:.75rem;color:#64748b;margin-top:.25rem;">{{ stats.paid_count }} Rechnungen bezahlt</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card-inv" style="background:linear-gradient(135deg,rgba(245,158,11,.1),#1e293b);">
            <div class="text-secondary mb-1" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.06em;">Offen</div>
            <div class="stat-value-lg" style="color:#fbbf24;">{{ stats.open_amount|number_format(2,',','.') }} €</div>
            <div style="font-size:.75rem;color:#64748b;margin-top:.25rem;">{{ stats.open_count }} Rechnung(en)</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card-inv" style="background:linear-gradient(135deg,rgba(239,68,68,.1),#1e293b);">
            <div class="text-secondary mb-1" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.06em;">Überfällig</div>
            <div class="stat-value-lg" style="color:#f87171;">{{ stats.overdue_amount|number_format(2,',','.') }} €</div>
            <div style="font-size:.75rem;color:#64748b;margin-top:.25rem;">{{ stats.overdue_count }} Rechnung(en)</div>
        </div>
    </div>
</div>

{# ── Toolbar ───────────────────────────────────────────────────────── #}
<div class="d-flex align-items-center justify-content-between mb-3 gap-2 flex-wrap">
    <div class="d-flex gap-2 flex-wrap">
        <a href="/admin/invoices" class="btn btn-sm {% if status == '' %}btn-primary{% else %}btn-outline-secondary{% endif %}">Alle</a>
        <a href="/admin/invoices?status=open"     class="btn btn-sm {% if status == 'open' %}btn-primary{% else %}btn-outline-secondary{% endif %}">Offen</a>
        <a href="/admin/invoices?status=paid"     class="btn btn-sm {% if status == 'paid' %}btn-primary{% else %}btn-outline-secondary{% endif %}">Bezahlt</a>
        <a href="/admin/invoices?status=overdue"  class="btn btn-sm {% if status == 'overdue' %}btn-primary{% else %}btn-outline-secondary{% endif %}">Überfällig</a>
        <a href="/admin/invoices?status=draft"    class="btn btn-sm {% if status == 'draft' %}btn-primary{% else %}btn-outline-secondary{% endif %}">Entwurf</a>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <form method="GET" action="/admin/invoices" class="d-flex gap-2">
            {% if status %}<input type="hidden" name="status" value="{{ status }}">{% endif %}
            <input type="text" name="search" value="{{ search }}" class="form-control form-control-sm" placeholder="Suche…" style="width:200px;">
            <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
            {% if search %}<a href="/admin/invoices{% if status %}?status={{ status }}{% endif %}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x"></i></a>{% endif %}
        </form>
        <a href="/admin/invoices/create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Neue Rechnung
        </a>
        <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-download me-1"></i>Export
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin/invoices/tax-export"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Steuerexport (CSV)</a></li>
            </ul>
        </div>
    </div>
</div>

{# ── Tabelle ───────────────────────────────────────────────────────── #}
<div class="card">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th class="px-3" style="width:36px;">#</th>
                    <th>Rechnungsnr.</th>
                    <th>Kunde</th>
                    <th>Datum</th>
                    <th>Fällig</th>
                    <th class="text-end">Betrag</th>
                    <th>Status</th>
                    <th>Zahlungsart</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for inv in invoices %}
                {% set statusLabel = {
                    'draft':     'Entwurf',
                    'open':      'Offen',
                    'paid':      'Bezahlt',
                    'overdue':   'Überfällig',
                    'cancelled': 'Storniert'
                } %}
                {% set methodLabel = {
                    'rechnung':    'Rechnung',
                    'ueberweisung':'Überweisung',
                    'lastschrift': 'Lastschrift',
                    'bar':         'Bar'
                } %}
                <tr class="inv-row" onclick="window.location='/admin/invoices/{{ inv.id }}'">
                    <td class="px-3 text-secondary">{{ inv.id }}</td>
                    <td><strong class="text-white">{{ inv.invoice_number }}</strong></td>
                    <td>
                        <div style="font-weight:500;color:#e2e8f0;">{{ inv.tenant_display }}</div>
                        <div style="font-size:.75rem;color:#64748b;">{{ inv.tenant_email }}</div>
                    </td>
                    <td style="white-space:nowrap;">
                        {% if inv.issue_date %}
                            {{ inv.issue_date|date('d.m.Y') }}
                        {% endif %}
                    </td>
                    <td style="white-space:nowrap;">
                        {% if inv.due_date %}
                            {% if inv.days_overdue %}
                                <span style="color:#f87171;">{{ inv.due_date|date('d.m.Y') }}</span>
                                <span style="font-size:.7rem;color:#f87171;"> (+{{ inv.days_overdue }}d)</span>
                            {% else %}
                                {{ inv.due_date|date('d.m.Y') }}
                            {% endif %}
                        {% else %}
                            <span class="text-secondary">—</span>
                        {% endif %}
                    </td>
                    <td class="text-end" style="white-space:nowrap;">
                        <strong style="color:{% if inv.status == 'paid' %}#34d399{% elseif inv.status == 'overdue' %}#f87171{% else %}#e2e8f0{% endif %};">
                            {{ inv.total_gross|number_format(2,',','.') }} €
                        </strong>
                    </td>
                    <td>
                        <span class="badge-inv badge-{{ inv.status }}">{{ statusLabel[inv.status] ?? inv.status }}</span>
                    </td>
                    <td>
                        <span style="font-size:.75rem;color:#64748b;">{{ methodLabel[inv.payment_method] ?? inv.payment_method }}</span>
                    </td>
                    <td class="text-end" onclick="event.stopPropagation()">
                        <a href="/admin/invoices/{{ inv.id }}" class="btn btn-sm btn-outline-secondary py-0 px-2"><i class="bi bi-eye"></i></a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="9" class="text-center py-5 text-secondary">
                        <i class="bi bi-receipt" style="font-size:2rem;opacity:.3;display:block;margin-bottom:.5rem;"></i>
                        Keine Rechnungen gefunden.
                        <a href="/admin/invoices/create" class="d-block mt-2 text-primary">Erste Rechnung erstellen →</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ── Pagination ────────────────────────────────────────────────────── #}
{% if pagination.last_page > 1 %}
<nav class="mt-3 d-flex justify-content-between align-items-center">
    <small class="text-secondary">{{ pagination.total }} Rechnungen gesamt</small>
    <ul class="pagination pagination-sm mb-0">
        {% if pagination.has_prev %}
        <li class="page-item"><a class="page-link" href="?page={{ pagination.page - 1 }}&status={{ status }}&search={{ search }}">‹</a></li>
        {% endif %}
        {% for p in 1..pagination.last_page %}
        <li class="page-item {% if p == pagination.page %}active{% endif %}">
            <a class="page-link" href="?page={{ p }}&status={{ status }}&search={{ search }}">{{ p }}</a>
        </li>
        {% endfor %}
        {% if pagination.has_next %}
        <li class="page-item"><a class="page-link" href="?page={{ pagination.page + 1 }}&status={{ status }}&search={{ search }}">›</a></li>
        {% endif %}
    </ul>
</nav>
{% endif %}

{% endblock %}
