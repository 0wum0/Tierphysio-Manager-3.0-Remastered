{% extends 'layouts/base.twig' %}

{% block content %}

{# ── Stats ────────────────────────────────────────────────────────────────── #}
<div class="row g-3 mb-3">
    <div class="col-6 col-md-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted fs-xs text-uppercase mb-1" style="letter-spacing:.06em;">Monatsumsatz</div>
                <div class="h3 fw-700 mb-0">{{ stats.revenue_month|number_format(2,',','.') }} €</div>
                <div class="text-muted fs-xs mt-1">Bezahlte Rechnungen</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted fs-xs text-uppercase mb-1" style="letter-spacing:.06em;">Jahresumsatz</div>
                <div class="h3 fw-700 mb-0 text-success">{{ stats.revenue_year|number_format(2,',','.') }} €</div>
                <div class="text-muted fs-xs mt-1">{{ stats.paid_count }} Rechnungen bezahlt</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted fs-xs text-uppercase mb-1" style="letter-spacing:.06em;">Offen</div>
                <div class="h3 fw-700 mb-0 text-warning">{{ stats.open_amount|number_format(2,',','.') }} €</div>
                <div class="text-muted fs-xs mt-1">{{ stats.open_count }} Rechnung(en)</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted fs-xs text-uppercase mb-1" style="letter-spacing:.06em;">Überfällig</div>
                <div class="h3 fw-700 mb-0 text-danger">{{ stats.overdue_amount|number_format(2,',','.') }} €</div>
                <div class="text-muted fs-xs mt-1">{{ stats.overdue_count }} Rechnung(en)</div>
            </div>
        </div>
    </div>
</div>

{# ── Toolbar ───────────────────────────────────────────────────────── #}
<div class="d-flex align-items-center justify-content-between mb-3 gap-2 flex-wrap">
    <div class="d-flex gap-2 flex-wrap">
        <a href="/admin/invoices" class="btn btn-sm {% if status == '' %}btn-primary{% else %}btn-outline-secondary{% endif %}">Alle</a>
        <a href="/admin/invoices?status=open"     class="btn btn-sm {% if status == 'open' %}btn-primary{% else %}btn-outline-secondary{% endif %}">Offen</a>
        <a href="/admin/invoices?status=paid"     class="btn btn-sm {% if status == 'paid' %}btn-primary{% else %}btn-outline-secondary{% endif %}">Bezahlt</a>
        <a href="/admin/invoices?status=overdue"  class="btn btn-sm {% if status == 'overdue' %}btn-primary{% else %}btn-outline-secondary{% endif %}">Überfällig</a>
        <a href="/admin/invoices?status=draft"    class="btn btn-sm {% if status == 'draft' %}btn-primary{% else %}btn-outline-secondary{% endif %}">Entwurf</a>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <form method="GET" action="/admin/invoices" class="d-flex gap-2">
            {% if status %}<input type="hidden" name="status" value="{{ status }}">{% endif %}
            <input type="text" name="search" value="{{ search }}" class="form-control form-control-sm" placeholder="Suche…" style="min-width:160px;max-width:220px;">
            <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
            {% if search %}<a href="/admin/invoices{% if status %}?status={{ status }}{% endif %}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x"></i></a>{% endif %}
        </form>
        <a href="/admin/invoices/create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Neue Rechnung
        </a>
        <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-download me-1"></i>Export
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin/invoices/tax-export"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Steuerexport (CSV)</a></li>
            </ul>
        </div>
    </div>
</div>

{# ── Tabelle ───────────────────────────────────────────────────────── #}
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover table-sm mb-0">
            <thead class="fs-xs text-muted">
                <tr>
                    <th class="px-4" style="width:36px;">#</th>
                    <th>Rechnungsnr.</th>
                    <th>Kunde</th>
                    <th>Datum</th>
                    <th>Fällig</th>
                    <th class="text-end">Betrag</th>
                    <th>Status</th>
                    <th>Zahlungsart</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for inv in invoices %}
                {% set statusLabel = {
                    'draft':     'Entwurf',
                    'open':      'Offen',
                    'paid':      'Bezahlt',
                    'overdue':   'Überfällig',
                    'cancelled': 'Storniert'
                } %}
                {% set methodLabel = {
                    'rechnung':    'Rechnung',
                    'ueberweisung':'Überweisung',
                    'lastschrift': 'Lastschrift',
                    'bar':         'Bar'
                } %}
                <tr class="cursor-pointer" onclick="window.location='/admin/invoices/{{ inv.id }}'" style="cursor:pointer;">
                    <td class="px-4 text-muted">{{ inv.id }}</td>
                    <td><strong class="fs-sm">{{ inv.invoice_number }}</strong></td>
                    <td>
                        <div class="fw-500 fs-sm">{{ inv.tenant_display }}</div>
                        <div class="text-muted fs-xs">{{ inv.tenant_email }}</div>
                    </td>
                    <td class="text-nowrap fs-sm">{{ inv.issue_date ? inv.issue_date|date('d.m.Y') : '' }}</td>
                    <td class="text-nowrap fs-sm">
                        {% if inv.due_date %}
                            {% if inv.days_overdue %}
                                <span class="text-danger">{{ inv.due_date|date('d.m.Y') }}</span>
                                <span class="text-danger fs-xs"> (+{{ inv.days_overdue }}d)</span>
                            {% else %}
                                {{ inv.due_date|date('d.m.Y') }}
                            {% endif %}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td class="text-end text-nowrap">
                        <strong class="fs-sm {% if inv.status == 'paid' %}text-success{% elseif inv.status == 'overdue' %}text-danger{% endif %}">
                            {{ inv.total_gross|number_format(2,',','.') }} €
                        </strong>
                    </td>
                    <td>
                        <span class="badge-inv badge-inv-{{ inv.status }}">{{ statusLabel[inv.status] ?? inv.status }}</span>
                    </td>
                    <td class="text-muted fs-sm">{{ methodLabel[inv.payment_method] ?? inv.payment_method }}</td>
                    <td class="text-end" onclick="event.stopPropagation()">
                        <a href="/admin/invoices/{{ inv.id }}" class="btn btn-sm btn-outline-secondary">
                            <svg class="sa-icon"><use href="/sa/icons/sprite.svg#eye"></use></svg>
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="9" class="text-center py-5 text-muted">
                        <svg class="sa-icon sa-icon-3x d-block mx-auto mb-2 opacity-25"><use href="/sa/icons/sprite.svg#file-text"></use></svg>
                        Keine Rechnungen gefunden.
                        <a href="/admin/invoices/create" class="d-block mt-2">Erste Rechnung erstellen →</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ── Pagination ────────────────────────────────────────────────────── #}
{% if pagination.last_page > 1 %}
<nav class="mt-3 d-flex justify-content-between align-items-center">
    <span class="text-muted fs-sm">{{ pagination.total }} Rechnungen gesamt</span>
    <ul class="pagination pagination-sm mb-0">
        {% if pagination.has_prev %}
        <li class="page-item"><a class="page-link" href="?page={{ pagination.page - 1 }}&status={{ status }}&search={{ search }}">‹</a></li>
        {% endif %}
        {% for p in 1..pagination.last_page %}
        <li class="page-item {% if p == pagination.page %}active{% endif %}">
            <a class="page-link" href="?page={{ p }}&status={{ status }}&search={{ search }}">{{ p }}</a>
        </li>
        {% endfor %}
        {% if pagination.has_next %}
        <li class="page-item"><a class="page-link" href="?page={{ pagination.page + 1 }}&status={{ status }}&search={{ search }}">›</a></li>
        {% endif %}
    </ul>
</nav>
{% endif %}

{% endblock %}
