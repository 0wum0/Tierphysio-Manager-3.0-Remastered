{% extends 'layouts/base.twig' %}

{% block content %}

{# ── Header ────────────────────────────────────────────────────────── #}
<div class="d-flex align-items-start justify-content-between mb-4 gap-3 flex-wrap">
    <div class="d-flex align-items-center gap-3">
        <a href="/admin/invoices" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Zurück</a>
        <div>
            <h5 class="mb-0 fw-700">{{ invoice.invoice_number }}</h5>
            <div class="d-flex align-items-center gap-2 mt-1">
                <span class="badge-inv badge-inv-{{ invoice.status }}">
                    {% set statusLabels = {'draft':'Entwurf','open':'Offen','paid':'Bezahlt','overdue':'Überfällig','cancelled':'Storniert'} %}
                    {{ statusLabels[invoice.status] ?? invoice.status }}
                </span>
                {% if invoice.finalized_at %}
                <span class="finalized-badge"><i class="bi bi-lock-fill"></i> GoBD-finalisiert</span>
                {% endif %}
                {% if invoice.email_sent_at %}
                <span class="text-muted fs-xs"><i class="bi bi-envelope-check me-1"></i>E-Mail gesendet {{ invoice.email_sent_at|date('d.m.Y') }}</span>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a href="/admin/invoices/{{ invoice.id }}/pdf" class="btn btn-sm btn-outline-secondary" target="_blank">
            <i class="bi bi-file-earmark-pdf me-1"></i>PDF
        </a>
        {% if not invoice.finalized_at %}
        <a href="/admin/invoices/{{ invoice.id }}/edit" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-pencil me-1"></i>Bearbeiten
        </a>
        {% endif %}
        <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">Aktionen</button>
            <ul class="dropdown-menu dropdown-menu-end">
                {# Status-Änderungen #}
                {% if invoice.status != 'paid' %}
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/status" class="d-inline">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <input type="hidden" name="status" value="paid">
                        <button type="submit" class="dropdown-item text-success"><i class="bi bi-check-circle me-2"></i>Als bezahlt markieren</button>
                    </form>
                </li>
                {% endif %}
                {% if invoice.status == 'draft' %}
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/status">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <input type="hidden" name="status" value="open">
                        <button type="submit" class="dropdown-item"><i class="bi bi-send me-2"></i>Als offen setzen</button>
                    </form>
                </li>
                {% endif %}
                {% if invoice.status in ['open','overdue'] %}
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/status">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <input type="hidden" name="status" value="cancelled">
                        <button type="submit" class="dropdown-item text-warning"><i class="bi bi-x-circle me-2"></i>Stornieren</button>
                    </form>
                </li>
                {% endif %}
                <li><hr class="dropdown-divider"></li>
                {# E-Mail senden #}
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/send-email">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="dropdown-item"><i class="bi bi-envelope me-2"></i>Per E-Mail senden</button>
                    </form>
                </li>
                {# Finalisieren #}
                {% if not invoice.finalized_at %}
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/finalize" onsubmit="return confirm('Rechnung unwiderruflich finalisieren (GoBD)? Diese Aktion kann nicht rückgängig gemacht werden.')">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="dropdown-item"><i class="bi bi-lock me-2"></i>GoBD-finalisieren</button>
                    </form>
                </li>
                {% endif %}
                {# Löschen #}
                {% if invoice.status not in ['paid','cancelled'] and not invoice.finalized_at %}
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/delete" onsubmit="return confirm('Rechnung wirklich löschen?')">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash3 me-2"></i>Löschen</button>
                    </form>
                </li>
                {% endif %}
            </ul>
        </div>
    </div>
</div>

<div class="row g-4">

    {# ── Linke Spalte: Positionen ──────────────────────────────────── #}
    <div class="col-lg-8">

        {# Kundendaten #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;">
                <i class="bi bi-person-circle me-1"></i>Kunde
            </div>
            <div class="card-body px-4 py-3">
                {% set tenantName = invoice.tenant_name ?? invoice.owner_name %}
                <div class="fw-700 fs-md mb-1">{{ tenantName }}</div>
                {% if invoice.tenant_email %}
                <div class="text-muted fs-sm"><i class="bi bi-envelope me-1"></i>{{ invoice.tenant_email }}</div>
                {% endif %}
                {% if invoice.address %}
                <div class="text-muted fs-sm mt-1"><i class="bi bi-geo-alt me-1"></i>{{ invoice.address }}{% if invoice.zip or invoice.city %}, {{ invoice.zip }} {{ invoice.city }}{% endif %}</div>
                {% endif %}
                <div class="mt-2">
                    <span class="text-muted fs-xs">Kundennummer: <strong>K-{{ '%04d'|format(invoice.tenant_id) }}</strong></span>
                    <a href="/admin/tenants/{{ invoice.tenant_id }}" class="ms-2 fs-xs">Praxis anzeigen →</a>
                </div>
            </div>
        </div>

        {# Positionen-Tabelle #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;">
                <i class="bi bi-list-ul me-1"></i>Rechnungspositionen
            </div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th style="width:5%">Pos.</th>
                            <th style="width:45%">Beschreibung</th>
                            <th class="text-end" style="width:10%">Menge</th>
                            <th class="text-end" style="width:15%">Einzelpreis</th>
                            <th class="text-end" style="width:10%">MwSt.</th>
                            <th class="text-end" style="width:15%">Gesamt</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for pos in positions %}
                        <tr>
                            <td class="text-secondary">{{ loop.index }}</td>
                            <td>{{ pos.description }}</td>
                            <td class="text-end">{{ pos.quantity|number_format(2,',','.') }}</td>
                            <td class="text-end">{{ pos.unit_price|number_format(2,',','.') }} €</td>
                            <td class="text-end">{{ pos.tax_rate|number_format(0,',','.') }} %</td>
                            <td class="text-end"><strong>{{ pos.total|number_format(2,',','.') }} €</strong></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# Notizen #}
        {% if invoice.notes or invoice.payment_terms %}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;">
                <i class="bi bi-chat-text me-1"></i>Hinweise
            </div>
            <div class="card-body px-4 py-3">
                {% if invoice.notes %}
                <p class="text-muted fs-sm mb-1">{{ invoice.notes }}</p>
                {% endif %}
                {% if invoice.payment_terms %}
                <p class="text-muted fs-sm mb-0"><i class="bi bi-info-circle me-1"></i>{{ invoice.payment_terms }}</p>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </div>

    {# ── Rechte Spalte: Details & Summen ───────────────────────────── #}
    <div class="col-lg-4">

        {# Rechnungsdetails #}
        <div class="card mb-3">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;">
                <i class="bi bi-info-circle me-1"></i>Details
            </div>
            <div class="card-body px-4 py-3">
                {% set methodLabels = {'rechnung':'Rechnung','ueberweisung':'Überweisung','lastschrift':'Lastschrift','bar':'Barzahlung'} %}
                {% macro dr(label, value, cls='') %}
                <div class="d-flex justify-content-between border-bottom py-2 fs-sm">
                    <span class="text-muted">{{ label }}</span>
                    <span class="{% if cls %}{{ cls }}{% endif %}">{{ value }}</span>
                </div>
                {% endmacro %}
                <div class="d-flex justify-content-between border-bottom py-2 fs-sm"><span class="text-muted">Rechnungsnr.</span><strong>{{ invoice.invoice_number }}</strong></div>
                <div class="d-flex justify-content-between border-bottom py-2 fs-sm"><span class="text-muted">Rechnungsdatum</span><span>{{ invoice.issue_date|date('d.m.Y') }}</span></div>
                {% if invoice.due_date %}
                <div class="d-flex justify-content-between border-bottom py-2 fs-sm"><span class="text-muted">Fällig am</span><span class="{% if invoice.status == 'overdue' %}text-danger{% endif %}">{{ invoice.due_date|date('d.m.Y') }}</span></div>
                {% endif %}
                <div class="d-flex justify-content-between border-bottom py-2 fs-sm"><span class="text-muted">Zahlungsart</span><span>{{ methodLabels[invoice.payment_method] ?? invoice.payment_method }}</span></div>
                {% if invoice.paid_at %}
                <div class="d-flex justify-content-between border-bottom py-2 fs-sm"><span class="text-muted">Bezahlt am</span><span class="text-success">{{ invoice.paid_at|date('d.m.Y') }}</span></div>
                {% endif %}
                <div class="d-flex justify-content-between border-bottom py-2 fs-sm"><span class="text-muted">Erstellt</span><span class="text-muted">{{ invoice.created_at|date('d.m.Y H:i') }}</span></div>
                {% if invoice.finalized_at %}
                <div class="d-flex justify-content-between py-2 fs-sm"><span class="text-muted">Finalisiert</span><span class="text-success">{{ invoice.finalized_at|date('d.m.Y H:i') }}</span></div>
                {% endif %}
            </div>
        </div>

        {# Summen #}
        <div class="card mb-3">
            <div class="card-body px-4 py-3">
                <div class="d-flex justify-content-between py-2 border-bottom fs-sm"><span class="text-muted">Nettobetrag</span><span>{{ invoice.total_net|number_format(2,',','.') }} €</span></div>
                <div class="d-flex justify-content-between py-2 border-bottom fs-sm"><span class="text-muted">Mehrwertsteuer</span><span>{{ invoice.total_tax|number_format(2,',','.') }} €</span></div>
                <div class="d-flex justify-content-between pt-3 fw-700 fs-md border-top"><span>Gesamtbetrag</span><span class="text-success">{{ invoice.total_gross|number_format(2,',','.') }} €</span></div>
            </div>
        </div>

        {# Schnellaktionen #}
        <div class="card">
            <div class="card-header px-4 py-3 text-muted fs-xs fw-700 text-uppercase" style="letter-spacing:.08em;">
                <i class="bi bi-lightning me-1"></i>Schnellaktionen
            </div>
            <div class="card-body px-4 py-3">
            <div class="d-grid gap-2">
                <a href="/admin/invoices/{{ invoice.id }}/pdf" target="_blank" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-file-earmark-pdf me-1"></i>PDF herunterladen
                </a>
                <form method="POST" action="/admin/invoices/{{ invoice.id }}/send-email">
                    {{ csrf_field()|raw }}
                    <button type="submit" class="btn btn-sm btn-outline-secondary w-100">
                        <i class="bi bi-envelope me-1"></i>Per E-Mail senden
                    </button>
                </form>
                {% if invoice.status != 'paid' %}
                <form method="POST" action="/admin/invoices/{{ invoice.id }}/status">
                    {{ csrf_field()|raw }}
                    <input type="hidden" name="status" value="paid">
                    <button type="submit" class="btn btn-sm btn-success w-100">
                        <i class="bi bi-check-circle me-1"></i>Als bezahlt markieren
                    </button>
                </form>
                {% endif %}
            </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
