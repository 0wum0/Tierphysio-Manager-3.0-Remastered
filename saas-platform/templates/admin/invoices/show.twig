{% extends 'layouts/base.twig' %}
{% set active_nav = 'invoices' %}

{% block styles %}
<style>
.badge-inv { font-size:.75rem; padding:.3rem .7rem; border-radius:1rem; font-weight:700; }
.badge-draft    { background:#1e293b; color:#64748b; border:1px solid #334155; }
.badge-open     { background:#0c2a4a; color:#7dd3fc; }
.badge-paid     { background:#064e3b; color:#6ee7b7; }
.badge-overdue  { background:#3b1a08; color:#fb923c; }
.badge-cancelled{ background:#1c1c1c; color:#94a3b8; }
.detail-card { background:#1e293b; border:1px solid #334155; border-radius:.75rem; padding:1.5rem; margin-bottom:1rem; }
.detail-row { display:flex; justify-content:space-between; align-items:flex-start; padding:.4rem 0; border-bottom:1px solid #1e293b; font-size:.875rem; }
.detail-row:last-child { border-bottom:none; }
.detail-label { color:#64748b; white-space:nowrap; margin-right:1rem; }
.detail-value { color:#e2e8f0; text-align:right; }
.totals-summary { background:#0f172a; border:1px solid #334155; border-radius:.75rem; padding:1.25rem; }
.totals-row { display:flex; justify-content:space-between; padding:.35rem 0; font-size:.9rem; }
.totals-row.gross { border-top:2px solid #334155; margin-top:.5rem; padding-top:.75rem; font-size:1.1rem; font-weight:800; }
.pos-table th { font-size:.75rem; text-transform:uppercase; letter-spacing:.05em; color:#64748b; }
.finalized-badge { display:inline-flex; align-items:center; gap:.35rem; background:rgba(16,185,129,.1); border:1px solid rgba(16,185,129,.3); color:#34d399; border-radius:.5rem; padding:.25rem .75rem; font-size:.75rem; font-weight:600; }
</style>
{% endblock %}

{% block content %}

{# ── Header ────────────────────────────────────────────────────────── #}
<div class="d-flex align-items-start justify-content-between mb-4 gap-3 flex-wrap">
    <div class="d-flex align-items-center gap-3">
        <a href="/admin/invoices" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Zurück</a>
        <div>
            <h4 class="mb-0 text-white">{{ invoice.invoice_number }}</h4>
            <div class="d-flex align-items-center gap-2 mt-1">
                <span class="badge-inv badge-{{ invoice.status }}">
                    {% set statusLabels = {'draft':'Entwurf','open':'Offen','paid':'Bezahlt','overdue':'Überfällig','cancelled':'Storniert'} %}
                    {{ statusLabels[invoice.status] ?? invoice.status }}
                </span>
                {% if invoice.finalized_at %}
                <span class="finalized-badge"><i class="bi bi-lock-fill"></i> GoBD-finalisiert</span>
                {% endif %}
                {% if invoice.email_sent_at %}
                <span style="font-size:.75rem;color:#64748b;"><i class="bi bi-envelope-check me-1"></i>E-Mail gesendet {{ invoice.email_sent_at|date('d.m.Y') }}</span>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a href="/admin/invoices/{{ invoice.id }}/pdf" class="btn btn-sm btn-outline-secondary" target="_blank">
            <i class="bi bi-file-earmark-pdf me-1"></i>PDF
        </a>
        {% if not invoice.finalized_at %}
        <a href="/admin/invoices/{{ invoice.id }}/edit" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-pencil me-1"></i>Bearbeiten
        </a>
        {% endif %}
        <div class="dropdown">
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">Aktionen</button>
            <ul class="dropdown-menu dropdown-menu-end">
                {# Status-Änderungen #}
                {% if invoice.status != 'paid' %}
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/status" class="d-inline">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <input type="hidden" name="status" value="paid">
                        <button type="submit" class="dropdown-item text-success"><i class="bi bi-check-circle me-2"></i>Als bezahlt markieren</button>
                    </form>
                </li>
                {% endif %}
                {% if invoice.status == 'draft' %}
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/status">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <input type="hidden" name="status" value="open">
                        <button type="submit" class="dropdown-item"><i class="bi bi-send me-2"></i>Als offen setzen</button>
                    </form>
                </li>
                {% endif %}
                {% if invoice.status in ['open','overdue'] %}
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/status">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <input type="hidden" name="status" value="cancelled">
                        <button type="submit" class="dropdown-item text-warning"><i class="bi bi-x-circle me-2"></i>Stornieren</button>
                    </form>
                </li>
                {% endif %}
                <li><hr class="dropdown-divider"></li>
                {# E-Mail senden #}
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/send-email">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="dropdown-item"><i class="bi bi-envelope me-2"></i>Per E-Mail senden</button>
                    </form>
                </li>
                {# Finalisieren #}
                {% if not invoice.finalized_at %}
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/finalize" onsubmit="return confirm('Rechnung unwiderruflich finalisieren (GoBD)? Diese Aktion kann nicht rückgängig gemacht werden.')">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="dropdown-item"><i class="bi bi-lock me-2"></i>GoBD-finalisieren</button>
                    </form>
                </li>
                {% endif %}
                {# Löschen #}
                {% if invoice.status not in ['paid','cancelled'] and not invoice.finalized_at %}
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form method="POST" action="/admin/invoices/{{ invoice.id }}/delete" onsubmit="return confirm('Rechnung wirklich löschen?')">
                        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash3 me-2"></i>Löschen</button>
                    </form>
                </li>
                {% endif %}
            </ul>
        </div>
    </div>
</div>

<div class="row g-4">

    {# ── Linke Spalte: Positionen ──────────────────────────────────── #}
    <div class="col-lg-8">

        {# Kundendaten #}
        <div class="detail-card">
            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#64748b;margin-bottom:1rem;">
                <i class="bi bi-person-circle me-1"></i>Kunde
            </div>
            {% set tenantName = invoice.tenant_name ?? (invoice.first_name ~ ' ' ~ invoice.last_name) %}
            <div style="font-size:1.1rem;font-weight:700;color:#e2e8f0;margin-bottom:.5rem;">{{ tenantName }}</div>
            {% if invoice.tenant_email %}
            <div style="font-size:.875rem;color:#64748b;"><i class="bi bi-envelope me-1"></i>{{ invoice.tenant_email }}</div>
            {% endif %}
            {% if invoice.address %}
            <div style="font-size:.875rem;color:#64748b;margin-top:.35rem;"><i class="bi bi-geo-alt me-1"></i>{{ invoice.address }}{% if invoice.zip or invoice.city %}, {{ invoice.zip }} {{ invoice.city }}{% endif %}</div>
            {% endif %}
            <div style="margin-top:.5rem;">
                <span style="font-size:.75rem;color:#64748b;">Kundennummer:</span>
                <span style="font-size:.75rem;color:#94a3b8;margin-left:.5rem;">K-{{ '%04d'|format(invoice.tenant_id) }}</span>
                <a href="/admin/tenants/{{ invoice.tenant_id }}" class="ms-2" style="font-size:.75rem;color:#2563eb;">Praxis anzeigen →</a>
            </div>
        </div>

        {# Positionen-Tabelle #}
        <div class="detail-card">
            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#64748b;margin-bottom:1rem;">
                <i class="bi bi-list-ul me-1"></i>Rechnungspositionen
            </div>
            <div class="table-responsive">
                <table class="table mb-0 pos-table">
                    <thead>
                        <tr>
                            <th style="width:5%">Pos.</th>
                            <th style="width:45%">Beschreibung</th>
                            <th class="text-end" style="width:10%">Menge</th>
                            <th class="text-end" style="width:15%">Einzelpreis</th>
                            <th class="text-end" style="width:10%">MwSt.</th>
                            <th class="text-end" style="width:15%">Gesamt</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for pos in positions %}
                        <tr>
                            <td class="text-secondary">{{ loop.index }}</td>
                            <td>{{ pos.description }}</td>
                            <td class="text-end">{{ pos.quantity|number_format(2,',','.') }}</td>
                            <td class="text-end">{{ pos.unit_price|number_format(2,',','.') }} €</td>
                            <td class="text-end">{{ pos.tax_rate|number_format(0,',','.') }} %</td>
                            <td class="text-end"><strong>{{ pos.total|number_format(2,',','.') }} €</strong></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# Notizen #}
        {% if invoice.notes or invoice.payment_terms %}
        <div class="detail-card">
            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#64748b;margin-bottom:1rem;">
                <i class="bi bi-chat-text me-1"></i>Hinweise
            </div>
            {% if invoice.notes %}
            <p style="font-size:.875rem;color:#94a3b8;margin-bottom:.5rem;">{{ invoice.notes }}</p>
            {% endif %}
            {% if invoice.payment_terms %}
            <p style="font-size:.875rem;color:#64748b;margin-bottom:0;"><i class="bi bi-info-circle me-1"></i>{{ invoice.payment_terms }}</p>
            {% endif %}
        </div>
        {% endif %}
    </div>

    {# ── Rechte Spalte: Details & Summen ───────────────────────────── #}
    <div class="col-lg-4">

        {# Rechnungsdetails #}
        <div class="detail-card">
            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#64748b;margin-bottom:1rem;">
                <i class="bi bi-info-circle me-1"></i>Details
            </div>
            {% set methodLabels = {'rechnung':'Rechnung','ueberweisung':'Überweisung','lastschrift':'Lastschrift','bar':'Barzahlung'} %}
            <div class="detail-row">
                <span class="detail-label">Rechnungsnr.</span>
                <span class="detail-value"><strong>{{ invoice.invoice_number }}</strong></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Rechnungsdatum</span>
                <span class="detail-value">{{ invoice.issue_date|date('d.m.Y') }}</span>
            </div>
            {% if invoice.due_date %}
            <div class="detail-row">
                <span class="detail-label">Fällig am</span>
                <span class="detail-value {% if invoice.status == 'overdue' %}text-danger{% endif %}">{{ invoice.due_date|date('d.m.Y') }}</span>
            </div>
            {% endif %}
            <div class="detail-row">
                <span class="detail-label">Zahlungsart</span>
                <span class="detail-value">{{ methodLabels[invoice.payment_method] ?? invoice.payment_method }}</span>
            </div>
            {% if invoice.paid_at %}
            <div class="detail-row">
                <span class="detail-label">Bezahlt am</span>
                <span class="detail-value" style="color:#34d399;">{{ invoice.paid_at|date('d.m.Y') }}</span>
            </div>
            {% endif %}
            <div class="detail-row">
                <span class="detail-label">Erstellt</span>
                <span class="detail-value" style="color:#64748b;">{{ invoice.created_at|date('d.m.Y H:i') }}</span>
            </div>
            {% if invoice.finalized_at %}
            <div class="detail-row">
                <span class="detail-label">Finalisiert</span>
                <span class="detail-value" style="color:#34d399;">{{ invoice.finalized_at|date('d.m.Y H:i') }}</span>
            </div>
            {% endif %}
        </div>

        {# Summen #}
        <div class="totals-summary">
            <div class="totals-row">
                <span class="text-secondary">Nettobetrag</span>
                <span>{{ invoice.total_net|number_format(2,',','.') }} €</span>
            </div>
            <div class="totals-row">
                <span class="text-secondary">Mehrwertsteuer</span>
                <span>{{ invoice.total_tax|number_format(2,',','.') }} €</span>
            </div>
            <div class="totals-row gross">
                <span>Gesamtbetrag</span>
                <span style="color:#34d399;">{{ invoice.total_gross|number_format(2,',','.') }} €</span>
            </div>
        </div>

        {# Schnellaktionen #}
        <div class="detail-card mt-3">
            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#64748b;margin-bottom:1rem;">
                <i class="bi bi-lightning me-1"></i>Schnellaktionen
            </div>
            <div class="d-grid gap-2">
                <a href="/admin/invoices/{{ invoice.id }}/pdf" target="_blank" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-file-earmark-pdf me-1"></i>PDF herunterladen
                </a>
                <form method="POST" action="/admin/invoices/{{ invoice.id }}/send-email">
                    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                    <button type="submit" class="btn btn-sm btn-outline-secondary w-100">
                        <i class="bi bi-envelope me-1"></i>Per E-Mail senden
                    </button>
                </form>
                {% if invoice.status != 'paid' %}
                <form method="POST" action="/admin/invoices/{{ invoice.id }}/status">
                    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                    <input type="hidden" name="status" value="paid">
                    <button type="submit" class="btn btn-sm btn-success w-100">
                        <i class="bi bi-check-circle me-1"></i>Als bezahlt markieren
                    </button>
                </form>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
