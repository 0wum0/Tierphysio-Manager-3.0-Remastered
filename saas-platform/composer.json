{
    "name": "tierphysio/saas-platform",
    "description": "Tierphysio SaaS Platform - Lizenz- und Aboverwaltung",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "twig/twig": "^3.8",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.9",
        "ramsey/uuid": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "Saas\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}
