<!DOCTYPE html>
<html lang="{{ current_locale }}" data-bs-theme="dark" class="set-nav-dark">
{# data-bs-theme="dark" is the default fallback. saveloadscript.js (in <head>)
   overrides it immediately from localStorage when the user has saved a preference. #}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, maximum-scale=5">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="csrf-token" content="{{ csrf_token }}">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="msapplication-tap-highlight" content="no">
    <title>{% block title %}{{ page_title ?? app_name }}{% endblock %} — {{ app_name }}</title>

    {# Vendor css #}
    <link rel="stylesheet" media="screen, print" href="/themes/smart-tierphysio/plugins/waves/waves.min.css">

    {# Base css — SmartAdmin core (includes Bootstrap 5) #}
    <link rel="stylesheet" media="screen, print" href="/themes/smart-tierphysio/css/smartapp.min.css">

    {# Icons #}
    <link rel="stylesheet" media="screen, print" href="/themes/smart-tierphysio/webfonts/smartadmin/sa-icons.css">
    <link rel="stylesheet" media="screen, print" href="/themes/smart-tierphysio/webfonts/fontawesome/fontawesome.css">

    {# App custom overrides #}
    <link rel="stylesheet" media="screen, print" href="/themes/smart-tierphysio/bridge.css?v=20260308f">

    {# Per-user UI settings from DB — must be before saveloadscript.js #}
    <script>window.__serverUiSettings = {{ (server_ui_settings ?? 'null')|json_encode|raw }};</script>
    {# Save/Load functionality — MUST be in <head> so theme is applied before CSS renders #}
    <script src="/themes/smart-tierphysio/scripts/core/saveloadscript.js"></script>

    {% block head %}{% endblock %}
</head>
<body>

<div class="app-wrap">

    {# ═══════════════════════════════════════════════════════
       TOP HEADER
       ═══════════════════════════════════════════════════════ #}
    <header class="app-header">
        <div class="d-flex flex-grow-1 w-100 me-auto align-items-center">

            {# App Logo in header — SmartAdmin CSS shows/hides based on layout class #}
            {%- set _logo_blobs %}
                <div class="logo-backdrop">
                    <div class="blobs">
                        <svg viewBox="0 0 1200 1200">
                            <g class="blob blob-1"><path d="M 100 600 q 0 -700, 500 -500 t 500 500 t -500 500 T 100 600 z"/></g>
                            <g class="blob blob-2"><path d="M 100 600 q -50 -400, 500 -500 t 450 550 t -500 500 T 100 600 z"/></g>
                            <g class="blob blob-3"><path d="M 100 600 q 0 -400, 500 -500 t 400 500 t -500 500 T 100 600 z"/></g>
                            <g class="blob blob-4"><path d="M 150 600 q 0 -600, 500 -500 t 500 550 t -500 500 T 150 600 z"/></g>
                            <g class="blob blob-1 alt"><path d="M 150 600 q 0 -600, 500 -500 t 500 550 t -500 500 T 150 600 z"/></g>
                            <g class="blob blob-2 alt"><path d="M 100 600 q 100 -600, 500 -500 t 400 500 t -500 500 T 100 600 z"/></g>
                            <g class="blob blob-3 alt"><path d="M 100 600 q 0 -400, 500 -500 t 400 500 t -500 500 T 100 600 z"/></g>
                            <g class="blob blob-4 alt"><path d="M 150 600 q 0 -600, 500 -500 t 500 550 t -500 500 T 150 600 z"/></g>
                        </svg>
                    </div>
                </div>
            {%- endset %}
            <a href="/dashboard" class="app-logo flex-shrink-0">
                {% if global_settings is defined and global_settings.company_logo is defined and global_settings.company_logo %}
                    <img src="/uploads/{{ global_settings.company_logo }}" alt="{{ app_name }}" class="custom-logo">
                {% else %}
                    <svg class="custom-logo" viewBox="-2 -2 36 36" width="32" height="32" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <g transform="translate(16,16)">
                            <ellipse cx="0" cy="0" rx="14" ry="5.5" fill="url(#sg0)" opacity="0.9">
                                <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="3s" repeatCount="indefinite"/>
                            </ellipse>
                            <ellipse cx="0" cy="0" rx="14" ry="5.5" fill="url(#sg1)" opacity="0.9">
                                <animateTransform attributeName="transform" type="rotate" from="60" to="420" dur="3s" repeatCount="indefinite"/>
                            </ellipse>
                            <ellipse cx="0" cy="0" rx="14" ry="5.5" fill="url(#sg2)" opacity="0.9">
                                <animateTransform attributeName="transform" type="rotate" from="120" to="480" dur="3s" repeatCount="indefinite"/>
                            </ellipse>
                            <circle cx="0" cy="0" r="4.5" fill="white" opacity="0.95"/>
                        </g>
                        <defs>
                            <linearGradient id="sg0" x1="-14" y1="0" x2="14" y2="0" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#A8ECF9"/><stop offset="1" stop-color="#6EA8FE"/>
                            </linearGradient>
                            <linearGradient id="sg1" x1="-14" y1="0" x2="14" y2="0" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#6EA8FE"/><stop offset="1" stop-color="#a78bfa"/>
                            </linearGradient>
                            <linearGradient id="sg2" x1="-14" y1="0" x2="14" y2="0" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#a78bfa"/><stop offset="1" stop-color="#A8ECF9"/>
                            </linearGradient>
                        </defs>
                    </svg>
                {% endif %}
                <span class="app-logo-text ms-2 fw-700 fs-md text-truncate" style="position:relative;z-index:2;">{{ app_name }}</span>
                {{ _logo_blobs|raw }}
            </a>

            {# Mobile hamburger #}
            <button class="mobile-menu-icon me-2 d-flex d-sm-flex d-md-flex d-lg-none flex-shrink-0"
                    data-action="toggle-swap" data-toggleclass="app-mobile-menu-open"
                    aria-label="Menü öffnen">
                <svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#menu"></use></svg>
            </button>

            {# Desktop sidebar collapse #}
            <button type="button" class="collapse-icon me-3 d-none d-lg-inline-flex d-xl-inline-flex d-xxl-inline-flex"
                    data-action="toggle" data-class="set-nav-minified"
                    aria-label="Navigation minimieren">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 5 8">
                    <polygon fill="#878787" points="4.5,1 3.8,0.2 0,4 3.8,7.8 4.5,7 1.5,4"/>
                </svg>
            </button>

            {# Search #}
            <div class="app-search position-relative" id="global-search-wrap" autocomplete="off">
                <input type="text" class="form-control" placeholder="Suchen…" id="global-search-input"
                       autocomplete="off" spellcheck="false" role="combobox" aria-expanded="false"
                       aria-autocomplete="list" aria-controls="global-search-dropdown">
                <div id="global-search-dropdown"
                     style="display:none;position:absolute;top:calc(100% + 6px);left:0;right:0;z-index:9999;
                            background:var(--bs-body-bg);border:1px solid var(--bs-border-color);
                            border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.18);
                            min-width:320px;max-height:420px;overflow-y:auto;">
                </div>
            </div>
            <script>
            (function(){
                var inp   = document.getElementById('global-search-input');
                var drop  = document.getElementById('global-search-dropdown');
                var timer = null;
                var currentPatientId = null;

                function esc(s){ return String(s).replace(/[&<>"']/g,function(c){return({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];}); }

                function statusColor(s){
                    return s==='aktiv'?'#22c55e':s==='verstorben'?'#6b7280':s==='inaktiv'?'#6b7280':'#f59e0b';
                }

                function renderResults(items){
                    if(!items.length){
                        drop.innerHTML='<div style="padding:1rem 1.25rem;font-size:.85rem;color:var(--bs-secondary-color);">Keine Ergebnisse</div>';
                        return;
                    }
                    var html='';
                    var patients = items.filter(function(i){return i.type==='patient';});
                    var owners   = items.filter(function(i){return i.type==='owner';});

                    if(patients.length){
                        html+='<div style="padding:.45rem 1rem .2rem;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--bs-secondary-color);">Patienten</div>';
                        patients.forEach(function(p){
                            html+='<button type="button" class="gs-item" data-type="patient" data-id="'+p.id+'" '
                                +'style="display:flex;align-items:center;gap:.75rem;width:100%;border:none;background:transparent;'
                                +'padding:.55rem 1rem;cursor:pointer;text-align:left;transition:background .12s;"'
                                +' onmouseenter="this.style.background=\'var(--bs-tertiary-bg)\'" onmouseleave="this.style.background=\'transparent\'">';
                            html+='<span style="width:32px;height:32px;border-radius:50%;background:var(--bs-tertiary-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;">';
                            if(p.photo){
                                html+='<img src="/patienten/'+p.id+'/foto/'+esc(p.photo)+'" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">';
                            } else {
                                html+='<svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';
                            }
                            html+='</span>';
                            html+='<span style="min-width:0;flex:1;">';
                            html+='<span style="display:flex;align-items:center;gap:.4rem;"><strong style="font-size:.875rem;">'+esc(p.name)+'</strong>';
                            if(p.status) html+='<span style="width:8px;height:8px;border-radius:50%;background:'+statusColor(p.status)+';flex-shrink:0;"></span>';
                            html+='</span>';
                            if(p.sub) html+='<span style="font-size:.75rem;color:var(--bs-secondary-color);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block;">'+esc(p.sub)+'</span>';
                            html+='</span></button>';
                        });
                    }

                    if(owners.length){
                        html+='<div style="padding:.45rem 1rem .2rem;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--bs-secondary-color);border-top:1px solid var(--bs-border-color);margin-top:.25rem;">Tierhalter</div>';
                        owners.forEach(function(o){
                            html+='<button type="button" class="gs-item" data-type="owner" data-id="'+o.id+'" '
                                +'style="display:flex;align-items:center;gap:.75rem;width:100%;border:none;background:transparent;'
                                +'padding:.55rem 1rem;cursor:pointer;text-align:left;transition:background .12s;"'
                                +' onmouseenter="this.style.background=\'var(--bs-tertiary-bg)\'" onmouseleave="this.style.background=\'transparent\'">';
                            html+='<span style="width:32px;height:32px;border-radius:50%;background:var(--bs-tertiary-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.8rem;font-weight:700;color:var(--bs-secondary-color);">'
                                +esc((o.name||'?').split(' ').map(function(w){return w[0]||'';}).join('').substring(0,2).toUpperCase())
                                +'</span>';
                            html+='<span style="min-width:0;flex:1;">';
                            html+='<strong style="font-size:.875rem;">'+esc(o.name)+'</strong>';
                            if(o.sub) html+='<span style="font-size:.75rem;color:var(--bs-secondary-color);display:block;">'+esc(o.sub)+'</span>';
                            if(o.animals && o.animals.length){
                                html+='<span style="font-size:.7rem;color:var(--bs-secondary-color);">🐾 ';
                                html+=o.animals.map(function(a){return esc(a.name);}).join(', ');
                                html+='</span>';
                            }
                            html+='</span></button>';
                        });
                    }
                    drop.innerHTML = html;

                    drop.querySelectorAll('.gs-item').forEach(function(btn){
                        btn.addEventListener('click', function(){
                            var type = this.dataset.type;
                            var id   = parseInt(this.dataset.id);
                            closeDropdown();
                            inp.value = '';
                            if(type === 'patient'){
                                openPatientFromSearch(id);
                            } else {
                                window.location.href = '/tierhalter/' + id;
                            }
                        });
                    });
                }

                function openPatientFromSearch(id){
                    if(typeof window._gsOpenPatient === 'function'){
                        window._gsOpenPatient(id);
                    } else {
                        window.location.href = '/patienten/' + id;
                    }
                }

                function closeDropdown(){
                    drop.style.display = 'none';
                    inp.setAttribute('aria-expanded','false');
                }

                inp.addEventListener('input', function(){
                    clearTimeout(timer);
                    var q = inp.value.trim();
                    if(q.length < 2){ closeDropdown(); return; }
                    timer = setTimeout(function(){
                        fetch('/api/global-search?q=' + encodeURIComponent(q))
                            .then(function(r){ return r.json(); })
                            .then(function(data){
                                drop.style.display = 'block';
                                inp.setAttribute('aria-expanded','true');
                                renderResults(data);
                            })
                            .catch(function(){ closeDropdown(); });
                    }, 220);
                });

                inp.addEventListener('keydown', function(e){
                    if(e.key === 'Escape') closeDropdown();
                });

                document.addEventListener('click', function(e){
                    if(!document.getElementById('global-search-wrap').contains(e.target)) closeDropdown();
                });
            })();
            </script>
        </div>

        {# Neuer Termin — global header button #}
        <button type="button" class="btn btn-system" id="btn-global-new-apt"
                title="Neuen Termin erstellen" aria-label="Neuen Termin erstellen">
            <svg class="sa-icon sa-icon-2x" fill="none" viewBox="0 0 24 24">
                <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.7"/>
                <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.7"/>
                <line x1="12" y1="14" x2="12" y2="18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                <line x1="10" y1="16" x2="14" y2="16" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
            </svg>
        </button>

        {# Settings drawer toggle #}
        <button type="button" class="btn btn-system hidden-mobile"
                data-action="toggle-swap" data-toggleclass="open"
                data-target="aside.js-drawer-settings"
                aria-label="Einstellungen">
            <svg class="sa-icon sa-icon-2x">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#settings"></use>
            </svg>
        </button>

        {# Dark / Light toggle #}
        <button type="button" class="btn btn-system" data-action="toggle-theme"
                aria-label="Dark/Light Mode" aria-pressed="false">
            <svg class="sa-icon sa-icon-2x sa-mode-light">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#sun"></use>
            </svg>
            <svg class="sa-icon sa-icon-2x sa-mode-dark">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#moon"></use>
            </svg>
        </button>

        {# App Drawer toggle — Nachrichten #}
        <button type="button" class="btn btn-system position-relative"
                data-action="toggle-swap" data-toggleclass="open" data-target="aside.js-app-drawer"
                aria-label="Nachrichten öffnen" id="btn-app-drawer-toggle">
            <span id="drawer-header-badge" class="badge badge-icon pos-top pos-end" style="display:none;background:#ef4444;"></span>
            <svg class="sa-icon sa-icon-2x">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#message-square"></use>
            </svg>
        </button>

        {# Fullscreen — CSS-based, persists across page navigation via saveloadscript.js #}
        <button type="button" class="btn btn-system d-none d-sm-block d-sm-none d-md-none d-lg-block"
                data-action="toggle" data-class="set-fullscreen" aria-label="Vollbild">
            <svg class="sa-icon sa-icon-2x sa-fullscreen-on">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#minimize"></use>
            </svg>
            <svg class="sa-icon sa-icon-2x sa-fullscreen-off">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#maximize"></use>
            </svg>
        </button>

        {# Notifications (intake plugin) #}
        {% if intake_unread_count is defined %}
        <button type="button" class="btn btn-system dropdown-toggle no-arrow"
                data-bs-toggle="dropdown" aria-expanded="false" aria-label="Benachrichtigungen">
            {% if intake_unread_count > 0 %}
            <span class="badge badge-icon pos-top pos-end">{{ intake_unread_count > 9 ? '9+' : intake_unread_count }}</span>
            {% endif %}
            <svg class="sa-icon sa-icon-2x">
                <use href="/themes/smart-tierphysio/icons/sprite.svg#bell"></use>
            </svg>
        </button>
        <div class="dropdown-menu dropdown-menu-animated dropdown-xl dropdown-menu-end p-0">
            <div class="notification-header rounded-top mb-2">
                <h4 class="m-0">
                    {{ intake_unread_count ?? 0 }} Neu
                    <small class="mb-0 opacity-80">Patientenanmeldungen</small>
                </h4>
            </div>
            <div class="custom-scroll" style="max-height:320px;overflow-y:auto;">
                {% if intake_latest is defined and intake_latest|length > 0 %}
                <ul class="notification">
                    {% for item in intake_latest %}
                    <li class="unread alert alert-dismissable">
                        <a href="/eingangsmeldungen/{{ item.id }}" class="d-flex align-items-center text-decoration-none">
                            <span class="d-flex flex-column flex-1 ms-1">
                                <span class="name">🐾 {{ item.patient_name }}</span>
                                <span class="msg-a fs-sm">{{ item.owner_first_name }} {{ item.owner_last_name }}</span>
                                <span class="fs-nano text-muted mt-1">{{ item.created_at|datetime_de }}</span>
                            </span>
                        </a>
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <div class="p-4 text-center text-muted fs-sm">Keine neuen Anmeldungen 🎉</div>
                {% endif %}
            </div>
            <div class="py-2 px-3 d-block rounded-bottom text-end border-light border-bottom-0 border-end-0 border-start-0">
                <a href="/eingangsmeldungen" class="fs-xs fw-500">Alle anzeigen →</a>
            </div>
        </div>
        {% endif %}

        {# User avatar + dropdown #}
        <button type="button" data-bs-toggle="dropdown"
                title="{{ current_user.email ?? current_user.name }}"
                class="btn-system bg-transparent d-flex flex-shrink-0 align-items-center justify-content-center"
                aria-label="Benutzermenü">
            <span class="profile-image profile-image-md rounded-circle d-flex align-items-center justify-content-center fw-700"
                  style="background:var(--bs-primary);color:#fff;font-size:.72rem;width:36px;height:36px;">
                {{ current_user.name|initials }}
            </span>
        </button>
        <div class="dropdown-menu dropdown-menu-animated dropdown-menu-end">
            <div class="notification-header rounded-top mb-2">
                <div class="d-flex flex-row align-items-center mt-1 mb-1 color-white">
                    <span class="status status-success d-inline-block me-2">
                        <span class="profile-image rounded-circle d-flex align-items-center justify-content-center fw-700"
                              style="background:var(--bs-primary);color:#fff;font-size:.72rem;width:40px;height:40px;">
                            {{ current_user.name|initials }}
                        </span>
                    </span>
                    <div class="info-card-text">
                        <div class="fs-lg text-truncate text-truncate-lg">{{ current_user.name }}</div>
                        <span class="text-truncate text-truncate-md opacity-80 fs-sm">
                            {{ current_user.email ?? (current_user.role == 'admin' ? 'Administrator' : 'Mitarbeiter') }}
                        </span>
                    </div>
                </div>
            </div>
            <div class="dropdown-divider m-0"></div>
            <a href="/einstellungen" class="dropdown-item" role="button">
                <svg class="sa-icon me-1"><use href="/themes/smart-tierphysio/icons/sprite.svg#settings"></use></svg>
                Einstellungen
            </a>
            <a href="/profil" class="dropdown-item" role="button">
                <svg class="sa-icon me-1"><use href="/themes/smart-tierphysio/icons/sprite.svg#user"></use></svg>
                Profil
            </a>
            <div class="dropdown-divider m-0"></div>
            <form action="/logout" method="POST" style="margin:0;">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <button type="submit" class="dropdown-item d-flex justify-content-between align-items-center py-3 fw-500">
                    <span class="text-danger">Abmelden</span>
                    <span class="d-block text-truncate text-truncate-sm text-muted fs-xs">{{ current_user.name }}</span>
                </button>
            </form>
        </div>
    </header>

    {# ═══════════════════════════════════════════════════════
       SIDEBAR
       ═══════════════════════════════════════════════════════ #}
    <aside class="app-sidebar d-flex flex-column">

        {# Logo in Sidebar — SmartAdmin CSS shows/hides based on layout class #}
        <a href="/dashboard" class="app-logo flex-shrink-0">
            {% if global_settings is defined and global_settings.company_logo is defined and global_settings.company_logo %}
                <img src="/uploads/{{ global_settings.company_logo }}" alt="{{ app_name }}" class="custom-logo">
            {% else %}
                <svg class="custom-logo" viewBox="-2 -2 36 36" width="32" height="32" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <g transform="translate(16,16)">
                        <ellipse cx="0" cy="0" rx="14" ry="5.5" fill="url(#sg0b)" opacity="0.9">
                            <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="3s" repeatCount="indefinite"/>
                        </ellipse>
                        <ellipse cx="0" cy="0" rx="14" ry="5.5" fill="url(#sg1b)" opacity="0.9">
                            <animateTransform attributeName="transform" type="rotate" from="60" to="420" dur="3s" repeatCount="indefinite"/>
                        </ellipse>
                        <ellipse cx="0" cy="0" rx="14" ry="5.5" fill="url(#sg2b)" opacity="0.9">
                            <animateTransform attributeName="transform" type="rotate" from="120" to="480" dur="3s" repeatCount="indefinite"/>
                        </ellipse>
                        <circle cx="0" cy="0" r="4.5" fill="white" opacity="0.95"/>
                    </g>
                    <defs>
                        <linearGradient id="sg0b" x1="-14" y1="0" x2="14" y2="0" gradientUnits="userSpaceOnUse">
                            <stop stop-color="#A8ECF9"/><stop offset="1" stop-color="#6EA8FE"/>
                        </linearGradient>
                        <linearGradient id="sg1b" x1="-14" y1="0" x2="14" y2="0" gradientUnits="userSpaceOnUse">
                            <stop stop-color="#6EA8FE"/><stop offset="1" stop-color="#a78bfa"/>
                        </linearGradient>
                        <linearGradient id="sg2b" x1="-14" y1="0" x2="14" y2="0" gradientUnits="userSpaceOnUse">
                            <stop stop-color="#a78bfa"/><stop offset="1" stop-color="#A8ECF9"/>
                        </linearGradient>
                    </defs>
                </svg>
            {% endif %}
            <span class="app-logo-text ms-2 fw-700 fs-md text-truncate" style="position:relative;z-index:2;">{{ app_name }}</span>
            <div class="logo-backdrop">
                <div class="blobs">
