{# ═══════════════════════════════════════════════════════
   SCRIPTS — loaded at bottom like in dist/index.html
   ═══════════════════════════════════════════════════════ #}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="/themes/smart-tierphysio/plugins/bootstrap/bootstrap.bundle.min.js"></script>
<script src="/themes/smart-tierphysio/scripts/core/smartNavigation.js"></script>
<script src="/themes/smart-tierphysio/scripts/core/smartFilter.js"></script>
<script src="/themes/smart-tierphysio/scripts/core/smartSlimscroll.js"></script>
<script src="/themes/smart-tierphysio/plugins/sortablejs/Sortable.min.js"></script>
<script src="/themes/smart-tierphysio/plugins/waves/waves.min.js"></script>
<script src="/themes/smart-tierphysio/scripts/core/smartApp.js"></script>

<script>
/* ═══════════════════════════════════════════════════════
   SmartTierphysio — Bridge JS
   ═══════════════════════════════════════════════════════ */
(function () {
    'use strict';

    /* ── 1. Modal System — wraps Bootstrap 5 API ── */
    function openModal(id) {
        var el = document.getElementById(id);
        if (!el) return;
        bootstrap.Modal.getOrCreateInstance(el).show();
    }
    function closeModal(id) {
        if (id) {
            var el = document.getElementById(id);
            if (el) bootstrap.Modal.getOrCreateInstance(el).hide();
        } else {
            document.querySelectorAll('.modal.show').forEach(function (m) {
                bootstrap.Modal.getOrCreateInstance(m).hide();
            });
        }
    }
    window.openModal  = openModal;
    window.closeModal = closeModal;

    /* delegate legacy [data-modal-open/close] */
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-modal-open]');
        if (btn) { e.preventDefault(); openModal(btn.getAttribute('data-modal-open')); return; }
        var cls = e.target.closest('[data-modal-close]');
        if (cls) { e.preventDefault(); closeModal(cls.getAttribute('data-modal-close')); return; }
    });

    /* ── 2. Settings Tabs (delegated) ── */
    document.addEventListener('click', function (e) {
        var tab = e.target.closest('.settings-tab');
        if (!tab) return;
        var tabId = tab.getAttribute('data-tab');
        if (!tabId) return;
        var container = tab.closest('.settings-tabs');
        if (container) container.querySelectorAll('.settings-tab').forEach(function (t) { t.classList.remove('active'); });
        document.querySelectorAll('.settings-tab-content').forEach(function (c) { c.classList.remove('active'); });
        tab.classList.add('active');
        var content = document.getElementById('tab-' + tabId);
        if (content) content.classList.add('active');
        try { sessionStorage.setItem('activeSettingsTab', tabId); } catch (ex) {}
    });
    (function () {
        var tabs = document.querySelectorAll('.settings-tab');
        if (!tabs.length) return;
        try {
            var saved = sessionStorage.getItem('activeSettingsTab');
            var target = saved ? document.querySelector('.settings-tab[data-tab="' + saved + '"]') : null;
            if (!target) target = tabs[0];
            if (target) target.click();
        } catch (e) { if (tabs[0]) tabs[0].click(); }
    })();

    /* ── 3. data-confirm ── */
    document.addEventListener('submit', function (e) {
        var msg = e.target.getAttribute('data-confirm');
        if (msg && !confirm(msg)) e.preventDefault();
    });
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-confirm]:not(form)');
        if (btn) {
            var msg = btn.getAttribute('data-confirm');
            if (msg && !confirm(msg)) e.preventDefault();
        }
    });

    /* ── 4. Auto-dismiss alerts ── */
    document.querySelectorAll('[data-auto-dismiss]').forEach(function (el) {
        var t = parseInt(el.getAttribute('data-auto-dismiss')) || 5000;
        setTimeout(function () {
            el.style.transition = 'opacity .4s';
            el.style.opacity = '0';
            setTimeout(function () { el.remove(); }, 400);
        }, t);
    });

    /* ── 5. Sync colour theme radio from localStorage ── */
    (function () {
        try {
            var cfg = JSON.parse(localStorage.getItem('layoutSettings') || '{}');
            var savedStyle = cfg.themeStyle || '';
            document.querySelectorAll('[data-action="theme-style"]').forEach(function (r) {
                r.checked = (r.getAttribute('data-theme-style') === savedStyle);
            });
        } catch (e) {}
    })();

})();
</script>

