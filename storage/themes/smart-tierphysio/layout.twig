<script>
(function(){
    var _formDataLoaded = false;
    var _gapt_csrf     = document.querySelector('meta[name="csrf-token"]')?.content || '{{ csrf_token }}';

    function pad(n){ return String(n).padStart(2,'0'); }
    function fmtLocal(d){ return d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate())+'T'+pad(d.getHours())+':'+pad(d.getMinutes()); }

    function loadFormData() {
        if (_formDataLoaded) return;
        _formDataLoaded = true;
        fetch('/api/kalender/form-data')
            .then(function(r){ return r.json(); })
            .then(function(data){
                var pSel = document.getElementById('gapt-patient');
                var oSel = document.getElementById('gapt-owner');
                var tSel = document.getElementById('gapt-treatment');
                (data.patients||[]).forEach(function(p){
                    var o = new Option(p.name + (p.species ? ' ('+p.species+')' : ''), p.id);
                    pSel.appendChild(o);
                });
                (data.owners||[]).forEach(function(o){
                    var opt = new Option(o.first_name + ' ' + o.last_name, o.id);
                    oSel.appendChild(opt);
                });
                (data.treatment_types||[]).forEach(function(tt){
                    var opt = new Option(tt.name, tt.id);
                    if (tt.color) opt.dataset.color = tt.color;
                    tSel.appendChild(opt);
                });
            })
            .catch(function(){});
    }

    document.getElementById('btn-global-new-apt').addEventListener('click', function(){
        loadFormData();
        var now = new Date();
        var end = new Date(now.getTime() + 60*60*1000);
        document.getElementById('form-global-apt').reset();
        document.getElementById('gapt-start').value = fmtLocal(now);
        document.getElementById('gapt-end').value   = fmtLocal(end);
        document.getElementById('gapt-color').value = '#4f7cff';
        // Clear manual flag for auto-title generation
        document.getElementById('gapt-title').removeAttribute('data-manual');
        bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-global-apt')).show();
        setTimeout(function(){ document.getElementById('gapt-title').focus(); }, 300);
    });

    document.getElementById('gapt-treatment').addEventListener('change', function(){
        var opt = this.options[this.selectedIndex];
        if (opt && opt.dataset.color) document.getElementById('gapt-color').value = opt.dataset.color;
    });

    document.getElementById('gapt-start').addEventListener('change', function(){
        var s = new Date(this.value);
        if (!isNaN(s)){
            document.getElementById('gapt-end').value = fmtLocal(new Date(s.getTime()+60*60*1000));
        }
    });

    /* Owner change → filter patients */
    document.getElementById('gapt-owner').addEventListener('change', async function() {
        const ownerSelect = this;
        const patientSelect = document.getElementById('gapt-patient');
        const ownerId = ownerSelect.value;
        
        // Store current patient value
        const currentPatientId = patientSelect.value;
        
        if (!ownerId) {
            // Reset to all patients
            const response = await fetch('/api/kalender/form-data');
            const data = await response.json();
            patientSelect.innerHTML = '<option value="">— kein Patient —</option>';
            data.patients.forEach(p => {
                const opt = document.createElement('option');
                opt.value = p.id;
                opt.textContent = `${p.name}${p.species ? ' (' + p.species + ')' : ''}`;
                patientSelect.appendChild(opt);
            });
            // Restore selection if possible
            if (currentPatientId) patientSelect.value = currentPatientId;
            updateGlobalAutoTitle();
            return;
        }

        // Load patients for this owner
        try {
            // Use the existing form-data API since patients-by-owner API is not working
            const response = await fetch('/api/kalender/form-data');
            const data = await response.json();
            const allPatients = data.patients || [];
            const patients = allPatients.filter(p => p.owner_id == ownerId);
            
            patientSelect.innerHTML = '<option value="">— kein Patient —</option>';
            patients.forEach(p => {
                const opt = document.createElement('option');
                opt.value = p.id;
                opt.textContent = `${p.name}${p.species ? ' (' + p.species + ')' : ''}`;
                patientSelect.appendChild(opt);
            });
            
            // Auto-select first patient if none was selected before
            if (!currentPatientId && patients.length > 0) {
                patientSelect.value = patients[0].id;
            } else if (currentPatientId) {
                // Try to restore previous selection if it's still in the list
                const exists = Array.from(patientSelect.options).some(opt => opt.value === currentPatientId);
                if (exists) {
                    patientSelect.value = currentPatientId;
                }
            }
            updateGlobalAutoTitle();
        } catch (error) {
            console.error('Failed to load patients:', error);
        }
    });

    /* Patient change → auto-select owner */
    document.getElementById('gapt-patient').addEventListener('change', async function() {
        const patientSelect = this;
        const ownerSelect = document.getElementById('gapt-owner');
        const patientId = patientSelect.value;
        
        if (!patientId) {
            // Don't change owner when patient is cleared
            updateGlobalAutoTitle();
            return;
        }

        // Get patient data to find owner
        try {
            const response = await fetch('/api/kalender/form-data');
            const data = await response.json();
            const patient = data.patients.find(p => p.id == patientId);
            
            if (patient && patient.owner_id) {
                // Check if owner is already selected to avoid circular updates
                if (ownerSelect.value != patient.owner_id) {
                    // Auto-select the owner
                    ownerSelect.value = patient.owner_id;
                    
                    // Store current patient selection
                    const currentPatientId = patientSelect.value;
                    
                    // Trigger owner change to filter patients properly
                    const event = new Event('change', { bubbles: true });
                    ownerSelect.dispatchEvent(event);
                    
                    // Restore patient selection after filtering
                    setTimeout(() => {
                        const patientOptions = Array.from(patientSelect.options);
                        const exists = patientOptions.some(opt => opt.value === currentPatientId);
                        
                        if (exists) {
                            patientSelect.value = currentPatientId;
                        }
                        updateGlobalAutoTitle();
                    }, 200);
                } else {
                    updateGlobalAutoTitle();
                }
            }
        } catch (error) {
            console.error('Failed to get patient data:', error);
        }
    });

    /* Auto-generate title from owner, patient, and treatment type */
    function updateGlobalAutoTitle() {
        const titleField = document.getElementById('gapt-title');
        const ownerSelect = document.getElementById('gapt-owner');
        const patientSelect = document.getElementById('gapt-patient');
        const treatmentSelect = document.getElementById('gapt-treatment');
        
        const ownerOption = ownerSelect.options[ownerSelect.selectedIndex];
        const patientOption = patientSelect.options[patientSelect.selectedIndex];
        const treatmentOption = treatmentSelect.options[treatmentSelect.selectedIndex];
        
        const ownerName = ownerSelect.value ? (ownerOption.textContent || '') : '';
        const patientName = patientSelect.value ? (patientOption.textContent || '') : '';
        const treatmentName = treatmentSelect.value ? (treatmentOption.textContent || '') : '';
        
        // Only auto-generate if user hasn't manually changed the title
        if (!titleField.hasAttribute('data-manual')) {
            let newTitle = '';
            
            if (ownerName && patientName) {
                // Format: "Nachname, Tiername – Behandlung"
                const ownerLastName = ownerName.split(' ').pop() || ownerName; // Get last word (last name)
                const patientCleanName = patientName.split(' (')[0] || patientName; // Remove species from patient name
                newTitle = `${ownerLastName}, ${patientCleanName}`;
                
                if (treatmentName) {
                    newTitle += ` – ${treatmentName}`;
                }
            } else if (patientName && treatmentName) {
                // Fallback: "Tiername – Behandlung"
                const patientCleanName = patientName.split(' (')[0] || patientName;
                newTitle = `${patientCleanName} – ${treatmentName}`;
            } else if (patientName) {
                // Fallback: Just patient name
                const patientCleanName = patientName.split(' (')[0] || patientName;
                newTitle = patientCleanName;
            }
            
            if (newTitle && newTitle !== titleField.value) {
                titleField.value = newTitle;
            }
        }
    }

    // Track manual title changes
    document.getElementById('gapt-title').addEventListener('input', function() {
        this.setAttribute('data-manual', 'true');
    });

    // Add event listeners for auto-title generation
    document.getElementById('gapt-owner').addEventListener('change', updateGlobalAutoTitle);
    document.getElementById('gapt-patient').addEventListener('change', updateGlobalAutoTitle);
    document.getElementById('gapt-treatment').addEventListener('change', updateGlobalAutoTitle);

    document.getElementById('form-global-apt').addEventListener('submit', async function(e){
        e.preventDefault();
        var data = new FormData(this);
        data.set('_csrf_token', _gapt_csrf);
        if (document.getElementById('gapt-allday').checked) data.set('all_day','1');
        var btn = this.querySelector('[type=submit]');
        btn.disabled = true;
        try {
            var res  = await fetch('/api/kalender/events', { method:'POST', body:data });
            var json = await res.json();
            if (json.success) {
                bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-global-apt')).hide();
                if (typeof window.showAppToast === 'function') {
                    window.showAppToast({ type:'success', title:'Termin erstellt', message: json.event?.title || 'Neuer Termin gespeichert' }, 4000);
                }
                if (typeof window._globalCalendar !== 'undefined' && window._globalCalendar?.refetchEvents) {
                    window._globalCalendar.refetchEvents();
                }
            } else {
                alert(json.error || 'Fehler beim Speichern.');
            }
        } catch(err) {
            alert('Netzwerkfehler: ' + err.message);
        }
        btn.disabled = false;
    });

    /* Expose opener globally so other scripts can trigger it with pre-filled data */
    window.openGlobalNewApt = function(opts) {
        loadFormData();
        opts = opts || {};
        document.getElementById('form-global-apt').reset();
        var now = new Date();
        var end = new Date(now.getTime()+60*60*1000);
        document.getElementById('gapt-start').value = opts.start || fmtLocal(now);
        document.getElementById('gapt-end').value   = opts.end   || fmtLocal(end);
        document.getElementById('gapt-color').value = '#4f7cff';
        // Clear manual flag for auto-title generation
        document.getElementById('gapt-title').removeAttribute('data-manual');
        if (opts.patient_id) {
            setTimeout(function(){ 
                document.getElementById('gapt-patient').value = opts.patient_id; 
                updateGlobalAutoTitle();
            }, 400);
        }
        if (opts.owner_id) {
            setTimeout(function(){ 
                document.getElementById('gapt-owner').value = opts.owner_id; 
                // Trigger patient filtering and title update
                const event = new Event('change', { bubbles: true });
                document.getElementById('gapt-owner').dispatchEvent(event);
            }, 400);
        }
        bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-global-apt')).show();
        setTimeout(function(){ document.getElementById('gapt-title').focus(); }, 300);
    };
})();
</script>

<script>
(function(){
    var _drawerLoaded    = false;
    var _drawerUsers     = [];
    var _activeThreadId  = null;
    var _activeThreadStatus = 'open';
    var _csrfMeta        = document.querySelector('meta[name="csrf-token"]');
    var _csrf            = _csrfMeta ? _csrfMeta.getAttribute('content') : '';

    var panelList   = document.getElementById('drawer-panel-list');
    var panelThread = document.getElementById('drawer-panel-thread');

    function esc(s){
        var r = {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'};
        return String(s||'').replace(/[&<>"]/g,function(c){ return r[c]; });
    }

    function relTime(dateStr){
        if(!dateStr) return '';
        var d   = new Date(dateStr.replace(' ','T'));
        var now = new Date();
        var diff = Math.floor((now - d)/1000);
        if(diff < 60)   return 'Gerade eben';
        if(diff < 3600) return Math.floor(diff/60) + ' Min.';
        if(diff < 86400) return Math.floor(diff/3600) + ' Std.';
        return d.toLocaleDateString('de-DE', {day:'2-digit',month:'2-digit'});
    }

    /* ── Show / hide panels ── */
    function showListPanel(){
        panelList.style.display   = 'flex';
        panelThread.style.display = 'none';
        _activeThreadId = null;
    }

    function showThreadPanel(threadId, subject, status){
        _activeThreadId     = threadId;
        _activeThreadStatus = status || 'open';
        document.getElementById('drawer-thread-subject').textContent = subject || '';
        document.getElementById('drawer-thread-fullpage').href = '/portal-admin/nachrichten/' + threadId;

        var msgList   = document.getElementById('drawer-msg-list');
        var replyArea = document.getElementById('drawer-reply-area');
        var closedNote = document.getElementById('drawer-thread-closed-note');

        msgList.innerHTML = '<div class="text-center text-muted py-4 fs-xs"><div class="spinner-border spinner-border-sm"></div></div>';

        if(_activeThreadStatus === 'closed'){
            replyArea.classList.add('d-none');
            closedNote.classList.remove('d-none');
        } else {
            replyArea.classList.remove('d-none');
            closedNote.classList.add('d-none');
            document.getElementById('drawer-reply-body').value = '';
            document.getElementById('drawer-reply-error').classList.add('d-none');
        }

        panelList.style.display   = 'none';
        panelThread.style.display = 'flex';

        /* Load messages */
        fetch('/api/portal-admin/nachrichten/' + threadId + '/messages')
            .then(function(r){ return r.ok ? r.json() : Promise.reject(r.status); })
            .then(function(data){
                renderMessages(data.messages || []);
            })
            .catch(function(){
                msgList.innerHTML = '<div class="text-center text-muted py-3 fs-xs">Fehler beim Laden</div>';
            });
    }

    function renderMessages(msgs){
        var msgList = document.getElementById('drawer-msg-list');
        if(!msgs.length){
            msgList.innerHTML = '<div class="text-center text-muted py-4 fs-xs">Keine Nachrichten</div>';
            return;
        }
        var html = '';
        msgs.forEach(function(m){
            var isAdmin = m.sender_type === 'admin';
            var name    = isAdmin ? esc(m.sender_name || 'Team') : 'Besitzer';
            var color   = isAdmin ? '#4f7cff' : '#22c55e';
            var align   = isAdmin ? 'flex-start' : 'flex-end';
            var bg      = isAdmin ? 'rgba(79,124,255,0.10)' : 'var(--bs-tertiary-bg)';
            var border  = isAdmin ? '1px solid rgba(79,124,255,0.2)' : '1px solid var(--bs-border-color)';
            var radius  = isAdmin ? '4px 10px 10px 10px' : '10px 4px 10px 10px';
            var bodyTxt = esc(m.body||'').replace(/\n/g,'<br>');
            html +=
                '<div style="display:flex;flex-direction:column;align-items:' + align + ';">'
                + '<span style="font-size:.65rem;color:' + color + ';font-weight:600;margin-bottom:2px;">' + name + '</span>'
                + '<div style="max-width:90%;padding:.5rem .75rem;border-radius:' + radius + ';background:' + bg + ';border:' + border + ';font-size:.8rem;line-height:1.5;">' + bodyTxt + '</div>'
                + '<span style="font-size:.6rem;color:var(--bs-secondary-color);margin-top:2px;">' + esc(m.created_at||'') + '</span>'
                + '</div>';
        });
        msgList.innerHTML = html;
        msgList.scrollTop = msgList.scrollHeight;
    }

    function appendDrawerMessage(m){
        var msgList = document.getElementById('drawer-msg-list');
        var isAdmin = m.sender_type === 'admin';
        var name    = isAdmin ? esc(m.sender_name || 'Team') : 'Besitzer';
        var color   = isAdmin ? '#4f7cff' : '#22c55e';
        var align   = isAdmin ? 'flex-start' : 'flex-end';
        var bg      = isAdmin ? 'rgba(79,124,255,0.10)' : 'var(--bs-tertiary-bg)';
        var border  = isAdmin ? '1px solid rgba(79,124,255,0.2)' : '1px solid var(--bs-border-color)';
        var radius  = isAdmin ? '4px 10px 10px 10px' : '10px 4px 10px 10px';
        var bodyTxt = esc(m.body||'').replace(/\n/g,'<br>');
        var wrap = document.createElement('div');
        wrap.style.cssText = 'display:flex;flex-direction:column;align-items:' + align + ';';
        wrap.innerHTML =
            '<span style="font-size:.65rem;color:' + color + ';font-weight:600;margin-bottom:2px;">' + name + '</span>'
            + '<div style="max-width:90%;padding:.5rem .75rem;border-radius:' + radius + ';background:' + bg + ';border:' + border + ';font-size:.8rem;line-height:1.5;">' + bodyTxt + '</div>'
            + '<span style="font-size:.6rem;color:var(--bs-secondary-color);margin-top:2px;">' + esc(m.created_at||'') + '</span>';
        msgList.appendChild(wrap);
        msgList.scrollTop = msgList.scrollHeight;
    }

    /* ── Load thread list ── */
    function loadDrawer(){
        fetch('/api/portal-admin/nachrichten-drawer')
            .then(function(r){ return r.ok ? r.json() : Promise.reject(r.status); })
            .then(function(data){
                var badge = document.getElementById('drawer-unread-badge');
                if(data.total_unread > 0){
                    badge.textContent = data.total_unread;
                    badge.style.display = '';
                } else {
                    badge.style.display = 'none';
                }
                updateHeaderBadge(data.total_unread);

                var list = document.getElementById('drawer-thread-list');
                if(!data.threads || data.threads.length === 0){
                    list.innerHTML = '<div class="text-center text-muted py-5 fs-sm">Keine Nachrichten</div>';
                    return;
                }
                var html = '';
                data.threads.forEach(function(t){
                    var unreadDot = t.unread > 0
                        ? '<span style="width:8px;height:8px;border-radius:50%;background:#ef4444;display:inline-block;flex-shrink:0;"></span>'
                        : '<span style="width:8px;height:8px;display:inline-block;flex-shrink:0;"></span>';
                    var statusBadge = t.status === 'closed'
                        ? '<span class="badge bg-secondary ms-1" style="font-size:.6rem;">Geschl.</span>'
                        : '';
                    html += '<button type="button"'
                        + ' data-tid="' + t.id + '"'
                        + ' data-subject="' + esc(t.subject) + '"'
                        + ' data-status="' + esc(t.status) + '"'
                        + ' class="drawer-thread-item d-flex align-items-start gap-2 px-2 py-2 rounded w-100 text-start border-0 bg-transparent'
                        + (t.unread > 0 ? ' fw-600' : '') + '">'
                        + '<span class="flex-shrink-0 mt-1">' + unreadDot + '</span>'
                        + '<span style="min-width:0;flex:1;">'
                        + '<span class="d-flex align-items-center gap-1">'
                        + '<span class="text-truncate fs-sm fw-600" style="max-width:140px;">' + esc(t.owner_name) + '</span>'
                        + statusBadge
                        + '<span class="ms-auto fs-nano text-muted flex-shrink-0">' + relTime(t.last_message) + '</span>'
                        + '</span>'
                        + '<span class="text-truncate fs-xs text-muted d-block">' + esc(t.subject) + '</span>'
                        + '</span>'
                        + '</button>';
                });
                list.innerHTML = html;

                /* Delegate clicks on thread buttons */
                list.querySelectorAll('.drawer-thread-item').forEach(function(btn){
                    btn.addEventListener('click', function(){
                        showThreadPanel(
                            parseInt(this.dataset.tid),
                            this.dataset.subject,
                            this.dataset.status
                        );
                    });
                });
            })
            .catch(function(){
                document.getElementById('drawer-thread-list').innerHTML =
                    '<div class="text-center text-muted py-3 fs-xs">Fehler beim Laden</div>';
            });
    }

    function updateHeaderBadge(count){
        var hBadge = document.getElementById('drawer-header-badge');
        if(!hBadge) return;
        if(count > 0){
            hBadge.textContent = count > 9 ? '9+' : count;
            hBadge.style.display = '';
        } else {
            hBadge.style.display = 'none';
        }
    }

    /* ── Back button ── */
    document.getElementById('drawer-back-btn').addEventListener('click', function(){
        showListPanel();
        loadDrawer();
    });

    /* ── Reply in drawer ── */
    document.getElementById('drawer-reply-btn').addEventListener('click', function(){
        if(!_activeThreadId) return;
        var body  = document.getElementById('drawer-reply-body').value.trim();
        var errEl = document.getElementById('drawer-reply-error');
        errEl.classList.add('d-none');
        if(!body){
            errEl.textContent = 'Bitte eine Nachricht eingeben.';
            errEl.classList.remove('d-none');
            return;
        }
        var btn = this;
        btn.disabled = true;
        var fd = new FormData();
        fd.append('_csrf_token', _csrf);
        fd.append('body', body);
        fetch('/api/portal-admin/nachrichten/' + _activeThreadId + '/antworten', { method:'POST', body:fd })
            .then(function(r){ return r.json(); })
            .then(function(data){
                if(data.ok){
                    document.getElementById('drawer-reply-body').value = '';
                    appendDrawerMessage({
                        sender_type: 'admin',
                        sender_name: data.sender_name || 'Team',
                        body: data.body,
                        created_at: data.created_at || ''
                    });
                    loadDrawer();
                } else {
                    errEl.textContent = data.error || 'Fehler.';
                    errEl.classList.remove('d-none');
                }
            })
            .catch(function(){
                errEl.textContent = 'Netzwerkfehler.';
                errEl.classList.remove('d-none');
            })
            .finally(function(){ btn.disabled = false; });
    });

    /* ── Open drawer → load threads ── */
    document.querySelectorAll('[data-target="aside.js-app-drawer"]').forEach(function(btn){
        btn.addEventListener('click', function(){
            showListPanel();
            if(!_drawerLoaded){
                _drawerLoaded = true;
                loadDrawer();
                fetch('/api/portal-admin/portal-users')
                    .then(function(r){ return r.ok ? r.json() : []; })
                    .then(function(users){
                        _drawerUsers = users;
                        var sel = document.getElementById('drawer-owner-select');
                        sel.innerHTML = '<option value="">— Tierhalter wählen —</option>';
                        users.forEach(function(u){
                            var opt = document.createElement('option');
                            opt.value = u.owner_id;
                            opt.textContent = u.first_name + ' ' + u.last_name + (u.email ? ' (' + u.email + ')' : '');
                            sel.appendChild(opt);
                        });
                    })
                    .catch(function(){});
            } else {
                loadDrawer();
            }
        });
    });

    /* ── Send new thread from drawer ── */
    document.getElementById('drawer-send-btn').addEventListener('click', function(){
        var ownerId = document.getElementById('drawer-owner-select').value;
        var subject = document.getElementById('drawer-subject').value.trim();
        var body    = document.getElementById('drawer-body').value.trim();
        var errEl   = document.getElementById('drawer-send-error');
        errEl.classList.add('d-none');
        if(!ownerId || !subject || !body){
            errEl.textContent = 'Bitte alle Felder ausfüllen.';
            errEl.classList.remove('d-none');
            return;
        }
        var fd = new FormData();
        fd.append('_csrf_token', _csrf);
        fd.append('owner_id', ownerId);
        fd.append('subject', subject);
        fd.append('body', body);
        var btn = this;
        btn.disabled = true;
        fetch('/api/portal-admin/nachrichten/neu', { method:'POST', body:fd })
            .then(function(r){ return r.json(); })
            .then(function(data){
                if(data.ok){
                    document.getElementById('drawer-subject').value = '';
                    document.getElementById('drawer-body').value = '';
                    document.getElementById('drawer-owner-select').value = '';
                    bootstrap.Collapse.getOrCreateInstance(document.getElementById('drawer-new-form')).hide();
                    loadDrawer();
                    if(typeof window.showAppToast === 'function'){
                        window.showAppToast({type:'success', title:'Gesendet', message:'Nachricht wurde übermittelt.'}, 3000);
                    }
                } else {
                    errEl.textContent = data.error || 'Fehler beim Senden.';
                    errEl.classList.remove('d-none');
                }
            })
            .catch(function(){
                errEl.textContent = 'Netzwerkfehler.';
                errEl.classList.remove('d-none');
            })
            .finally(function(){ btn.disabled = false; });
    });

    function refreshBadgeOnly(){
        fetch('/api/portal-admin/nachrichten-drawer')
            .then(function(r){ return r.ok ? r.json() : null; })
            .then(function(data){
                if(!data) return;
                updateHeaderBadge(data.total_unread);
                var badge = document.getElementById('drawer-unread-badge');
                if(badge){
                    if(data.total_unread > 0){
                        badge.textContent = data.total_unread;
                        badge.style.display = '';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            }).catch(function(){});
    }

    /* Initial badge on page load */
    refreshBadgeOnly();
    setInterval(refreshBadgeOnly, 60000);
})();
</script>

<script>
/* ── SearchableSelect: wiederverwendbare Such-Dropdown-Komponente ── */
window.SearchableSelect = (function(){
    'use strict';
    var CHEVRON = '<svg class="ss-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none"><polyline stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="6 9 12 15 18 9"/></svg>';

    function esc(s){ return String(s).replace(/[&<>"']/g,function(c){return({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]);}); }

    function highlight(text, q){
        if(!q) return esc(text);
        var re = new RegExp('('+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','gi');
        return esc(text).replace(re,'<mark>$1</mark>');
    }

    function SearchableSelect(opts){
        /* opts: { target: <select>, placeholder, onSelect } */
        var sel      = opts.target;
        var ph       = opts.placeholder || '— wählen —';
        var onSelect = opts.onSelect || null;
        var wrap, display, displayText, dropdown, searchInput, list;
        var items    = [];   /* [{value, label}] */
        var current  = {value: sel.value, label: ''};

        function build(){
            wrap = document.createElement('div');
            wrap.className = 'ss-wrap';

            display = document.createElement('div');
            display.className = 'ss-display';
            display.setAttribute('tabindex','0');
            display.setAttribute('role','combobox');
            display.setAttribute('aria-expanded','false');

            displayText = document.createElement('span');
            displayText.className = 'ss-display-text placeholder';
            displayText.textContent = ph;
            display.appendChild(displayText);
            display.insertAdjacentHTML('beforeend', CHEVRON);

            dropdown = document.createElement('div');
            dropdown.className = 'ss-dropdown';

            var searchWrap = document.createElement('div');
            searchWrap.className = 'ss-search-wrap';
            searchInput = document.createElement('input');
            searchInput.type = 'text';
            searchInput.className = 'ss-search';
            searchInput.placeholder = 'Suchen…';
            searchInput.setAttribute('autocomplete','off');
            searchWrap.appendChild(searchInput);
            dropdown.appendChild(searchWrap);

            list = document.createElement('div');
            list.className = 'ss-list';
            dropdown.appendChild(list);

            wrap.appendChild(display);
            wrap.appendChild(dropdown);

            sel.parentNode.insertBefore(wrap, sel);
            sel.style.display = 'none';
            wrap.appendChild(sel);
        }

        function readItems(){
            items = [];
            Array.from(sel.options).forEach(function(o){
                items.push({value: String(o.value), label: o.textContent.trim()});
            });
        }

        function renderList(q){
            q = (q||'').trim().toLowerCase();
            list.innerHTML = '';
            var shown = 0;
            items.forEach(function(item){
                if(!item.value) return;
                if(q && item.label.toLowerCase().indexOf(q) === -1) return;
                var div = document.createElement('div');
                div.className = 'ss-option' + (item.value === current.value ? ' selected' : '');
                div.dataset.value = item.value;
                div.innerHTML = highlight(item.label, q);
                div.addEventListener('mousedown', function(e){ e.preventDefault(); selectItem(item); });
                list.appendChild(div);
                shown++;
            });
            if(!shown){
                var empty = document.createElement('div');
                empty.className = 'ss-option ss-empty';
                empty.textContent = 'Keine Einträge gefunden';
                list.appendChild(empty);
            }
        }

        function selectItem(item){
            current = item;
            sel.value = item.value;
            displayText.textContent = item.label;
            displayText.classList.remove('placeholder');
            sel.dispatchEvent(new Event('change', {bubbles:true}));
            if(onSelect) onSelect(item.value, item.label);
            close();
        }

        function open(){
            readItems();
            renderList('');
            searchInput.value = '';
            wrap.classList.add('open');
            display.setAttribute('aria-expanded','true');
            setTimeout(function(){ searchInput.focus(); }, 10);
        }

        function close(){
            wrap.classList.remove('open');
            display.setAttribute('aria-expanded','false');
        }

        function syncFromSelect(){
            readItems();
            var val = String(sel.value);
            var found = items.find(function(i){ return i.value === val; });
            if(found && found.value){
                current = found;
                displayText.textContent = found.label;
                displayText.classList.remove('placeholder');
            } else {
                current = {value:'', label:''};
                displayText.textContent = ph;
                displayText.classList.add('placeholder');
            }
        }

        build();
        syncFromSelect();

        display.addEventListener('click', function(){ wrap.classList.contains('open') ? close() : open(); });
        display.addEventListener('keydown', function(e){
            if(e.key==='Enter'||e.key===' '){ e.preventDefault(); open(); }
            if(e.key==='Escape') close();
        });
        searchInput.addEventListener('input', function(){ renderList(this.value); });
        searchInput.addEventListener('keydown', function(e){
            if(e.key==='Escape'){ close(); display.focus(); }
        });

        document.addEventListener('click', function(e){
            if(!wrap.contains(e.target)) close();
        });

        /* public API */
        return {
            setItems: function(newItems, selectedVal){
                /* newItems: [{value, label}] */
                sel.innerHTML = '';
                var emptyOpt = document.createElement('option');
                emptyOpt.value = '';
                emptyOpt.textContent = ph;
                sel.appendChild(emptyOpt);
                newItems.forEach(function(i){
                    var o = document.createElement('option');
                    o.value = i.value;
                    o.textContent = i.label;
                    sel.appendChild(o);
                });
                sel.value = selectedVal || '';
                syncFromSelect();
            },
            getValue: function(){ return sel.value; },
            syncFromSelect: syncFromSelect
        };
    }

    return SearchableSelect;
})();
</script>

<script>
/* ── Vollbild: body.fullscreen-active mit html.set-fullscreen synchronisieren ── */
(function(){
    /* On page load: if set-fullscreen is already on <html> (restored by saveloadscript),
       also add fullscreen-active on <body> so SmartAdmin icon CSS works */
    if(document.documentElement.classList.contains('set-fullscreen')){
        document.body.classList.add('fullscreen-active');
    }

    /* Whenever the fullscreen button is clicked, mirror the class on <body> */
    document.addEventListener('click', function(e){
        var btn = e.target.closest('[data-action="toggle"][data-class="set-fullscreen"]');
        if(!btn) return;
        /* classList.toggle runs after this handler via smartApp, so use setTimeout */
        setTimeout(function(){
            var isOn = document.documentElement.classList.contains('set-fullscreen');
            document.body.classList.toggle('fullscreen-active', isOn);
        }, 0);
    });
})();
</script>

{% if google_sync_bridge_url is defined and google_sync_bridge_url %}
{# ── Google Calendar Sync Bridge — injected by google-calendar-sync plugin ── #}
<script>
(function() {
    var SYNC_URL  = {{ google_sync_bridge_url|json_encode|raw }};
    var CSRF_META = document.querySelector('meta[name="csrf-token"]');
    var csrfToken = CSRF_META ? CSRF_META.getAttribute('content') : '';

    function syncAppointment(id, action) {
        if (!id) return;
        var fd = new FormData();
        fd.append('_csrf_token', csrfToken);
        fd.append('action', action);
        fetch(SYNC_URL + '/' + id, { method: 'POST', body: fd })
            .catch(function() { /* never crash the UI */ });
    }

    /* Patch fetch to intercept calendar API responses */
    var _origFetch = window.fetch;
    window.fetch = function(input, init) {
        return _origFetch.apply(this, arguments).then(function(response) {
            try {
                var url    = typeof input === 'string' ? input : (input.url || '');
                var method = (init && init.method ? init.method : 'GET').toUpperCase();

                /* Only care about calendar API mutations */
                if (url.indexOf('/api/kalender/events') !== -1 && method === 'POST') {
                    var cloned = response.clone();
                    cloned.json().then(function(data) {
                        if (!data || !data.success) return;
                        var id = data.id || (data.event && data.event.id) || null;
                        if (!id) return;

                        /* Determine action from URL pattern */
                        var isDelete    = url.indexOf('/loeschen') !== -1;
                        var isReschedule = url.indexOf('/reschedule') !== -1;
                        var isUpdate    = !isDelete && url.match(/\/api\/kalender\/events\/\d+$/);
                        var action = isDelete ? 'delete' : (isUpdate || isReschedule ? 'update' : 'create');

                        syncAppointment(id, action);
                    }).catch(function() {});
                }
            } catch (e) {}
            return response;
        });
    };
})();
</script>
{% endif %}

