{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% block content %}

<div class="page-header">
    <div>
        <h1 class="page-title">Übungen — {{ owner.first_name }} {{ owner.last_name }}</h1>
        <p class="page-subtitle">Heimtraining für Tierbesitzer verwalten</p>
    </div>
    <a href="/portal-admin" class="btn btn-secondary btn-sm">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
        Portal-Verwaltung
    </a>
</div>

{% if success %}
<div class="alert alert-success alert-dismissible fade show" role="alert">
    {{ success }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}
{% if error %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    {{ error }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

{% if patients is empty %}
<div class="alert alert-warning">Keine Patienten für diesen Tierhalter gefunden.</div>
{% else %}

{# ── Per-patient accordion ── #}
<div class="accordion" id="acc-patients">
{% for patient in patients %}
{% set exList = exercises_by_patient[patient.id] ?? [] %}
<div class="card mb-3">
    <div class="card-header d-flex align-items-center justify-content-between gap-2 py-2 px-3"
         style="cursor:pointer;" data-bs-toggle="collapse"
         data-bs-target="#acc-pat-{{ patient.id }}" aria-expanded="true">
        <div class="d-flex align-items-center gap-2">
            <span class="fw-600">🐾 {{ patient.name }}</span>
            <span class="badge bg-secondary fs-nano">{{ patient.species }}</span>
            <span class="badge bg-primary fs-nano">{{ exList|length }} Übung{{ exList|length != 1 ? 'en' : '' }}</span>
        </div>
        <button type="button" class="btn btn-xs btn-primary"
                onclick="event.stopPropagation(); openAddExercise({{ patient.id }}, {{ patient.name|json_encode }});">
            <i class="fal fa-plus mr-1"></i> Übung hinzufügen
        </button>
    </div>
    <div id="acc-pat-{{ patient.id }}" class="collapse show">
        <div class="card-body p-0">
            {% if exList %}
                {% for ex in exList %}
                <div class="d-flex align-items-start gap-3 p-3 border-bottom">
                    {% if ex.image %}
                    <div style="flex-shrink:0;">
                        <img src="/storage/uploads/exercises/{{ ex.image }}" alt=""
                             style="width:64px;height:52px;object-fit:cover;border-radius:6px;">
                    </div>
                    {% endif %}
                    <div style="flex:1;min-width:0;">
                        <div class="fw-500">{{ ex.title }}</div>
                        {% if ex.description %}
                        <div class="text-muted fs-sm mt-1" style="white-space:pre-line;">{{ ex.description|slice(0,120) }}{% if ex.description|length > 120 %}…{% endif %}</div>
                        {% endif %}
                        {% if ex.video_url %}
                        <div class="mt-1">
                            <a href="{{ ex.video_url }}" target="_blank" class="btn btn-xs btn-outline-info">
                                <i class="fal fa-play mr-1"></i> Video
                            </a>
                        </div>
                        {% endif %}
                        <div class="mt-1">
                            {% if ex.is_active %}
                                <span class="badge bg-success fs-nano">Aktiv</span>
                            {% else %}
                                <span class="badge bg-secondary fs-nano">Inaktiv</span>
                            {% endif %}
                            <span class="text-muted fs-nano ms-2">Reihenf. {{ ex.sort_order }}</span>
                        </div>
                    </div>
                    <div class="d-flex flex-column gap-1" style="flex-shrink:0;">
                        <button class="btn btn-xs btn-outline-primary"
                                onclick="openEditExercise({{ ex|json_encode }})">
                            <i class="fal fa-edit"></i>
                        </button>
                        <form method="POST" action="/portal-admin/uebungen/{{ ex.id }}/loeschen">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-xs btn-outline-danger"
                                    onclick="return confirm('Übung löschen?');">
                                <i class="fal fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
                {% endfor %}
            {% else %}
            <div class="p-3 text-muted fs-sm">Noch keine Übungen für {{ patient.name }}.</div>
            {% endif %}
        </div>
    </div>
</div>
{% endfor %}
</div>
{% endif %}

{# ── Add Exercise Modal ── #}
<div class="modal fade" id="modal-add-ex" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="form-add-ex" method="POST"
                  action="/portal-admin/tiere/{{ owner.id }}/uebungen"
                  enctype="multipart/form-data">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="patient_id" id="add-ex-patient-id" value="">
                <div class="modal-header">
                    <h5 class="modal-title">Neue Übung — <span id="add-ex-patient-name"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label class="form-label">Titel <span class="text-danger">*</span></label>
                        <input type="text" name="title" class="form-control" required
                               placeholder="z.B. Passive Mobilisation Hüfte">
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Beschreibung</label>
                        <textarea name="description" class="form-control" rows="4"
                                  placeholder="Schritt-für-Schritt-Anleitung..."></textarea>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Video-URL <span class="text-muted fs-nano">(optional)</span></label>
                        <input type="url" name="video_url" class="form-control"
                               placeholder="https://youtube.com/watch?v=...">
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Bild <span class="text-muted fs-nano">(optional)</span></label>
                        <input type="file" name="image" class="form-control" accept="image/*">
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Reihenfolge</label>
                        <input type="number" name="sort_order" class="form-control" value="0" min="0">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        Hinzufügen
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ── Edit Exercise Modal ── #}
<div class="modal fade" id="modal-edit-ex" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="form-edit-ex" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="modal-header">
                    <h5 class="modal-title">Übung bearbeiten</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label class="form-label">Titel</label>
                        <input type="text" name="title" id="ex-edit-title" class="form-control" required>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Beschreibung</label>
                        <textarea name="description" id="ex-edit-desc" class="form-control" rows="4"></textarea>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Video-URL</label>
                        <input type="url" name="video_url" id="ex-edit-video" class="form-control">
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Neues Bild (optional)</label>
                        <input type="file" name="image" class="form-control" accept="image/*">
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Reihenfolge</label>
                        <input type="number" name="sort_order" id="ex-edit-sort" class="form-control" min="0">
                    </div>
                    <div class="form-group">
                        <div class="form-check form-switch">
                            <input type="checkbox" class="form-check-input" id="ex-edit-active" name="is_active" value="1">
                            <label class="form-check-label" for="ex-edit-active">Aktiv</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Speichern</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function openAddExercise(patientId, patientName) {
    document.getElementById('add-ex-patient-id').value = patientId;
    document.getElementById('add-ex-patient-name').textContent = patientName;
    document.getElementById('form-add-ex').reset();
    document.getElementById('add-ex-patient-id').value = patientId;
    new bootstrap.Modal(document.getElementById('modal-add-ex')).show();
}
function openEditExercise(ex) {
    document.getElementById('form-edit-ex').action = '/portal-admin/uebungen/' + ex.id + '/bearbeiten';
    document.getElementById('ex-edit-title').value     = ex.title       || '';
    document.getElementById('ex-edit-desc').value      = ex.description || '';
    document.getElementById('ex-edit-video').value     = ex.video_url   || '';
    document.getElementById('ex-edit-sort').value      = ex.sort_order  || 0;
    document.getElementById('ex-edit-active').checked  = ex.is_active == 1;
    new bootstrap.Modal(document.getElementById('modal-edit-ex')).show();
}
</script>

{% endblock %}
