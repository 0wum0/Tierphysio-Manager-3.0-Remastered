{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% block content %}

<div id="content">
<div class="subheader">
    <h1 class="subheader-title">
        <i class="subheader-icon fal fa-dumbbell"></i> Übungen — {{ patient.name }}
        <small>Heimtraining für Tierbesitzer verwalten</small>
    </h1>
    <div class="subheader-action">
        <a href="/portal-admin" class="btn btn-outline-secondary btn-sm">
            <i class="fal fa-arrow-left mr-1"></i> Portal-Verwaltung
        </a>
    </div>
</div>

{% if success %}
<div class="alert alert-success alert-dismissible fade show" role="alert">
    {{ success }}
    <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
</div>
{% endif %}
{% if error %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    {{ error }}
    <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
</div>
{% endif %}

<div class="row">

    {# ── Add Exercise Form ── #}
    <div class="col-12 col-lg-4">
        <div id="panel-add" class="panel">
            <div class="panel-hdr">
                <h2>Neue Übung hinzufügen</h2>
            </div>
            <div class="panel-container show">
                <div class="panel-content">
                    <form action="/portal-admin/tiere/{{ patient.id }}/uebungen" method="POST"
                          enctype="multipart/form-data">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                        <div class="form-group">
                            <label class="form-label">Titel <span class="text-danger">*</span></label>
                            <input type="text" name="title" class="form-control" required
                                   placeholder="z.B. Passive Mobilisation Hüfte">
                        </div>

                        <div class="form-group">
                            <label class="form-label">Beschreibung</label>
                            <textarea name="description" class="form-control" rows="4"
                                      placeholder="Schritt-für-Schritt-Anleitung..."></textarea>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Video-URL <span class="text-muted fs-nano">(optional, YouTube oder direkt)</span></label>
                            <input type="url" name="video_url" class="form-control"
                                   placeholder="https://youtube.com/watch?v=...">
                        </div>

                        <div class="form-group">
                            <label class="form-label">Bild <span class="text-muted fs-nano">(optional, JPG/PNG/WebP)</span></label>
                            <input type="file" name="image" class="form-control" accept="image/*">
                        </div>

                        <div class="form-group">
                            <label class="form-label">Reihenfolge</label>
                            <input type="number" name="sort_order" class="form-control" value="0" min="0">
                        </div>

                        <button type="submit" class="btn btn-primary btn-block waves-effect waves-themed">
                            <i class="fal fa-plus mr-1"></i> Übung hinzufügen
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    {# ── Exercise List ── #}
    <div class="col-12 col-lg-8">
        <div id="panel-list" class="panel">
            <div class="panel-hdr">
                <h2>Übungen ({{ exercises|length }})</h2>
            </div>
            <div class="panel-container show">
                <div class="panel-content p-0">
                    {% if exercises %}
                        {% for ex in exercises %}
                        <div class="d-flex align-items-start gap-3 p-3 border-bottom">
                            {% if ex.image %}
                            <div style="flex-shrink:0;">
                                <img src="/storage/uploads/exercises/{{ ex.image }}" alt=""
                                     style="width:64px;height:52px;object-fit:cover;border-radius:6px;">
                            </div>
                            {% endif %}
                            <div style="flex:1;min-width:0;">
                                <div class="fw-500">{{ ex.title }}</div>
                                {% if ex.description %}
                                <div class="text-muted fs-sm mt-1" style="white-space:pre-line;">{{ ex.description|slice(0,120) }}{% if ex.description|length > 120 %}…{% endif %}</div>
                                {% endif %}
                                {% if ex.video_url %}
                                <div class="mt-1">
                                    <a href="{{ ex.video_url }}" target="_blank" class="btn btn-xs btn-outline-info">
                                        <i class="fal fa-play mr-1"></i>Video
                                    </a>
                                </div>
                                {% endif %}
                                <div class="mt-1">
                                    {% if ex.is_active %}
                                        <span class="badge badge-success fs-nano">Aktiv</span>
                                    {% else %}
                                        <span class="badge badge-secondary fs-nano">Inaktiv</span>
                                    {% endif %}
                                    <span class="text-muted fs-nano ms-2">Reihenf. {{ ex.sort_order }}</span>
                                </div>
                            </div>
                            <div class="d-flex flex-column gap-1" style="flex-shrink:0;">
                                {# Edit modal trigger #}
                                <button class="btn btn-xs btn-outline-primary"
                                        onclick="openEditExercise({{ ex|json_encode }})">
                                    <i class="fal fa-edit"></i>
                                </button>
                                {# Delete #}
                                <form method="POST" action="/portal-admin/uebungen/{{ ex.id }}/loeschen">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                    <button type="submit" class="btn btn-xs btn-outline-danger"
                                            onclick="return confirm('Übung löschen?');">
                                        <i class="fal fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                        {% endfor %}
                    {% else %}
                    <div class="p-4 text-center text-muted">
                        <i class="fal fa-dumbbell fa-3x mb-3 d-block opacity-30"></i>
                        Noch keine Übungen für {{ patient.name }}.
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Edit Modal ── #}
<div class="modal fade" id="modal-edit-ex" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form id="form-edit-ex" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="modal-header">
                    <h5 class="modal-title">Übung bearbeiten</h5>
                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Titel</label>
                        <input type="text" name="title" id="ex-edit-title" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Beschreibung</label>
                        <textarea name="description" id="ex-edit-desc" class="form-control" rows="4"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Video-URL</label>
                        <input type="url" name="video_url" id="ex-edit-video" class="form-control">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Neues Bild (optional)</label>
                        <input type="file" name="image" class="form-control" accept="image/*">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Reihenfolge</label>
                        <input type="number" name="sort_order" id="ex-edit-sort" class="form-control" min="0">
                    </div>
                    <div class="form-group">
                        <div class="custom-control custom-switch">
                            <input type="checkbox" class="custom-control-input" id="ex-edit-active" name="is_active" value="1">
                            <label class="custom-control-label" for="ex-edit-active">Aktiv</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Speichern</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function openEditExercise(ex) {
    document.getElementById('form-edit-ex').action = '/portal-admin/uebungen/' + ex.id + '/bearbeiten';
    document.getElementById('ex-edit-title').value  = ex.title  || '';
    document.getElementById('ex-edit-desc').value   = ex.description || '';
    document.getElementById('ex-edit-video').value  = ex.video_url   || '';
    document.getElementById('ex-edit-sort').value   = ex.sort_order  || 0;
    document.getElementById('ex-edit-active').checked = ex.is_active == 1;
    $('#modal-edit-ex').modal('show');
}
</script>

</div>
{% endblock %}
