{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% block content %}

<div id="content">
<div class="subheader">
    <h1 class="subheader-title">
        <i class="subheader-icon fal fa-home"></i> Besitzerportal
        <small>Verwaltung der Portal-Zugänge für Tierhalter</small>
    </h1>
    <div class="subheader-action">
        <a href="/portal-admin/einladen" class="btn btn-primary btn-sm waves-effect waves-themed">
            <i class="fal fa-plus mr-1"></i> Besitzer einladen
        </a>
    </div>
</div>

{% if success %}
<div class="alert alert-success alert-dismissible fade show" role="alert">
    {{ success }}
    <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
</div>
{% endif %}
{% if error %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    {{ error }}
    <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
</div>
{% endif %}

<div class="row">
    <div class="col-12">
        <div id="panel-1" class="panel">
            <div class="panel-hdr">
                <h2>Portal-Zugänge</h2>
                <div class="panel-toolbar">
                    <a href="/portal-admin/einladen" class="btn btn-sm btn-primary waves-effect waves-themed">
                        <i class="fal fa-envelope mr-1"></i> Neuen Besitzer einladen
                    </a>
                </div>
            </div>
            <div class="panel-container show">
                <div class="panel-content p-0">
                    {% if portal_users %}
                    <div class="table-responsive">
                    <table class="table table-hover table-striped table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Besitzer</th>
                                <th>E-Mail</th>
                                <th>Status</th>
                                <th>Einladung</th>
                                <th>Letzter Login</th>
                                <th class="text-center">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for u in portal_users %}
                            <tr>
                                <td class="fw-500">{{ u.first_name }} {{ u.last_name }}</td>
                                <td>{{ u.email }}</td>
                                <td>
                                    {% if u.is_active and u.password_hash %}
                                        <span class="badge badge-success">Aktiv</span>
                                    {% elseif u.invite_token and not u.invite_used_at %}
                                        <span class="badge badge-warning">Eingeladen</span>
                                    {% elseif not u.is_active %}
                                        <span class="badge badge-secondary">Deaktiviert</span>
                                    {% else %}
                                        <span class="badge badge-info">Unbekannt</span>
                                    {% endif %}
                                </td>
                                <td class="fs-sm text-muted">
                                    {% if u.invite_used_at %}
                                        Angenommen {{ u.invite_used_at|date('d.m.Y') }}
                                    {% elseif u.invite_expires %}
                                        Läuft ab {{ u.invite_expires|date('d.m.Y') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td class="fs-sm text-muted">
                                    {% if u.last_login %}{{ u.last_login|date('d.m.Y H:i') }}{% else %}—{% endif %}
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center flex-wrap">
                                        <a href="/portal-admin/tiere/{{ u.owner_id }}/uebungen"
                                           class="btn btn-xs btn-outline-info" title="Übungen verwalten">
                                            💪
                                        </a>
                                        <a href="/portal-admin/tiere/{{ u.owner_id }}/hausaufgaben"
                                           class="btn btn-xs btn-outline-success" title="Hausaufgaben verwalten">
                                            📋
                                        </a>
                                        <form method="POST" action="/portal-admin/{{ u.id }}/neu-einladen" style="display:inline;">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                            <button type="submit" class="btn btn-xs btn-outline-primary" title="Neu einladen"
                                                    onclick="return confirm('Neue Einladung senden?');">
                                                <i class="fal fa-envelope"></i>
                                            </button>
                                        </form>
                                        {% if u.is_active %}
                                        <form method="POST" action="/portal-admin/{{ u.id }}/deaktivieren" style="display:inline;">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                            <button type="submit" class="btn btn-xs btn-outline-danger" title="Deaktivieren"
                                                    onclick="return confirm('Zugang deaktivieren?');">
                                                <i class="fal fa-ban"></i>
                                            </button>
                                        </form>
                                        {% else %}
                                        <form method="POST" action="/portal-admin/{{ u.id }}/aktivieren" style="display:inline;">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                            <button type="submit" class="btn btn-xs btn-outline-success" title="Aktivieren">
                                                <i class="fal fa-check"></i>
                                            </button>
                                        </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                    </div>
                    {% else %}
                    <div class="p-4 text-center text-muted">
                        <i class="fal fa-home fa-3x mb-3 d-block opacity-30"></i>
                        <p>Noch keine Portal-Zugänge erstellt.</p>
                        <a href="/portal-admin/einladen" class="btn btn-primary btn-sm">Ersten Besitzer einladen</a>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

</div>
{% endblock %}
