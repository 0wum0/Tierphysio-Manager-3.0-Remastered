{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% block content %}

<div class="page-header">
    <div>
        <h1 class="page-title">Besitzerportal</h1>
        <p class="page-subtitle">Verwaltung der Portal-Zugänge für Tierhalter</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/portal-admin/nachrichten" class="btn btn-outline-secondary btn-sm" style="position:relative;">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Nachrichten
            {% if admin_unread > 0 %}
            <span class="badge ms-1" style="background:#ef4444;font-size:.6rem;padding:1px 5px;">{{ admin_unread }}</span>
            {% endif %}
        </a>
        <a href="/portal-admin/einladen" class="btn btn-primary btn-sm">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            Besitzer einladen
        </a>
    </div>
</div>

{% if success %}
<div class="alert alert-success alert-dismissible fade show" role="alert">
    {{ success }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}
{% if error %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    {{ error }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

{# ── Portal-URL Einstellungen ── #}
<div class="glass-card mb-3">
    <div class="d-flex align-items-center gap-2 mb-3">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="2" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="2"/><path stroke="currentColor" stroke-width="2" d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        <h2 class="h6 mb-0">Portal-URL Einstellungen</h2>
    </div>
    <form method="POST" action="/portal-admin/einstellungen" class="row g-2 align-items-end">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <div class="col-12 col-md-8">
            <label class="form-label mb-1" style="font-size:0.8rem;">
                Portal-Basis-URL
                <span class="text-muted" style="font-weight:400;">(wird in allen Einladungs-E-Mails verwendet)</span>
            </label>
            <input type="url" name="portal_base_url" class="form-control form-control-sm"
                   value="{{ portal_base_url }}"
                   placeholder="https://portal.example.com"
                   pattern="https?://.*">
            <div class="form-text" style="font-size:0.72rem;">
                {% if portal_base_url %}
                    Aktuell: <a href="{{ portal_base_url }}/portal/login" target="_blank" class="text-primary">{{ portal_base_url }}/portal/login</a>
                {% else %}
                    Leer = automatisch vom Server-Host abgeleitet (Standardverhalten)
                {% endif %}
            </div>
        </div>
        <div class="col-12 col-md-auto">
            <button type="submit" class="btn btn-primary btn-sm">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg>
                Speichern
            </button>
        </div>
    </form>
</div>

<div class="glass-card p-0">
                    {% if portal_users %}
                    <div class="table-responsive">
                    <table class="table table-hover table-striped table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Besitzer</th>
                                <th>E-Mail</th>
                                <th>Status</th>
                                <th>Einladung</th>
                                <th>Letzter Login</th>
                                <th class="text-center">Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for u in portal_users %}
                            <tr>
                                <td class="fw-500">{{ u.first_name }} {{ u.last_name }}</td>
                                <td>{{ u.email }}</td>
                                <td>
                                    {% if u.is_active and u.password_hash %}
                                        <span class="badge bg-success">Aktiv</span>
                                    {% elseif u.invite_token and not u.invite_used_at %}
                                        <span class="badge bg-warning text-dark">Eingeladen</span>
                                    {% elseif not u.is_active %}
                                        <span class="badge bg-secondary">Deaktiviert</span>
                                    {% else %}
                                        <span class="badge bg-info text-dark">Unbekannt</span>
                                    {% endif %}
                                </td>
                                <td class="fs-sm text-muted">
                                    {% if u.invite_used_at %}
                                        Angenommen {{ u.invite_used_at|date('d.m.Y') }}
                                    {% elseif u.invite_expires %}
                                        Läuft ab {{ u.invite_expires|date('d.m.Y') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td class="fs-sm text-muted">
                                    {% if u.last_login %}{{ u.last_login|date('d.m.Y H:i') }}{% else %}—{% endif %}
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center flex-wrap">
                                        <a href="/portal-admin/tiere/{{ u.owner_id }}/uebungen"
                                           class="btn btn-xs btn-outline-info" title="Übungen verwalten">
                                            💪
                                        </a>
                                        <a href="/portal-admin/tiere/{{ u.owner_id }}/hausaufgaben"
                                           class="btn btn-xs btn-outline-success" title="Hausaufgaben verwalten">
                                            📋
                                        </a>
                                        <a href="/portal-admin/tiere/{{ u.owner_id }}/befunde"
                                           class="btn btn-xs btn-outline-primary" title="Befundbögen verwalten">
                                            🩺
                                        </a>
                                        <form method="POST" action="/portal-admin/{{ u.id }}/neu-einladen" style="display:inline;">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                            <button type="submit" class="btn btn-xs btn-outline-primary" title="Neu einladen"
                                                    onclick="return confirm('Neue Einladung senden?');">
                                                <i class="fal fa-envelope"></i>
                                            </button>
                                        </form>
                                        {% if u.is_active %}
                                        <form method="POST" action="/portal-admin/{{ u.id }}/deaktivieren" style="display:inline;">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                            <button type="submit" class="btn btn-xs btn-outline-danger" title="Deaktivieren"
                                                    onclick="return confirm('Zugang deaktivieren?');">
                                                <i class="fal fa-ban"></i>
                                            </button>
                                        </form>
                                        {% else %}
                                        <form method="POST" action="/portal-admin/{{ u.id }}/aktivieren" style="display:inline;">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                            <button type="submit" class="btn btn-xs btn-outline-success" title="Aktivieren">
                                                <i class="fal fa-check"></i>
                                            </button>
                                        </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                    </div>
                    {% else %}
                    <div class="p-4 text-center text-muted">
                        <i class="fal fa-home fa-3x mb-3 d-block opacity-30"></i>
                        <p>Noch keine Portal-Zugänge erstellt.</p>
                        <a href="/portal-admin/einladen" class="btn btn-primary btn-sm">Ersten Besitzer einladen</a>
                    </div>
                    {% endif %}
</div>

{% endblock %}
