{% extends '@owner-portal/portal_layout.twig' %}
{% set active_nav = 'tiere' %}
{% block content %}

<div class="mb-3">
    <a href="/portal/tiere/{{ pet.id }}" class="small text-secondary text-decoration-none">← {{ pet.name }}</a>
</div>

<h1 class="portal-page-title">📋 Hausaufgaben — {{ pet.name }}</h1>

{% if plans %}
    {% for plan in plans %}
    {% set tasks = tasks_by_plan[plan.id] ?? [] %}
    <div class="card mb-4">
      <div class="card-body">

        {# ── Plan header ── #}
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-3 pb-3 border-bottom">
            <div>
                <div class="fw-semibold">
                    📅 Hausaufgabenplan vom {{ plan.plan_date|date('d.m.Y') }}
                </div>
                {% if plan.therapist_name %}
                <div class="small text-secondary mt-1">{{ plan.therapist_name }}</div>
                {% endif %}
                {% if plan.next_appointment %}
                <div class="small text-secondary mt-1">🔄 Wiedervorstellung: {{ plan.next_appointment }}</div>
                {% endif %}
            </div>
            <a href="/portal/tiere/{{ pet.id }}/hausaufgaben/{{ plan.id }}/pdf" target="_blank"
               class="portal-btn portal-btn-secondary portal-btn-sm" style="flex-shrink:0;">
                📄 PDF herunterladen
            </a>
        </div>

        {# ── Physio principles ── #}
        {% if plan.physio_principles %}
        <div class="mb-3">
            <div class="small text-secondary text-uppercase fw-semibold mb-1" style="letter-spacing:0.06em;">Physiotherapeutische Grundsätze</div>
            <div class="small" style="white-space:pre-line;">{{ plan.physio_principles }}</div>
        </div>
        {% endif %}

        {# ── Goals ── #}
        {% if plan.short_term_goals or plan.long_term_goals %}
        <div class="homework-goals-grid row g-3 mb-3">
            {% if plan.short_term_goals %}
            <div class="col-md-6">
                <div class="p-3 rounded" style="background:var(--bs-tertiary-bg);">
                    <div class="small text-secondary text-uppercase fw-semibold mb-1" style="letter-spacing:0.06em;">Kurzfristige Ziele</div>
                    <div class="small" style="white-space:pre-line;">{{ plan.short_term_goals }}</div>
                </div>
            </div>
            {% endif %}
            {% if plan.long_term_goals %}
            <div class="col-md-6">
                <div class="p-3 rounded" style="background:var(--bs-tertiary-bg);">
                    <div class="small text-secondary text-uppercase fw-semibold mb-1" style="letter-spacing:0.06em;">Langfristige Ziele</div>
                    <div class="small" style="white-space:pre-line;">{{ plan.long_term_goals }}</div>
                </div>
            </div>
            {% endif %}
        </div>
        {% endif %}

        {# ── Therapy means ── #}
        {% if plan.therapy_means %}
        <div class="mb-3">
            <div class="small text-secondary text-uppercase fw-semibold mb-1" style="letter-spacing:0.06em;">Therapiemittel</div>
            <div class="small">{{ plan.therapy_means }}</div>
        </div>
        {% endif %}

        {# ── Tasks / Therapieplan mit Checkliste ── #}
        {% if tasks %}
        {% set checks = checks_by_plan[plan.id] ?? {} %}
        <div class="mb-3">
            <div class="small text-secondary text-uppercase fw-semibold mb-2" style="letter-spacing:0.06em;">Therapieplan</div>
            {% for task in tasks %}
            {% set is_checked = checks[task.id] ?? false %}
            <div class="border rounded mb-2 overflow-hidden homework-task-item {% if is_checked %}task-done{% endif %}"
                 data-task-id="{{ task.id }}" data-plan-id="{{ plan.id }}"
                 style="transition:opacity .2s;">
                <div class="d-flex align-items-center gap-3 px-3 py-2" style="background:var(--bs-tertiary-bg);">
                    {# ── Checkbox ── #}
                    <button class="task-check-btn btn p-0 border-0 flex-shrink-0"
                            data-task="{{ task.id }}" data-plan="{{ plan.id }}"
                            data-checked="{{ is_checked ? '1' : '0' }}"
                            type="button"
                            style="width:24px;height:24px;border-radius:6px;background:{% if is_checked %}#22c55e{% else %}rgba(128,128,128,0.15){% endif %};display:flex;align-items:center;justify-content:center;transition:background .2s;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" style="opacity:{% if is_checked %}1{% else %}0.3{% endif %};transition:opacity .2s;">
                            <path stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M20 6L9 17l-5-5"/>
                        </svg>
                    </button>
                    <div class="fw-semibold small flex-fill {% if is_checked %}text-decoration-line-through text-secondary{% endif %}"
                         style="transition:all .2s;">{{ task.title }}</div>
                    {% if task.frequency or task.duration %}
                    <div class="small text-secondary text-nowrap">
                        {% if task.frequency %}{{ task.frequency }}{% endif %}
                        {% if task.frequency and task.duration %} · {% endif %}
                        {% if task.duration %}{{ task.duration }}{% endif %}
                    </div>
                    {% endif %}
                </div>
                {% if task.description or task.therapist_notes %}
                <div class="px-3 py-2">
                    {% if task.description %}
                    <div class="small" style="white-space:pre-line;line-height:1.55;">{{ task.description }}</div>
                    {% endif %}
                    {% if task.therapist_notes %}
                    <div class="small text-secondary fst-italic mt-1">{{ task.therapist_notes }}</div>
                    {% endif %}
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# ── General notes / Beachte ── #}
        {% if plan.general_notes %}
        <div class="alert alert-warning d-flex gap-2 align-items-start mb-0">
            <span>⚠️</span>
            <div>
                <div class="fw-semibold small text-uppercase mb-1">Beachte</div>
                <div class="small" style="white-space:pre-line;">{{ plan.general_notes }}</div>
            </div>
        </div>
        {% endif %}

      </div>
    </div>
    {% endfor %}
{% else %}
    <div class="card">
      <div class="card-body text-center py-5">
        <div class="fs-1 mb-2" style="opacity:.3;">📋</div>
        <p class="text-secondary">Noch keine Hausaufgaben hinterlegt.</p>
        <p class="text-secondary small">Ihr Therapeut wird bald einen Plan für {{ pet.name }} erstellen.</p>
      </div>
    </div>
{% endif %}

{% endblock %}

{% block scripts %}
<script>
(function(){
    document.querySelectorAll('.task-check-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var taskId  = btn.dataset.task;
            var planId  = btn.dataset.plan;
            var checked = btn.dataset.checked === '1';
            var newVal  = !checked;

            /* Optimistic UI update */
            var item  = btn.closest('.homework-task-item');
            var label = item.querySelector('.fw-semibold.flex-fill');
            var svg   = btn.querySelector('svg');

            btn.dataset.checked        = newVal ? '1' : '0';
            btn.style.background       = newVal ? '#22c55e' : 'rgba(128,128,128,0.15)';
            svg.style.opacity          = newVal ? '1' : '0.3';
            label.style.textDecoration = newVal ? 'line-through' : '';
            label.style.opacity        = newVal ? '0.5' : '1';

            fetch('/api/portal/hausaufgaben/' + planId + '/aufgabe/' + taskId + '/abhaken', {
                method:  'POST',
                headers: {'Content-Type': 'application/json'},
                body:    JSON.stringify({checked: newVal})
            })
            .then(function(r){ return r.json(); })
            .catch(function() {
                /* Revert on error */
                btn.dataset.checked        = checked ? '1' : '0';
                btn.style.background       = checked ? '#22c55e' : 'rgba(128,128,128,0.15)';
                svg.style.opacity          = checked ? '1' : '0.3';
                label.style.textDecoration = checked ? 'line-through' : '';
                label.style.opacity        = checked ? '0.5' : '1';
            });
        });
    });
})();
</script>
{% endblock %}
