{% extends '@owner-portal/portal_layout.twig' %}
{% set active_nav = 'dashboard' %}
{% block content %}

<h1 class="portal-page-title">
    Willkommen, {{ portal_user.first_name }}!
</h1>

{# ── Stats row ── #}
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:0.75rem;margin-bottom:1.5rem;">
    <div class="portal-card" style="margin:0;text-align:center;">
        <div style="font-size:1.8rem;font-weight:800;color:#4f7cff;">{{ pets|length }}</div>
        <div style="font-size:0.78rem;color:rgba(255,255,255,0.45);margin-top:0.2rem;">Tiere</div>
    </div>
    <div class="portal-card" style="margin:0;text-align:center;">
        <div style="font-size:1.8rem;font-weight:800;color:#22c55e;">{{ upcoming_appointments|length }}</div>
        <div style="font-size:0.78rem;color:rgba(255,255,255,0.45);margin-top:0.2rem;">Kommende Termine</div>
    </div>
    <div class="portal-card" style="margin:0;text-align:center;">
        <div style="font-size:1.8rem;font-weight:800;color:{% if open_invoices|length > 0 %}#f59e0b{% else %}#22c55e{% endif %};">{{ open_invoices|length }}</div>
        <div style="font-size:0.78rem;color:rgba(255,255,255,0.45);margin-top:0.2rem;">Offene Rechnungen</div>
    </div>
    <div class="portal-card" style="margin:0;text-align:center;">
        <div style="font-size:1.8rem;font-weight:800;color:#a78bfa;">{{ exercises|length }}</div>
        <div style="font-size:0.78rem;color:rgba(255,255,255,0.45);margin-top:0.2rem;">Übungen</div>
    </div>
</div>

{# ── My Pets ── #}
<div class="portal-card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
        <h2 style="margin:0;">🐾 Meine Tiere</h2>
        <a href="/portal/tiere" class="portal-btn portal-btn-secondary portal-btn-sm">Alle anzeigen</a>
    </div>
    {% if pets %}
        <div class="pet-grid">
        {% for pet in pets %}
            <a href="/portal/tiere/{{ pet.id }}" class="pet-card">
                <div class="pet-card-img">
                    {% if pet.photo %}
                        <img src="/storage/uploads/{{ pet.photo }}" alt="{{ pet.name }}" style="width:100%;height:140px;object-fit:cover;">
                    {% else %}
                        <svg width="40" height="40" fill="none" viewBox="0 0 24 24" style="opacity:.3;"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/><path stroke="currentColor" stroke-width="1.5" d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                    {% endif %}
                </div>
                <div class="pet-card-body">
                    <div class="pet-card-name">{{ pet.name }}</div>
                    <div class="pet-card-meta">{{ pet.species }}{% if pet.breed %} · {{ pet.breed }}{% endif %}</div>
                    {% if pet.last_treatment %}
                        <div class="pet-card-meta" style="margin-top:0.3rem;">Letzte Behandlung: {{ pet.last_treatment|date('d.m.Y') }}</div>
                    {% endif %}
                </div>
            </a>
        {% endfor %}
        </div>
    {% else %}
        <p style="color:rgba(255,255,255,0.4);font-size:0.875rem;">Keine Tiere vorhanden.</p>
    {% endif %}
</div>

{# ── Upcoming Appointments ── #}
{% if upcoming_appointments %}
<div class="portal-card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
        <h2 style="margin:0;">📅 Nächste Termine</h2>
        <a href="/portal/termine" class="portal-btn portal-btn-secondary portal-btn-sm">Alle Termine</a>
    </div>
    {% for appt in upcoming_appointments|slice(0, 3) %}
    <div style="display:flex;gap:0.75rem;align-items:flex-start;padding:0.6rem 0;border-bottom:1px solid rgba(255,255,255,0.06);">
        <div style="width:8px;height:8px;border-radius:50%;background:{{ appt.treatment_type_color ?? '#4f7cff' }};margin-top:5px;flex-shrink:0;"></div>
        <div>
            <div style="font-weight:500;font-size:0.875rem;">{{ appt.title }}</div>
            <div style="font-size:0.78rem;color:rgba(255,255,255,0.45);">{{ appt.start_at|date('d.m.Y H:i') }}{% if appt.patient_name %} · {{ appt.patient_name }}{% endif %}</div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{# ── Open Invoices ── #}
{% if open_invoices %}
<div class="portal-card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
        <h2 style="margin:0;">🧾 Offene Rechnungen</h2>
        <a href="/portal/rechnungen" class="portal-btn portal-btn-secondary portal-btn-sm">Alle Rechnungen</a>
    </div>
    {% for inv in open_invoices|slice(0, 3) %}
    <div style="display:flex;justify-content:space-between;align-items:center;padding:0.6rem 0;border-bottom:1px solid rgba(255,255,255,0.06);">
        <div>
            <div style="font-weight:500;font-size:0.875rem;">{{ inv.invoice_number }}</div>
            <div style="font-size:0.78rem;color:rgba(255,255,255,0.45);">{{ inv.issue_date|date('d.m.Y') }}{% if inv.patient_name %} · {{ inv.patient_name }}{% endif %}</div>
        </div>
        <div style="text-align:right;">
            <div style="font-weight:700;">{{ inv.total_gross|number_format(2,',','.') }} €</div>
            <span class="badge-status {% if inv.status == 'overdue' %}badge-overdue{% else %}badge-open{% endif %}">
                {% if inv.status == 'overdue' %}Überfällig{% else %}Offen{% endif %}
            </span>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{# ── Exercises teaser ── #}
{% if exercises %}
<div class="portal-card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
        <h2 style="margin:0;">💪 Heimübungen</h2>
    </div>
    {% for ex in exercises|slice(0, 2) %}
    <div class="exercise-card">
        <div class="exercise-title">{{ ex.title }}</div>
        {% if ex.patient_name %}<div style="font-size:0.75rem;color:rgba(255,255,255,0.4);margin-bottom:0.3rem;">für {{ ex.patient_name }}</div>{% endif %}
        {% if ex.description %}<div class="exercise-desc">{{ ex.description|slice(0,120) }}{% if ex.description|length > 120 %}…{% endif %}</div>{% endif %}
    </div>
    {% endfor %}
    {% if exercises|length > 2 %}
        <div style="font-size:0.8rem;color:rgba(255,255,255,0.4);margin-top:0.5rem;">+ {{ exercises|length - 2 }} weitere Übungen</div>
    {% endif %}
</div>
{% endif %}

{% endblock %}
