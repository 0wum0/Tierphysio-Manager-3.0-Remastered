{% extends '@owner-portal/portal_layout.twig' %}
{% set active_nav = 'dashboard' %}
{% block content %}

<h1 class="portal-page-title portal-page-title-gradient">
    Willkommen, {{ portal_user.first_name }}!
</h1>

{# ── Stats row ── #}
<div class="row g-3 mb-4">
    <div class="col"><div class="card text-center h-100"><div class="card-body py-3">
        <div class="fs-2 fw-bold text-primary">{{ pets|length }}</div>
        <div class="small text-secondary mt-1">Tiere</div>
    </div></div></div>
    <div class="col"><div class="card text-center h-100"><div class="card-body py-3">
        <div class="fs-2 fw-bold text-success">{{ upcoming_appointments|length }}</div>
        <div class="small text-secondary mt-1">Kommende Termine</div>
    </div></div></div>
    <div class="col"><div class="card text-center h-100"><div class="card-body py-3">
        <div class="fs-2 fw-bold {% if open_invoices|length > 0 %}text-warning{% else %}text-success{% endif %}">{{ open_invoices|length }}</div>
        <div class="small text-secondary mt-1">Offene Rechnungen</div>
    </div></div></div>
    <div class="col"><div class="card text-center h-100"><div class="card-body py-3">
        <div class="fs-2 fw-bold" style="color:var(--bs-purple,#a78bfa);">{{ exercises|length }}</div>
        <div class="small text-secondary mt-1">Übungen</div>
    </div></div></div>
    {% if show_homework ?? false %}
    <div class="col"><div class="card text-center h-100"><div class="card-body py-3">
        <div class="fs-2 fw-bold" style="color:var(--bs-teal,#14b8a6);">{{ homework_plans|length }}</div>
        <div class="small text-secondary mt-1">Hausaufgaben</div>
    </div></div></div>
    {% endif %}
</div>

{# ── My Pets ── #}
<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h5 mb-0">🐾 Meine Tiere</h2>
        <a href="/portal/tiere" class="portal-btn portal-btn-secondary portal-btn-sm">Alle anzeigen</a>
    </div>
    {% if pets %}
        <div class="pet-grid">
        {% for pet in pets %}
            <a href="/portal/tiere/{{ pet.id }}" class="pet-card">
                <div class="pet-card-img">
                    {% if pet.photo %}
                        <img src="/portal/tiere/{{ pet.id }}/foto/{{ pet.photo }}" alt="{{ pet.name }}" style="width:100%;height:140px;object-fit:cover;">
                    {% else %}
                        <svg width="40" height="40" fill="none" viewBox="0 0 24 24" style="opacity:.3;"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/><path stroke="currentColor" stroke-width="1.5" d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                    {% endif %}
                </div>
                <div class="pet-card-body">
                    <div class="pet-card-name">{{ pet.name }}</div>
                    <div class="pet-card-meta">{{ pet.species }}{% if pet.breed %} · {{ pet.breed }}{% endif %}</div>
                    {% if pet.last_treatment %}
                        <div class="pet-card-meta" style="margin-top:0.3rem;">Letzte Behandlung: {{ pet.last_treatment|date('d.m.Y') }}</div>
                    {% endif %}
                </div>
            </a>
        {% endfor %}
        </div>
    {% else %}
        <p class="text-secondary small">Keine Tiere vorhanden.</p>
    {% endif %}
  </div>
</div>

{# ── Upcoming Appointments ── #}
{% if upcoming_appointments %}
<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h5 mb-0">📅 Nächste Termine</h2>
        <a href="/portal/termine" class="portal-btn portal-btn-secondary portal-btn-sm">Alle Termine</a>
    </div>
    {% for appt in upcoming_appointments|slice(0, 3) %}
    <div class="d-flex gap-3 align-items-start py-2 border-bottom border-opacity-10">
        <div style="width:8px;height:8px;border-radius:50%;background:{{ appt.treatment_type_color ?? 'var(--bs-primary)' }};margin-top:5px;flex-shrink:0;"></div>
        <div>
            <div class="fw-500 small">{{ appt.title }}</div>
            <div class="small text-secondary">{{ appt.start_at|date('d.m.Y H:i') }}{% if appt.patient_name %} · {{ appt.patient_name }}{% endif %}</div>
        </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ── Open Invoices ── #}
{% if open_invoices %}
<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h5 mb-0">🧾 Offene Rechnungen</h2>
        <a href="/portal/rechnungen" class="portal-btn portal-btn-secondary portal-btn-sm">Alle Rechnungen</a>
    </div>
    {% for inv in open_invoices|slice(0, 3) %}
    <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-opacity-10">
        <div>
            <div class="fw-500 small">{{ inv.invoice_number }}</div>
            <div class="small text-secondary">{{ inv.issue_date|date('d.m.Y') }}{% if inv.patient_name %} · {{ inv.patient_name }}{% endif %}</div>
        </div>
        <div class="text-end">
            <div class="fw-bold">{{ inv.total_gross|number_format(2,',','.') }} €</div>
            <span class="badge-status {% if inv.status == 'overdue' %}badge-overdue{% else %}badge-open{% endif %}">
                {% if inv.status == 'overdue' %}Überfällig{% else %}Offen{% endif %}
            </span>
        </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ── Exercises teaser ── #}
{% if exercises %}
<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h5 mb-0">💪 Heimübungen</h2>
    </div>
    {% for ex in exercises|slice(0, 2) %}
    <div class="exercise-card">
        <div class="exercise-title">{{ ex.title }}</div>
        {% if ex.patient_name %}<div class="small text-secondary mb-1">für {{ ex.patient_name }}</div>{% endif %}
        {% if ex.description %}<div class="exercise-desc">{{ ex.description|slice(0,120) }}{% if ex.description|length > 120 %}…{% endif %}</div>{% endif %}
    </div>
    {% endfor %}
    {% if exercises|length > 2 %}
        <div class="small text-secondary mt-2">+ {{ exercises|length - 2 }} weitere Übungen</div>
    {% endif %}
  </div>
</div>
{% endif %}

{# ── Homework teaser ── #}
{% if (show_homework ?? false) and homework_plans is defined and homework_plans|length > 0 %}
<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h5 mb-0">📋 Hausaufgaben</h2>
    </div>
    {% for plan in homework_plans|slice(0, 3) %}
    <a href="/portal/tiere/{{ plan.patient_id }}/hausaufgaben"
       class="d-flex align-items-center gap-3 py-2 text-decoration-none"
       style="border-bottom:1px solid var(--bs-border-color);color:inherit;">
        <div style="width:8px;height:8px;border-radius:50%;background:var(--bs-teal,#14b8a6);flex-shrink:0;"></div>
        <div class="flex-fill">
            <div class="fw-500 small">Hausaufgabenplan vom {{ plan.plan_date|date('d.m.Y') }}</div>
            {% if plan.patient_name %}
            <div class="small text-secondary">🐾 {{ plan.patient_name }}</div>
            {% endif %}
        </div>
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="opacity:.4;flex-shrink:0;"><polyline stroke="currentColor" stroke-width="2" points="9 18 15 12 9 6"/></svg>
    </a>
    {% endfor %}
    {% if homework_plans|length > 3 %}
    <div class="small text-secondary mt-2 pt-1">+ {{ homework_plans|length - 3 }} weitere Pläne</div>
    {% endif %}
  </div>
</div>
{% endif %}


{# ── Therapiefortschritt-Verlauf (Chart) ── #}
{% if progress_chart is not null and progress_chart|length > 0 %}
<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h5 mb-0">📈 {% if is_trainer_tenant ?? false %}Trainings-Verlauf{% else %}Fortschritts-Verlauf{% endif %}</h2>
        <span class="small text-secondary">Letzte 90 Tage</span>
    </div>
    {% for petChart in progress_chart %}
    <div class="mb-3{% if not loop.last %} pb-3{% endif %}"
         {% if not loop.last %}style="border-bottom:1px solid var(--bs-border-color);"{% endif %}>
        <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="fw-600 small">🐾 {{ petChart.pet_name }}</div>
            <a href="/portal/tcp/tiere/{{ petChart.pet_id }}/fortschritt"
               class="portal-btn portal-btn-secondary portal-btn-sm">Details →</a>
        </div>
        <div style="position:relative;height:220px;">
            <canvas id="progressChart-{{ petChart.pet_id }}"
                    data-chart='{{ petChart.chart|json_encode|e('html_attr') }}'></canvas>
        </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ── Hausaufgaben-Fortschritt (Bar Chart) ── #}
{% if homework_stats is not null and homework_stats|length > 0 %}
<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h5 mb-0">✅ Hausaufgaben-Fortschritt</h2>
        <span class="small text-secondary">{{ homework_stats|length }} aktive Pläne</span>
    </div>
    <div class="homework-stats-list" style="display:flex;flex-direction:column;gap:0.85rem;">
        {% for stat in homework_stats %}
        <a href="/portal/tiere/{{ stat.patient_id }}/hausaufgaben"
           class="text-decoration-none"
           style="color:inherit;display:block;padding:0.55rem 0.65rem;border-radius:10px;transition:background 0.18s ease;"
           onmouseover="this.style.background='var(--bs-tertiary-bg)'" onmouseout="this.style.background=''">
            <div class="d-flex align-items-center justify-content-between mb-1" style="gap:.75rem;">
                <div class="small fw-600" style="min-width:0;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    🐾 {{ stat.patient_name }}
                    <span class="text-secondary" style="font-weight:400;">· {{ stat.plan_date|date('d.m.Y') }}</span>
                </div>
                <div class="small fw-700" style="flex-shrink:0;min-width:92px;text-align:right;">
                    {{ stat.checked }} / {{ stat.total }}
                    <span style="color:{% if stat.pct >= 80 %}#22c55e{% elseif stat.pct >= 40 %}#f59e0b{% else %}#94a3b8{% endif %};margin-left:0.4rem;">{{ stat.pct }}%</span>
                </div>
            </div>
            <div style="height:8px;background:var(--bs-tertiary-bg);border-radius:999px;overflow:hidden;">
                <div style="height:100%;width:{{ stat.pct }}%;border-radius:999px;transition:width 0.6s ease;
                            background:linear-gradient(90deg,
                                {% if stat.pct >= 80 %}#22c55e,#4ade80
                                {% elseif stat.pct >= 40 %}#f59e0b,#fbbf24
                                {% else %}#94a3b8,#cbd5e1{% endif %});"></div>
            </div>
        </a>
        {% endfor %}
    </div>
  </div>
</div>
{% endif %}

{# ── TherapyCare Pro: Therapiefortschritt ── #}
{% if tcp_dashboard is not null and tcp_dashboard|length > 0 %}
<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h5 mb-0">📈 {% if is_trainer_tenant ?? false %}Trainings-Fortschritt{% else %}Therapiefortschritt{% endif %}</h2>
    </div>
    {% for entry in tcp_dashboard %}
    <div class="mb-3 pb-3" style="border-bottom:1px solid var(--bs-border-color);">
        <div class="fw-600 small mb-2">🐾 {{ entry.pet.name }}</div>
        {% if entry.latest is not empty %}
            {% for val in entry.latest|slice(0,3) %}
            <div class="d-flex align-items-center gap-2 mb-1">
                <div class="small text-secondary" style="min-width:90px;">{{ val.category_name }}</div>
                <div style="flex:1;height:5px;background:rgba(128,128,128,0.15);border-radius:999px;overflow:hidden;">
                    {% set pct = (((val.score - (val.scale_min ?? 1)) / ((val.scale_max ?? 10) - (val.scale_min ?? 1))) * 100)|round %}
                    <div style="height:100%;width:{{ pct }}%;background:{{ val.category_color }};border-radius:999px;"></div>
                </div>
                <div class="small fw-600" style="min-width:32px;color:{{ val.category_color }};">{{ val.score }}/{{ val.scale_max ?? 10 }}</div>
            </div>
            {% endfor %}
        {% endif %}
        <div class="d-flex gap-2 mt-2 flex-wrap">
            {# Fortschritt + Story sind immer sichtbar (User-Spec); show_progress in getPortalVisibility ist hart auf 1 gesetzt. #}
            <a href="/portal/tcp/tiere/{{ entry.pet.id }}/fortschritt" class="portal-btn portal-btn-secondary portal-btn-sm">{% if is_trainer_tenant ?? false %}Verlauf{% else %}Fortschritt{% endif %} →</a>
            <a href="/portal/tcp/tiere/{{ entry.pet.id }}/fortschritt/story" class="portal-btn portal-btn-primary portal-btn-sm">{% if is_trainer_tenant ?? false %}Trainings-Story{% else %}Therapie-Story{% endif %} →</a>
            {% if entry.visibility.show_reports %}
            <a href="/portal/tcp/tiere/{{ entry.pet.id }}/berichte" class="portal-btn portal-btn-secondary portal-btn-sm">Berichte →</a>
            {% endif %}
            {% if entry.visibility.show_natural %}
            <a href="/portal/tcp/tiere/{{ entry.pet.id }}/naturheilkunde" class="portal-btn portal-btn-secondary portal-btn-sm">Naturheilkunde →</a>
            {% endif %}
            <a href="/portal/tcp/tiere/{{ entry.pet.id }}/feedback" class="portal-btn portal-btn-secondary portal-btn-sm">Feedback geben →</a>
        </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ── Letzte Aktivität ── #}
{% if recent_activity is defined and recent_activity|length > 0 %}
<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h5 mb-0">🕐 Letzte Aktivität</h2>
    </div>
    {% for act in recent_activity %}
    <div class="d-flex align-items-center gap-3 py-2" style="{% if not loop.last %}border-bottom:1px solid var(--bs-border-color);{% endif %}">
        <div style="width:32px;height:32px;border-radius:50%;background:rgba(79,70,229,.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.9rem;">✅</div>
        <div class="flex-fill">
            <div class="fw-500 small">{{ act.title }}</div>
            {% if act.pet_name %}
            <div class="small text-secondary">🐾 {{ act.pet_name }}</div>
            {% endif %}
        </div>
        <div class="small text-secondary text-end" style="white-space:nowrap;">{{ act.created_at|date('d.m.Y') }}</div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{% endblock %}

{% block scripts %}
{% if progress_chart is not null and progress_chart|length > 0 %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
(function () {
    'use strict';
    if (typeof Chart === 'undefined') return;

    /* Chart.js global defaults matching portal theme */
    var cs = getComputedStyle(document.documentElement);
    var textMuted  = cs.getPropertyValue('--bs-secondary-color').trim() || '#94a3b8';
    var borderCol  = cs.getPropertyValue('--bs-border-color').trim()    || '#334155';
    Chart.defaults.color       = textMuted;
    Chart.defaults.borderColor = borderCol;
    Chart.defaults.font.family = 'Inter, system-ui, sans-serif';

    document.querySelectorAll('canvas[id^="progressChart-"]').forEach(function (canvas) {
        var raw;
        try { raw = JSON.parse(canvas.dataset.chart || '{}'); }
        catch (e) { return; }
        if (!raw.datasets || raw.datasets.length === 0) return;

        /* Format labels as "DD.MM." for compact display */
        var labels = (raw.labels || []).map(function (d) {
            if (!d || d.length < 10) return d;
            return d.substr(8, 2) + '.' + d.substr(5, 2) + '.';
        });

        new Chart(canvas, {
            type: 'line',
            data: { labels: labels, datasets: raw.datasets },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { boxWidth: 10, font: { size: 11 }, padding: 12, usePointStyle: true }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15,23,42,0.95)',
                        borderColor: borderCol,
                        borderWidth: 1,
                        titleColor: '#fff',
                        bodyColor: '#e2e8f0',
                        padding: 10,
                        cornerRadius: 8
                    }
                },
                scales: {
                    x: { grid: { display: false }, ticks: { font: { size: 10 } } },
                    y: {
                        beginAtZero: true,
                        suggestedMax: 10,
                        grid: { color: borderCol },
                        ticks: { stepSize: 2, font: { size: 10 } }
                    }
                }
            }
        });
    });
})();
</script>
{% endif %}
{% endblock %}
