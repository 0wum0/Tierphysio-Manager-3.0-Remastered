{% extends '@owner-portal/portal_layout.twig' %}
{% set active_nav = 'tiere' %}
{% block content %}

<div class="mb-3">
    <a href="/portal/tiere/{{ pet.id }}" class="small text-secondary text-decoration-none">← {{ pet.name }}</a>
</div>

<h1 class="portal-page-title">✏️ {{ pet.name }} bearbeiten</h1>

{% if success %}
    <div class="alert alert-success">{{ success }}</div>
{% endif %}
{% if error %}
    <div class="alert alert-danger">{{ error }}</div>
{% endif %}

<form action="/portal/tiere/{{ pet.id }}/bearbeiten" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    {# ── Foto ── #}
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h6 fw-semibold mb-3">Tierfoto</h2>
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div id="photo-preview" style="width:90px;height:90px;border-radius:12px;overflow:hidden;background:var(--bs-tertiary-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                {% if pet.photo %}
                    <img src="/patienten/{{ pet.id }}/foto/{{ pet.photo }}" alt="{{ pet.name }}"
                         style="width:100%;height:100%;object-fit:cover;" id="photo-img">
                {% else %}
                    <svg width="36" height="36" fill="none" viewBox="0 0 24 24" style="opacity:.3;" id="photo-placeholder"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/><path stroke="currentColor" stroke-width="1.5" d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                {% endif %}
            </div>
            <div>
                <label for="photo" class="btn btn-sm btn-outline-secondary mb-1">
                    📷 Foto auswählen
                </label>
                <input type="file" id="photo" name="photo" accept="image/*" class="d-none">
                <div class="small text-secondary">JPG, PNG, WebP · max. 5 MB</div>
            </div>
        </div>
      </div>
    </div>

    {# ── Stammdaten ── #}
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h6 fw-semibold mb-3">Stammdaten</h2>

        <div class="row g-3">
            <div class="col-md-6">
                <label for="name" class="form-label small fw-semibold">Name <span class="text-danger">*</span></label>
                <input type="text" id="name" name="name" class="form-control"
                       value="{{ pet.name }}" required>
            </div>
            <div class="col-md-6">
                <label for="species" class="form-label small fw-semibold">Tierart</label>
                <input type="text" id="species" name="species" class="form-control"
                       value="{{ pet.species ?? '' }}" placeholder="z.B. Hund, Katze, Pferd">
            </div>
            <div class="col-md-6">
                <label for="breed" class="form-label small fw-semibold">Rasse</label>
                <input type="text" id="breed" name="breed" class="form-control"
                       value="{{ pet.breed ?? '' }}">
            </div>
            <div class="col-md-6">
                <label for="birth_date" class="form-label small fw-semibold">Geburtsdatum</label>
                <input type="date" id="birth_date" name="birth_date" class="form-control"
                       value="{{ pet.birth_date ? pet.birth_date|date('Y-m-d') : '' }}">
            </div>
            <div class="col-md-6">
                <label for="gender" class="form-label small fw-semibold">Geschlecht</label>
                <select id="gender" name="gender" class="form-select">
                    <option value="">— bitte wählen —</option>
                    <option value="männlich"   {% if pet.gender == 'männlich'   %}selected{% endif %}>männlich</option>
                    <option value="weiblich"   {% if pet.gender == 'weiblich'   %}selected{% endif %}>weiblich</option>
                    <option value="kastriert"  {% if pet.gender == 'kastriert'  %}selected{% endif %}>kastriert</option>
                    <option value="sterilisiert" {% if pet.gender == 'sterilisiert' %}selected{% endif %}>sterilisiert</option>
                    <option value="unbekannt"  {% if pet.gender == 'unbekannt'  %}selected{% endif %}>unbekannt</option>
                </select>
            </div>
            <div class="col-md-6">
                <label for="color" class="form-label small fw-semibold">Farbe / Zeichnung</label>
                <input type="text" id="color" name="color" class="form-control"
                       value="{{ pet.color ?? '' }}">
            </div>
            <div class="col-md-6">
                <label for="chip_number" class="form-label small fw-semibold">Chip-Nr.</label>
                <input type="text" id="chip_number" name="chip_number" class="form-control"
                       value="{{ pet.chip_number ?? '' }}">
            </div>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Speichern</button>
        <a href="/portal/tiere/{{ pet.id }}" class="btn btn-outline-secondary">Abbrechen</a>
    </div>
</form>

<script>
(function(){
    var input   = document.getElementById('photo');
    var preview = document.getElementById('photo-preview');
    input.addEventListener('change', function(){
        if (!this.files || !this.files[0]) return;
        var reader = new FileReader();
        reader.onload = function(e){
            preview.innerHTML = '<img src="' + e.target.result + '" style="width:100%;height:100%;object-fit:cover;">';
        };
        reader.readAsDataURL(this.files[0]);
    });
})();
</script>

{% endblock %}
