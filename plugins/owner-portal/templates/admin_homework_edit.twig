{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% block content %}

<div class="page-header">
    <div>
        <h1 class="page-title">Hausaufgabenplan bearbeiten</h1>
        {% if owner %}<p class="page-subtitle">{{ owner.first_name }} {{ owner.last_name }}</p>{% endif %}
    </div>
    <div class="d-flex gap-2">
        <a href="/portal-admin/hausaufgaben/{{ plan.id }}/pdf" target="_blank" class="btn btn-secondary btn-sm">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="14 2 14 8 20 8"/></svg>
            PDF Vorschau
        </a>
        {% if owner %}
        <a href="/portal-admin/tiere/{{ owner.id }}/hausaufgaben" class="btn btn-secondary btn-sm">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            Zurück
        </a>
        {% endif %}
    </div>
</div>

{% if success %}
<div class="alert alert-success alert-dismissible fade show">
    {{ success }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}
{% if error %}
<div class="alert alert-danger alert-dismissible fade show">
    {{ error }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

<form method="POST" action="/portal-admin/hausaufgaben/{{ plan.id }}/bearbeiten">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    <div class="card mb-4">
        <div class="card-header">
            <div class="card-title">
                <i class="fal fa-info-circle mr-2"></i>Allgemeine Informationen
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-500">Tier</label>
                    {% for patient in patients %}
                    {% if patient.id == plan.patient_id %}
                    <input type="text" class="form-control" value="{{ patient.name }} ({{ patient.species }})" readonly>
                    {% endif %}
                    {% endfor %}
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-500">Datum <span class="text-danger">*</span></label>
                    <input type="date" name="plan_date" class="form-control" required
                           value="{{ plan.plan_date }}">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-500">Status</label>
                    <select name="status" class="form-select">
                        <option value="active" {{ plan.status == 'active' ? 'selected' : '' }}>Aktiv</option>
                        <option value="archived" {{ plan.status == 'archived' ? 'selected' : '' }}>Archiviert</option>
                    </select>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-6">
                    <label class="form-label fw-500">Therapeutin</label>
                    <input type="text" name="therapist_name" class="form-control"
                           value="{{ plan.therapist_name }}"
                           placeholder="z.B. Eileen Wenzel (Physiotherapeutin / TFA)">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-500">Wiedervorstellung</label>
                    <input type="text" name="next_appointment" class="form-control"
                           value="{{ plan.next_appointment }}"
                           placeholder="z.B. in 2 Wochen">
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <div class="card-title">
                <i class="fal fa-bullseye mr-2"></i>Therapieziele &amp; Grundsätze
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-500">Physiotherapeutische Grundsätze</label>
                    <textarea name="physio_principles" class="form-control" rows="3">{{ plan.physio_principles }}</textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-500">Therapiemittel</label>
                    <textarea name="therapy_means" class="form-control" rows="3">{{ plan.therapy_means }}</textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-500">Kurzfristige Ziele (innerhalb 3 Behandlungen)</label>
                    <textarea name="short_term_goals" class="form-control" rows="2">{{ plan.short_term_goals }}</textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-500">Langfristige Ziele (Endziele)</label>
                    <textarea name="long_term_goals" class="form-control" rows="2">{{ plan.long_term_goals }}</textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center w-100">
                <div class="card-title mb-0">
                    <i class="fal fa-list-ul mr-2"></i>Therapieaufgaben
                </div>
                <div class="d-flex gap-2">
                    {% if templates %}
                    <button type="button" class="btn btn-xs btn-outline-secondary"
                            onclick="document.getElementById('modal-template-select') && new bootstrap.Modal(document.getElementById('modal-template-select')).show()">
                        <i class="fal fa-copy mr-1"></i> Aus Vorlage
                    </button>
                    {% endif %}
                    <button type="button" class="btn btn-xs btn-outline-info" onclick="openLibraryPicker()">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24" class="me-1"><path stroke="currentColor" stroke-width="2" d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path stroke="currentColor" stroke-width="2" d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                        Aus Bibliothek
                    </button>
                    <button type="button" class="btn btn-xs btn-primary" onclick="addTask()">
                        <i class="fal fa-plus mr-1"></i> Aufgabe hinzufügen
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div id="tasks-container">
                {% for task in tasks %}
                <div class="border rounded p-3 mb-2 task-row" id="task-row-{{ loop.index0 }}">
                    <input type="hidden" name="task_template_id[]" value="{{ task.template_id }}">
                    <div class="d-flex gap-2 align-items-start">
                        <div style="flex:1;">
                            <div class="row g-2 mb-2">
                                <div class="col-md-6">
                                    <input type="text" name="task_title[]" class="form-control form-control-sm"
                                           placeholder="Titel *" required value="{{ task.title }}">
                                </div>
                                <div class="col-md-3">
                                    <input type="text" name="task_frequency[]" class="form-control form-control-sm"
                                           placeholder="Häufigkeit" value="{{ task.frequency }}">
                                </div>
                                <div class="col-md-3">
                                    <input type="text" name="task_duration[]" class="form-control form-control-sm"
                                           placeholder="Dauer" value="{{ task.duration }}">
                                </div>
                            </div>
                            <textarea name="task_description[]" class="form-control form-control-sm mb-2" rows="2"
                                      placeholder="Beschreibung">{{ task.description }}</textarea>
                            <textarea name="task_notes[]" class="form-control form-control-sm" rows="1"
                                      placeholder="Therapeutenhinweise">{{ task.therapist_notes }}</textarea>
                        </div>
                        <button type="button" class="btn btn-xs btn-outline-danger"
                                onclick="this.closest('.task-row').remove(); updateTasksEmpty();">
                            <i class="fal fa-trash"></i>
                        </button>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% if tasks is empty %}
            <p id="tasks-empty" class="text-muted fs-sm mb-0">Noch keine Aufgaben. Klicken Sie auf "Aufgabe hinzufügen".</p>
            {% else %}
            <p id="tasks-empty" class="text-muted fs-sm mb-0" style="display:none;"></p>
            {% endif %}
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <div class="card-title">
                <i class="fal fa-exclamation-triangle mr-2"></i>Beachte / Hinweise
            </div>
        </div>
        <div class="card-body">
            <textarea name="general_notes" class="form-control" rows="5">{{ plan.general_notes }}</textarea>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mb-4">
        {% if owner %}
        <a href="/portal-admin/tiere/{{ owner.id }}/hausaufgaben" class="btn btn-secondary">Abbrechen</a>
        {% endif %}
        <button type="submit" class="btn btn-primary waves-effect waves-themed">
            <i class="fal fa-save mr-1"></i> Änderungen speichern
        </button>
    </div>
</form>

{# ── Library Picker Modal ── #}
<div class="modal fade" id="modal-library-picker" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path stroke="currentColor" stroke-width="2" d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                    Übungsbibliothek
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-2 mb-3">
                    <div class="col-12 col-sm-auto flex-fill">
                        <input type="text" id="lib-search" class="form-control form-control-sm"
                               placeholder="Suche nach Titel oder Beschreibung...">
                    </div>
                    <div class="col-12 col-sm-auto">
                        <select id="lib-category" class="form-select form-select-sm">
                            <option value="">Alle Kategorien</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="filterLibrary()">Filtern</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary ms-1" onclick="resetLibraryFilter()">Zurücksetzen</button>
                    </div>
                </div>
                <div id="lib-results" class="row g-2">
                    <div class="col-12 text-center text-muted py-4">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                        <span class="ms-2">Lade Übungen…</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Template Selector Modal ── #}
{% if templates %}
<div class="modal fade" id="modal-template-select" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Vorlage auswählen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-2">
                {% for tpl in templates %}
                <div class="col-md-6">
                    <div class="card card-hover h-100 tpl-select-card" style="cursor:pointer;"
                         data-tpl="{{ tpl|json_encode|e('html_attr') }}">
                        <div class="card-body p-3">
                            <div class="fw-500 mb-1">
                                {% if tpl.category_emoji %}{{ tpl.category_emoji }} {% endif %}{{ tpl.title }}
                            </div>
                            {% if tpl.description %}
                            <div class="text-muted fs-sm">{{ tpl.description|slice(0,100) }}{% if tpl.description|length > 100 %}…{% endif %}</div>
                            {% endif %}
                            <div class="mt-2 d-flex gap-2 flex-wrap">
                                {% if tpl.frequency %}
                                <span class="badge bg-light text-dark fs-nano">{{ tpl.frequency }}</span>
                                {% endif %}
                                {% if tpl.duration_value %}
                                <span class="badge bg-light text-dark fs-nano">{{ tpl.duration_value }} {{ tpl.duration_unit }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}

<script>
var taskCount = {{ tasks|length }};

function addTask(prefill) {
    var container = document.getElementById('tasks-container');
    var i = taskCount++;
    var p = prefill || {};
    var html = `
    <div class="border rounded p-3 mb-2 task-row" id="task-row-${i}">
        <input type="hidden" name="task_template_id[]" value="${p.id || ''}">
        <div class="d-flex gap-2 align-items-start">
            <div style="flex:1;">
                <div class="row g-2 mb-2">
                    <div class="col-md-6">
                        <input type="text" name="task_title[]" class="form-control form-control-sm"
                               placeholder="Titel *" required value="${escHtml(p.title||'')}">
                    </div>
                    <div class="col-md-3">
                        <input type="text" name="task_frequency[]" class="form-control form-control-sm"
                               placeholder="Häufigkeit" value="${escHtml(p.frequency||'')}">
                    </div>
                    <div class="col-md-3">
                        <input type="text" name="task_duration[]" class="form-control form-control-sm"
                               placeholder="Dauer" value="${escHtml(p.duration||'')}">
                    </div>
                </div>
                <textarea name="task_description[]" class="form-control form-control-sm mb-2" rows="2"
                          placeholder="Beschreibung">${escHtml(p.description||'')}</textarea>
                <textarea name="task_notes[]" class="form-control form-control-sm" rows="1"
                          placeholder="Therapeutenhinweise">${escHtml(p.therapist_notes||'')}</textarea>
            </div>
            <button type="button" class="btn btn-xs btn-outline-danger"
                    onclick="this.closest('.task-row').remove(); updateTasksEmpty();">
                <i class="fal fa-trash"></i>
            </button>
        </div>
    </div>`;
    container.insertAdjacentHTML('beforeend', html);
    updateTasksEmpty();
}

function updateTasksEmpty() {
    var empty = document.getElementById('tasks-empty');
    var rows = document.querySelectorAll('.task-row');
    if (empty) empty.style.display = rows.length === 0 ? '' : 'none';
}

/* Delegated click handler for template cards (replaces inline onclick) */
document.addEventListener('click', function(e) {
    var card = e.target.closest('.tpl-select-card');
    if (!card) return;
    try {
        var tpl = JSON.parse(card.getAttribute('data-tpl') || '{}');
        selectTemplate(tpl);
    } catch(err) {}
});

function selectTemplate(tpl) {
    var freqMap = {
        'daily': 'Täglich', 'twice_daily': '2x täglich',
        'three_times_daily': '3x täglich', 'weekly': 'Wöchentlich', 'as_needed': 'Bei Bedarf'
    };
    var unitMap = { 'minutes': 'Minuten', 'hours': 'Stunden', 'days': 'Tage', 'weeks': 'Wochen' };
    addTask({
        id:              tpl.id,
        title:           tpl.title,
        description:     tpl.description || '',
        frequency:       freqMap[tpl.frequency] || tpl.frequency || '',
        duration:        tpl.duration_value ? (tpl.duration_value + ' ' + (unitMap[tpl.duration_unit] || tpl.duration_unit)) : '',
        therapist_notes: tpl.therapist_notes || '',
    });
    var modal = bootstrap.Modal.getInstance(document.getElementById('modal-template-select'));
    if (modal) modal.hide();
}

function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ── Übungsbibliothek Picker ── */
var _libAllExercises = null;
var _libModal        = null;

function openLibraryPicker() {
    _libModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-library-picker'));
    _libModal.show();
    if (_libAllExercises === null) {
        loadLibrary();
    } else {
        renderLibraryResults(_libAllExercises);
    }
}

function loadLibrary() {
    fetch('/api/tcp/bibliothek', {headers:{'X-Requested-With':'XMLHttpRequest'}})
        .then(function(r){ return r.json(); })
        .then(function(data) {
            if (!data.ok) { showLibraryError(); return; }
            _libAllExercises = data.exercises || [];
            populateLibraryCategories(_libAllExercises);
            renderLibraryResults(_libAllExercises);
        })
        .catch(showLibraryError);
}

function populateLibraryCategories(exercises) {
    var sel = document.getElementById('lib-category');
    var cats = {};
    exercises.forEach(function(e){ if(e.category) cats[e.category] = true; });
    var frag = '';
    Object.keys(cats).sort().forEach(function(c){
        frag += '<option value="' + escHtml(c) + '">' + escHtml(c) + '</option>';
    });
    sel.innerHTML = '<option value="">Alle Kategorien</option>' + frag;
}

function filterLibrary() {
    if (!_libAllExercises) return;
    var search = (document.getElementById('lib-search').value || '').toLowerCase();
    var cat    = document.getElementById('lib-category').value || '';
    var filtered = _libAllExercises.filter(function(e) {
        var matchCat    = !cat    || e.category === cat;
        var matchSearch = !search || e.title.toLowerCase().indexOf(search) >= 0
                                  || (e.description || '').toLowerCase().indexOf(search) >= 0;
        return matchCat && matchSearch;
    });
    renderLibraryResults(filtered);
}

function resetLibraryFilter() {
    document.getElementById('lib-search').value = '';
    document.getElementById('lib-category').value = '';
    if (_libAllExercises) renderLibraryResults(_libAllExercises);
}

function renderLibraryResults(exercises) {
    var container = document.getElementById('lib-results');
    if (!exercises || exercises.length === 0) {
        container.innerHTML = '<div class="col-12 text-center text-muted py-4">Keine Übungen gefunden.</div>';
        return;
    }
    var html = '';
    exercises.forEach(function(e) {
        var desc   = e.description ? escHtml(e.description.substring(0, 100)) + (e.description.length > 100 ? '…' : '') : '';
        var badges = '';
        if (e.frequency) badges += '<span class="badge bg-light text-dark fs-nano me-1">' + escHtml(e.frequency) + '</span>';
        if (e.duration)  badges += '<span class="badge bg-light text-dark fs-nano me-1">' + escHtml(e.duration)  + '</span>';
        if (e.species_tags) {
            e.species_tags.split(',').forEach(function(t){
                if(t.trim()) badges += '<span class="badge bg-info text-dark fs-nano me-1">' + escHtml(t.trim()) + '</span>';
            });
        }
        html += '<div class="col-12 col-md-6 col-xl-4">';
        html +=   '<div class="card h-100 lib-exercise-card" style="cursor:pointer;" data-lib-ex="' + escHtml(JSON.stringify(e)) + '">';
        html +=     '<div class="card-body p-3">';
        html +=       '<div class="d-flex align-items-start gap-2 mb-1">';
        html +=         '<div class="flex-fill">';
        html +=           '<div class="fw-600 mb-1">' + escHtml(e.title) + '</div>';
        html +=           '<span class="badge bg-secondary fs-nano">' + escHtml(e.category || 'sonstiges') + '</span>';
        html +=         '</div>';
        html +=         '<button type="button" class="btn btn-xs btn-primary lib-add-btn flex-shrink-0">+ Hinzufügen</button>';
        html +=       '</div>';
        if (desc) html += '<div class="text-muted fs-sm mt-1 mb-2">' + desc + '</div>';
        if (badges) html += '<div class="mt-1">' + badges + '</div>';
        html +=     '</div>';
        html +=   '</div>';
        html += '</div>';
    });
    container.innerHTML = html;
}

function showLibraryError() {
    document.getElementById('lib-results').innerHTML =
        '<div class="col-12"><div class="alert alert-warning">Bibliothek konnte nicht geladen werden. Bitte prüfen Sie ob TherapyCare Pro aktiv ist.</div></div>';
}

document.addEventListener('click', function(e) {
    var btn  = e.target.closest('.lib-add-btn');
    var card = e.target.closest('.lib-exercise-card');
    if (!btn && !card) return;
    var target = btn ? btn.closest('.lib-exercise-card') : card;
    if (!target) return;
    try {
        var ex = JSON.parse(target.getAttribute('data-lib-ex') || '{}');
        addTask({
            title:           ex.title        || '',
            description:     ex.description  || '',
            instructions:    ex.instructions || '',
            frequency:       ex.frequency    || '',
            duration:        ex.duration     || '',
            therapist_notes: ex.contraindications ? 'Kontraindikationen: ' + ex.contraindications : '',
        });
        if (_libModal) _libModal.hide();
    } catch(err) {}
});

document.getElementById('lib-search').addEventListener('keydown', function(e){
    if (e.key === 'Enter') { e.preventDefault(); filterLibrary(); }
});
</script>

</div>
{% endblock %}
