{% extends '@owner-portal/portal_layout.twig' %}
{% set active_nav = 'tiere' %}
{% block content %}

<div class="mb-3">
    <a href="/portal/tiere" class="small text-secondary text-decoration-none">← Alle Tiere</a>
</div>

{# ── Pet Header ── #}
<div class="card mb-3">
  <div class="card-body d-flex gap-3 align-items-start flex-wrap">
    <div style="flex-shrink:0;">
        {% if pet.photo %}
            <img src="/portal/tiere/{{ pet.id }}/foto/{{ pet.photo }}" alt="{{ pet.name }}"
                 style="width:90px;height:90px;object-fit:cover;border-radius:12px;">
        {% else %}
            <div style="width:90px;height:90px;border-radius:12px;background:var(--bs-tertiary-bg);display:flex;align-items:center;justify-content:center;">
                <svg width="36" height="36" fill="none" viewBox="0 0 24 24" style="opacity:.3;"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/><path stroke="currentColor" stroke-width="1.5" d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            </div>
        {% endif %}
    </div>
    <div class="flex-fill min-width-0">
        <h1 class="h4 mb-1">{{ pet.name }}</h1>
        <div class="d-flex flex-wrap gap-2 small text-secondary">
            {% if pet.species %}<span>🐾 {{ pet.species }}</span>{% endif %}
            {% if pet.breed %}<span>{{ pet.breed }}</span>{% endif %}
            {% if pet.birth_date %}<span>📅 geb. {{ pet.birth_date|date('d.m.Y') }}</span>{% endif %}
            {% if pet.gender %}<span>{{ pet.gender }}</span>{% endif %}
            {% if pet.color %}<span>{{ pet.color }}</span>{% endif %}
            {% if pet.chip_number %}<span>Chip: {{ pet.chip_number }}</span>{% endif %}
        </div>
        <div class="mt-2">
            <span class="badge-status {% if pet.status == 'aktiv' %}badge-paid{% elseif pet.status == 'verstorben' %}badge-draft{% else %}badge-open{% endif %}">
                {{ pet.status }}
            </span>
        </div>
    </div>
    <div class="d-flex flex-column gap-2">
        <a href="/portal/tiere/{{ pet.id }}/bearbeiten" class="portal-btn portal-btn-secondary portal-btn-sm">
            ✏️ Bearbeiten
        </a>
        <a href="/portal/tiere/{{ pet.id }}/uebungen" class="portal-btn portal-btn-secondary portal-btn-sm">
            💪 Übungen
        </a>
        {% if show_homework ?? true %}
        <a href="/portal/tiere/{{ pet.id }}/hausaufgaben" class="portal-btn portal-btn-secondary portal-btn-sm">
            📋 Hausaufgaben
        </a>
        {% endif %}
    </div>
  </div>
</div>

{# ── Tab Navigation ── #}
{# NOTE: Behandlungen und Notizen sind nur für Therapeuten sichtbar, nicht im Besitzerportal #}
<div class="d-flex gap-1 border-bottom mb-3" style="overflow-x:auto;">
    {% set tabs = [
        {id:'dokumente',      label:'Dokumente',      count: documents|length},
        {id:'fotos',          label:'Fotos',          count: photos|length},
    ] %}
    {% if homework_plans is defined and homework_plans|length > 0 %}
        {% set tabs = tabs|merge([{id:'hausaufgaben', label:'Hausaufgaben', count: homework_plans|length}]) %}
    {% endif %}
    {% if befunde is defined and befunde|length > 0 %}
        {% set tabs = tabs|merge([{id:'befunde', label:'Befundbögen', count: befunde|length}]) %}
    {% endif %}
    {% if tcp_progress is defined and tcp_progress|length > 0 %}
        {% set tabs = tabs|merge([{id:'fortschritt', label:'Fortschritt', count: tcp_progress|length}]) %}
    {% endif %}
    {% if tcp_natural is defined and tcp_natural|length > 0 %}
        {% set tabs = tabs|merge([{id:'naturheilkunde', label:'Naturheilkunde', count: tcp_natural|length}]) %}
    {% endif %}
    {% if tcp_reports is defined and tcp_reports|length > 0 %}
        {% set tabs = tabs|merge([{id:'berichte', label:'Therapieberichte', count: tcp_reports|length}]) %}
    {% endif %}
    {% if tcp_feedback is defined %}
        {% set tabs = tabs|merge([{id:'feedback', label:'Feedback', count: tcp_feedback|length}]) %}
    {% endif %}
    {% for tab in tabs %}
    <button class="pet-tab-btn" data-tab="{{ tab.id }}"
            style="background:none;border:none;color:var(--bs-secondary-color);padding:0.6rem 0.9rem;font-size:0.85rem;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:color .15s;">
        {{ tab.label }}
        {% if tab.count > 0 %}<span class="badge bg-primary bg-opacity-25 text-primary ms-1" style="font-size:0.68rem;">{{ tab.count }}</span>{% endif %}
    </button>
    {% endfor %}
</div>

{# ── Dokumente ── #}
<div class="pet-tab-panel" id="panel-dokumente">
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5 mb-3">Dokumente</h2>
        {% if documents %}
            {% for entry in documents %}
            <div class="timeline-entry">
                <div class="timeline-date">{{ entry.entry_date|date('d.m.Y') }}</div>
                <div style="display:flex;align-items:center;gap:0.75rem;">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" style="opacity:.5;flex-shrink:0;"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>
                    <div>
                        <div class="timeline-title">{{ entry.title }}</div>
                        {% if entry.attachment %}
                            <a href="/uploads/{{ entry.attachment }}" target="_blank"
                               class="small text-primary">Herunterladen →</a>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
        {% else %}
            <p class="text-secondary small">Keine Dokumente vorhanden.</p>
        {% endif %}
      </div>
    </div>
</div>

{# ── Fotos ── #}
<div class="pet-tab-panel" id="panel-fotos" style="display:none;">
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5 mb-3">Fotos</h2>
        {% if photos %}
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:0.5rem;">
            {% for entry in photos %}
                {% if entry.attachment %}
                <div>
                    <a href="/uploads/{{ entry.attachment }}" target="_blank">
                        <img src="/uploads/{{ entry.attachment }}" alt="{{ entry.title }}"
                             style="width:100%;height:110px;object-fit:cover;border-radius:8px;border:1px solid rgba(255,255,255,0.08);">
                    </a>
                    <div class="small text-secondary text-center mt-1">{{ entry.entry_date|date('d.m.Y') }}</div>
                </div>
                {% endif %}
            {% endfor %}
            </div>
        {% else %}
            <p class="text-secondary small">Keine Fotos vorhanden.</p>
        {% endif %}
      </div>
    </div>
</div>

{# ── Hausaufgaben ── #}
{% if homework_plans is defined and homework_plans|length > 0 %}
<div class="pet-tab-panel" id="panel-hausaufgaben" style="display:none;">
    {% for plan in homework_plans %}
    {% set planId = plan.id %}
    {% set tasks = tasks_by_plan[planId] ?? [] %}
    {% set checks = checks_by_plan[planId] ?? [] %}
    <div class="card mb-3">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
          <div>
            <h3 class="h6 mb-0 fw-semibold">{{ plan.title ?? 'Hausaufgabenplan' }}</h3>
            {% if plan.plan_date %}<div class="text-secondary" style="font-size:0.75rem;">{{ plan.plan_date|date('d.m.Y') }}</div>{% endif %}
          </div>
          <div class="d-flex gap-2">
            {% if tasks|length > 0 %}
              {% set doneCount = 0 %}
              {% for t in tasks %}{% if checks[t.id] is defined and checks[t.id] %}{% set doneCount = doneCount + 1 %}{% endif %}{% endfor %}
              <span class="badge bg-primary bg-opacity-25 text-primary" style="font-size:0.7rem;">{{ doneCount }}/{{ tasks|length }}</span>
            {% endif %}
            <a href="/portal/tiere/{{ pet.id }}/hausaufgaben/{{ plan.id }}/pdf"
               class="portal-btn portal-btn-secondary portal-btn-sm" target="_blank">PDF</a>
          </div>
        </div>
        {% if plan.description %}
        <p class="text-secondary small mb-2">{{ plan.description }}</p>
        {% endif %}
        {% if tasks %}
        <ul class="list-unstyled mb-0">
        {% for task in tasks %}
            {% set isChecked = checks[task.id] is defined and checks[task.id] %}
            <li class="d-flex align-items-start gap-2 py-2" style="border-top:1px solid var(--bs-border-color);">
                <input type="checkbox" class="homework-check mt-1" style="cursor:pointer;width:16px;height:16px;flex-shrink:0;"
                       data-plan="{{ plan.id }}" data-task="{{ task.id }}"
                       {% if isChecked %}checked{% endif %}
                       title="Aufgabe abhaken">
                <div class="flex-fill">
                    <div class="fw-medium" style="font-size:0.875rem;{% if isChecked %}text-decoration:line-through;opacity:0.6;{% endif %}">{{ task.title }}</div>
                    {% if task.description %}<div class="text-secondary" style="font-size:0.78rem;">{{ task.description }}</div>{% endif %}
                    {% if task.repetitions %}<div class="text-secondary" style="font-size:0.72rem;">{{ task.repetitions }}</div>{% endif %}
                </div>
            </li>
        {% endfor %}
        </ul>
        {% else %}
        <p class="text-secondary small mb-0">Keine Aufgaben in diesem Plan.</p>
        {% endif %}
      </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{# ── Befundbögen ── #}
{% if befunde is defined and befunde|length > 0 %}
<div class="pet-tab-panel" id="panel-befunde" style="display:none;">
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5 mb-3">Befundbögen</h2>
        {% for bf in befunde %}
        <div class="d-flex align-items-center gap-3 py-2" style="border-bottom:1px solid var(--bs-border-color);">
            <div class="flex-fill">
                <div class="fw-semibold" style="font-size:0.875rem;">
                    BF-{{ '%04d'|format(bf.id) }} &mdash; {{ bf.datum|date('d.m.Y') }}
                </div>
                {% if bf.ersteller_name %}<div class="text-secondary" style="font-size:0.75rem;">{{ bf.ersteller_name }}</div>{% endif %}
                <span class="badge-status {% if bf.status == 'versendet' %}badge-paid{% elseif bf.status == 'abgeschlossen' %}bg-info bg-opacity-25 text-info{% else %}badge-draft{% endif %}" style="font-size:0.65rem;">
                    {% if bf.status == 'versendet' %}Versendet{% elseif bf.status == 'abgeschlossen' %}Abgeschlossen{% else %}Entwurf{% endif %}
                </span>
            </div>
            <a href="/portal/befunde/{{ bf.id }}" class="portal-btn portal-btn-secondary portal-btn-sm">Ansehen →</a>
        </div>
        {% endfor %}
      </div>
    </div>
</div>
{% endif %}

{# ── TherapyCare Pro: Fortschritt ── #}
{% if tcp_progress is defined and tcp_progress|length > 0 %}
<div class="pet-tab-panel" id="panel-fortschritt" style="display:none;">
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5 mb-3">Therapiefortschritt</h2>
        {% for entry in tcp_progress %}
        <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="small fw-semibold">{{ entry.category_name }}</span>
                <span class="small" style="color:{{ entry.category_color }};">
                    {{ entry.score }} / {{ entry.scale_max ?? 10 }}
                </span>
            </div>
            {% set pct = (((entry.score - (entry.scale_min ?? 1)) / ((entry.scale_max ?? 10) - (entry.scale_min ?? 1))) * 100)|round %}
            <div style="height:6px;background:rgba(128,128,128,0.2);border-radius:999px;overflow:hidden;">
                <div style="height:100%;width:{{ pct }}%;background:{{ entry.category_color }};border-radius:999px;"></div>
            </div>
            <div class="text-secondary" style="font-size:0.7rem;margin-top:0.2rem;">
                {{ entry.entry_date|date('d.m.Y') }}{% if entry.notes %} · {{ entry.notes }}{% endif %}
            </div>
        </div>
        {% endfor %}
        <div class="mt-3">
            <a href="/portal/tcp/tiere/{{ pet.id }}/fortschritt" class="portal-btn portal-btn-secondary portal-btn-sm">
                Vollständiger Verlauf →
            </a>
        </div>
      </div>
    </div>
</div>
{% endif %}

{# ── TherapyCare Pro: Naturheilkunde ── #}
{% if tcp_natural is defined and tcp_natural|length > 0 %}
<div class="pet-tab-panel" id="panel-naturheilkunde" style="display:none;">
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5 mb-3">Naturheilkunde</h2>
        {% for entry in tcp_natural %}
        <div class="timeline-entry">
            <div class="timeline-date">{{ entry.entry_date|date('d.m.Y') }}</div>
            <div class="timeline-title">{{ entry.type_name ?? entry.custom_type ?? 'Behandlung' }}</div>
            {% if entry.notes %}<div class="timeline-content">{{ entry.notes|nl2br }}</div>{% endif %}
            {% if entry.dosage %}<div class="small text-secondary mt-1">Dosierung: {{ entry.dosage }}</div>{% endif %}
        </div>
        {% endfor %}
        <div class="mt-3">
            <a href="/portal/tcp/tiere/{{ pet.id }}/naturheilkunde" class="portal-btn portal-btn-secondary portal-btn-sm">
                Alle Einträge →
            </a>
        </div>
      </div>
    </div>
</div>
{% endif %}

{# ── TherapyCare Pro: Therapieberichte ── #}
{% if tcp_reports is defined and tcp_reports|length > 0 %}
<div class="pet-tab-panel" id="panel-berichte" style="display:none;">
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5 mb-3">Therapieberichte</h2>
        {% for report in tcp_reports %}
        <div class="d-flex align-items-center gap-3 py-2" style="border-bottom:1px solid rgba(128,128,128,0.15);">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;opacity:.5;">
                <path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/>
            </svg>
            <div class="flex-fill">
                <div class="small fw-semibold">{{ report.title ?? 'Therapiebericht' }}</div>
                <div class="text-secondary" style="font-size:0.72rem;">{{ report.created_at|date('d.m.Y') }}</div>
            </div>
            <a href="/portal/tcp/tiere/{{ pet.id }}/berichte/{{ report.id }}/download"
               class="portal-btn portal-btn-secondary portal-btn-sm">
                PDF →
            </a>
        </div>
        {% endfor %}
      </div>
    </div>
</div>
{% endif %}

{# ── TherapyCare Pro: Feedback ── #}
{% if tcp_feedback is defined %}
<div class="pet-tab-panel" id="panel-feedback" style="display:none;">
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5 mb-3">Übungs-Feedback</h2>
        {% if tcp_feedback|length > 0 %}
            {% for fb in tcp_feedback %}
            <div class="timeline-entry">
                <div class="timeline-date">{{ fb.feedback_date|date('d.m.Y') }}</div>
                <div class="timeline-title">
                    {{ fb.homework_title ?? 'Übung' }}
                    <span class="badge ms-2
                        {% if fb.status == 'done' %}bg-success
                        {% elseif fb.status == 'pain' %}bg-danger
                        {% elseif fb.status == 'difficult' %}bg-warning text-dark
                        {% else %}bg-secondary{% endif %}"
                        style="font-size:0.65rem;">
                        {% if fb.status == 'done' %}Durchgeführt
                        {% elseif fb.status == 'not_done' %}Nicht durchgeführt
                        {% elseif fb.status == 'pain' %}Schmerzen
                        {% elseif fb.status == 'difficult' %}Schwierig
                        {% else %}{{ fb.status }}{% endif %}
                    </span>
                </div>
                {% if fb.comment %}<div class="timeline-content">{{ fb.comment|nl2br }}</div>{% endif %}
            </div>
            {% endfor %}
        {% else %}
            <p class="text-secondary small">Noch kein Feedback eingereicht.</p>
        {% endif %}
        <div class="mt-3">
            <a href="/portal/tcp/tiere/{{ pet.id }}/feedback" class="portal-btn portal-btn-secondary portal-btn-sm">
                Feedback einreichen →
            </a>
        </div>
      </div>
    </div>
</div>
{% endif %}

<script>
(function(){
    var btns   = document.querySelectorAll('.pet-tab-btn');
    var panels = document.querySelectorAll('.pet-tab-panel');
    function activate(id) {
        btns.forEach(function(b){
            var active = b.dataset.tab === id;
            b.style.color        = active ? 'var(--bs-body-color)' : 'var(--bs-secondary-color)';
            b.style.borderBottom = active ? '2px solid var(--bs-primary)' : '2px solid transparent';
        });
        panels.forEach(function(p){ p.style.display = p.id === 'panel-' + id ? '' : 'none'; });
    }
    btns.forEach(function(b){ b.addEventListener('click', function(){ activate(b.dataset.tab); }); });
    activate('dokumente');
})();
</script>

<script>
/* Homework checkbox toggle */
document.querySelectorAll('.homework-check').forEach(function(cb) {
    cb.addEventListener('change', function() {
        var planId = this.dataset.plan;
        var taskId = this.dataset.task;
        var checked = this.checked;
        var li = this.closest('li');
        var titleEl = li ? li.querySelector('.fw-medium') : null;
        fetch('/api/portal/hausaufgaben/' + planId + '/aufgabe/' + taskId + '/abhaken', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({checked: checked})
        }).then(function(r) { return r.json(); }).then(function(data) {
            if (data.ok && titleEl) {
                titleEl.style.textDecoration = checked ? 'line-through' : '';
                titleEl.style.opacity = checked ? '0.6' : '1';
            }
        }).catch(function() {});
    });
});
</script>
{% endblock %}
