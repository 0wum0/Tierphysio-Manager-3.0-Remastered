<!DOCTYPE html>
<html lang="de" data-bs-theme="dark" class="set-nav-dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Besitzerportal — Login</title>
    <link rel="stylesheet" href="/themes/smart-tierphysio/css/smartapp.min.css">
    <link rel="stylesheet" href="/themes/smart-tierphysio/bridge.css?v=20260308f">
    <script src="/themes/smart-tierphysio/scripts/core/saveloadscript.js"></script>
    <style>
        body { min-height:100vh; display:flex; align-items:center; justify-content:center; }
        .login-wrap { width:100%; max-width:420px; padding:1.5rem; }
    </style>
</head>
<body>
<div class="login-wrap">
    <div class="card">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <svg width="40" height="40" fill="none" viewBox="0 0 24 24">
                    <path stroke="var(--bs-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline stroke="var(--bs-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" points="9 22 9 12 15 12 15 22"/>
                </svg>
            </div>
            <h1 class="h4 text-center mb-1">Besitzerportal</h1>
            <p class="text-secondary text-center small mb-4">Melden Sie sich an, um Ihre Tiere, Termine und Rechnungen zu sehen.</p>

            {% if error %}
                <div class="alert alert-danger">{{ error }}</div>
            {% endif %}
            {% if success %}
                <div class="alert alert-success">{{ success }}</div>
            {% endif %}

            <form action="/portal/login" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                {% if tid %}
                    <input type="hidden" name="tid" value="{{ tid }}">
                {% endif %}
                <div class="mb-3">
                    <label for="email" class="form-label small fw-semibold">E-Mail-Adresse</label>
                    <input type="email" id="email" name="email" class="form-control" required autocomplete="email" autofocus>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label small fw-semibold">Passwort</label>
                    <input type="password" id="password" name="password" class="form-control" required autocomplete="current-password">
                </div>
                <button type="submit" class="btn btn-primary w-100 mt-1">Anmelden</button>
            </form>
        </div>
    </div>
    <p class="text-center text-secondary small mt-3">Tierphysio Praxis &mdash; Besitzerportal</p>
</div>
<script src="/themes/smart-tierphysio/scripts/bootstrap.bundle.min.js"></script>
</body>
</html>
