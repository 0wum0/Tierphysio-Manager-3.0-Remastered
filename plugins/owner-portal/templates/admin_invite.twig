{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% block content %}

<div class="page-header">
    <div>
        <h1 class="page-title">Besitzer einladen</h1>
        <p class="page-subtitle">Einladungslink per E-Mail senden</p>
    </div>
    <a href="/portal-admin" class="btn btn-secondary btn-sm">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
        Zurück
    </a>
</div>

{% if error %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    {{ error }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

<div class="row">
    <div class="col-12 col-md-7 col-lg-6">
        <div class="glass-card">
            <h3 class="font-semibold mb-4" style="font-size:0.95rem;">Einladung senden</h3>
                    <form action="/portal-admin/einladen" method="POST">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                        <div class="form-group">
                            <label class="form-label" for="owner_id">Besitzer auswählen</label>
                            <select name="owner_id" id="owner_id" class="form-control" required>
                                <option value="">— Besitzer wählen —</option>
                                {% for owner in owners %}
                                    {% if owner.id not in linked_owner_ids %}
                                    <option value="{{ owner.id }}" {% if owner.email %}data-email="{{ owner.email }}"{% endif %}>
                                        {{ owner.last_name }}, {{ owner.first_name }}
                                        {% if owner.email %} ({{ owner.email }}){% endif %}
                                    </option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                            <div class="form-hint">Besitzer die bereits ein Portal-Konto haben werden nicht angezeigt.</div>
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="email">E-Mail-Adresse für das Portal-Konto</label>
                            <input type="email" name="email" id="email" class="form-control"
                                   placeholder="email@example.com" required autocomplete="off">
                            <div class="form-hint">An diese Adresse wird der Einladungslink gesendet.</div>
                        </div>

                        <div class="alert alert-info fs-sm" role="alert">
                            <i class="fal fa-info-circle mr-1"></i>
                            Der Besitzer erhält eine E-Mail mit einem Einladungslink, über den er sein Passwort festlegen kann.
                            Der Link ist <strong>7 Tage</strong> gültig.
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="fal fa-envelope mr-1"></i> Einladung senden
                        </button>
                    </form>
        </div>
    </div>
</div>

<script>
document.getElementById('owner_id').addEventListener('change', function() {
    var opt = this.options[this.selectedIndex];
    var email = opt.getAttribute('data-email') || '';
    document.getElementById('email').value = email;
});
</script>

{% endblock %}
