{% extends '@owner-portal/portal_layout.twig' %}
{% set active_nav = 'termine' %}
{% block content %}

<h1 class="portal-page-title">📅 Meine Termine</h1>

{# ── Upcoming ── #}
<div class="card mb-3">
  <div class="card-body">
    <h2 class="h5 mb-3">Kommende Termine</h2>
    {% if upcoming %}
        {% for appt in upcoming %}
        <div class="d-flex gap-3 align-items-start py-2 border-bottom border-opacity-10">
            <div style="width:10px;height:10px;border-radius:50%;background:{{ appt.treatment_type_color ?? 'var(--bs-primary)' }};margin-top:5px;flex-shrink:0;"></div>
            <div class="flex-fill min-width-0">
                <div class="fw-semibold">{{ appt.title }}</div>
                <div class="small text-secondary mt-1">
                    {{ appt.start_at|date('d.m.Y') }} · {{ appt.start_at|date('H:i') }} Uhr
                    {% if appt.end_at %} – {{ appt.end_at|date('H:i') }}{% endif %}
                </div>
                {% if appt.patient_name %}
                <div class="small text-secondary">🐾 {{ appt.patient_name }}</div>
                {% endif %}
                {% if appt.treatment_type_name %}
                <div class="mt-1">
                    <span class="badge bg-primary bg-opacity-25 text-primary" style="font-size:0.7rem;">{{ appt.treatment_type_name }}</span>
                </div>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    {% else %}
        <p class="text-secondary small">Keine kommenden Termine.</p>
    {% endif %}
  </div>
</div>

{# ── Past ── #}
{% if past %}
<div class="card mb-3">
  <div class="card-body">
    <h2 class="h5 mb-3">Vergangene Termine</h2>
    {% for appt in past %}
    <div class="d-flex gap-3 align-items-start py-2 border-bottom border-opacity-10">
        <div style="width:8px;height:8px;border-radius:50%;background:var(--bs-secondary-color);margin-top:5px;flex-shrink:0;opacity:.4;"></div>
        <div class="flex-fill">
            <div class="small text-secondary fw-500">{{ appt.title }}</div>
            <div class="small text-secondary" style="opacity:.6;">
                {{ appt.start_at|date('d.m.Y H:i') }}
                {% if appt.patient_name %} · {{ appt.patient_name }}{% endif %}
            </div>
        </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{% endblock %}
