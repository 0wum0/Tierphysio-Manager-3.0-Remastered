<!DOCTYPE html>
<html lang="de" data-bs-theme="dark" class="set-nav-dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Passwort festlegen — Besitzerportal</title>
    <link rel="stylesheet" href="/themes/smart-tierphysio/css/smartapp.min.css">
    <link rel="stylesheet" href="/themes/smart-tierphysio/bridge.css?v=20260308f">
    <script src="/themes/smart-tierphysio/scripts/core/saveloadscript.js"></script>
    <style>
        body { min-height:100vh; display:flex; align-items:center; justify-content:center; }
        .wrap { width:100%; max-width:420px; padding:1.5rem; }
    </style>
</head>
<body>
<div class="wrap">
    <div class="card">
        <div class="card-body p-4">
            <h1 class="h4 mb-1">🔐 Passwort festlegen</h1>
            <p class="text-secondary small mb-4">Willkommen! Bitte legen Sie Ihr Passwort für das Besitzerportal fest.</p>

            {% if error %}
                <div class="alert alert-danger">{{ error }}</div>
            {% endif %}

            <form action="/portal/einladung/{{ token }}" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="mb-3">
                    <label for="password" class="form-label small fw-semibold">Neues Passwort</label>
                    <input type="password" id="password" name="password" class="form-control" required autocomplete="new-password" autofocus>
                    <div class="form-text">Mindestens 8 Zeichen.</div>
                </div>
                <div class="mb-3">
                    <label for="password_confirm" class="form-label small fw-semibold">Passwort bestätigen</label>
                    <input type="password" id="password_confirm" name="password_confirm" class="form-control" required autocomplete="new-password">
                </div>
                <button type="submit" class="btn btn-primary w-100 mt-1">Passwort speichern &amp; einloggen</button>
            </form>
        </div>
    </div>
</div>
<script src="/themes/smart-tierphysio/scripts/bootstrap.bundle.min.js"></script>
</body>
</html>
