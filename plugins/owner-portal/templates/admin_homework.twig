{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% block content %}

<div id="content">
<div class="subheader">
    <h1 class="subheader-title">
        <i class="subheader-icon fal fa-clipboard-list"></i>
        Hausaufgaben — {{ owner.first_name }} {{ owner.last_name }}
        <small>Therapiepläne für Tierbesitzer verwalten</small>
    </h1>
    <div class="subheader-action">
        <a href="/portal-admin/tiere/{{ owner.id }}/uebungen" class="btn btn-outline-secondary btn-sm mr-2">
            <i class="fal fa-dumbbell mr-1"></i> Übungen
        </a>
        <a href="/portal-admin" class="btn btn-outline-secondary btn-sm">
            <i class="fal fa-arrow-left mr-1"></i> Portal-Verwaltung
        </a>
    </div>
</div>

{% if success %}
<div class="alert alert-success alert-dismissible fade show" role="alert">
    {{ success }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}
{% if error %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    {{ error }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

{% if patients is empty %}
<div class="alert alert-warning">Keine Patienten für diesen Tierhalter gefunden.</div>
{% else %}

{# ── Per-patient accordion ── #}
<div class="accordion" id="acc-patients">
{% for patient in patients %}
{% set planList = plans_by_patient[patient.id] ?? [] %}
<div class="card mb-3">
    <div class="card-header d-flex align-items-center justify-content-between gap-2 py-2 px-3"
         style="cursor:pointer;" data-bs-toggle="collapse"
         data-bs-target="#acc-pat-{{ patient.id }}" aria-expanded="true">
        <div class="d-flex align-items-center gap-2">
            <span class="fw-600">🐾 {{ patient.name }}</span>
            <span class="badge bg-secondary fs-nano">{{ patient.species }}</span>
            <span class="badge bg-primary fs-nano">{{ planList|length }} Plan{{ planList|length != 1 ? '&#8203;' : '' }}</span>
        </div>
        <button type="button" class="btn btn-xs btn-primary"
                onclick="event.stopPropagation(); openCreatePlan({{ patient.id }}, {{ patient.name|json_encode }});">
            <i class="fal fa-plus mr-1"></i> Hausaufgabenplan erstellen
        </button>
    </div>
    <div id="acc-pat-{{ patient.id }}" class="collapse show">
        <div class="card-body p-0">
            {% if planList %}
                {% for plan in planList %}
                <div class="d-flex align-items-start gap-3 p-3 border-bottom">
                    <div style="flex:1;min-width:0;">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span class="fw-600">
                                <i class="fal fa-calendar-alt mr-1 text-muted"></i>
                                Hausaufgabenplan vom {{ plan.plan_date|date('d.m.Y') }}
                            </span>
                            {% if plan.status == 'active' %}
                                <span class="badge badge-success fs-nano">Aktiv</span>
                            {% else %}
                                <span class="badge badge-secondary fs-nano">Archiviert</span>
                            {% endif %}
                        </div>
                        {% if plan.therapist_name %}
                        <div class="text-muted fs-sm">
                            <i class="fal fa-user-md mr-1"></i>{{ plan.therapist_name }}
                        </div>
                        {% endif %}
                        {% if plan.next_appointment %}
                        <div class="text-muted fs-sm mt-1">
                            <i class="fal fa-clock mr-1"></i>Wiedervorstellung: {{ plan.next_appointment }}
                        </div>
                        {% endif %}
                        {% if plan.pdf_sent_at %}
                        <div class="text-success fs-nano mt-1">
                            <i class="fal fa-check mr-1"></i>Per E-Mail gesendet am {{ plan.pdf_sent_at|date('d.m.Y H:i') }}
                            {% if plan.pdf_sent_to %} an {{ plan.pdf_sent_to }}{% endif %}
                        </div>
                        {% endif %}
                    </div>
                    <div class="d-flex flex-column gap-1" style="flex-shrink:0;">
                        <a href="/portal-admin/hausaufgaben/{{ plan.id }}/bearbeiten"
                           class="btn btn-xs btn-outline-primary">
                            <i class="fal fa-edit mr-1"></i> Bearbeiten
                        </a>
                        <a href="/portal-admin/hausaufgaben/{{ plan.id }}/pdf" target="_blank"
                           class="btn btn-xs btn-outline-info">
                            <i class="fal fa-file-pdf mr-1"></i> PDF
                        </a>
                        <form method="POST" action="/portal-admin/hausaufgaben/{{ plan.id }}/senden"
                              onsubmit="return confirm('Hausaufgaben per E-Mail senden an {{ owner.email }}?');">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-xs btn-outline-success w-100">
                                <i class="fal fa-paper-plane mr-1"></i> Senden
                            </button>
                        </form>
                        <form method="POST" action="/portal-admin/hausaufgaben/{{ plan.id }}/loeschen"
                              onsubmit="return confirm('Hausaufgabenplan wirklich löschen?');">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-xs btn-outline-danger w-100">
                                <i class="fal fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
                {% endfor %}
            {% else %}
            <div class="p-3 text-muted fs-sm">Noch keine Hausaufgabenpläne für {{ patient.name }}.</div>
            {% endif %}
        </div>
    </div>
</div>
{% endfor %}
</div>
{% endif %}

{# ── Create Plan Modal ── #}
<div class="modal fade" id="modal-create-plan" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <form id="form-create-plan" method="POST"
                  action="/portal-admin/tiere/{{ owner.id }}/hausaufgaben">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="patient_id" id="create-patient-id" value="">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fal fa-clipboard-list mr-2"></i>
                        Neuer Hausaufgabenplan — <span id="create-patient-name"></span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-500">Datum <span class="text-danger">*</span></label>
                            <input type="date" name="plan_date" class="form-control" required
                                   value="{{ "now"|date("Y-m-d") }}">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-500">Therapeutin</label>
                            <input type="text" name="therapist_name" class="form-control"
                                   placeholder="z.B. Eileen Wenzel (Physiotherapeutin)">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-500">Wiedervorstellung</label>
                            <input type="text" name="next_appointment" class="form-control"
                                   placeholder="z.B. in 2 Wochen">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-500">Physiotherapeutische Grundsätze</label>
                            <textarea name="physio_principles" class="form-control" rows="3"
                                      placeholder="z.B. Schmerzfreiheit, Stabilisierung/Mobilisierung der Bewegungsabläufe..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-500">Therapiemittel</label>
                            <textarea name="therapy_means" class="form-control" rows="3"
                                      placeholder="z.B. Wärme, Massage, Dehnung..."></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-500">Kurzfristige Ziele (innerhalb 3 Behandlungen)</label>
                            <textarea name="short_term_goals" class="form-control" rows="2"
                                      placeholder="z.B. Schmerzfreiheit, Mobilisierung..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-500">Langfristige Ziele (Endziele)</label>
                            <textarea name="long_term_goals" class="form-control" rows="2"
                                      placeholder="z.B. Mobilisierung/Stabilisierung der Rückenmuskulatur..."></textarea>
                        </div>
                    </div>

                    {# ── Tasks section ── #}
                    <div class="border-top pt-3 mt-2">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0"><i class="fal fa-list-ul mr-2"></i>Therapieaufgaben</h6>
                            <div class="d-flex gap-2">
                                {% if templates %}
                                <button type="button" class="btn btn-xs btn-outline-secondary"
                                        onclick="openTemplateSelector()">
                                    <i class="fal fa-copy mr-1"></i> Aus Vorlage
                                </button>
                                {% endif %}
                                <button type="button" class="btn btn-xs btn-primary" onclick="addTask()">
                                    <i class="fal fa-plus mr-1"></i> Aufgabe hinzufügen
                                </button>
                            </div>
                        </div>
                        <div id="tasks-container">
                            {# Tasks added dynamically #}
                        </div>
                        <p id="tasks-empty" class="text-muted fs-sm mb-0">Noch keine Aufgaben. Klicken Sie auf "Aufgabe hinzufügen".</p>
                    </div>

                    <div class="mt-3">
                        <label class="form-label fw-500">Beachte / Hinweise (WICHTIG)</label>
                        <textarea name="general_notes" class="form-control" rows="4"
                                  placeholder="z.B. WICHTIG! Aufwärmphasen sind bei älteren Patienten..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary waves-effect waves-themed">
                        <i class="fal fa-save mr-1"></i> Plan speichern
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ── Template Selector Modal ── #}
{% if templates %}
<div class="modal fade" id="modal-template-select" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Vorlage auswählen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-2">
                {% for tpl in templates %}
                <div class="col-md-6">
                    <div class="card card-hover h-100" style="cursor:pointer;"
                         onclick="selectTemplate({{ tpl|json_encode }})">
                        <div class="card-body p-3">
                            <div class="fw-500 mb-1">
                                {% if tpl.category_emoji %}{{ tpl.category_emoji }} {% endif %}{{ tpl.title }}
                            </div>
                            {% if tpl.description %}
                            <div class="text-muted fs-sm" style="white-space:pre-line;">{{ tpl.description|slice(0,100) }}{% if tpl.description|length > 100 %}…{% endif %}</div>
                            {% endif %}
                            <div class="mt-2 d-flex gap-2 flex-wrap">
                                {% if tpl.frequency %}
                                <span class="badge bg-light text-dark fs-nano">{{ tpl.frequency }}</span>
                                {% endif %}
                                {% if tpl.duration_value %}
                                <span class="badge bg-light text-dark fs-nano">{{ tpl.duration_value }} {{ tpl.duration_unit }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}

<script>
var taskCount = 0;

function openCreatePlan(patientId, patientName) {
    document.getElementById('create-patient-id').value = patientId;
    document.getElementById('create-patient-name').textContent = patientName;
    document.getElementById('tasks-container').innerHTML = '';
    taskCount = 0;
    updateTasksEmpty();
    new bootstrap.Modal(document.getElementById('modal-create-plan')).show();
}

function addTask(prefill) {
    var container = document.getElementById('tasks-container');
    var i = taskCount++;
    var p = prefill || {};
    var html = `
    <div class="border rounded p-3 mb-2 task-row" id="task-row-${i}">
        <input type="hidden" name="task_template_id[]" value="${p.id || ''}">
        <div class="d-flex gap-2 align-items-start">
            <div style="flex:1;">
                <div class="row g-2 mb-2">
                    <div class="col-md-6">
                        <input type="text" name="task_title[]" class="form-control form-control-sm"
                               placeholder="Titel der Aufgabe *" required value="${escHtml(p.title||'')}">
                    </div>
                    <div class="col-md-3">
                        <input type="text" name="task_frequency[]" class="form-control form-control-sm"
                               placeholder="Häufigkeit" value="${escHtml(p.frequency||'')}">
                    </div>
                    <div class="col-md-3">
                        <input type="text" name="task_duration[]" class="form-control form-control-sm"
                               placeholder="Dauer" value="${escHtml(p.duration||'')}">
                    </div>
                </div>
                <textarea name="task_description[]" class="form-control form-control-sm mb-2" rows="2"
                          placeholder="Beschreibung / Durchführung">${escHtml(p.description||'')}</textarea>
                <textarea name="task_notes[]" class="form-control form-control-sm" rows="1"
                          placeholder="Therapeutenhinweise (optional)">${escHtml(p.therapist_notes||'')}</textarea>
            </div>
            <button type="button" class="btn btn-xs btn-outline-danger"
                    onclick="document.getElementById('task-row-${i}').remove(); updateTasksEmpty();">
                <i class="fal fa-trash"></i>
            </button>
        </div>
    </div>`;
    container.insertAdjacentHTML('beforeend', html);
    updateTasksEmpty();
}

function updateTasksEmpty() {
    var empty = document.getElementById('tasks-empty');
    var rows = document.querySelectorAll('.task-row');
    if (empty) empty.style.display = rows.length === 0 ? '' : 'none';
}

function openTemplateSelector() {
    new bootstrap.Modal(document.getElementById('modal-template-select')).show();
}

function selectTemplate(tpl) {
    // Map frequency enum to readable text
    var freqMap = {
        'daily': 'Täglich', 'twice_daily': '2x täglich',
        'three_times_daily': '3x täglich', 'weekly': 'Wöchentlich', 'as_needed': 'Bei Bedarf'
    };
    var unitMap = { 'minutes': 'Minuten', 'hours': 'Stunden', 'days': 'Tage', 'weeks': 'Wochen' };
    addTask({
        id:              tpl.id,
        title:           tpl.title,
        description:     tpl.description || '',
        frequency:       freqMap[tpl.frequency] || tpl.frequency || '',
        duration:        tpl.duration_value ? (tpl.duration_value + ' ' + (unitMap[tpl.duration_unit] || tpl.duration_unit)) : '',
        therapist_notes: tpl.therapist_notes || '',
    });
    var modal = bootstrap.Modal.getInstance(document.getElementById('modal-template-select'));
    if (modal) modal.hide();
}

function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>

</div>
{% endblock %}
