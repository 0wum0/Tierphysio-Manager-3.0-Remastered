{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% block title %}{{ page_title }}{% endblock %}
{% block head %}<link rel="stylesheet" href="/plugin-assets/therapy-care-pro/therapy-care-pro.css">{% endblock %}
{% block content %}
<div class="container-fluid px-3 px-lg-4 py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb fs-sm">
            <li class="breadcrumb-item"><a href="/patienten">Patienten</a></li>
            <li class="breadcrumb-item"><a href="/patienten/{{ patient.id }}">{{ patient.name }}</a></li>
            <li class="breadcrumb-item active">Erweiterte Timeline</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <div>
            <h1 class="h4 fw-700 mb-0">Erweiterte Timeline</h1>
            <div class="text-muted fs-sm">{{ patient.name }}</div>
        </div>
        <div class="ms-auto"><a href="/patienten/{{ patient.id }}" class="btn btn-outline-secondary btn-sm">Zurueck</a></div>
    </div>

    {# Filter bar #}
    <form method="GET" class="card shadow-sm mb-4">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-sm-auto">
                    <select name="type" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">Alle Typen</option>
                        <option value="progress"       {% if type_filter == 'progress'        %}selected{% endif %}>Fortschritt</option>
                        <option value="feedback"       {% if type_filter == 'feedback'        %}selected{% endif %}>Feedback</option>
                        <option value="therapy_report" {% if type_filter == 'therapy_report'  %}selected{% endif %}>Therapiebericht</option>
                        <option value="natural_therapy"{% if type_filter == 'natural_therapy' %}selected{% endif %}>Naturheilkunde</option>
                        <option value="treatment"      {% if type_filter == 'treatment'       %}selected{% endif %}>Behandlung</option>
                        <option value="note"           {% if type_filter == 'note'            %}selected{% endif %}>Notiz</option>
                        <option value="document"       {% if type_filter == 'document'        %}selected{% endif %}>Dokument</option>
                    </select>
                </div>
                <div class="col-6 col-sm-auto">
                    <input type="date" name="date_from" class="form-control form-control-sm" value="{{ date_from }}" placeholder="Von">
                </div>
                <div class="col-6 col-sm-auto">
                    <input type="date" name="date_to" class="form-control form-control-sm" value="{{ date_to }}" placeholder="Bis">
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-sm btn-outline-primary">Filtern</button>
                    {% if type_filter or date_from or date_to %}
                    <a href="/patienten/{{ patient.id }}/timeline" class="btn btn-sm btn-outline-secondary ms-1">Zuruecksetzen</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </form>

    {% if timeline is not empty %}
    <div class="position-relative ps-4" style="border-left:2px solid var(--bs-border-color);margin-left:10px;">
        {% set prev_date = '' %}
        {% for entry in timeline %}

        {# Date separator #}
        {% if entry.entry_date|date_de != prev_date %}
        <div class="position-relative mb-2 mt-3" style="margin-left:-22px;">
            <span class="badge fs-nano" style="background:var(--bs-tertiary-bg);color:var(--bs-secondary-color);border:1px solid var(--bs-border-color);">
                {{ entry.entry_date|date_de }}
            </span>
        </div>
        {% set prev_date = entry.entry_date|date_de %}
        {% endif %}

        {# Timeline dot #}
        <div class="position-absolute" style="left:-9px;top:auto;margin-top:3px;">
            <div style="width:16px;height:16px;border-radius:50%;background:var(--bs-body-bg);border:2px solid var(--bs-border-color);"></div>
        </div>

        <div class="card shadow-sm mb-2 ms-2">
            <div class="card-body py-2 px-3">
                <div class="d-flex align-items-start gap-2 flex-wrap">
                    <div class="flex-fill">
                        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                            {# Event type badge #}
                            {% set evType = entry.tcp_event_type ?? entry.type %}
                            {% set evLabels = {
                                'progress':        ['Fortschritt',     'tcp-event-progress'],
                                'feedback':        ['Feedback',        'tcp-event-feedback'],
                                'therapy_report':  ['Bericht',         'tcp-event-therapy-report'],
                                'natural_therapy': ['Naturheilkunde',  'tcp-event-natural-therapy'],
                                'reminder_sent':   ['Erinnerung',      'tcp-event-reminder-sent'],
                                'exercise_created':['Uebung',          'tcp-event-exercise-created'],
                                'treatment':       ['Behandlung',      'tcp-event-treatment'],
                                'document':        ['Dokument',        'tcp-event-document'],
                                'note':            ['Notiz',           'tcp-event-note']
                            } %}
                            {% set evInfo = evLabels[evType] ?? [evType, 'tcp-event-note'] %}
                            <span class="tcp-event-badge {{ evInfo[1] }}">{{ evInfo[0] }}</span>
                            <span class="fw-600 fs-sm">{{ entry.title }}</span>
                        </div>
                        {% if entry.content %}
                        <div class="fs-sm text-muted">{{ entry.content|truncate(150) }}</div>
                        {% endif %}
                    </div>
                    <div class="text-muted fs-nano text-nowrap">
                        {{ entry.user_name ?? '' }}
                    </div>
                </div>
            </div>
        </div>

        {% endfor %}
    </div>
    {% else %}
    <div class="card shadow-sm">
        <div class="card-body text-muted text-center py-5">
            <svg width="40" height="40" fill="none" viewBox="0 0 24 24" class="mb-2"><rect stroke="currentColor" stroke-width="1.5" x="3" y="3" width="18" height="18" rx="2"/><line stroke="currentColor" stroke-width="1.5" x1="8" y1="12" x2="16" y2="12"/></svg>
            <div>Keine Timeline-Eintraege fuer diesen Filter.</div>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
