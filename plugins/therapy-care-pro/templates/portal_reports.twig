{% extends '@owner-portal/portal_layout.twig' %}
{% block title %}{{ page_title }}{% endblock %}
{% block head %}<link rel="stylesheet" href="/plugin-assets/therapy-care-pro/therapy-care-pro.css">{% endblock %}
{% block content %}
<div class="portal-body">

    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <div>
            <h1 class="h5 fw-700 mb-0">Therapieberichte</h1>
            <div class="text-muted fs-sm">{{ patient.name }}</div>
        </div>
        <a href="/portal/tiere/{{ patient.id }}" class="btn btn-outline-secondary btn-sm ms-auto">Zurueck</a>
    </div>

    {% if reports is not empty %}
    <div class="card portal-card shadow-sm">
        <div class="list-group list-group-flush">
            {% for report in reports %}
            <div class="list-group-item py-3">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:40px;height:40px;border-radius:8px;background:rgba(139,92,246,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><path stroke="#8b5cf6" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="#8b5cf6" stroke-width="2" points="14 2 14 8 20 8"/></svg>
                    </div>
                    <div class="flex-fill">
                        <div class="fw-700 fs-sm">{{ report.title }}</div>
                        <div class="text-muted fs-nano">Erstellt am {{ report.created_at|datetime_de }}</div>
                    </div>
                    <a href="/portal/tcp/tiere/{{ patient.id }}/berichte/{{ report.id }}/download"
                       class="btn btn-sm btn-outline-primary">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" points="7 10 12 15 17 10"/><line stroke="currentColor" stroke-width="2" x1="12" y1="15" x2="12" y2="3"/></svg>
                        PDF
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% else %}
    <div class="card portal-card shadow-sm">
        <div class="card-body text-muted text-center py-5 fs-sm">
            Es sind noch keine Therapieberichte fuer {{ patient.name }} freigegeben.
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}
