{% extends '@owner-portal/portal_layout.twig' %}
{% block title %}{{ page_title }}{% endblock %}
{% block head %}<link rel="stylesheet" href="/plugin-assets/therapy-care-pro/therapy-care-pro.css">{% endblock %}
{% block content %}
<div class="portal-body">

    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <div>
            <h1 class="h5 fw-700 mb-0">Therapiefortschritt</h1>
            <div class="text-muted fs-sm">{{ patient.name }}</div>
        </div>
        <div class="ms-auto d-flex gap-2 flex-wrap">
            {% if media is defined and media|length > 0 and story_url is defined %}
            <a href="{{ story_url }}" class="btn btn-primary btn-sm">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><polyline stroke="currentColor" stroke-width="2" points="12 6 12 12 16 14"/></svg>
                <span class="ms-1">Verlauf-Story ansehen</span>
            </a>
            {% endif %}
            <a href="/portal/tiere/{{ patient.id }}" class="btn btn-outline-secondary btn-sm">Zurueck</a>
        </div>
    </div>

    {% if latest is not empty %}
    <div class="card portal-card shadow-sm mb-4">
        <div class="card-header fw-700">Aktuelle Werte</div>
        <div class="card-body p-3">
            {% for entry in latest %}
            <div class="d-flex align-items-center gap-3 mb-3">
                <div style="min-width:90px;font-weight:600;font-size:.85rem;">{{ entry.category_name }}</div>
                <div class="flex-fill">
                    {% set pct = ((entry.score - entry.scale_min) / max(1, entry.scale_max - entry.scale_min)) * 100 %}
                    <div class="d-flex align-items-center gap-2">
                        <div class="tcp-progress-bar-track">
                            <div class="tcp-progress-bar-fill" style="width:{{ pct }}%;background:{{ entry.category_color }};"></div>
                        </div>
                        <span class="fw-700 fs-sm text-nowrap" style="min-width:36px;color:{{ entry.category_color }}">{{ entry.score }}/{{ entry.scale_max }}</span>
                    </div>
                    {% if entry.scale_label_min or entry.scale_label_max %}
                    <div class="d-flex justify-content-between fs-nano text-muted mt-1">
                        <span>{{ entry.scale_label_min }}</span>
                        <span>{{ entry.scale_label_max }}</span>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {% if chart_data.datasets is not empty %}
    <div class="card portal-card shadow-sm mb-4">
        <div class="card-header fw-700">Verlaufsgrafik</div>
        <div class="card-body">
            <div class="tcp-chart-wrapper">
                <canvas id="tcpPortalChart"></canvas>
            </div>
        </div>
    </div>
    {% else %}
    <div class="card portal-card shadow-sm mb-4">
        <div class="card-body text-muted text-center py-4 fs-sm">Noch keine Verlaufsdaten vorhanden.</div>
    </div>
    {% endif %}

    {# ─────────────────────────────────────────────────────────────
       Vorher/Nachher Galerie (read-only) — wird vom Therapeuten gefüllt.
       Direktlink in den Story-Modus für eine größere Bilderstrecke.
       ───────────────────────────────────────────────────────────── #}
    {% if media is defined and media|length > 0 %}
    <div class="card portal-card shadow-sm mb-4">
        <div class="card-header fw-700 d-flex align-items-center">
            <span>📸 Bilder & Videos</span>
            <span class="ms-auto text-muted fs-nano">{{ media|length }} Datei{{ media|length == 1 ? '' : 'en' }}</span>
        </div>
        <div class="card-body">
            <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(120px, 1fr));gap:.5rem;">
                {% for m in media|slice(0, 12) %}
                <a href="{{ media_url_base }}/{{ m.id }}" target="_blank" rel="noopener"
                   class="d-block rounded overflow-hidden border position-relative"
                   style="aspect-ratio:1/1;background:#000;text-decoration:none;">
                    {% if m.media_type == 'image' %}
                    <img src="{{ media_url_base }}/{{ m.id }}" alt=""
                         style="width:100%;height:100%;object-fit:cover;" loading="lazy">
                    {% else %}
                    <div class="d-flex align-items-center justify-content-center text-white" style="width:100%;height:100%;background:#222;">
                        <svg width="28" height="28" fill="currentColor" viewBox="0 0 24 24"><polygon points="6 4 20 12 6 20 6 4"/></svg>
                    </div>
                    {% endif %}
                    {% if m.phase_label != 'verlauf' %}
                    <span class="position-absolute top-0 start-0 m-1 badge {{ m.phase_label == 'vorher' ? 'bg-warning text-dark' : 'bg-success text-white' }}" style="font-size:.6rem;">
                        {{ m.phase_label }}
                    </span>
                    {% endif %}
                </a>
                {% endfor %}
            </div>
            {% if media|length > 12 and story_url is defined %}
            <div class="text-center mt-3">
                <a href="{{ story_url }}" class="btn btn-sm btn-outline-primary">
                    Alle {{ media|length }} Medien in der Story-Ansicht →
                </a>
            </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
(function() {
    var data = {{ chart_data|json_encode|raw }};
    if (!data.datasets || data.datasets.length === 0) return;
    var isDark = document.documentElement.getAttribute('data-bs-theme') !== 'light';
    var gridColor = isDark ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.07)';
    var textColor = isDark ? 'rgba(255,255,255,0.6)'  : 'rgba(0,0,0,0.55)';
    var ctx = document.getElementById('tcpPortalChart');
    if (!ctx) return;
    new Chart(ctx, {
        type: 'line',
        data: data,
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { labels: { color: textColor, usePointStyle: true, font: { size: 11 } } }
            },
            scales: {
                x: { grid: { color: gridColor }, ticks: { color: textColor, font: { size: 11 } } },
                y: { min: 1, max: 10, grid: { color: gridColor }, ticks: { color: textColor, stepSize: 1 } }
            }
        }
    });
})();
</script>
{% endblock %}
