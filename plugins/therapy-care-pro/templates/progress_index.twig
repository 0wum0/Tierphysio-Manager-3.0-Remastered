{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block title %}{{ page_title }}{% endblock %}

{% block head %}
<link rel="stylesheet" href="/plugin-assets/therapy-care-pro/therapy-care-pro.css">
{% endblock %}

{% block content %}
<div class="container-fluid px-3 px-lg-4 py-4">

    {# Breadcrumb #}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb fs-sm">
            <li class="breadcrumb-item"><a href="/patienten">Patienten</a></li>
            <li class="breadcrumb-item"><a href="/patienten/{{ patient.id }}">{{ patient.name }}</a></li>
            <li class="breadcrumb-item active">Therapiefortschritt</li>
        </ol>
    </nav>

    {# Flash #}
    {% if success %}<div class="alert alert-success alert-sm py-2 mb-3">{{ success }}</div>{% endif %}
    {% if error   %}<div class="alert alert-danger  alert-sm py-2 mb-3">{{ error }}</div>{% endif %}

    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <div>
            <h1 class="h4 fw-700 mb-0">Therapiefortschritt</h1>
            <div class="text-muted fs-sm">{{ patient.name }}
                {% if patient.species %} · {{ patient.species }}{% endif %}
                {% if patient.breed %}, {{ patient.breed }}{% endif %}
            </div>
        </div>
        <div class="ms-auto d-flex gap-2 flex-wrap">
            <a href="/patienten/{{ patient.id }}/berichte/neu" class="btn btn-secondary btn-sm">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>
                <span class="d-none d-sm-inline ms-1">Therapiebericht</span>
            </a>
            <a href="/patienten/{{ patient.id }}" class="btn btn-outline-secondary btn-sm">← Zurück</a>
        </div>
    </div>

    <div class="row g-3">

        {# Left col: Chart + filter #}
        <div class="col-12 col-xl-8">
            <div class="card shadow-sm mb-3">
                <div class="card-header d-flex align-items-center gap-2 flex-wrap">
                    <span class="fw-700">Verlaufsgrafik</span>
                    <form method="GET" action="/patienten/{{ patient.id }}/fortschritt" class="d-flex gap-2 ms-auto align-items-center flex-wrap">
                        <input type="date" name="date_from" class="form-control form-control-sm" style="width:140px;" value="{{ date_from }}">
                        <span class="text-muted fs-sm">bis</span>
                        <input type="date" name="date_to"   class="form-control form-control-sm" style="width:140px;" value="{{ date_to }}">
                        <button type="submit" class="btn btn-sm btn-outline-primary">Filtern</button>
                    </form>
                </div>
                <div class="card-body">
                    {% if chart_data.datasets is not empty %}
                    <div class="tcp-chart-wrapper">
                        <canvas id="tcpProgressChart"></canvas>
                    </div>
                    {% else %}
                    <div class="text-muted text-center py-5">
                        <svg width="36" height="36" fill="none" viewBox="0 0 24 24" class="mb-2"><polyline stroke="currentColor" stroke-width="1.5" points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                        <div>Noch keine Daten für diesen Zeitraum.</div>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Entry list #}
            {% if entries is not empty %}
            <div class="card shadow-sm">
                <div class="card-header fw-700">Alle Einträge</div>
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Datum</th>
                                <th>Kategorie</th>
                                <th>Wert</th>
                                <th>Notiz</th>
                                <th>Erfasst von</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for entry in entries|reverse %}
                            <tr>
                                <td class="fs-sm text-nowrap">{{ entry.entry_date|date_de }}</td>
                                <td>
                                    <span class="d-flex align-items-center gap-1">
                                        <span class="tcp-cat-dot" style="background:{{ entry.category_color }};"></span>
                                        <span class="fs-sm">{{ entry.category_name }}</span>
                                    </span>
                                </td>
                                <td>
                                    {% set pct = ((entry.score - entry.scale_min) / max(1, entry.scale_max - entry.scale_min)) %}
                                    {% set scoreClass = pct >= 0.7 ? 'score-high' : (pct >= 0.4 ? 'score-mid' : 'score-low') %}
                                    <span class="tcp-score-badge {{ scoreClass }}">{{ entry.score }}</span>
                                </td>
                                <td class="fs-sm text-muted">{{ entry.notes|truncate(40) }}</td>
                                <td class="fs-sm text-muted">{{ entry.recorded_by_name ?? '—' }}</td>
                                <td>
                                    <form method="POST" action="/patienten/{{ patient.id }}/fortschritt/{{ entry.id }}/loeschen"
                                          onsubmit="return confirm('Eintrag löschen?')">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                        <button class="btn btn-xs btn-outline-danger">
                                            <svg width="11" height="11" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" d="M19 6l-1 14H6L5 6"/></svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            {% endif %}
        </div>

        {# Right col: New entry + current values #}
        <div class="col-12 col-xl-4">

            {# Current values #}
            {% if latest is not empty %}
            <div class="card shadow-sm mb-3">
                <div class="card-header fw-700">Aktuelle Werte</div>
                <div class="card-body p-2">
                    {% for entry in latest %}
                    <div class="d-flex align-items-center gap-2 p-2 rounded mb-1" style="background:var(--bs-tertiary-bg)">
                        <span class="tcp-cat-dot" style="background:{{ entry.category_color }};"></span>
                        <div class="flex-fill">
                            <div class="fw-600 fs-sm">{{ entry.category_name }}</div>
                            {% set pct = ((entry.score - entry.scale_min) / max(1, entry.scale_max - entry.scale_min)) * 100 %}
                            <div class="d-flex align-items-center gap-2 mt-1">
                                <div class="tcp-progress-bar-track">
                                    <div class="tcp-progress-bar-fill" style="width:{{ pct }}%;background:{{ entry.category_color }};"></div>
                                </div>
                                <span class="fs-nano fw-700 text-nowrap">{{ entry.score }}/{{ entry.scale_max }}</span>
                            </div>
                            {% if entry.scale_label_min or entry.scale_label_max %}
                            <div class="d-flex justify-content-between fs-nano text-muted mt-1">
                                <span>{{ entry.scale_label_min }}</span>
                                <span>{{ entry.scale_label_max }}</span>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {# New entry form #}
            <div class="card shadow-sm">
                <div class="card-header fw-700">Neue Werte erfassen</div>
                <div class="card-body">
                    <form method="POST" action="/patienten/{{ patient.id }}/fortschritt">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                        <div class="mb-3">
                            <label class="form-label fs-sm">Datum</label>
                            <input type="date" name="entry_date" class="form-control form-control-sm" value="{{ 'now'|date('Y-m-d') }}">
                        </div>
                        {% for cat in categories %}
                        <div class="mb-3">
                            <label class="form-label fs-sm d-flex align-items-center gap-1 mb-1">
                                <span class="tcp-cat-dot" style="background:{{ cat.color }};"></span>
                                {{ cat.name }}
                                <span class="text-muted fw-400 ms-1">({{ cat.scale_min }}–{{ cat.scale_max }})</span>
                            </label>
                            <div class="d-flex align-items-center gap-2">
                                <input type="range" class="form-range flex-fill"
                                    name="entries[{{ cat.id }}]"
                                    min="{{ cat.scale_min }}" max="{{ cat.scale_max }}"
                                    value="{{ ((cat.scale_max - cat.scale_min) / 2 + cat.scale_min)|round }}"
                                    oninput="document.getElementById('score-{{ cat.id }}').textContent=this.value">
                                <span class="fw-700 fs-sm text-nowrap" id="score-{{ cat.id }}" style="min-width:24px;color:{{ cat.color }}">
                                    {{ ((cat.scale_max - cat.scale_min) / 2 + cat.scale_min)|round }}
                                </span>
                            </div>
                            {% if cat.scale_label_min or cat.scale_label_max %}
                            <div class="d-flex justify-content-between fs-nano text-muted">
                                <span>{{ cat.scale_label_min }}</span>
                                <span>{{ cat.scale_label_max }}</span>
                            </div>
                            {% endif %}
                            <input type="text" name="notes_{{ cat.id }}" class="form-control form-control-sm mt-1"
                                placeholder="Notiz (optional)">
                        </div>
                        {% endfor %}
                        <button type="submit" class="btn btn-primary btn-sm w-100">Werte speichern</button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
(function() {
    const data = {{ chart_data|json_encode|raw }};
    if (!data.datasets || data.datasets.length === 0) return;

    const isDark = document.documentElement.getAttribute('data-bs-theme') !== 'light';
    const gridColor = isDark ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.07)';
    const textColor = isDark ? 'rgba(255,255,255,0.6)'  : 'rgba(0,0,0,0.55)';

    const ctx = document.getElementById('tcpProgressChart');
    if (!ctx) return;

    new Chart(ctx, {
        type: 'line',
        data: data,
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: {
                    display: true,
                    labels: { color: textColor, usePointStyle: true, pointStyle: 'circle', padding: 16, font: { size: 11 } }
                },
                tooltip: {
                    callbacks: {
                        label: function(ctx) {
                            if (ctx.parsed.y === null) return null;
                            return ' ' + ctx.dataset.label + ': ' + ctx.parsed.y;
                        }
                    }
                }
            },
            scales: {
                x: {
                    grid: { color: gridColor },
                    ticks: { color: textColor, font: { size: 11 } }
                },
                y: {
                    min: 1, max: 10,
                    grid: { color: gridColor },
                    ticks: { color: textColor, font: { size: 11 }, stepSize: 1 }
                }
            }
        }
    });
})();
</script>
{% endblock %}
