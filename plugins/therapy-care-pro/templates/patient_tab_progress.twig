{# TherapyCare Pro — Patient Tab (embedded in patient detail) #}
{% set latest        = latest        ?? tcp_progress       ?? [] %}
{% set categories    = categories    ?? tcp_categories     ?? [] %}
{% set visibility    = visibility    ?? tcp_visibility     ?? {'show_progress':0,'show_natural':0,'show_reports':0} %}
{% set natural       = natural       ?? tcp_natural        ?? [] %}
{% set natural_types = types         ?? tcp_natural_types  ?? {} %}
{% set reports       = reports       ?? tcp_reports        ?? [] %}
<link rel="stylesheet" href="/plugin-assets/therapy-care-pro/therapy-care-pro.css">

<div class="p-3 tcp-anchor-target" id="tcp-fortschritt-content">

    <ul class="nav nav-pills mb-3" id="tcp-inner-tabs-{{ patient.id }}" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#tcp-pane-progress-{{ patient.id }}" type="button" role="tab">{% if is_trainer ?? false %}Trainings-Fortschritt{% else %}Fortschritt{% endif %}</button>
        </li>
        {# Naturheilkunde und Therapieberichte sind reine Tierphysio-Konzepte.
           Trainer-Tenants bekommen dafür keinen sinnvollen Inhalt — Tabs werden
           ausgeblendet. Panels bleiben im DOM (leer) damit data-bs-target-Ziele
           auch im unwahrscheinlichen Fall eines direkten Anchor-Links nicht
           kaputtgehen. #}
        {% if not (is_trainer ?? false) %}
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#tcp-pane-natural-{{ patient.id }}" type="button" role="tab">Naturheilkunde</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#tcp-pane-reports-{{ patient.id }}" type="button" role="tab">Therapieberichte</button>
        </li>
        {% endif %}
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="tcp-pane-progress-{{ patient.id }}" role="tabpanel">
            <div id="tcp-tab-chart-wrap-{{ patient.id }}" class="border rounded p-3 mb-3">
                <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                    <div class="fw-700 fs-sm">Verlaufsgrafik</div>
                    <div class="d-flex gap-1 flex-wrap">
                        {% if media_all is defined and media_all|length > 0 %}
                        <a href="{{ story_url }}" target="_blank" rel="noopener" class="btn btn-primary btn-sm" style="font-size:0.7rem;">
                            <svg width="11" height="11" fill="none" viewBox="0 0 24 24" style="vertical-align:-1px;"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><polyline stroke="currentColor" stroke-width="2" points="12 6 12 12 16 14"/></svg>
                            {% if is_trainer ?? false %}Trainings-Story{% else %}Therapie-Story{% endif %}
                        </a>
                        {% endif %}
                        <a href="/patienten/{{ patient.id }}/fortschritt" class="btn btn-outline-secondary btn-sm" style="font-size:0.7rem;">Vollansicht →</a>
                    </div>
                </div>
                <div style="position:relative;height:180px;">
                    <canvas id="tcp-tab-chart-{{ patient.id }}"></canvas>
                    <div id="tcp-tab-chart-loading-{{ patient.id }}" class="text-muted fs-sm text-center" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">Lade Verlaufsdaten…</div>
                </div>
            </div>

            {% if latest is not empty %}
            <div class="row g-2 mb-3" id="tcp-latest-wrap-{{ patient.id }}">
                {% for entry in latest %}
                <div class="col-6 col-md-4">
                    <div class="d-flex align-items-center gap-2 p-2 rounded" style="background:var(--bs-tertiary-bg)">
                        <span class="tcp-cat-dot" style="background:{{ entry.category_color }};"></span>
                        <div class="flex-fill overflow-hidden">
                            <div class="fw-600 fs-sm text-truncate">{{ entry.category_name }}</div>
                            {% set pct = ((entry.score - entry.scale_min) / max(1, entry.scale_max - entry.scale_min)) * 100 %}
                            <div class="d-flex align-items-center gap-1 mt-1">
                                <div class="tcp-progress-bar-track">
                                    <div class="tcp-progress-bar-fill" style="width:{{ pct }}%;background:{{ entry.category_color }};"></div>
                                </div>
                                <span class="fs-nano fw-700" style="min-width:28px;text-align:right;">{{ entry.score }}/{{ entry.scale_max }}</span>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="text-muted fs-sm mb-3">{% if is_trainer ?? false %}Noch keine Trainings-Fortschrittswerte erfasst.{% else %}Noch keine Fortschrittswerte erfasst.{% endif %}</div>
            {% endif %}

            {% if categories is not empty %}
            <div class="border rounded p-3 mb-3">
                <div class="fw-700 fs-sm mb-2">Werte schnell erfassen</div>
                <form method="POST" action="/patienten/{{ patient.id }}/fortschritt" id="tcp-quick-progress-form-{{ patient.id }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="entry_date" value="{{ 'now'|date('Y-m-d') }}">
                    <div class="row g-2">
                        {% for cat in categories %}
                        <div class="col-12 col-sm-6">
                            <label class="form-label fs-nano fw-600 mb-1 d-flex align-items-center gap-1">
                                <span class="tcp-cat-dot" style="background:{{ cat.color }};"></span>
                                {{ cat.name }}
                                <span class="text-muted fw-400">({{ cat.scale_min }}–{{ cat.scale_max }})</span>
                            </label>
                            <input type="range" class="form-range"
                                name="entries[{{ cat.id }}]"
                                min="{{ cat.scale_min }}" max="{{ cat.scale_max }}"
                                value="{{ ((cat.scale_max - cat.scale_min) / 2 + cat.scale_min)|round }}"
                                oninput="this.nextElementSibling.textContent=this.value">
                            <span class="fs-nano text-muted">{{ ((cat.scale_max - cat.scale_min) / 2 + cat.scale_min)|round }}</span>
                        </div>
                        {% endfor %}
                    </div>
                    <div class="mt-3 d-flex gap-2 align-items-center flex-wrap">
                        <button type="submit" class="btn btn-primary btn-sm">Werte speichern</button>
                        <a href="/patienten/{{ patient.id }}/fortschritt" class="btn btn-outline-secondary btn-sm">Verlauf & Grafik</a>
                        <span class="fs-nano text-success d-none" id="tcp-progress-save-ok-{{ patient.id }}">Gespeichert ✓</span>
                    </div>
                </form>
            </div>
            {% endif %}

            {# ────────────────────────────────────────────────────────────
               MEDIA-GALERIE + UPLOAD (Modal-Akte)
               Identische Funktion zur Vollansicht — Halter kann ohne
               Modal-Verlassen Bilder/Videos zu jedem Eintrag hochladen,
               ansehen und löschen. Upload-POST navigiert zur Vollansicht
               (gleiches Verhalten wie Quick-Form-Speichern).
               ──────────────────────────────────────────────────────────── #}
            {% if entries is defined and entries is not empty %}
            <div class="border rounded p-3 mb-3" id="tcp-tab-media-{{ patient.id }}">
                <div class="d-flex justify-content-between align-items-center mb-2 gap-2 flex-wrap">
                    <div class="fw-700 fs-sm d-flex align-items-center gap-1">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><rect stroke="currentColor" stroke-width="2" x="3" y="3" width="18" height="18" rx="2"/><circle stroke="currentColor" stroke-width="2" cx="8.5" cy="8.5" r="1.5"/><polyline stroke="currentColor" stroke-width="2" points="21 15 16 10 5 21"/></svg>
                        Vorher / Nachher Medien
                    </div>
                    <span class="text-muted fs-nano">
                        {% set _mc = media_all|default([])|length %}{{ _mc }} Datei{{ _mc == 1 ? '' : 'en' }}
                    </span>
                </div>

                {# Upload-Form — Modal-kompatibel: action wird per JS auf den
                   gewählten Eintrag umgebogen, dann normaler POST. #}
                <form method="POST" enctype="multipart/form-data" action="#"
                      id="tcp-tab-media-form-{{ patient.id }}"
                      class="row g-2 align-items-end mb-2">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                    <div class="col-12 col-md-5">
                        <label class="form-label fs-nano fw-600 mb-1">Zu Eintrag</label>
                        <select name="_entry_id" class="form-select form-select-sm" required
                                onchange="this.form.action='/patienten/{{ patient.id }}/fortschritt/'+this.value+'/media';">
                            <option value="">— wählen —</option>
                            {% for e in entries|reverse %}
                            <option value="{{ e.id }}">{{ e.entry_date|date_de }} · {{ e.category_name }} ({{ e.score }}/{{ e.scale_max }})</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="col-6 col-md-2">
                        <label class="form-label fs-nano fw-600 mb-1">Phase</label>
                        <select name="phase_label" class="form-select form-select-sm">
                            <option value="vorher">Vorher</option>
                            <option value="nachher">Nachher</option>
                            <option value="verlauf" selected>Verlauf</option>
                        </select>
                    </div>

                    <div class="col-6 col-md-3">
                        <label class="form-label fs-nano fw-600 mb-1">Datei(en)</label>
                        <input type="file" name="media[]" class="form-control form-control-sm"
                               accept="image/*,video/*,audio/*" multiple required>
                    </div>

                    <div class="col-12 col-md-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" style="vertical-align:-1px;"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            Hochladen
                        </button>
                    </div>
                    <div class="col-12">
                        <small class="text-muted fs-nano">Max. 25 MB · Bilder, Videos, Audio · Mehrfach-Auswahl möglich</small>
                    </div>
                </form>

                {# Galerie — kompakter (Modal-Breite begrenzt) #}
                {% if media_all|length > 0 %}
                <div class="mt-2" style="max-height: 320px; overflow-y: auto;">
                    {% for entry in entries|reverse %}
                        {% set entry_media = media_by_entry[entry.id] ?? [] %}
                        {% if entry_media|length > 0 %}
                        <div class="border rounded p-2 mb-2" style="background:var(--bs-tertiary-bg);">
                            <div class="d-flex align-items-center gap-2 mb-2 fs-nano">
                                <span class="tcp-cat-dot" style="background:{{ entry.category_color }};"></span>
                                <strong>{{ entry.entry_date|date_de }}</strong>
                                <span class="text-muted">· {{ entry.category_name }} · {{ entry.score }}/{{ entry.scale_max }}</span>
                                <span class="ms-auto text-muted">{{ entry_media|length }}×</span>
                            </div>
                            <div class="d-flex flex-wrap gap-1">
                                {% for m in entry_media %}
                                <div class="position-relative" style="width:72px;">
                                    {% set phase_class = m.phase_label == 'vorher' ? 'bg-warning text-dark'
                                        : (m.phase_label == 'nachher' ? 'bg-success text-white' : 'bg-secondary text-white') %}
                                    <a href="{{ media_url_base }}/{{ m.id }}" target="_blank" rel="noopener"
                                       class="d-block rounded overflow-hidden border"
                                       style="aspect-ratio:1/1;background:#000;">
                                        {% if m.media_type == 'image' %}
                                        <img src="{{ media_url_base }}/{{ m.id }}" alt=""
                                             style="width:100%;height:100%;object-fit:cover;" loading="lazy">
                                        {% elseif m.media_type == 'video' %}
                                        <div class="d-flex align-items-center justify-content-center text-white" style="width:100%;height:100%;background:#222;">
                                            <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><polygon points="6 4 20 12 6 20 6 4"/></svg>
                                        </div>
                                        {% else %}
                                        <div class="d-flex align-items-center justify-content-center text-white fs-nano" style="width:100%;height:100%;background:#444;">
                                            AUDIO
                                        </div>
                                        {% endif %}
                                    </a>
                                    <span class="position-absolute top-0 start-0 m-1 badge {{ phase_class }}" style="font-size:.55rem;line-height:1;padding:2px 4px;">{{ m.phase_label[0:1]|upper }}</span>
                                    <form method="POST"
                                          action="/patienten/{{ patient.id }}/fortschritt/media/{{ m.id }}/loeschen"
                                          class="position-absolute top-0 end-0 m-1"
                                          onsubmit="return confirm('Datei löschen?');">
                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                        <button type="submit" class="btn btn-danger" style="padding:0 4px;font-size:9px;line-height:1;">×</button>
                                    </form>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
                {% else %}
                <div class="text-muted fs-nano text-center py-2">
                    Noch keine Medien hochgeladen — Lade Bilder hoch um die {% if is_trainer ?? false %}Trainings-Story{% else %}Therapie-Story{% endif %} aufzubauen.
                </div>
                {% endif %}
            </div>
            {% endif %}

            <div class="border rounded p-3">
                <div class="fw-700 fs-sm mb-2">Portal-Freigaben</div>
                <form method="POST" action="/patienten/{{ patient.id }}/portal-freigaben">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <div class="tcp-visibility-row">
                        <div>
                            <div class="tcp-visibility-label">{% if is_trainer ?? false %}Trainings-Fortschritt im Portal sichtbar{% else %}Fortschritt im Portal sichtbar{% endif %}</div>
                            <div class="tcp-visibility-desc">{% if is_trainer ?? false %}Halter kann Verlaufsgrafik einsehen{% else %}Tierhalter kann Verlaufsgrafik einsehen{% endif %}</div>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" name="show_progress" value="1"
                                {% if visibility.show_progress %}checked{% endif %}
                                onchange="this.closest('form').submit()">
                        </div>
                    </div>
                    {# Naturheilkunde und Therapieberichte sind rein tierphysio-spezifisch.
                       Für Trainer ausblenden. Fehlen die Checkboxen beim POST, bleiben die
                       DB-Werte show_natural/show_reports unverändert (Controller patcht
                       nur Keys die im POST vorhanden sind — siehe portalVisibilityUpdate). #}
                    {% if not (is_trainer ?? false) %}
                    <div class="tcp-visibility-row">
                        <div>
                            <div class="tcp-visibility-label">Naturheilkunde sichtbar</div>
                            <div class="tcp-visibility-desc">Naturheilkundliche Maßnahmen für Besitzer</div>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" name="show_natural" value="1"
                                {% if visibility.show_natural %}checked{% endif %}
                                onchange="this.closest('form').submit()">
                        </div>
                    </div>
                    <div class="tcp-visibility-row">
                        <div>
                            <div class="tcp-visibility-label">Therapieberichte freigeben</div>
                            <div class="tcp-visibility-desc">Besitzer kann generierte Berichte herunterladen</div>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" name="show_reports" value="1"
                                {% if visibility.show_reports %}checked{% endif %}
                                onchange="this.closest('form').submit()">
                        </div>
                    </div>
                    {% endif %}
                </form>
            </div>
        </div>

        <div class="tab-pane fade" id="tcp-pane-natural-{{ patient.id }}" role="tabpanel">
            {% include '@therapy-care-pro/patient_tab_natural.twig' with {
                patient: patient,
                entries: natural,
                types: natural_types,
                csrf_token: csrf_token
            } %}
        </div>

        <div class="tab-pane fade" id="tcp-pane-reports-{{ patient.id }}" role="tabpanel">
            <div class="border rounded p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="fw-700 fs-sm">Therapieberichte</div>
                    <a href="/patienten/{{ patient.id }}/berichte" class="btn btn-outline-secondary btn-sm">Vollansicht →</a>
                </div>

                {% if reports is not empty %}
                    <div class="list-group list-group-flush">
                        {% for report in reports|slice(0,8) %}
                            <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center gap-2">
                                <div class="min-width-0">
                                    <div class="fw-600 fs-sm text-truncate">{{ report.title ?: 'Therapiebericht' }}</div>
                                    <div class="fs-nano text-muted">{{ report.created_at|date('d.m.Y H:i') }}</div>
                                </div>
                                <div class="d-flex gap-1">
                                    {% if report.filename %}
                                        <a class="btn btn-xs btn-outline-secondary" href="/patienten/{{ patient.id }}/berichte/{{ report.id }}/download">PDF</a>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-muted fs-sm">Noch keine Therapieberichte vorhanden.</div>
                {% endif %}

                <div class="mt-3">
                    <a href="/patienten/{{ patient.id }}/berichte/neu" class="btn btn-primary btn-sm">Neuen Bericht erstellen</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    var pid = {{ patient.id }};
    var wrapEl    = document.getElementById('tcp-tab-chart-wrap-' + pid);
    var loadingEl = document.getElementById('tcp-tab-chart-loading-' + pid);

    function renderChart(chartData) {
        if (loadingEl) loadingEl.style.display = 'none';
        if (!chartData || !chartData.datasets || !chartData.datasets.length) {
            if (wrapEl) wrapEl.style.display = 'none';
            return;
        }
        var isDark = document.documentElement.getAttribute('data-bs-theme') !== 'light';
        var gc = isDark ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.07)';
        var tc = isDark ? 'rgba(255,255,255,0.6)'  : 'rgba(0,0,0,0.55)';
        var ctx = document.getElementById('tcp-tab-chart-' + pid);
        if (!ctx) return;
        if (ctx._tcpChart) { try { ctx._tcpChart.destroy(); } catch (e) {} }
        ctx._tcpChart = new Chart(ctx, {
            type: 'line', data: chartData,
            options: {
                responsive: true, maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: { legend: { display: true, labels: { color: tc, usePointStyle: true, pointStyle: 'circle', padding: 12, font: { size: 10 } } } },
                scales: {
                    x: { grid: { color: gc }, ticks: { color: tc, font: { size: 10 } } },
                    y: { min: 1, max: 10, grid: { color: gc }, ticks: { color: tc, font: { size: 10 }, stepSize: 1 } }
                }
            }
        });
    }

    function loadData() {
        fetch('/api/tcp/patienten/' + pid + '/fortschritt', {headers:{'X-Requested-With':'XMLHttpRequest'}})
            .then(function(r){return r.json();})
            .then(function(d){ renderChart(d.chart || null); })
            .catch(function(){ if (wrapEl) wrapEl.style.display = 'none'; });
    }

    var form = document.getElementById('tcp-quick-progress-form-' + pid);
    if (form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            var ok = document.getElementById('tcp-progress-save-ok-' + pid);
            fetch(form.action, {
                method: 'POST',
                headers: {'X-Requested-With': 'XMLHttpRequest'},
                body: new FormData(form)
            }).then(function(r){return r.json();})
              .then(function(d){
                if (d && d.ok) {
                    if (ok) {
                        ok.classList.remove('d-none');
                        setTimeout(function(){ ok.classList.add('d-none'); }, 2000);
                    }
                    loadData();
                }
              })
              .catch(function(){});
        });
    }

    if (typeof Chart === 'undefined') {
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js';
        s.onload = loadData;
        document.head.appendChild(s);
    } else {
        loadData();
    }
})();
</script>
