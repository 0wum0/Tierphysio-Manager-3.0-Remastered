{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}

<div class="page-header">
    <div>
        <h1 class="page-title">{{ page_title }}</h1>
        {% if single_invoice is defined %}
            <p class="page-subtitle">Rechnung {{ single_invoice.invoice_number }}</p>
        {% else %}
            <p class="page-subtitle">{{ logs|length }} Einträge</p>
        {% endif %}
    </div>
    <div class="d-flex gap-2">
        {% if single_invoice is defined %}
            <a href="/rechnungen/{{ single_invoice.id }}" class="btn btn-secondary btn-sm">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M19 12H5M12 5l-7 7 7 7"/></svg>
                Zur Rechnung
            </a>
        {% endif %}
        <a href="/steuerexport" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Steuerexport
        </a>
    </div>
</div>

{# GoBD Info Banner #}
<div class="alert mb-3" style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:0.85rem 1rem;">
    <div class="d-flex align-items-start gap-2">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" class="flex-shrink-0 mt-1" style="color:#2563eb;"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <div>
            <div class="fw-600 fs-sm" style="color:#1e40af;">GoBD-Protokoll (§ 147 AO / BMF-Schreiben 28.11.2019)</div>
            <p class="fs-nano text-muted mb-0">
                Dieses Protokoll ist unveränderlich. Jede Mutation an Rechnungen wird automatisch erfasst.
                Einträge dürfen weder gelöscht noch bearbeitet werden.
                Das Protokoll dient als Nachweis der ordnungsgemäßen Buchführung.
            </p>
        </div>
    </div>
</div>

<div class="panel">
    <div class="panel-hdr">
        <h2>Audit-Protokoll</h2>
        <div class="panel-toolbar">
            <span class="fs-nano text-muted">{{ logs|length }} Einträge</span>
        </div>
    </div>
    <div class="panel-container show">
        <div class="panel-content p-0">

        {% if logs %}
            <table class="table table-hover table-striped table-bordered mb-0">
                <thead>
                    <tr>
                        <th style="width:160px;">Zeitstempel</th>
                        <th style="width:130px;">Rechnungs-Nr.</th>
                        <th style="width:110px;">Aktion</th>
                        <th>Änderungsdetails</th>
                        <th style="width:80px;">Benutzer</th>
                        <th style="width:120px;">IP-Adresse</th>
                    </tr>
                </thead>
                <tbody>
                    {% for log in logs %}
                    <tr style="vertical-align:top;">
                        <td class="fs-nano text-nowrap text-muted">
                            {{ log.created_at|date('d.m.Y') }}<br>
                            <span class="fw-500">{{ log.created_at|date('H:i:s') }}</span>
                        </td>
                        <td class="fs-sm">
                            {% if log.invoice_id %}
                                <a href="/rechnungen/{{ log.invoice_id }}" class="text-primary fw-500">
                                    {{ log.invoice_number ?: ('#' ~ log.invoice_id) }}
                                </a>
                            {% else %}
                                {{ log.invoice_number ?: '—' }}
                            {% endif %}
                        </td>
                        <td>
                            {% set a = log.action %}
                            <span class="badge
                                {% if a == 'created' %}bg-success
                                {% elseif a == 'updated' %}bg-primary
                                {% elseif a == 'deleted' %}bg-danger
                                {% elseif a == 'finalized' %}bg-dark
                                {% elseif a == 'cancelled' %}bg-warning text-dark
                                {% elseif a == 'status_changed' %}bg-info
                                {% elseif a == 'email_sent' %}bg-secondary
                                {% elseif a == 'pdf_downloaded' %}bg-light text-dark border
                                {% else %}bg-secondary{% endif %}
                                fs-nano">
                                {% if a == 'created' %}Erstellt
                                {% elseif a == 'updated' %}Geändert
                                {% elseif a == 'deleted' %}Gelöscht
                                {% elseif a == 'finalized' %}Finalisiert
                                {% elseif a == 'cancelled' %}Storniert
                                {% elseif a == 'status_changed' %}Status
                                {% elseif a == 'email_sent' %}E-Mail
                                {% elseif a == 'pdf_downloaded' %}PDF
                                {% else %}{{ a }}{% endif %}
                            </span>
                        </td>
                        <td class="fs-nano" style="max-width:380px;">
                            {% if log.new_values %}
                                <div class="text-muted mb-1">Neue Werte:</div>
                                <code class="fs-nano d-block" style="white-space:pre-wrap;word-break:break-all;max-height:80px;overflow:auto;font-size:.62rem;">{{ log.new_values|slice(0, 300) }}</code>
                            {% endif %}
                            {% if log.old_values and log.action == 'updated' %}
                                <div class="text-muted mt-1 mb-1">Alte Werte:</div>
                                <code class="fs-nano d-block" style="white-space:pre-wrap;word-break:break-all;max-height:80px;overflow:auto;font-size:.62rem;opacity:.7;">{{ log.old_values|slice(0, 300) }}</code>
                            {% endif %}
                            {% if not log.new_values and not log.old_values %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="fs-nano text-muted">
                            {{ log.user_id ? ('ID ' ~ log.user_id) : '—' }}
                        </td>
                        <td class="fs-nano text-muted text-nowrap">
                            {{ log.ip_address ?: '—' }}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="text-center py-5">
                <svg width="40" height="40" fill="none" viewBox="0 0 24 24" class="mb-3 text-muted" style="opacity:.3;"><path stroke="currentColor" stroke-width="1.5" d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>
                <p class="text-muted fs-sm">Noch keine Protokolleinträge vorhanden.</p>
            </div>
        {% endif %}

        </div>
    </div>
</div>

{% endblock %}
