<!DOCTYPE html>
<html lang="de" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Willkommen! — {{ app_name }}</title>
    {# SmartAdmin Praxis-Design — identisch zum Praxis-Login. #}
    <link rel="stylesheet" href="/themes/smart-tierphysio/css/smartapp.min.css">
    <link rel="stylesheet" href="/themes/smart-tierphysio/webfonts/smartadmin/sa-icons.css">
    <style>
        body {
            min-height: 100vh;
            background: var(--bs-body-bg);
            display: flex; align-items: center; justify-content: center;
            padding: 2rem 1rem;
        }
        .ty-wrapper {
            max-width: 480px; width: 100%;
            position: relative; z-index: 1;
        }

        /* Logo-Pop-In (kein Glass-Gradient mehr — klare Praxis-Optik) */
        .ty-icon {
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 1.25rem;
            animation: popIn 0.6s cubic-bezier(.34, 1.56, .64, 1);
            filter: drop-shadow(0 0 14px rgba(110, 168, 254, 0.6));
        }
        @keyframes popIn {
            from { transform: scale(0.3); opacity: 0; }
            to   { transform: scale(1);   opacity: 1; }
        }

        /* Confetti-Layer (oben drauf, ohne Glass-Dependencies) */
        .ty-confetti {
            position: fixed; inset: 0;
            pointer-events: none; overflow: hidden; z-index: 0;
        }
        .confetti-piece {
            position: absolute; top: -10px; border-radius: 2px;
            animation: fall linear forwards;
        }
        @keyframes fall {
            to { transform: translateY(110vh) rotate(720deg); opacity: 0; }
        }

        /* Check-Liste mit Bootstrap-Vars */
        .check-list {
            display: flex; flex-direction: column; gap: 0.65rem;
            text-align: left; margin: 1.5rem 0;
        }
        .check-item {
            display: flex; align-items: center; gap: 0.75rem;
            font-size: 0.88rem;
        }
        .check-icon {
            width: 24px; height: 24px; border-radius: 50%;
            background: rgba(var(--bs-success-rgb), 0.2);
            color: var(--bs-success);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; font-size: 0.75rem; font-weight: 700;
        }
    </style>
</head>
<body>

<div class="ty-confetti" id="confetti-container"></div>

<div class="ty-wrapper">
    <div class="card">
        <div class="card-body p-4 text-center">
            <div class="ty-icon">
                {# Einladungs-Flow zeigt IMMER die Pfote — siehe form.twig Kommentar. #}
                <svg width="72" height="72" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="tyPaw" x1="0" y1="0" x2="1" y2="1">
                                <stop offset="0%"   stop-color="#6EA8FE"/>
                                <stop offset="100%" stop-color="#a78bfa"/>
                            </linearGradient>
                        </defs>
                        <ellipse fill="url(#tyPaw)" cx="9"   cy="3.5" rx="2" ry="2.5"/>
                        <ellipse fill="url(#tyPaw)" cx="15"  cy="3.5" rx="2" ry="2.5"/>
                        <ellipse fill="url(#tyPaw)" cx="4.5" cy="8"   rx="2" ry="2.5"/>
                        <ellipse fill="url(#tyPaw)" cx="19.5" cy="8"  rx="2" ry="2.5"/>
                        <path fill="url(#tyPaw)" d="M12 10c-3.5 0-6.5 2-6.5 5.5 0 2 1 3.5 2.5 4.5h8c1.5-1 2.5-2.5 2.5-4.5C18.5 12 15.5 10 12 10z"/>
                    </svg>
            </div>

            <h1 class="fw-700 mb-2" style="font-size:1.8rem;letter-spacing:-0.02em;">Sie sind dabei!</h1>
            <p class="text-muted fs-sm mb-1" style="line-height:1.7;">
                {% if is_trainer ?? false %}
                    Ihre Registrierung war erfolgreich. Sie und Ihr Hund sind jetzt als aktive Kunden bei uns eingetragen.
                {% else %}
                    Ihre Registrierung war erfolgreich. Sie und Ihr Tier sind jetzt als aktive Patienten in unserem System eingetragen.
                {% endif %}
            </p>

            <div class="check-list">
                <div class="check-item">
                    <div class="check-icon">✓</div>
                    <span><strong>{% if is_trainer ?? false %}Halter-Profil{% else %}Besitzerprofil{% endif %}</strong> wurde angelegt</span>
                </div>
                <div class="check-item">
                    <div class="check-icon">✓</div>
                    <span><strong>{% if is_trainer ?? false %}Hundeprofil{% else %}Patientenakte{% endif %}</strong> wurde erstellt</span>
                </div>
                <div class="check-item">
                    <div class="check-icon">✓</div>
                    <span>{% if is_trainer ?? false %}Das Trainer-Team{% else %}Unser Team{% endif %} wurde <strong>benachrichtigt</strong></span>
                </div>
            </div>

            <p class="text-muted fs-xs mb-0">
                {% if is_trainer ?? false %}Wir freuen uns auf das erste Training bei{% else %}Wir freuen uns auf Ihren ersten Besuch bei{% endif %}<br>
                <strong class="text-body">{{ company_name ?: app_name }}</strong>
            </p>
        </div>
    </div>
</div>

<script>
(function () {
    /* Confetti-Farben auf Bootstrap-Semantik abgestimmt. */
    const colors = ['#4f7cff', '#8b5cf6', '#22c55e', '#f59e0b', '#ef4444', '#06b6d4'];
    const c = document.getElementById('confetti-container');
    if (!c) return;
    for (let i = 0; i < 70; i++) {
        const p = document.createElement('div');
        p.className = 'confetti-piece';
        p.style.left              = Math.random() * 100 + 'vw';
        p.style.background        = colors[Math.floor(Math.random() * colors.length)];
        p.style.width             = (Math.random() * 8 + 4) + 'px';
        p.style.height            = (Math.random() * 8 + 4) + 'px';
        p.style.animationDuration = (Math.random() * 3 + 2) + 's';
        p.style.animationDelay    = (Math.random() * 2) + 's';
        p.style.opacity           = Math.random() * 0.8 + 0.2;
        c.appendChild(p);
    }
})();
</script>

</body>
</html>
