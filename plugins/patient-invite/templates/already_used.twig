<!DOCTYPE html>
<html lang="de" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Bereits registriert — {{ app_name }}</title>
    {# SmartAdmin Praxis-Design — identisch zum Praxis-Login. #}
    <link rel="stylesheet" href="/themes/smart-tierphysio/css/smartapp.min.css">
    <link rel="stylesheet" href="/themes/smart-tierphysio/webfonts/smartadmin/sa-icons.css">
    <style>
        body {
            min-height: 100vh;
            background: var(--bs-body-bg);
            display: flex; align-items: center; justify-content: center;
            padding: 2rem 1rem;
        }
        .wrapper { max-width: 440px; width: 100%; }
        .status-icon {
            width: 72px; height: 72px; border-radius: 50%;
            background: rgba(var(--bs-success-rgb), 0.15);
            color: var(--bs-success);
            display: inline-flex; align-items: center; justify-content: center;
            margin: 0 auto 1.25rem;
        }
    </style>
</head>
<body>

<div class="wrapper">
    <div class="card">
        <div class="card-body p-4 text-center">
            <div class="status-icon">
                <svg width="36" height="36" fill="none" viewBox="0 0 24 24">
                    <polyline points="20 6 9 17 4 12" stroke="currentColor"
                              stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>

            <h1 class="fw-700 fs-lg mb-2">Bereits registriert</h1>

            <p class="text-muted fs-sm mb-0" style="line-height:1.7;">
                Sie haben sich über diesen Einladungslink bereits erfolgreich registriert.<br>
                {% if is_trainer ?? false %}Wir freuen uns auf das nächste Training!{% else %}Wir freuen uns auf Ihren Besuch!{% endif %}
            </p>

            <div class="mt-4 pt-3 border-top text-muted fs-xs">
                <strong class="text-body">{{ company_name ?: app_name }}</strong>
            </div>
        </div>
    </div>
</div>

</body>
</html>
