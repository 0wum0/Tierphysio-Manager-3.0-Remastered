<!DOCTYPE html>
<html lang="de" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Anmeldung — {{ app_name }}</title>
    {# SmartAdmin Praxis-Design — identische CSS-Basis wie der Praxis-Login,
       damit die Einladungs-Seite visuell perfekt in die Praxis-Software passt.
       KEIN Glass-Design, keine app.css/liquid-glass.css mehr. #}
    <link rel="stylesheet" href="/themes/smart-tierphysio/css/smartapp.min.css">
    <link rel="stylesheet" href="/themes/smart-tierphysio/webfonts/smartadmin/sa-icons.css">
    <style>
        body {
            min-height: 100vh;
            background: var(--bs-body-bg);
            padding: 2rem 1rem 4rem;
        }
        .invite-shell { max-width: 640px; margin: 0 auto; }

        /* ── Brand-Header (identisch zum Login-Muster) ── */
        .invite-brand { text-align: center; margin-bottom: 1.75rem; }
        .invite-brand-icon {
            display: inline-flex; align-items: center; justify-content: center;
            margin-bottom: 0.75rem;
            filter: drop-shadow(0 0 10px rgba(110,168,254,0.5));
            animation: tp-paw-pulse 2s ease-in-out infinite;
        }
        @keyframes tp-paw-pulse {
            0%, 100% { transform: scale(1);    filter: drop-shadow(0 0 0 #6EA8FE); }
            50%      { transform: scale(1.18); filter: drop-shadow(0 0 12px #a78bfa); }
        }
        .invite-brand-name {
            font-size: 1.8rem; font-weight: 700; letter-spacing: -0.02em; margin: 0 0 0.25rem;
            background: linear-gradient(90deg, #6EA8FE, #a78bfa);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .invite-brand-sub { color: var(--bs-secondary-color); font-size: 0.9rem; margin: 0 0 0.75rem; }

        .invite-badge {
            display: inline-flex; align-items: center; gap: 0.5rem;
            background: rgba(var(--bs-primary-rgb), 0.12);
            border: 1px solid rgba(var(--bs-primary-rgb), 0.3);
            color: var(--bs-primary);
            border-radius: 999px; padding: 0.35rem 1rem;
            font-size: 0.82rem; font-weight: 600; margin-bottom: 1.25rem;
        }

        /* ── Progress + Stepper ── */
        .invite-progress {
            height: 3px; background: var(--bs-border-color); border-radius: 100px;
            margin-bottom: 1.25rem; overflow: hidden;
        }
        .invite-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--bs-primary), #8b5cf6);
            transition: width 0.4s ease;
        }

        .invite-stepper {
            display: flex; margin-bottom: 1.5rem;
            background: var(--bs-tertiary-bg);
            border: 1px solid var(--bs-border-color);
            border-radius: 14px; overflow: hidden;
        }
        .invite-stepper .step {
            flex: 1; padding: 0.7rem 0.5rem; text-align: center;
            font-size: 0.78rem; font-weight: 600; color: var(--bs-secondary-color);
            border-right: 1px solid var(--bs-border-color);
            transition: background-color 0.2s, color 0.2s;
        }
        .invite-stepper .step:last-child { border-right: none; }
        .invite-stepper .step.active {
            background: rgba(var(--bs-primary-rgb), 0.12);
            color: var(--bs-body-color);
        }
        .invite-stepper .step.done { color: var(--bs-success); }
        .invite-stepper .step-num {
            display: inline-flex; align-items: center; justify-content: center;
            width: 22px; height: 22px; border-radius: 50%;
            background: var(--bs-border-color); color: var(--bs-body-color);
            font-size: 0.72rem; margin-right: 0.4rem; font-weight: 700;
        }
        .invite-stepper .step.active .step-num { background: var(--bs-primary); color: #fff; }
        .invite-stepper .step.done   .step-num { background: var(--bs-success); color: #fff; }

        .step-panel { display: none; }
        .step-panel.active { display: block; animation: fadeIn 0.3s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

        /* ── Photo-Zone im Bootstrap-Stil ── */
        .photo-zone {
            border: 2px dashed var(--bs-border-color);
            border-radius: 14px; padding: 2rem; text-align: center; cursor: pointer;
            background: var(--bs-tertiary-bg);
            transition: border-color 0.2s, background-color 0.2s;
        }
        .photo-zone:hover, .photo-zone.dragover {
            border-color: var(--bs-primary);
            background: rgba(var(--bs-primary-rgb), 0.06);
        }
        .photo-preview {
            width: 120px; height: 120px; object-fit: cover;
            border-radius: 12px; margin: 0 auto 0.75rem; display: block;
        }

        /* ── Summary-Box ── */
        .summary-box {
            background: var(--bs-tertiary-bg);
            border: 1px solid var(--bs-border-color);
            border-radius: 12px;
            padding: 1rem 1.25rem;
            font-size: 0.88rem; line-height: 1.8;
            text-align: left;
        }

        /* ── Footer ── */
        .invite-footer {
            text-align: center; margin-top: 1.5rem;
            font-size: .78rem; color: var(--bs-secondary-color);
        }

        @media (max-width: 500px) {
            .invite-stepper .step { font-size: 0.7rem; padding: 0.55rem 0.25rem; }
            .invite-stepper .step-num { width: 18px; height: 18px; font-size: 0.65rem; margin-right: 0.25rem; }
        }
    </style>
</head>
<body>

<div class="invite-shell">

    {# ── Brand-Header ──
       WICHTIG: Einladungsseiten zeigen IMMER nur das Pfoten-Logo —
       kein custom company_logo, weder für Praxis noch für Hundeschule.
       Der Inviter (Praxis/Hundeschule) wird ausschließlich über den
       Namen im Badge kommuniziert. So bleiben Einladungs-URLs auch
       ohne korrekt konfiguriertes Logo visuell konsistent. #}
    <div class="invite-brand">
        <div class="invite-brand-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <linearGradient id="ivfPaw" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#6EA8FE"/>
                        <stop offset="100%" stop-color="#a78bfa"/>
                    </linearGradient>
                </defs>
                <ellipse fill="url(#ivfPaw)" cx="9"  cy="3.5" rx="2" ry="2.5"/>
                <ellipse fill="url(#ivfPaw)" cx="15" cy="3.5" rx="2" ry="2.5"/>
                <ellipse fill="url(#ivfPaw)" cx="4.5" cy="8"  rx="2" ry="2.5"/>
                <ellipse fill="url(#ivfPaw)" cx="19.5" cy="8" rx="2" ry="2.5"/>
                <path fill="url(#ivfPaw)" d="M12 10c-3.5 0-6.5 2-6.5 5.5 0 2 1 3.5 2.5 4.5h8c1.5-1 2.5-2.5 2.5-4.5C18.5 12 15.5 10 12 10z"/>
            </svg>
        </div>
        <div class="invite-brand-name">{{ app_name }}</div>
        <div class="invite-brand-sub">
            {% if is_trainer ?? false %}
                Bitte füllen Sie das Formular aus, um sich und Ihren Hund anzumelden.
            {% else %}
                Bitte füllen Sie das Formular aus, um sich und Ihr Tier anzumelden.
            {% endif %}
        </div>

        <div class="invite-badge">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24">
                <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                      d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Persönliche Einladung von <strong class="ms-1">{{ company_name ?: app_name }}</strong>
        </div>
    </div>

    {# ── Server-Side Validation Errors ── #}
    {% if errors is defined and errors|length > 0 %}
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-3 py-2" style="font-size:.85rem;">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:2px;">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
            <line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <div>
            {% for e in errors %}<div>{{ e }}</div>{% endfor %}
        </div>
    </div>
    {% endif %}

    {# ── Progress-Bar + Stepper ── #}
    <div class="invite-progress"><div class="invite-progress-fill" id="progress-fill" style="width:25%;"></div></div>

    <div class="invite-stepper">
        <div class="step active" data-step="1"><span class="step-num">1</span>{% if is_trainer ?? false %}Halter{% else %}Besitzer{% endif %}</div>
        <div class="step"        data-step="2"><span class="step-num">2</span>{% if is_trainer ?? false %}Hund{% else %}Tier{% endif %}</div>
        <div class="step"        data-step="3"><span class="step-num">3</span>Foto</div>
        <div class="step"        data-step="4"><span class="step-num">4</span>Fertig</div>
    </div>

    <form id="invite-form" method="POST" enctype="multipart/form-data" action="/einladung/{{ token }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

        {# ── STEP 1: Besitzer ── #}
        <div class="step-panel active card" id="step-1">
            <div class="card-body p-4">
                <h3 class="fw-700 fs-md mb-3">Ihre Angaben</h3>

                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label">Vorname *</label>
                        <input type="text" name="owner_first_name" class="form-control"
                               value="{{ old.owner_first_name ?? (invite.email|split('@')|first) }}"
                               placeholder="Max" required>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Nachname *</label>
                        <input type="text" name="owner_last_name" class="form-control"
                               value="{{ old.owner_last_name ?? '' }}" placeholder="Mustermann" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label">E-Mail-Adresse *</label>
                        <input type="email" name="owner_email" class="form-control"
                               value="{{ old.owner_email ?? invite.email }}" placeholder="max@beispiel.de" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Telefon *</label>
                        <input type="tel" name="owner_phone" class="form-control"
                               value="{{ old.owner_phone ?? invite.phone }}" placeholder="+49 151 12345678" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Straße &amp; Hausnummer</label>
                        <input type="text" name="owner_street" class="form-control"
                               value="{{ old.owner_street ?? '' }}" placeholder="Musterstraße 1">
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label">PLZ</label>
                        <input type="text" name="owner_zip" class="form-control"
                               value="{{ old.owner_zip ?? '' }}" placeholder="12345">
                    </div>
                    <div class="col-sm-8">
                        <label class="form-label">Ort</label>
                        <input type="text" name="owner_city" class="form-control"
                               value="{{ old.owner_city ?? '' }}" placeholder="Musterstadt">
                    </div>
                </div>
            </div>
        </div>

        {# ── STEP 2: Tier / Hund ── #}
        <div class="step-panel card" id="step-2">
            <div class="card-body p-4">
                <h3 class="fw-700 fs-md mb-3">{% if is_trainer ?? false %}Angaben zu Ihrem Hund{% else %}Angaben zum Tier{% endif %}</h3>

                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label">{% if is_trainer ?? false %}Name des Hundes *{% else %}Name des Tieres *{% endif %}</label>
                        <input type="text" name="patient_name" class="form-control"
                               value="{{ old.patient_name ?? '' }}" placeholder="Bello" required>
                    </div>
                    <div class="col-sm-6">
                        {% if is_trainer ?? false %}
                            {# Hundeschule akzeptiert konzeptionell nur Hunde —
                               das Feld bleibt aus Konsistenzgründen im Formular,
                               ist aber auf „Hund" fixiert. Ein verstecktes Input
                               sichert den Submit-Wert. #}
                            <label class="form-label">Tierart</label>
                            <input type="text" class="form-control" value="Hund" disabled readonly>
                            <input type="hidden" name="patient_species" value="Hund">
                        {% else %}
                            <label class="form-label">Tierart *</label>
                            <select name="patient_species" class="form-select" required>
                                <option value="">Bitte wählen</option>
                                {% set species = ['Hund','Katze','Pferd','Kaninchen','Vogel','Reptil','Nagetier','Fisch','Sonstige'] %}
                                {% for s in species %}
                                <option value="{{ s }}" {% if (old.patient_species ?? '') == s %}selected{% endif %}>{{ s }}</option>
                                {% endfor %}
                            </select>
                        {% endif %}
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Rasse</label>
                        <input type="text" name="patient_breed" class="form-control"
                               value="{{ old.patient_breed ?? '' }}" placeholder="Golden Retriever">
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Geschlecht</label>
                        <select name="patient_gender" class="form-select">
                            <option value="">Unbekannt</option>
                            <option value="männlich"     {% if (old.patient_gender ?? '') == 'männlich'     %}selected{% endif %}>Männlich</option>
                            <option value="weiblich"     {% if (old.patient_gender ?? '') == 'weiblich'     %}selected{% endif %}>Weiblich</option>
                            <option value="kastriert"    {% if (old.patient_gender ?? '') == 'kastriert'    %}selected{% endif %}>Kastriert</option>
                            <option value="sterilisiert" {% if (old.patient_gender ?? '') == 'sterilisiert' %}selected{% endif %}>Sterilisiert</option>
                        </select>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Geburtsdatum</label>
                        <input type="date" name="patient_birth_date" class="form-control"
                               value="{{ old.patient_birth_date ?? '' }}">
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">Fellfarbe</label>
                        <input type="text" name="patient_color" class="form-control"
                               value="{{ old.patient_color ?? '' }}" placeholder="Braun-weiß">
                    </div>
                    <div class="col-12">
                        <label class="form-label">Chip-Nummer / Transponder</label>
                        <input type="text" name="patient_chip" class="form-control"
                               value="{{ old.patient_chip ?? '' }}" placeholder="276097202012345">
                    </div>
                </div>
            </div>
        </div>

        {# ── STEP 3: Foto ── #}
        <div class="step-panel card" id="step-3">
            <div class="card-body p-4">
                <h3 class="fw-700 fs-md mb-1">Foto Ihres Tieres</h3>
                <p class="text-muted fs-sm mb-3">Optional — hilft uns, Ihr Tier beim ersten Besuch schnell zu erkennen.</p>

                <div class="photo-zone" id="photo-zone" onclick="document.getElementById('photo-input').click()">
                    <img id="photo-preview" class="photo-preview" src="" alt="" style="display:none;">
                    <div id="photo-placeholder">
                        <div style="font-size:2.5rem;margin-bottom:0.75rem;">📷</div>
                        <div class="fw-600 fs-md mb-1">Foto hochladen</div>
                        <div class="text-muted fs-sm">JPG, PNG, WEBP bis 8 MB</div>
                    </div>
                    <input type="file" name="patient_photo" id="photo-input" accept="image/*" style="display:none;">
                </div>

                <div class="text-center mt-2">
                    <button type="button" class="btn btn-secondary btn-sm" id="remove-photo" style="display:none;" onclick="removePhoto()">Foto entfernen</button>
                </div>
            </div>
        </div>

        {# ── STEP 4: Bestätigen ── #}
        <div class="step-panel card" id="step-4">
            <div class="card-body p-4 text-center">
                <div style="font-size:3rem;margin-bottom:1rem;">✅</div>
                <h3 class="fw-700 fs-lg mb-2">Alles bereit!</h3>
                <p class="text-muted fs-sm mb-3" style="line-height:1.7;">
                    Bitte überprüfen Sie Ihre Angaben und klicken Sie auf <strong>Jetzt registrieren</strong>.<br>
                    Sie werden nach der Registrierung sofort als aktiver Besitzer aufgenommen.
                </p>

                <div id="summary" class="summary-box"></div>

                <div class="mt-3 text-start">
                    <label class="form-check d-flex align-items-start gap-2">
                        <input type="checkbox" class="form-check-input" name="gdpr_consent" value="1" required>
                        <span class="form-check-label text-muted fs-sm">
                            Ich habe die <a href="/datenschutz" target="_blank">Datenschutzerklärung</a>
                            gelesen und stimme der Verarbeitung meiner Daten zu. *
                        </span>
                    </label>
                </div>
            </div>
        </div>

        {# ── Navigation ── #}
        <div class="d-flex justify-content-between align-items-center mt-3">
            <button type="button" class="btn btn-secondary" id="btn-prev" style="visibility:hidden;">← Zurück</button>
            <div class="text-muted fs-sm" id="step-indicator">Schritt 1 von 4</div>
            <button type="button" class="btn btn-primary" id="btn-next">Weiter →</button>
        </div>
    </form>

    <div class="invite-footer">
        &copy; {{ "now"|date("Y") }} {{ company_name ?: app_name }} · powered by <strong>{{ app_name }}</strong>
    </div>

</div>

<script>
let currentStep = 1;
const totalSteps = 4;

function updateStep(step) {
    document.querySelectorAll('.step-panel').forEach(function (p, i) {
        p.classList.toggle('active', i + 1 === step);
    });
    document.querySelectorAll('.invite-stepper .step').forEach(function (t, i) {
        t.classList.remove('active', 'done');
        if (i + 1 === step) t.classList.add('active');
        if (i + 1 < step)   t.classList.add('done');
    });

    document.getElementById('step-indicator').textContent = 'Schritt ' + step + ' von ' + totalSteps;
    document.getElementById('btn-prev').style.visibility = step > 1 ? 'visible' : 'hidden';
    document.getElementById('btn-next').textContent = step === totalSteps ? '🚀 Jetzt registrieren' : 'Weiter →';
    document.getElementById('progress-fill').style.width = (step / totalSteps * 100) + '%';

    if (step === totalSteps) buildSummary();
}

function buildSummary() {
    const g = function (n) { return document.querySelector('[name="' + n + '"]')?.value || '—'; };
    const sel = function (n) {
        const el = document.querySelector('[name="' + n + '"]');
        return el ? (el.options[el.selectedIndex]?.text || '—') : '—';
    };
    document.getElementById('summary').innerHTML =
        '<strong>Besitzer:</strong> ' + g('owner_first_name') + ' ' + g('owner_last_name') + '<br>' +
        '<strong>E-Mail:</strong> ' + g('owner_email') + '<br>' +
        '<strong>Telefon:</strong> ' + g('owner_phone') + '<br>' +
        '<strong>Tier:</strong> ' + g('patient_name') + ' (' + sel('patient_species') + ')' + '<br>' +
        '<strong>Rasse:</strong> ' + g('patient_breed') + '<br>' +
        '<strong>Geschlecht:</strong> ' + sel('patient_gender');
}

function validateStep(step) {
    if (step === 1) {
        const fn = document.querySelector('[name="owner_first_name"]').value.trim();
        const ln = document.querySelector('[name="owner_last_name"]').value.trim();
        const em = document.querySelector('[name="owner_email"]').value.trim();
        const ph = document.querySelector('[name="owner_phone"]').value.trim();
        if (!fn || !ln) { alert('Bitte Vor- und Nachname ausfüllen.'); return false; }
        if (!em || !em.includes('@')) { alert('Bitte gültige E-Mail-Adresse eingeben.'); return false; }
        if (!ph) { alert('Bitte Telefonnummer eingeben.'); return false; }
    }
    if (step === 2) {
        const pn = document.querySelector('[name="patient_name"]').value.trim();
        const ps = document.querySelector('[name="patient_species"]').value;
        if (!pn) { alert('Bitte Name eingeben.'); return false; }
        /* Species kann versteckt auf „Hund" fixiert sein (Hundeschul-Modus),
           Select oder Hidden liefern beide .value — deshalb nur generisch prüfen. */
        if (!ps) { alert('Bitte Tierart auswählen.'); return false; }
    }
    return true;
}

document.getElementById('btn-next').addEventListener('click', function () {
    if (currentStep === totalSteps) {
        submitForm();
        return;
    }
    if (!validateStep(currentStep)) return;
    currentStep++;
    updateStep(currentStep);
    window.scrollTo({ top: 0, behavior: 'smooth' });
});

document.getElementById('btn-prev').addEventListener('click', function () {
    if (currentStep > 1) { currentStep--; updateStep(currentStep); window.scrollTo({ top: 0, behavior: 'smooth' }); }
});

function submitForm() {
    const btn = document.getElementById('btn-next');
    btn.disabled = true;
    btn.textContent = 'Wird registriert…';

    const form = document.getElementById('invite-form');
    const fd   = new FormData(form);

    fetch(form.action, {
        method: 'POST',
        body: fd,
        headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' }
    })
    .then(function (r) {
        const ct = r.headers.get('content-type') || '';
        if (!ct.includes('application/json')) {
            return r.text().then(function(t) {
                throw new Error('Server HTTP ' + r.status + ': ' + t.substring(0, 400));
            });
        }
        return r.json();
    })
    .then(function (data) {
        if (data.ok) {
            window.location.href = data.redirect;
        } else {
            const errs = data.errors ? data.errors.join('\n') : (data.error || 'Unbekannter Fehler');
            alert('Fehler:\n' + errs);
            btn.disabled = false;
            btn.textContent = '🚀 Jetzt registrieren';
        }
    })
    .catch(function (err) {
        alert('Fehler: ' + (err.message || 'Netzwerkfehler. Bitte erneut versuchen.'));
        btn.disabled = false;
        btn.textContent = '🚀 Jetzt registrieren';
    });
}

/* Photo upload */
document.getElementById('photo-input').addEventListener('change', function () {
    const file = this.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function (e) {
        const preview = document.getElementById('photo-preview');
        preview.src = e.target.result;
        preview.style.display = 'block';
        document.getElementById('photo-placeholder').style.display = 'none';
        document.getElementById('remove-photo').style.display = 'inline-flex';
    };
    reader.readAsDataURL(file);
});

function removePhoto() {
    document.getElementById('photo-input').value = '';
    document.getElementById('photo-preview').style.display = 'none';
    document.getElementById('photo-placeholder').style.display = 'block';
    document.getElementById('remove-photo').style.display = 'none';
}

const zone = document.getElementById('photo-zone');
zone.addEventListener('dragover', function (e) { e.preventDefault(); zone.classList.add('dragover'); });
zone.addEventListener('dragleave', function () { zone.classList.remove('dragover'); });
zone.addEventListener('drop', function (e) {
    e.preventDefault();
    zone.classList.remove('dragover');
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) {
        const dt = new DataTransfer();
        dt.items.add(file);
        document.getElementById('photo-input').files = dt.files;
        document.getElementById('photo-input').dispatchEvent(new Event('change'));
    }
});

updateStep(1);
</script>
</body>
</html>
