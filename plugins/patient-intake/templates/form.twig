<!DOCTYPE html>
<html lang="de" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title }} — {{ app_name }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/themes/smart-tierphysio/css/smartapp.min.css">
    <link rel="stylesheet" href="/themes/smart-tierphysio/webfonts/smartadmin/sa-icons.css">
    <link rel="stylesheet" href="/themes/smart-tierphysio/bridge.css?v=20260308f">
    <style>
        body {
            min-height: 100vh;
            display: flex; flex-direction: column;
            align-items: center; justify-content: flex-start;
            padding: 2rem 1rem 4rem;
            background: var(--bs-body-bg);
        }

        .intake-wrapper { width: 100%; max-width: 680px; }

        /* ── Brand header (matches Praxis-App login) ── */
        .intake-header { text-align: center; margin-bottom: 2.5rem; }
        .intake-logo {
            display: inline-flex; align-items: center; justify-content: center;
            margin-bottom: 1rem;
            filter: drop-shadow(0 0 10px rgba(110,168,254,0.5));
            animation: tp-paw-pulse 3s ease-in-out infinite;
        }
        .intake-title {
            font-size: 1.85rem; font-weight: 700;
            margin: 0 0 0.5rem;
            letter-spacing: -0.02em;
            background: linear-gradient(90deg, #6EA8FE, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .intake-subtitle {
            color: var(--bs-secondary-color);
            font-size: 0.95rem; margin: 0;
        }
        @keyframes tp-paw-pulse {
            0%, 100% { transform: scale(1);    filter: drop-shadow(0 0 0px #6EA8FE); }
            50%      { transform: scale(1.08); filter: drop-shadow(0 0 12px #a78bfa); }
        }

        /* ── Progress Steps ── */
        .steps-bar { display: flex; align-items: flex-start; justify-content: center; gap: 0; margin-bottom: 2.5rem; }
        .step-circle {
            width: 38px; height: 38px; border-radius: 50%;
            border: 2px solid var(--bs-border-color);
            background: var(--bs-tertiary-bg);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.82rem; font-weight: 700;
            color: var(--bs-secondary-color);
            transition: all 0.3s ease;
            flex-shrink: 0;
        }
        .step-circle.active {
            border-color: var(--bs-primary); background: var(--bs-primary);
            color: #fff;
            box-shadow: 0 0 0 4px color-mix(in srgb, var(--bs-primary) 20%, transparent);
        }
        .step-circle.done { border-color: #22c55e; background: #22c55e; color: #fff; }
        .step-label { font-size: 0.72rem; color: var(--bs-secondary-color); margin-top: 0.4rem; white-space: nowrap; }
        .step-label.active { color: var(--bs-primary); font-weight: 600; }
        .step-label.done { color: #22c55e; font-weight: 600; }
        .step-connector {
            width: 48px; height: 2px; margin-top: 18px;
            background: var(--bs-border-color);
            flex-shrink: 0; transition: background 0.3s;
        }
        .step-connector.done { background: #22c55e; }
        .step-wrap { display: flex; flex-direction: column; align-items: center; }

        /* ── Card (Praxis-Login-Style glass card) ── */
        .intake-card,
        .lg-card.intake-card {
            position: relative; overflow: visible;
            background: var(--bs-tertiary-bg);
            border: 1px solid var(--bs-border-color);
            border-radius: 16px;
            padding: 2rem 1.75rem;
            box-shadow: 0 8px 32px rgba(0,0,0,.18);
        }

        /* ── Form Steps ── */
        .form-step { display: none; }
        .form-step.active { display: block; animation: fadeSlideIn 0.35s ease; }
        @keyframes fadeSlideIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

        .step-heading { font-size: 1.1rem; font-weight: 700; margin: 0 0 1.5rem; display: flex; align-items: center; gap: 0.6rem; }
        .step-heading-icon {
            width: 32px; height: 32px; border-radius: 10px;
            background: linear-gradient(135deg, #6EA8FE, #a78bfa);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; font-size: 0.9rem;
            box-shadow: 0 4px 12px color-mix(in srgb, var(--bs-primary) 30%, transparent);
        }

        .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        @media (max-width: 500px) { .form-grid-2 { grid-template-columns: 1fr; } }

        /* ── Form fields ── */
        .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
        .form-group label {
            font-size: 0.82rem; font-weight: 600;
            color: var(--bs-secondary-color);
        }
        .form-group label .req { color: #ef4444; margin-left: 2px; }
        .form-group input,
        .form-group select,
        .form-group textarea {
            background: var(--bs-body-bg);
            border: 1px solid var(--bs-border-color);
            border-radius: 10px;
            padding: 0.65rem 0.9rem;
            font-size: 0.9rem;
            color: var(--bs-body-color);
            font-family: inherit;
            transition: border-color 0.2s, box-shadow 0.2s;
            width: 100%; box-sizing: border-box;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--bs-primary);
            box-shadow: 0 0 0 3px color-mix(in srgb, var(--bs-primary) 20%, transparent);
        }
        .form-group textarea { resize: vertical; min-height: 100px; }

        /* ── Photo Upload ── */
        .photo-upload-area {
            border: 2px dashed var(--bs-border-color);
            border-radius: 14px;
            padding: 2rem 1rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.25s;
            background: var(--bs-body-bg);
        }
        .photo-upload-area:hover, .photo-upload-area.dragover {
            border-color: var(--bs-primary);
            background: color-mix(in srgb, var(--bs-primary) 8%, var(--bs-body-bg));
        }
        .photo-upload-area .upload-icon { font-size: 2rem; margin-bottom: 0.5rem; }
        .photo-upload-area .upload-text { font-size: 0.85rem; color: var(--bs-secondary-color); }
        .photo-upload-area .upload-hint { font-size: 0.75rem; color: var(--bs-secondary-color); margin-top: 0.25rem; opacity: 0.7; }
        .photo-preview { margin-top: 1rem; display: none; }
        .photo-preview img {
            width: 120px; height: 120px;
            object-fit: cover;
            border-radius: 14px;
            border: 2px solid var(--bs-border-color);
        }
        .photo-remove { display: inline-block; margin-top: 0.5rem; font-size: 0.78rem; color: #ef4444; cursor: pointer; }

        /* ── Appointment options ── */
        .apt-options { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
        @media (max-width: 500px) { .apt-options { grid-template-columns: 1fr 1fr; } }
        .apt-option { display: none; }
        .apt-option + label {
            display: flex; flex-direction: column; align-items: center;
            gap: 0.4rem; padding: 0.9rem 0.5rem;
            border: 2px solid var(--bs-border-color);
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.82rem;
            color: var(--bs-secondary-color);
            background: var(--bs-body-bg);
            text-align: center;
        }
        .apt-option + label:hover {
            border-color: var(--bs-primary);
            color: var(--bs-body-color);
        }
        .apt-option:checked + label {
            border-color: var(--bs-primary);
            background: color-mix(in srgb, var(--bs-primary) 12%, var(--bs-body-bg));
            color: var(--bs-primary);
            font-weight: 600;
        }
        .apt-option + label .apt-icon { font-size: 1.4rem; }

        /* ── Navigation (buttons) ── */
        .form-nav {
            display: flex; justify-content: space-between; align-items: center;
            margin-top: 2rem; padding-top: 1.5rem;
            border-top: 1px solid var(--bs-border-color);
        }
        .btn-prev {
            background: transparent;
            border: 1px solid var(--bs-border-color);
            color: var(--bs-body-color);
            padding: 0.65rem 1.4rem;
            border-radius: 10px;
            font-size: 0.88rem; font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-family: inherit;
        }
        .btn-prev:hover {
            border-color: var(--bs-primary);
            color: var(--bs-primary);
            background: color-mix(in srgb, var(--bs-primary) 5%, transparent);
        }
        .btn-next, .btn-submit {
            background: var(--bs-primary);
            border: none;
            color: #fff;
            padding: 0.7rem 1.8rem;
            border-radius: 10px;
            font-size: 0.9rem; font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-family: inherit;
            display: flex; align-items: center; gap: 0.5rem;
            box-shadow: 0 0 0 0 var(--bs-primary);
        }
        .btn-next:hover, .btn-submit:hover {
            background: color-mix(in srgb, var(--bs-primary) 88%, white);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px color-mix(in srgb, var(--bs-primary) 40%, transparent);
        }
        .btn-next:active, .btn-submit:active { transform: translateY(0); }
        .btn-next:disabled, .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

        /* ── Error / info messages ── */
        .field-error { font-size: 0.78rem; color: #ef4444; margin-top: 0.2rem; display: none; }
        .field-error.visible { display: block; }
        .form-errors {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.3);
            border-radius: 10px;
            padding: 1rem;
            margin-bottom: 1.5rem;
            font-size: 0.85rem;
            color: #fca5a5;
            display: none;
        }
        .form-errors.visible { display: block; }
        .form-errors ul { margin: 0.5rem 0 0; padding-left: 1.2rem; }
        .form-errors ul li { margin-bottom: 0.25rem; }

        /* ── Loading overlay ── */
        .submit-loading { display: none; align-items: center; gap: 0.75rem; font-size: 0.9rem; color: var(--bs-secondary-color); }
        .submit-loading.visible { display: flex; }
        .spinner {
            width: 20px; height: 20px;
            border: 2px solid var(--bs-border-color);
            border-top-color: var(--bs-primary);
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Disclaimer ── */
        .intake-disclaimer {
            font-size: 0.78rem;
            color: var(--bs-secondary-color);
            text-align: center;
            margin-top: 1.5rem;
            line-height: 1.5;
        }

        /* ── Info note ── */
        .info-note {
            background: color-mix(in srgb, var(--bs-primary) 8%, transparent);
            border: 1px solid color-mix(in srgb, var(--bs-primary) 22%, transparent);
            border-radius: 10px;
            padding: 0.75rem 1rem;
            font-size: 0.82rem;
            color: var(--bs-secondary-color);
            margin-bottom: 1.25rem;
            display: flex;
            gap: 0.5rem;
        }
        .info-note svg { flex-shrink: 0; margin-top: 1px; color: var(--bs-primary); }

        /* ── Focus-visible ring (a11y) ── */
        *:focus-visible {
            outline: 2px solid var(--bs-primary);
            outline-offset: 2px;
            border-radius: inherit;
        }
        .form-group input:focus-visible,
        .form-group select:focus-visible,
        .form-group textarea:focus-visible,
        .btn-next:focus-visible,
        .btn-prev:focus-visible,
        .btn-submit:focus-visible { outline: 0; }

        /* ── Reduced-motion support ── */
        @media (prefers-reduced-motion: reduce) {
            .intake-logo { animation: none; }
            .btn-next:hover, .btn-submit:hover { transform: none; }
        }
    </style>
</head>
<body>

<div class="intake-wrapper">

    <div class="intake-header">
        <div class="intake-logo">
            {% if global_settings is defined and global_settings.company_logo is defined and global_settings.company_logo %}
                <img src="/uploads/{{ global_settings.company_logo }}" alt="{{ app_name }}" style="width:64px;height:64px;border-radius:16px;object-fit:contain;">
            {% else %}
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="intakePaw" x1="0" y1="0" x2="1" y2="1">
                            <stop offset="0%" stop-color="#6EA8FE"/>
                            <stop offset="100%" stop-color="#a78bfa"/>
                        </linearGradient>
                    </defs>
                    <ellipse fill="url(#intakePaw)" cx="9" cy="3.5" rx="2" ry="2.5"/>
                    <ellipse fill="url(#intakePaw)" cx="15" cy="3.5" rx="2" ry="2.5"/>
                    <ellipse fill="url(#intakePaw)" cx="4.5" cy="8" rx="2" ry="2.5"/>
                    <ellipse fill="url(#intakePaw)" cx="19.5" cy="8" rx="2" ry="2.5"/>
                    <path fill="url(#intakePaw)" d="M12 10c-3.5 0-6.5 2-6.5 5.5 0 2 1 3.5 2.5 4.5h8c1.5-1 2.5-2.5 2.5-4.5C18.5 12 15.5 10 12 10z"/>
                </svg>
            {% endif %}
        </div>
        <h1 class="intake-title">{{ app_name }}</h1>
        <p class="intake-subtitle">Bitte füllen Sie das Formular aus, um sich und Ihren Hund/e anzumelden</p>
    </div>

    <!-- Steps bar -->
    <div class="steps-bar">
        <div class="step-wrap">
            <div class="step-circle active" id="sc-1">1</div>
            <div class="step-label active" id="sl-1">Besitzer</div>
        </div>
        <div class="step-connector" id="conn-1"></div>
        <div class="step-wrap">
            <div class="step-circle" id="sc-2">2</div>
            <div class="step-label" id="sl-2">Tier</div>
        </div>
        <div class="step-connector" id="conn-2"></div>
        <div class="step-wrap">
            <div class="step-circle" id="sc-3">3</div>
            <div class="step-label" id="sl-3">Anliegen</div>
        </div>
        <div class="step-connector" id="conn-3"></div>
        <div class="step-wrap">
            <div class="step-circle" id="sc-4">4</div>
            <div class="step-label" id="sl-4">Termin</div>
        </div>
    </div>

    <div class="lg-card intake-card">

        <div class="form-errors" id="form-errors">
            <strong>Bitte korrigieren Sie folgende Fehler:</strong>
            <ul id="error-list"></ul>
        </div>

        <form id="intake-form" enctype="multipart/form-data" novalidate>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <input type="text" name="website" style="display:none;" tabindex="-1" autocomplete="off">

            <!-- ────── STEP 1: Besitzer ────── -->
            <div class="form-step active" id="step-1">
                <div class="step-heading">
                    <div class="step-heading-icon">👤</div>
                    Ihre Kontaktdaten
                </div>
                <div class="form-grid-2">
                    <div class="form-group">
                        <label for="owner_first_name">Vorname <span class="req">*</span></label>
                        <input type="text" id="owner_first_name" name="owner_first_name" placeholder="Max" autocomplete="given-name" required>
                    </div>
                    <div class="form-group">
                        <label for="owner_last_name">Nachname <span class="req">*</span></label>
                        <input type="text" id="owner_last_name" name="owner_last_name" placeholder="Mustermann" autocomplete="family-name" required>
                    </div>
                    <div class="form-group">
                        <label for="owner_email">E-Mail-Adresse <span class="req">*</span></label>
                        <input type="email" id="owner_email" name="owner_email" placeholder="max@beispiel.de" autocomplete="email" required>
                    </div>
                    <div class="form-group">
                        <label for="owner_phone">Telefon / Mobil <span class="req">*</span></label>
                        <input type="tel" id="owner_phone" name="owner_phone" placeholder="+49 123 456789" autocomplete="tel" required>
                    </div>
                    <div class="form-group" style="grid-column: span 2;">
                        <label for="owner_street">Straße &amp; Hausnummer</label>
                        <input type="text" id="owner_street" name="owner_street" placeholder="Musterstraße 12" autocomplete="street-address">
                    </div>
                    <div class="form-group">
                        <label for="owner_zip">PLZ</label>
                        <input type="text" id="owner_zip" name="owner_zip" placeholder="12345" autocomplete="postal-code" maxlength="10">
                    </div>
                    <div class="form-group">
                        <label for="owner_city">Ort</label>
                        <input type="text" id="owner_city" name="owner_city" placeholder="Musterstadt" autocomplete="address-level2">
                    </div>
                </div>
                <div class="form-nav">
                    <div></div>
                    <button type="button" class="btn-next" data-next="2">
                        Weiter
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/></svg>
                    </button>
                </div>
            </div>

            <!-- ────── STEP 2: Tier(e) ──────
                 Repeatable Hund-Karten. Index 0 ist Pflicht, weitere per
                 „+ Weiteren Hund hinzufügen" dynamisch hinzufügbar. Die
                 Klasse .dog-card wird unten vom JS als Template benutzt. -->
            <div class="form-step" id="step-2">
                <div class="step-heading">
                    <div class="step-heading-icon">🐾</div>
                    Angaben zu Ihrem Hund / Ihren Hunden
                </div>
                <div class="info-note">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="16" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="8" x2="12.01" y2="8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    Sie können mehrere Hunde anmelden. Klicken Sie unten auf „Weiteren Hund hinzufügen", um weitere Tiere zu erfassen.
                </div>

                <div id="dogs-container"></div>

                <button type="button" id="add-dog-btn"
                        style="margin-top:0.75rem; width:100%;
                               background: color-mix(in srgb, var(--bs-primary) 10%, transparent);
                               border: 2px dashed var(--bs-primary);
                               color: var(--bs-primary);
                               padding: 0.85rem;
                               border-radius: 12px;
                               font-size: 0.9rem; font-weight:600;
                               cursor: pointer;
                               transition: all 0.2s;
                               font-family: inherit;">
                    + Weiteren Hund hinzufügen
                </button>

                <div class="form-nav">
                    <button type="button" class="btn-prev" data-prev="1">← Zurück</button>
                    <button type="button" class="btn-next" data-next="3">
                        Weiter
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/></svg>
                    </button>
                </div>
            </div>

            {# HTML-Template für eine Hunde-Karte. Wird vom JS per
               innerHTML geklont — __IDX__ wird durch den laufenden Index
               ersetzt (0 für den ersten Hund, 1 für den zweiten etc.). #}
            <template id="dog-card-template">
                <div class="dog-card" data-dog-index="__IDX__"
                     style="position:relative; border:1px solid var(--bs-border-color); border-radius:14px; padding:1.25rem; margin-bottom:1rem; background:var(--bs-body-bg);">
                    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem;">
                        <div style="font-weight:700; font-size:0.95rem; display:flex; align-items:center; gap:0.5rem;">
                            <span style="background: linear-gradient(135deg,#6EA8FE,#a78bfa); color:#fff; width:26px; height:26px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:0.78rem;" class="dog-card-number">1</span>
                            <span class="dog-card-title">Hund 1</span>
                        </div>
                        <button type="button" class="dog-card-remove"
                                style="background:transparent; border:none; color:#ef4444; font-size:0.78rem; cursor:pointer; display:none;"
                                title="Diesen Hund entfernen">
                            ✕ Entfernen
                        </button>
                    </div>
                    <div class="form-grid-2">
                        <div class="form-group">
                            <label>Name des Hundes <span class="req">*</span></label>
                            <input type="text" name="dogs[__IDX__][name]" class="dog-field-name" placeholder="z.B. Bello" required>
                        </div>
                        <div class="form-group">
                            <label>Rasse</label>
                            <input type="text" name="dogs[__IDX__][breed]" placeholder="z.B. Labrador">
                        </div>
                        <div class="form-group">
                            <label>Geschlecht</label>
                            <select name="dogs[__IDX__][gender]">
                                <option value="">— Bitte wählen —</option>
                                <option value="männlich">Männlich</option>
                                <option value="weiblich">Weiblich</option>
                                <option value="kastriert">Kastriert (m)</option>
                                <option value="sterilisiert">Sterilisiert (w)</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Geburtsdatum (ca.)</label>
                            <input type="date" name="dogs[__IDX__][birth_date]">
                        </div>
                        <div class="form-group">
                            <label>Fellfarbe / Zeichnung</label>
                            <input type="text" name="dogs[__IDX__][color]" placeholder="z.B. schwarz-weiß">
                        </div>
                        <div class="form-group">
                            <label>Chip-Nummer</label>
                            <input type="text" name="dogs[__IDX__][chip]" placeholder="15-stellig (optional)">
                        </div>
                    </div>
                    {# Tierart bleibt fix „Hund" für die Hundeschul-Zielgruppe —
                       wird serverseitig als Standard gesetzt. Falls du sie
                       anpassen möchtest, kommentiere das Select ein: #}
                    <input type="hidden" name="dogs[__IDX__][species]" value="Hund">

                    <div class="form-group" style="margin-top:1rem;">
                        <label>Foto des Hundes</label>
                        <div class="photo-upload-area dog-photo-drop">
                            <div class="upload-icon">📷</div>
                            <div class="upload-text">Foto hier ablegen oder klicken zum Auswählen</div>
                            <div class="upload-hint">JPG, PNG, WebP · max. 8 MB</div>
                        </div>
                        <input type="file" class="dog-photo-input" name="dog_photos[__IDX__]" accept="image/*" style="display:none;">
                        <div class="photo-preview dog-photo-preview">
                            <img class="dog-photo-preview-img" src="" alt="Vorschau">
                            <br>
                            <span class="photo-remove dog-photo-remove">✕ Entfernen</span>
                        </div>
                    </div>
                </div>
            </template>

            <!-- ────── STEP 3: Anliegen ────── -->
            <div class="form-step" id="step-3">
                <div class="step-heading">
                    <div class="step-heading-icon">📋</div>
                    Ihr Anliegen
                </div>
                <div class="info-note">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="16" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="8" x2="12.01" y2="8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    Je genauer Sie Ihr Anliegen beschreiben, desto besser können wir uns auf den Termin vorbereiten.
                </div>
                <div class="form-group">
                    <label for="reason">Warum kommen Sie zu uns? <span class="req">*</span></label>
                    <textarea id="reason" name="reason" rows="5" placeholder="z.B. Mein Hund hat Probleme mit der Hüfte und läuft seit einigen Wochen leicht hinkend. Wir suchen eine physiotherapeutische Behandlung..." required></textarea>
                </div>
                <div class="form-group" style="margin-top:1rem;">
                    <label for="notes">Weitere Anmerkungen</label>
                    <textarea id="notes" name="notes" rows="3" placeholder="z.B. bekannte Diagnosen, Vorbehandlungen, Allergien, Besonderheiten..."></textarea>
                </div>
                <div class="form-nav">
                    <button type="button" class="btn-prev" data-prev="2">← Zurück</button>
                    <button type="button" class="btn-next" data-next="4">
                        Weiter
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6"/></svg>
                    </button>
                </div>
            </div>

            <!-- ────── STEP 4: Terminwunsch ────── -->
            <div class="form-step" id="step-4">
                <div class="step-heading">
                    <div class="step-heading-icon">📅</div>
                    Terminwunsch
                </div>

                <div class="form-group" style="margin-bottom:1.5rem;">
                    <label>Wann soll der Termin stattfinden?</label>
                    <div class="apt-options">
                        <div>
                            <input type="radio" class="apt-option" name="appointment_wish" id="apt_asap" value="Schnellstmöglich">
                            <label for="apt_asap"><span class="apt-icon">⚡</span>Schnellstmöglich</label>
                        </div>
                        <div>
                            <input type="radio" class="apt-option" name="appointment_wish" id="apt_week" value="Diese Woche">
                            <label for="apt_week"><span class="apt-icon">📆</span>Diese Woche</label>
                        </div>
                        <div>
                            <input type="radio" class="apt-option" name="appointment_wish" id="apt_nextweek" value="Nächste Woche">
                            <label for="apt_nextweek"><span class="apt-icon">🗓️</span>Nächste Woche</label>
                        </div>
                        <div>
                            <input type="radio" class="apt-option" name="appointment_wish" id="apt_flexible" value="Flexibel">
                            <label for="apt_flexible"><span class="apt-icon">🔄</span>Flexibel</label>
                        </div>
                        <div>
                            <input type="radio" class="apt-option" name="appointment_wish" id="apt_morning" value="Vormittags bevorzugt">
                            <label for="apt_morning"><span class="apt-icon">🌅</span>Vormittags</label>
                        </div>
                        <div>
                            <input type="radio" class="apt-option" name="appointment_wish" id="apt_afternoon" value="Nachmittags bevorzugt">
                            <label for="apt_afternoon"><span class="apt-icon">🌇</span>Nachmittags</label>
                        </div>
                    </div>
                </div>

                <!-- Summary preview -->
                <div style="background: color-mix(in srgb, var(--bs-primary) 8%, transparent); border: 1px solid color-mix(in srgb, var(--bs-primary) 22%, transparent); border-radius: 14px; padding: 1.25rem; margin-top: 0.5rem;">
                    <div style="font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--bs-secondary-color); margin-bottom: 1rem;">Zusammenfassung</div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 1.5rem; font-size: 0.85rem;">
                        <div><span style="color:var(--bs-secondary-color);">Besitzer:</span><br><strong id="sum-owner">—</strong></div>
                        <div><span style="color:var(--bs-secondary-color);">Tier:</span><br><strong id="sum-patient">—</strong></div>
                        <div><span style="color:var(--bs-secondary-color);">E-Mail:</span><br><span id="sum-email" style="color:var(--bs-secondary-color);">—</span></div>
                        <div><span style="color:var(--bs-secondary-color);">Telefon:</span><br><span id="sum-phone" style="color:var(--bs-secondary-color);">—</span></div>
                    </div>
                </div>

                {# DSGVO-Pflicht-Haken — Die Anmeldung lässt sich ohne aktiven
                   Haken weder clientseitig (HTML `required`) noch serverseitig
                   (Validierung in IntakeController) absenden. Der Link führt
                   auf die öffentliche Datenschutzerklärung. #}
                <div style="margin-top:1.75rem; padding:1rem 1.15rem; border:1px solid color-mix(in srgb, var(--bs-primary) 30%, transparent); background: color-mix(in srgb, var(--bs-primary) 6%, transparent); border-radius:12px;">
                    <div class="form-group" style="flex-direction:row; align-items:flex-start; gap:0.85rem; margin-bottom:0;">
                        <input type="checkbox" id="consent" name="consent" value="1"
                               style="margin-top:3px; flex-shrink:0; width:20px; height:20px; cursor:pointer; accent-color: var(--bs-primary);" required>
                        <label for="consent" style="font-size:0.85rem; color:var(--bs-body-color); cursor:pointer; line-height:1.55;">
                            <strong>Datenschutz — Pflichtfeld <span class="req">*</span></strong><br>
                            Ich habe die
                            <a href="/datenschutz" target="_blank" rel="noopener"
                               style="color:var(--bs-primary); text-decoration:underline;">Datenschutzerklärung</a>
                            gelesen und willige in die Verarbeitung meiner Daten zum Zweck der
                            Terminvereinbarung und Behandlung/Betreuung meines Hundes ein
                            (DSGVO Art. 6 Abs. 1 lit. a). Diese Einwilligung kann ich jederzeit widerrufen.
                        </label>
                    </div>
                </div>

                <div class="form-nav">
                    <button type="button" class="btn-prev" data-prev="3">← Zurück</button>
                    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.75rem;">
                        <div class="submit-loading" id="submit-loading">
                            <div class="spinner"></div>
                            <span>Wird gesendet…</span>
                        </div>
                        <button type="submit" class="btn-submit" id="btn-submit">
                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M22 2 11 13M22 2 15 22l-4-9-9-4 20-7z"/></svg>
                            Anmeldung absenden
                        </button>
                    </div>
                </div>
            </div>

        </form>
    </div>

    <p class="intake-disclaimer">
        Ihre Daten werden ausschließlich zur Terminvereinbarung verwendet und nicht an Dritte weitergegeben.<br>
        <strong>{{ app_name }}</strong> · Dieses Formular ist verschlüsselt übertragen.
    </p>

</div>

<script>
(function () {
    let currentStep = 1;
    const totalSteps = 4;

    function goTo(step) {
        if (step < 1 || step > totalSteps) return;

        /* Validate current before going forward */
        if (step > currentStep && !validateStep(currentStep)) return;

        document.getElementById('step-' + currentStep).classList.remove('active');
        currentStep = step;
        document.getElementById('step-' + currentStep).classList.add('active');

        /* Update step circles */
        for (let i = 1; i <= totalSteps; i++) {
            const sc = document.getElementById('sc-' + i);
            const sl = document.getElementById('sl-' + i);
            sc.classList.remove('active', 'done');
            sl.classList.remove('active', 'done');
            if (i < currentStep) { sc.classList.add('done'); sl.classList.add('done'); sc.innerHTML = '✓'; }
            else if (i === currentStep) { sc.classList.add('active'); sl.classList.add('active'); sc.innerHTML = i; }
            else { sc.innerHTML = i; }
        }

        /* Update connectors */
        for (let i = 1; i <= totalSteps - 1; i++) {
            const conn = document.getElementById('conn-' + i);
            if (conn) conn.classList.toggle('done', i < currentStep);
        }

        if (currentStep === 4) updateSummary();

        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function validateStep(step) {
        const panel = document.getElementById('step-' + step);
        const required = panel.querySelectorAll('[required]');
        let ok = true;

        required.forEach(function (field) {
            if (field.type === 'checkbox') {
                if (!field.checked) { highlight(field, true); ok = false; }
                else highlight(field, false);
            } else if (!field.value.trim()) {
                highlight(field, true); ok = false;
            } else if (field.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value)) {
                highlight(field, true); ok = false;
            } else {
                highlight(field, false);
            }
        });

        return ok;
    }

    function highlight(field, error) {
        field.style.borderColor = error ? 'rgba(239,68,68,0.7)' : '';
    }

    function updateSummary() {
        const fn = document.getElementById('owner_first_name').value;
        const ln = document.getElementById('owner_last_name').value;
        const dogNames = Array.from(document.querySelectorAll('.dog-field-name'))
            .map(el => el.value.trim())
            .filter(Boolean);
        document.getElementById('sum-owner').textContent = [fn, ln].filter(Boolean).join(' ') || '—';
        const patientLabel = dogNames.length === 0
            ? '—'
            : (dogNames.length === 1 ? dogNames[0] : dogNames.join(', ') + ' (' + dogNames.length + ' Hunde)');
        document.getElementById('sum-patient').textContent = patientLabel;
        document.getElementById('sum-email').textContent   = document.getElementById('owner_email').value || '—';
        document.getElementById('sum-phone').textContent   = document.getElementById('owner_phone').value || '—';
    }

    /* Button delegates */
    document.querySelectorAll('.btn-next').forEach(function (btn) {
        btn.addEventListener('click', function () { goTo(parseInt(btn.dataset.next)); });
    });
    document.querySelectorAll('.btn-prev').forEach(function (btn) {
        btn.addEventListener('click', function () { goTo(parseInt(btn.dataset.prev)); });
    });

    /* ── Multi-Hund-Handling ───────────────────────────────────────
       • Mindestens 1 Hund-Karte ist immer sichtbar (Index 0).
       • „+ Weiteren Hund hinzufügen" klont das Template, nimmt den
         nächsten freien Index.
       • „✕ Entfernen" entfernt die Karte und nummeriert die
         Anzeige-Labels (Hund 1, Hund 2, …) neu. Die Feld-Indices in
         den name-Attributen bleiben stabil — PHP iteriert serverseitig
         einfach über alle vorhandenen Keys. */
    const dogsContainer = document.getElementById('dogs-container');
    const addDogBtn     = document.getElementById('add-dog-btn');
    const dogTemplate   = document.getElementById('dog-card-template');
    let   dogCounter    = 0;

    function bindDogCardPhoto(card) {
        const drop    = card.querySelector('.dog-photo-drop');
        const input   = card.querySelector('.dog-photo-input');
        const preview = card.querySelector('.dog-photo-preview');
        const img     = card.querySelector('.dog-photo-preview-img');
        const remove  = card.querySelector('.dog-photo-remove');
        if (!drop || !input) return;

        const show = (file) => {
            if (!file || !file.type.startsWith('image/')) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                img.src = e.target.result;
                preview.style.display = 'block';
                drop.style.display = 'none';
            };
            reader.readAsDataURL(file);
        };

        drop.addEventListener('click', () => input.click());
        input.addEventListener('change', () => { if (input.files[0]) show(input.files[0]); });
        remove.addEventListener('click', () => {
            input.value = '';
            img.src = '';
            preview.style.display = 'none';
            drop.style.display = '';
        });
        drop.addEventListener('dragover',  (e) => { e.preventDefault(); drop.classList.add('dragover'); });
        drop.addEventListener('dragleave', () => drop.classList.remove('dragover'));
        drop.addEventListener('drop', (e) => {
            e.preventDefault();
            drop.classList.remove('dragover');
            const f = e.dataTransfer.files[0];
            if (!f) return;
            const dt = new DataTransfer();
            dt.items.add(f);
            input.files = dt.files;
            show(f);
        });
    }

    function renumberDogCards() {
        const cards = dogsContainer.querySelectorAll('.dog-card');
        cards.forEach((card, i) => {
            card.querySelector('.dog-card-number').textContent = (i + 1);
            card.querySelector('.dog-card-title').textContent  = 'Hund ' + (i + 1);
            const removeBtn = card.querySelector('.dog-card-remove');
            removeBtn.style.display = (i === 0 && cards.length === 1) ? 'none' : '';
        });
    }

    function addDogCard() {
        const html = dogTemplate.innerHTML.replaceAll('__IDX__', String(dogCounter));
        const wrap = document.createElement('div');
        wrap.innerHTML = html.trim();
        const card = wrap.firstElementChild;
        dogsContainer.appendChild(card);

        /* Remove-Handler */
        card.querySelector('.dog-card-remove').addEventListener('click', () => {
            if (dogsContainer.querySelectorAll('.dog-card').length <= 1) return;
            card.remove();
            renumberDogCards();
        });

        bindDogCardPhoto(card);
        dogCounter++;
        renumberDogCards();
    }

    /* Start mit einer Karte */
    addDogCard();
    addDogBtn.addEventListener('click', addDogCard);

    /* Form submit */
    document.getElementById('intake-form').addEventListener('submit', function (e) {
        e.preventDefault();

        if (!validateStep(4)) return;

        const submitBtn   = document.getElementById('btn-submit');
        const loadingEl   = document.getElementById('submit-loading');
        const errorsEl    = document.getElementById('form-errors');
        const errorList   = document.getElementById('error-list');

        submitBtn.disabled  = true;
        loadingEl.classList.add('visible');
        errorsEl.classList.remove('visible');

        const formData = new FormData(this);

        fetch('/anmeldung', {
            method: 'POST',
            body:   formData,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.ok) {
                window.location.href = '/anmeldung/danke';
            } else {
                submitBtn.disabled = false;
                loadingEl.classList.remove('visible');
                errorsEl.classList.add('visible');
                errorList.innerHTML = (data.errors || ['Unbekannter Fehler.']).map(function (e) { return '<li>' + e + '</li>'; }).join('');
            }
        })
        .catch(function () {
            submitBtn.disabled = false;
            loadingEl.classList.remove('visible');
            errorsEl.classList.add('visible');
            errorList.innerHTML = '<li>Netzwerkfehler. Bitte versuchen Sie es erneut.</li>';
        });
    });

    /* Keyboard enter on inputs → advance step */
    document.querySelectorAll('.form-step input:not([type=file]):not([type=checkbox]):not([type=radio])').forEach(function (inp) {
        inp.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                const nextBtn = document.querySelector('#step-' + currentStep + ' .btn-next');
                if (nextBtn) nextBtn.click();
            }
        });
    });
})();
</script>

</body>
</html>
