{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block head %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css">
<link rel="stylesheet" href="/assets/css/calendar.css">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.11/locales/de.global.min.js"></script>
{% endblock %}

{% block content %}
<div class="cal-ph">
    <h1 class="page-title" style="font-size:1.3rem;">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" style="margin-right:0.4rem;vertical-align:-2px;flex-shrink:0;"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/></svg>
        Terminkalender
    </h1>
    <div class="cal-ph-actions">
        <a href="/kalender/statistiken" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <span class="cal-btn-label">Statistiken</span>
        </a>
        <a href="/kalender/warteliste" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="8" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="8" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="6" x2="3.01" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="12" x2="3.01" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="18" x2="3.01" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <span class="cal-btn-label">Warteliste</span>
        </a>
        <a href="/kalender/ical-export" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <span class="cal-btn-label">iCal</span>
        </a>
        <button class="btn btn-primary btn-sm" id="btn-new-appointment">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            Neuer Termin
        </button>
    </div>
</div>

{# Stats Bar #}
<div class="cal-stats-bar">
    <div class="cal-stat" style="--stat-gradient:linear-gradient(135deg,#4f7cff,#7c9fff);">
        <div class="cal-stat-value">{{ stats.today ?? 0 }}</div>
        <div class="cal-stat-label">Heute</div>
    </div>
    <div class="cal-stat" style="--stat-gradient:linear-gradient(135deg,#a855f7,#7c3aed);">
        <div class="cal-stat-value">{{ stats.upcoming ?? 0 }}</div>
        <div class="cal-stat-label">Geplant</div>
    </div>
    <div class="cal-stat" style="--stat-gradient:linear-gradient(135deg,#22c55e,#16a34a);">
        <div class="cal-stat-value">{{ stats.completed ?? 0 }}</div>
        <div class="cal-stat-label">Abgeschlossen</div>
    </div>
    <div class="cal-stat" style="--stat-gradient:linear-gradient(135deg,#ef4444,#dc2626);">
        <div class="cal-stat-value">{{ stats.cancelled ?? 0 }}</div>
        <div class="cal-stat-label">Abgesagt</div>
    </div>
</div>

{# Calendar Container #}
<div class="cal-card">
    <div class="cal-toolbar">
        <div class="flex gap-1">
            <button class="cal-nav-btn" id="cal-prev" title="Zurück">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="cal-nav-btn" id="cal-today" title="Heute" style="width:auto;padding:0 0.75rem;font-size:0.75rem;font-weight:700;letter-spacing:0.03em;">Heute</button>
            <button class="cal-nav-btn" id="cal-next" title="Weiter">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="9 18 15 12 9 6"/></svg>
            </button>
        </div>
        <h2 class="cal-title" id="cal-title"></h2>
        <div class="flex gap-1">
            <button class="cal-view-btn active" data-view="dayGridMonth">Monat</button>
            <button class="cal-view-btn" data-view="timeGridWeek">Woche</button>
            <button class="cal-view-btn" data-view="timeGridDay">Tag</button>
            <button class="cal-view-btn" data-view="listWeek">Liste</button>
        </div>
    </div>
    <div class="cal-body">
        <div id="calendar"></div>
    </div>
</div>

{# iCal Import #}
<details class="cal-import-section">
    <summary>
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        iCal-Datei importieren (.ics)
    </summary>
    <div class="cal-import-body">
        <form action="/kalender/ical-import" method="POST" enctype="multipart/form-data" class="flex gap-3 items-center" style="width:100%;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <input type="file" name="ical_file" accept=".ics" class="form-control" style="flex:1;">
            <button type="submit" class="btn btn-primary btn-sm">Importieren</button>
        </form>
    </div>
</details>

{# ── Appointment Modal (Bootstrap 5) ── #}
<div class="modal fade" id="modal-appointment" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modal-apt-title">Neuer Termin</h5>
                <button type="button" class="btn-close" id="modal-apt-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
            </div>
            <div class="modal-body">
            <form id="form-appointment">
                <input type="hidden" id="apt-id" value="">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                <div class="form-grid-2 mb-3">
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">Titel *</label>
                        <input type="text" id="apt-title" name="title" class="form-control" required placeholder="Behandlung, Kontrolle...">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Start *</label>
                        <input type="datetime-local" id="apt-start" name="start_at" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Ende *</label>
                        <input type="datetime-local" id="apt-end" name="end_at" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{% if is_trainer ?? false %}Hund{% else %}Patient{% endif %}</label>
                        <select id="apt-patient" name="patient_id" class="form-control">
                            <option value="">— {% if is_trainer ?? false %}kein Hund{% else %}kein Patient{% endif %} —</option>
                            {% for p in patients %}
                            <option value="{{ p.id }}">{{ p.name }} ({{ p.species }})</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{% if is_trainer ?? false %}Halter{% else %}Tierhalter{% endif %}</label>
                        <select id="apt-owner" name="owner_id" class="form-control">
                            <option value="">— {% if is_trainer ?? false %}kein Halter{% else %}kein Tierhalter{% endif %} —</option>
                            {% for o in owners %}
                            <option value="{{ o.id }}">{{ o.first_name }} {{ o.last_name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">{% if is_trainer ?? false %}Trainingsart{% else %}Behandlungsart{% endif %}</label>
                        <select id="apt-treatment" name="treatment_type_id" class="form-control">
                            <option value="">— keine —</option>
                            {% for tt in treatment_types %}
                            <option value="{{ tt.id }}" data-color="{{ tt.color }}">{{ tt.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select id="apt-status" name="status" class="form-control">
                            <option value="scheduled">Geplant</option>
                            <option value="confirmed">Bestätigt</option>
                            <option value="completed">Abgeschlossen</option>
                            <option value="cancelled">Abgesagt</option>
                            <option value="noshow">Nicht erschienen</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Farbe</label>
                        <input type="color" id="apt-color" name="color" class="form-control" value="#4f7cff" style="height:40px;padding:0.2rem;cursor:pointer;">
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">Beschreibung</label>
                        <textarea id="apt-desc" name="description" class="form-control" rows="2" placeholder="Optionale Beschreibung..."></textarea>
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">Notizen (intern)</label>
                        <textarea id="apt-notes" name="notes" class="form-control" rows="2" placeholder="Interne Notizen..."></textarea>
                    </div>

                    {# Recurrence #}
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">Wiederholung</label>
                        <select id="apt-recurrence" name="recurrence_rule" class="form-control">
                            <option value="">Keine Wiederholung</option>
                            <option value="FREQ=DAILY;COUNT=30">Täglich (30x)</option>
                            <option value="FREQ=WEEKLY;COUNT=12">Wöchentlich (12x)</option>
                            <option value="FREQ=WEEKLY;COUNT=52">Wöchentlich (1 Jahr)</option>
                            <option value="FREQ=MONTHLY;COUNT=12">Monatlich (1 Jahr)</option>
                            <option value="custom">Benutzerdefiniert...</option>
                        </select>
                        <input type="text" id="apt-recurrence-custom" class="form-control mt-2" placeholder="z.B. FREQ=WEEKLY;BYDAY=MO,WE;COUNT=20" style="display:none;">
                    </div>

                    {# Reminder #}
                    <div class="form-group">
                        <label class="form-label">Erinnerung (Minuten vorher)</label>
                        <select id="apt-reminder" name="reminder_minutes" class="form-control">
                            <option value="0">Keine</option>
                            <option value="15">15 Minuten</option>
                            <option value="30">30 Minuten</option>
                            <option value="60" selected>1 Stunde</option>
                            <option value="120">2 Stunden</option>
                            <option value="1440">1 Tag</option>
                        </select>
                    </div>
                    <div class="form-group" style="display:flex;align-items:center;padding-top:1.5rem;">
                        <label style="cursor:pointer;font-size:0.875rem;display:flex;align-items:center;gap:0.5rem;">
                            <input type="checkbox" id="apt-allday" name="all_day" value="1" style="width:16px;height:16px;">
                            Ganztägig
                        </label>
                    </div>
                </div>

            </form>
            </div>
            <div class="modal-footer" style="justify-content:space-between;">
                <div style="display:flex;gap:.5rem;">
                    <button type="button" id="btn-apt-invoice" class="btn btn-secondary btn-sm" style="display:none;">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                        Rechnung erstellen
                    </button>
                    <button type="button" id="btn-apt-delete" class="btn btn-danger btn-sm" style="display:none;">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                        Löschen
                    </button>
                </div>
                <div style="display:flex;gap:.5rem;">
                    <button type="button" id="modal-apt-cancel" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" form="form-appointment" class="btn btn-primary">Speichern</button>
                </div>
            </div>
        </div>
    </div>
</div>

{# Delete confirm modal (Bootstrap 5) #}
<div class="modal fade" id="modal-apt-delete" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Termin löschen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Soll nur dieser Termin oder alle Wiederholungen gelöscht werden?</p>
                <input type="hidden" id="delete-apt-id" value="">
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" id="btn-delete-cancel" data-bs-dismiss="modal">Abbrechen</button>
                <button class="btn btn-outline-danger" id="btn-delete-single">Nur dieser</button>
                <button class="btn btn-danger" id="btn-delete-all">Alle löschen</button>
            </div>
        </div>
    </div>
</div>


<script>
(function() {
    const CSRF = document.querySelector('#form-appointment [name="_csrf_token"]')?.value || '{{ csrf_token }}';
    let calendar;
    let currentAptId = null;

    /* ── Init FullCalendar ── */
    function initCalendar() {
        const el = document.getElementById('calendar');
        if (!el || typeof FullCalendar === 'undefined') {
            setTimeout(initCalendar, 100);
            return;
        }

        calendar = new FullCalendar.Calendar(el, {
            locale: 'de',
            initialView: 'dayGridMonth',
            headerToolbar: false,
            firstDay: 1,
            height: 'auto',
            editable: true,
            selectable: true,
            nowIndicator: true,
            weekNumbers: true,
            weekNumberFormat: { week: 'short' },
            weekText: 'KW',
            eventTimeFormat: { hour: '2-digit', minute: '2-digit', hour12: false },
            slotMinTime: '07:00:00',
            slotMaxTime: '20:00:00',
            dayMaxEvents: 4,

            events: function(info, successCallback, failureCallback) {
                fetch('/api/kalender/events?start=' + info.startStr + '&end=' + info.endStr)
                    .then(r => r.json())
                    .then(successCallback)
                    .catch(failureCallback);
            },

            select: function(info) {
                openNewModal(info.startStr, info.endStr, info.allDay);
            },

            eventClick: function(info) {
                openEditModal(info.event);
            },

            eventDrop: function(info) {
                reschedule(info.event.id, info.event.startStr, info.event.endStr, info.revert);
            },

            eventResize: function(info) {
                reschedule(info.event.id, info.event.startStr, info.event.endStr, info.revert);
            },

            datesSet: function(info) {
                document.getElementById('cal-title').textContent = calendar.view.title;
            },
        });

        calendar.render();
        document.getElementById('cal-title').textContent = calendar.view.title;
    }

    /* ── Toolbar buttons ── */
    document.getElementById('cal-prev').addEventListener('click', () => { calendar.prev(); });
    document.getElementById('cal-next').addEventListener('click', () => { calendar.next(); });
    document.getElementById('cal-today').addEventListener('click', () => { calendar.today(); });
    document.querySelectorAll('.cal-view-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.cal-view-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            calendar.changeView(btn.dataset.view);
        });
    });

    /* ── Bootstrap 5 Modal instances (lazy) ── */
    let _bsAptModal = null;
    let _bsDeleteModal = null;
    function bsAptModal()    { return _bsAptModal    || (_bsAptModal    = new bootstrap.Modal(document.getElementById('modal-appointment'), { backdrop: true, keyboard: true })); }
    function bsDeleteModal() { return _bsDeleteModal || (_bsDeleteModal = new bootstrap.Modal(document.getElementById('modal-apt-delete'),  { backdrop: true, keyboard: true })); }
    const form = document.getElementById('form-appointment');

    function openNewModal(start, end, allDay) {
        currentAptId = null;
        form.reset();
        document.getElementById('apt-id').value = '';
        document.getElementById('modal-apt-title').textContent = 'Neuer Termin';
        document.getElementById('btn-apt-delete').style.display = 'none';
        document.getElementById('btn-apt-invoice').style.display = 'none';
        if (start) document.getElementById('apt-start').value = start.slice(0,16);
        if (end)   document.getElementById('apt-end').value   = end.slice(0,16);
        document.getElementById('apt-allday').checked = !!allDay;
        bsAptModal().show();
        setTimeout(() => document.getElementById('apt-title').focus(), 300);
    }

    function openEditModal(event) {
        currentAptId = event.id;
        const p = event.extendedProps;

        document.getElementById('apt-id').value               = event.id;
        document.getElementById('modal-apt-title').textContent = 'Termin bearbeiten';
        document.getElementById('apt-title').value             = event.title || '';
        document.getElementById('apt-start').value             = event.startStr?.slice(0,16) || '';
        document.getElementById('apt-end').value               = event.endStr?.slice(0,16) || '';
        document.getElementById('apt-allday').checked          = event.allDay;
        document.getElementById('apt-desc').value              = p.description || '';
        document.getElementById('apt-notes').value             = p.notes || '';
        document.getElementById('apt-status').value            = p.status || 'scheduled';
        document.getElementById('apt-color').value             = event.backgroundColor || '#4f7cff';
        setSelectVal('apt-patient',    p.patient_id);
        setSelectVal('apt-owner',      p.owner_id);
        setSelectVal('apt-treatment',  p.treatment_type_id);
        setSelectVal('apt-recurrence', p.recurrence_rule || '');
        setSelectVal('apt-reminder',   p.reminder_minutes ?? 60);

        document.getElementById('btn-apt-delete').style.display  = '';
        document.getElementById('btn-apt-invoice').style.display = '';
        bsAptModal().show();
    }

    function setSelectVal(id, val) {
        const sel = document.getElementById(id);
        if (!sel || val === null || val === undefined) return;
        sel.value = val;
        /* Sync SearchableSelect display if one wraps this select */
        if (id === 'apt-owner'   && ssAptOwner)   ssAptOwner.syncFromSelect();
        if (id === 'apt-patient' && ssAptPatient) ssAptPatient.syncFromSelect();
    }

    function closeModal() { bsAptModal().hide(); currentAptId = null; }

    document.getElementById('btn-new-appointment').addEventListener('click', () => {
        const now = new Date();
        const pad = n => String(n).padStart(2,'0');
        const fmt = d => `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
        const end = new Date(now.getTime() + 60*60*1000);
        openNewModal(fmt(now), fmt(end), false);
    });

    /* Recurrence custom */
    document.getElementById('apt-recurrence').addEventListener('change', function() {
        document.getElementById('apt-recurrence-custom').style.display = this.value === 'custom' ? '' : 'none';
        if (this.value === 'custom') document.getElementById('apt-recurrence-custom').name = 'recurrence_rule';
        else document.getElementById('apt-recurrence-custom').name = '';
    });

    /* Treatment type → auto-fill color */
    document.getElementById('apt-treatment').addEventListener('change', function() {
        const opt = this.options[this.selectedIndex];
        if (opt?.dataset.color) document.getElementById('apt-color').value = opt.dataset.color;
    });

    /* Auto-end 1h after start */
    document.getElementById('apt-start').addEventListener('change', function() {
        const start = new Date(this.value);
        if (!isNaN(start)) {
            const end = new Date(start.getTime() + 60*60*1000);
            const pad = n => String(n).padStart(2,'0');
            document.getElementById('apt-end').value = `${end.getFullYear()}-${pad(end.getMonth()+1)}-${pad(end.getDate())}T${pad(end.getHours())}:${pad(end.getMinutes())}`;
        }
    });

    /* ── SearchableSelect for owner + patient in appointment modal ── */
    let ssAptOwner   = null;
    let ssAptPatient = null;

    function initAptSearchableSelects() {
        const ownerEl   = document.getElementById('apt-owner');
        const patientEl = document.getElementById('apt-patient');
        if (!ownerEl || !patientEl || typeof SearchableSelect === 'undefined') return;

        ssAptPatient = new SearchableSelect({ target: patientEl, placeholder: '— {% if is_trainer ?? false %}kein Hund{% else %}kein Patient{% endif %} —' });

        ssAptOwner = new SearchableSelect({
            target: ownerEl,
            placeholder: '— {% if is_trainer ?? false %}kein Halter{% else %}kein Tierhalter{% endif %} —',
            onSelect: function(ownerId) {
                /* Trigger the existing owner-change handler on the raw select */
                ownerEl.dispatchEvent(new Event('change', { bubbles: true }));
            }
        });
    }
    (function waitForSS(attempts) {
        if (typeof window.SearchableSelect !== 'undefined') {
            initAptSearchableSelects();
        } else if (attempts < 50) {
            setTimeout(function() { waitForSS(attempts + 1); }, 50);
        }
    })(0);

    /* Owner change → filter patients */
    document.getElementById('apt-owner').addEventListener('change', async function() {
        const ownerSelect = this;
        const patientSelect = document.getElementById('apt-patient');
        const ownerId = ownerSelect.value;
        
        // Store current patient value
        const currentPatientId = patientSelect.value;
        
        if (!ownerId) {
            // Reset to all patients
            const response = await fetch('/api/kalender/form-data');
            const data = await response.json();
            patientSelect.innerHTML = '<option value="">— kein Patient —</option>';
            data.patients.forEach(p => {
                const opt = document.createElement('option');
                opt.value = p.id;
                opt.textContent = `${p.name} (${p.species})`;
                patientSelect.appendChild(opt);
            });
            // Restore selection if possible
            if (currentPatientId) patientSelect.value = currentPatientId;
            if (ssAptPatient) ssAptPatient.syncFromSelect();
            updateAutoTitle();
            return;
        }

        // Load patients for this owner
        try {
            // Use the existing form-data API since patients-by-owner API is not working
            const response = await fetch('/api/kalender/form-data');
            const data = await response.json();
            const allPatients = data.patients || [];
            const patients = allPatients.filter(p => p.owner_id == ownerId);
            
            patientSelect.innerHTML = '<option value="">— kein Patient —</option>';
            patients.forEach(p => {
                const opt = document.createElement('option');
                opt.value = p.id;
                opt.textContent = `${p.name} (${p.species})`;
                patientSelect.appendChild(opt);
            });
            
            // Auto-select first patient if none was selected before
            if (!currentPatientId && patients.length > 0) {
                patientSelect.value = patients[0].id;
            } else if (currentPatientId) {
                // Try to restore previous selection if it's still in the list
                const exists = Array.from(patientSelect.options).some(opt => opt.value === currentPatientId);
                if (exists) {
                    patientSelect.value = currentPatientId;
                }
            }
            if (ssAptPatient) ssAptPatient.syncFromSelect();
            updateAutoTitle();
        } catch (error) {
            console.error('Failed to load patients:', error);
        }
    });

    /* Patient change → auto-select owner */
    document.getElementById('apt-patient').addEventListener('change', async function() {
        const patientSelect = this;
        const ownerSelect = document.getElementById('apt-owner');
        const patientId = patientSelect.value;
        
        if (!patientId) {
            // Don't change owner when patient is cleared
            updateAutoTitle();
            return;
        }

        // Get patient data to find owner
        try {
            const response = await fetch('/api/kalender/form-data');
            const data = await response.json();
            const patient = data.patients.find(p => p.id == patientId);
            
            if (patient && patient.owner_id) {
                // Check if owner is already selected to avoid circular updates
                if (ownerSelect.value != patient.owner_id) {
                    // Auto-select the owner
                    ownerSelect.value = patient.owner_id;
                    
                    // Store current patient selection
                    const currentPatientId = patientSelect.value;
                    
                    // Trigger owner change to filter patients properly
                    const event = new Event('change', { bubbles: true });
                    ownerSelect.dispatchEvent(event);
                    
                    // Restore patient selection after filtering
                    setTimeout(() => {
                        const patientOptions = Array.from(patientSelect.options);
                        const exists = patientOptions.some(opt => opt.value === currentPatientId);
                        
                        if (exists) {
                            patientSelect.value = currentPatientId;
                        }
                        updateAutoTitle();
                    }, 200);
                } else {
                    updateAutoTitle();
                }
            }
        } catch (error) {
            console.error('Failed to get patient data:', error);
        }
    });

    /* Auto-generate title from owner, patient, and treatment type */
    function updateAutoTitle() {
        const titleField = document.getElementById('apt-title');
        const ownerSelect = document.getElementById('apt-owner');
        const patientSelect = document.getElementById('apt-patient');
        const treatmentSelect = document.getElementById('apt-treatment');

        const ownerOption     = ownerSelect?.options[ownerSelect.selectedIndex];
        const patientOption   = patientSelect?.options[patientSelect.selectedIndex];
        const treatmentOption = treatmentSelect?.options[treatmentSelect.selectedIndex];

        const ownerName     = ownerSelect?.value     ? (ownerOption?.textContent     || '') : '';
        const patientName   = patientSelect?.value   ? (patientOption?.textContent   || '') : '';
        const treatmentName = treatmentSelect?.value ? (treatmentOption?.textContent || '') : '';
        
        // Only auto-generate if user hasn't manually changed the title
        if (!titleField.hasAttribute('data-manual')) {
            let newTitle = '';
            
            if (ownerName && patientName) {
                // Format: "Nachname, Tiername – Behandlung"
                const ownerLastName = ownerName.split(' ').pop() || ownerName; // Get last word (last name)
                const patientCleanName = patientName.split(' (')[0] || patientName; // Remove species from patient name
                newTitle = `${ownerLastName}, ${patientCleanName}`;
                
                if (treatmentName) {
                    newTitle += ` – ${treatmentName}`;
                }
            } else if (patientName && treatmentName) {
                // Fallback: "Tiername – Behandlung"
                const patientCleanName = patientName.split(' (')[0] || patientName;
                newTitle = `${patientCleanName} – ${treatmentName}`;
            } else if (patientName) {
                // Fallback: Just patient name
                const patientCleanName = patientName.split(' (')[0] || patientName;
                newTitle = patientCleanName;
            }
            
            if (newTitle && newTitle !== titleField.value) {
                titleField.value = newTitle;
            }
        }
    }

    // Track manual title changes
    document.getElementById('apt-title').addEventListener('input', function() {
        this.setAttribute('data-manual', 'true');
    });

    // Clear manual flag when opening new modal
    const originalOpenNewModal = openNewModal;
    openNewModal = function(start, end, allDay) {
        originalOpenNewModal(start, end, allDay);
        document.getElementById('apt-title').removeAttribute('data-manual');
    };

    // Add event listeners for auto-title generation
    document.getElementById('apt-owner').addEventListener('change', updateAutoTitle);
    document.getElementById('apt-patient').addEventListener('change', updateAutoTitle);
    document.getElementById('apt-treatment').addEventListener('change', updateAutoTitle);

    /* ── Form submit ── */
    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        const data = new FormData(this);
        if (document.getElementById('apt-allday').checked) data.set('all_day', '1');
        if (document.getElementById('apt-recurrence').value === 'custom') {
            data.set('recurrence_rule', document.getElementById('apt-recurrence-custom').value);
        }
        const id  = document.getElementById('apt-id').value;
        const url = id ? '/api/kalender/events/' + id : '/api/kalender/events';
        const res  = await fetch(url, { method: 'POST', body: data });
        const json = await res.json();
        if (json.success) {
            calendar.refetchEvents();
            closeModal();
        } else {
            alert(json.error || 'Fehler beim Speichern.');
        }
    });

    /* ── Delete ── */
    document.getElementById('btn-apt-delete').addEventListener('click', () => {
        document.getElementById('delete-apt-id').value = currentAptId;
        bsAptModal().hide();
        bsDeleteModal().show();
    });

    async function doDelete(mode) {
        const id   = document.getElementById('delete-apt-id').value;
        const data = new FormData();
        data.append('_csrf_token', CSRF);
        data.append('mode', mode);
        const res  = await fetch('/api/kalender/events/' + id + '/loeschen', { method: 'POST', body: data });
        const json = await res.json();
        if (json.success) { calendar.refetchEvents(); bsDeleteModal().hide(); }
        else alert('Fehler beim Löschen.');
    }
    document.getElementById('btn-delete-single').addEventListener('click', () => doDelete('single'));
    document.getElementById('btn-delete-all').addEventListener('click',    () => doDelete('all'));

    /* ── Invoice from appointment ── */
    document.getElementById('btn-apt-invoice').addEventListener('click', async () => {
        const id = currentAptId;
        if (!id) return;
        const data = new FormData();
        data.append('_csrf_token', CSRF);
        await fetch('/kalender/' + id + '/rechnung', { method: 'POST', body: data });
        window.location.href = '/rechnungen/erstellen';
    });

    /* ── Drag reschedule ── */
    async function reschedule(id, start, end, revert) {
        const body = JSON.stringify({ start_at: start, end_at: end, _csrf_token: CSRF });
        const res  = await fetch('/api/kalender/events/' + id + '/reschedule', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body,
        });
        const json = await res.json();
        if (!json.success) { revert(); alert('Fehler beim Verschieben.'); }
    }

    initCalendar();
})();
</script>
{% endblock %}
