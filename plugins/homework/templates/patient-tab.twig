{# Hundeschul-/Hundetrainer-Modus: Terminologie wird umgeschaltet, die
   Backend-API (/api/patients/{id}/homework) bleibt identisch. Das gleiche
   Template funktioniert für Praxis und Hundeschule. #}
{% set hw_title_prefix = (is_trainer ?? false) ? 'Trainingsaufgaben' : 'Hausaufgaben' %}
{% set hw_add_label    = (is_trainer ?? false) ? 'Trainingsaufgabe hinzufügen' : 'Hausaufgabe hinzufügen' %}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 style="font-size:0.9rem;color:var(--text-muted);margin:0;">{{ hw_title_prefix }} für {{ patient.name }}</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-add-homework">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        {{ hw_add_label }}
    </button>
</div>

<div id="homework-list">
    <div class="text-center py-4" style="color:var(--text-muted);">
        <div class="spinner-border spinner-border-sm me-2"></div>
        Lade {{ hw_title_prefix }}…
    </div>
</div>

{# Hausaufgaben Modal #}
<div class="modal fade" id="modal-add-homework" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">{{ hw_add_label }}</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
            </div>
            <form id="homework-form" action="/api/patients/{{ patient.id }}/homework" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label class="form-label">{% if is_trainer ?? false %}Vorlage auswählen{% else %}Hausaufgabe auswählen{% endif %}</label>
                        <select name="homework_template_id" id="homework-template-select" class="form-control">
                            <option value="">— Vordefinierte Vorlage —</option>
                            <option value="custom">— Eigene Aufgabe —</option>
                        </select>
                    </div>
                    
                    <div id="custom-homework" style="display:none;">
                        <div class="form-group mb-3">
                            <label class="form-label">{% if is_trainer ?? false %}Titel der Trainingsaufgabe{% else %}Titel der Hausaufgabe{% endif %}</label>
                            <input type="text" name="title" class="form-control" placeholder="{% if is_trainer ?? false %}z.B. 10 Min. Leinenführigkeit täglich{% else %}z.B. tägliche Spaziergänge{% endif %}">
                        </div>
                        <div class="form-group mb-3">
                            <label class="form-label">Beschreibung</label>
                            <textarea name="description" class="form-control" rows="3" placeholder="{% if is_trainer ?? false %}Detaillierte Anweisungen für den Halter…{% else %}Detaillierte Anweisungen für den Besitzer…{% endif %}"></textarea>
                        </div>
                        <div class="form-group mb-3">
                            <label class="form-label">Kategorie</label>
                            <select name="category" class="form-control">
                                {% if is_trainer ?? false %}
                                {# Trainer-spezifischer Katalog — Keys sind als Strings in der DB
                                   gespeichert, kein ENUM-Constraint; mischen mit Praxis-Einträgen
                                   ist sicher. #}
                                <option value="grundkommandos">🐕 Grundkommandos</option>
                                <option value="leinenfuehrung">🦮 Leinenführung</option>
                                <option value="sozialisierung">🐾 Sozialisierung</option>
                                <option value="rueckruf">📣 Rückruf</option>
                                <option value="beschaeftigung">🧠 Beschäftigung/Nasenarbeit</option>
                                <option value="bewegung">🏃 Bewegung</option>
                                <option value="spielregeln">🎾 Spielregeln</option>
                                <option value="umgebungsreize">🌳 Umgebungsreize</option>
                                <option value="sonstiges">📌 Sonstiges</option>
                                {% else %}
                                <option value="bewegung">🏃 Bewegung</option>
                                <option value="dehnung">🤸 Dehnung</option>
                                <option value="massage">💆 Massage</option>
                                <option value="kalt_warm">🌡️ Kalt/Warm-Anwendungen</option>
                                <option value="medikamente">💊 Medikamente</option>
                                <option value="fuetterung">🍽️ Fütterung</option>
                                <option value="beobachtung">👁️ Beobachtung</option>
                                <option value="sonstiges">📌 Sonstiges</option>
                                {% endif %}
                            </select>
                        </div>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">Häufigkeit</label>
                        <select name="frequency" class="form-control">
                            <option value="daily">Täglich</option>
                            <option value="twice_daily">2x täglich</option>
                            <option value="three_times_daily">3x täglich</option>
                            <option value="weekly">Wöchentlich</option>
                            <option value="as_needed">Bei Bedarf</option>
                        </select>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">Dauer</label>
                        <div class="input-group">
                            <input type="number" name="duration_value" class="form-control" min="1" value="10">
                            <select name="duration_unit" class="form-control">
                                <option value="minutes">Minuten</option>
                                <option value="hours">Stunden</option>
                                <option value="days">Tage</option>
                                <option value="weeks">Wochen</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">Startdatum</label>
                        <input type="date" name="start_date" class="form-control" value="{{ "now"|date("Y-m-d") }}">
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">Enddatum (optional)</label>
                        <input type="date" name="end_date" class="form-control" placeholder="Kein Ende">
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">{% if is_trainer ?? false %}Notizen für den Trainer{% else %}Notizen für den Therapeuten{% endif %}</label>
                        <textarea name="therapist_notes" class="form-control" rows="2" placeholder="Interne Notizen…"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">{% if is_trainer ?? false %}Trainingsaufgabe zuweisen{% else %}Hausaufgabe zuweisen{% endif %}</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    let patientId = {{ patient.id }};
    let homeworkTemplates = [];
    
    // Hausaufgaben-Templates laden
    async function loadHomeworkTemplates() {
        try {
            const response = await fetch('/api/homework/templates');
            homeworkTemplates = await response.json();
            
            const select = document.getElementById('homework-template-select');
            select.innerHTML = '<option value="">— Vordefinierte Hausaufgabe —</option><option value="custom">— Eigene Hausaufgabe —</option>';
            
            homeworkTemplates.forEach(template => {
                const option = document.createElement('option');
                option.value = template.id;
                option.textContent = `${template.category_emoji} ${template.title}`;
                select.appendChild(option);
            });
        } catch (error) {
            console.error('Fehler beim Laden der Hausaufgaben-Templates:', error);
        }
    }
    
    // Hausaufgaben für Patienten laden
    async function loadPatientHomework() {
        try {
            const response = await fetch(`/api/patients/${patientId}/homework`);
            const homework = await response.json();
            
            const container = document.getElementById('homework-list');
            
            if (homework.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-4" style="color:var(--text-muted);">
                        <svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="margin:0 auto 1rem;opacity:0.4;"><path stroke="currentColor" stroke-width="1.5" d="M9 11l3 3L22 4"/><path stroke="currentColor" stroke-width="1.5" d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                        <div style="font-size:0.9rem;margin-bottom:0.5rem;">Noch keine Hausaufgaben zugewiesen</div>
                        <div style="font-size:0.8rem;opacity:0.7;">Klicke auf "Hausaufgabe hinzufügen" um zu beginnen</div>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = homework.map(hw => `
                <div class="homework-item" data-id="${hw.id}" style="border:1px solid var(--glass-border);border-radius:8px;padding:1rem;margin-bottom:0.75rem;background:var(--glass-bg);">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 style="margin:0;font-size:0.9rem;font-weight:600;">
                                ${hw.category_emoji} ${hw.title}
                            </h6>
                            <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.25rem;">
                                ${hw.frequency_display} • ${hw.duration_display}
                            </div>
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-outline-secondary" onclick="editHomework(${hw.id})" style="padding:0.25rem 0.5rem;font-size:0.75rem;">
                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteHomework(${hw.id})" style="padding:0.25rem 0.5rem;font-size:0.75rem;">
                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            </button>
                        </div>
                    </div>
                    <div style="font-size:0.85rem;line-height:1.4;color:var(--text-secondary);margin-bottom:0.5rem;">
                        ${hw.description}
                    </div>
                    <div style="font-size:0.8rem;color:var(--text-muted);">
                        <div>📅 ${hw.start_date} ${hw.end_date ? 'bis ' + hw.end_date : ''}</div>
                        ${hw.therapist_notes ? '<div>📝 ' + hw.therapist_notes + '</div>' : ''}
                    </div>
                    ${hw.status === 'completed' ? '<div class="badge bg-success" style="font-size:0.7rem;margin-top:0.5rem;">✓ Erledigt</div>' : ''}
                </div>
            `).join('');
            
        } catch (error) {
            console.error('Fehler beim Laden der Hausaufgaben:', error);
            document.getElementById('homework-list').innerHTML = `
                <div class="text-center py-4" style="color:var(--text-danger);">
                    <div style="font-size:0.9rem;">Fehler beim Laden der Hausaufgaben</div>
                </div>
            `;
        }
    }
    
    // Template-Auswahl-Handler
    document.getElementById('homework-template-select')?.addEventListener('change', function() {
        const customDiv = document.getElementById('custom-homework');
        if (this.value === 'custom') {
            customDiv.style.display = 'block';
        } else if (this.value) {
            const template = homeworkTemplates.find(t => t.id == this.value);
            if (template) {
                customDiv.style.display = 'none';
            }
        } else {
            customDiv.style.display = 'none';
        }
    });
    
    // Hausaufgaben-Formular-Handler
    document.getElementById('homework-form')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        
        try {
            const response = await fetch(`/api/patients/${patientId}/homework`, {
                method: 'POST',
                body: formData
            });
            
            if (response.ok) {
                bootstrap.Modal.getInstance(document.getElementById('modal-add-homework')).hide();
                this.reset();
                loadPatientHomework();
                
                // Erfolgsmeldung anzeigen
                const alert = document.createElement('div');
                alert.className = 'alert alert-success alert-dismissible fade show';
                alert.innerHTML = `
                    Hausaufgabe erfolgreich zugewiesen!
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                document.querySelector('.glass-card').prepend(alert);
                
                setTimeout(() => alert.remove(), 5000);
            } else {
                throw new Error('Fehler beim Speichern');
            }
        } catch (error) {
            console.error('Fehler:', error);
            alert('Fehler beim Speichern der Hausaufgabe');
        }
    });
    
    // Hausaufgabe löschen
    window.deleteHomework = async function(id) {
        if (!confirm('Hausaufgabe wirklich löschen?')) return;
        
        try {
            const response = await fetch(`/api/patients/${patientId}/homework/${id}`, {
                method: 'DELETE',
                headers: {
                    'X-CSRF-Token': '{{ csrf_token }}'
                }
            });
            
            if (response.ok) {
                loadPatientHomework();
            } else {
                throw new Error('Fehler beim Löschen');
            }
        } catch (error) {
            console.error('Fehler:', error);
            alert('Fehler beim Löschen der Hausaufgabe');
        }
    };
    
    // Initialisierung
    loadHomeworkTemplates();
    loadPatientHomework();
});
</script>
