# Environment
.env
.env.local
saas-platform/.env
saas-platform/.env.local

# Storage (keep structure, ignore contents)
/storage/cache/
/storage/logs/*.log
/storage/patients/*/
/storage/uploads/*
!/storage/cache/twig/.gitkeep
!/storage/uploads/.gitkeep
!/storage/patients/.gitkeep
!/storage/logs/.gitkeep

# SaaS-Platform Storage
/saas-platform/storage/logs/*.log
/saas-platform/storage/uploads/
/saas-platform/storage/tenants/

# Plugin enabled list (generated at runtime)
/plugins/enabled.json

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# PHP
*.phar

