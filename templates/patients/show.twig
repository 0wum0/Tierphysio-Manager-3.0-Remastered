{% extends 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="/patienten" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            {{ t('patients.back_to_list') }}
        </a>
        <h1 class="page-title">{{ patient.name }}</h1>
        <span class="badge badge-{{ patient.status|lower|replace({' ':'_', 'ä':'ae','ü':'ue','ö':'oe'}) }}">{{ patient.status }}</span>
    </div>
    <div class="flex gap-2 flex-wrap">
        {# ── Rechnungs-Badge ──────────────────────────────────────────── #}
        {% if invoice_stats is defined %}
            {% if invoice_stats.open_count > 0 %}
                <a href="/rechnungen?search={{ patient.name|url_encode }}" class="btn btn-sm invoice-badge-open" style="background:rgba(220,53,69,0.15);color:#dc3545;border:1.5px solid #dc3545;font-weight:600;position:relative;overflow:visible;">
                    <span class="pulse-ring" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:100%;height:100%;border-radius:6px;border:2px solid #dc3545;animation:badgePulse 1.4s ease-out infinite;pointer-events:none;"></span>
                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                    {{ invoice_stats.open_count }} Rechnung{{ invoice_stats.open_count != 1 ? 'en' : '' }} offen
                </a>
            {% elseif invoice_stats.paid_count > 0 %}
                <a href="/rechnungen?search={{ patient.name|url_encode }}" class="btn btn-sm" style="background:rgba(25,135,84,0.15);color:#198754;border:1.5px solid #198754;font-weight:600;">
                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="22 4 12 14.01 9 11.01"/></svg>
                    Rechnung{{ invoice_stats.paid_count != 1 ? 'en' : '' }} bezahlt
                </a>
            {% endif %}
        {% endif %}
        <button class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-create-invoice">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
            <span class="d-none d-md-inline">{{ t('patients.create_invoice') }}</span>
        </button>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-edit-patient">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            <span class="d-none d-md-inline">{{ t('common.edit') }}</span>
        </button>
        {% if plugin_header_actions is defined and plugin_header_actions %}
            {{ plugin_header_actions|raw }}
        {% endif %}
    </div>
</div>

<div class="flex gap-4" style="align-items:flex-start;flex-wrap:wrap;max-width:100%;overflow:hidden;">

    {# Left: Patient Info #}
    <div style="width:280px;flex-shrink:0;display:flex;flex-direction:column;gap:1rem;">

        {# Photo Card #}
        <div class="glass-card" style="padding:0;overflow:hidden;">
            <div style="height:200px;background:linear-gradient(135deg,var(--bg-elevated),var(--bg-surface));display:flex;align-items:center;justify-content:center;position:relative;">
                {% if patient.photo %}
                    <img src="/patienten/{{ patient.id }}/foto/{{ patient.photo }}" alt="{{ patient.name }}" style="width:100%;height:100%;object-fit:cover;">
                {% else %}
                    <svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="color:var(--text-muted);opacity:0.4;"><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {% endif %}
            </div>
            <div style="padding:1rem;">
                <form action="/patienten/{{ patient.id }}/foto" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <label class="form-label">{{ t('patients.photo') }}</label>
                    <div class="flex gap-2 mt-1">
                        <input type="file" name="photo" accept="image/*" class="form-control" style="font-size:0.8rem;padding:0.4rem;">
                        <button type="submit" class="btn btn-secondary btn-sm" style="flex-shrink:0;">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        {# Patient Details #}
        <div class="glass-card">
            <h3 class="font-semibold mb-3" style="font-size:0.9rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Details</h3>
            <div style="display:flex;flex-direction:column;gap:0.75rem;">
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.species') }}</div>
                    <div class="text-sm font-medium">{{ patient.species ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.breed') }}</div>
                    <div class="text-sm font-medium">{{ patient.breed ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.gender') }}</div>
                    <div class="text-sm font-medium">{{ patient.gender ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.birth_date') }}</div>
                    <div class="text-sm font-medium">{{ patient.birth_date ? patient.birth_date|date_de : '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.color') }}</div>
                    <div class="text-sm font-medium">{{ patient.color ?: '—' }}</div>
                </div>
                <div>
                    <div class="text-xs text-muted mb-1">{{ t('patients.chip_number') }}</div>
                    <div class="text-sm font-medium" style="font-family:monospace;">{{ patient.chip_number ?: '—' }}</div>
                </div>
                {% if patient.notes %}
                <div style="border-top:1px solid var(--glass-border);padding-top:0.75rem;">
                    <div class="text-xs text-muted mb-1">{{ t('patients.notes') }}</div>
                    <div class="text-sm" style="line-height:1.5;color:var(--text-secondary);">{{ patient.notes }}</div>
                </div>
                {% endif %}
            </div>
        </div>

        {# Owner Card #}
        {% if owner %}
        <div class="glass-card">
            <h3 class="font-semibold mb-3" style="font-size:0.9rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">{{ t('patients.owner') }}</h3>
            <a href="/tierhalter/{{ owner.id }}" style="text-decoration:none;">
                <div class="flex items-center gap-3">
                    <div class="avatar-placeholder avatar-md" style="font-size:0.875rem;">{{ owner.first_name|first ~ owner.last_name|first }}</div>
                    <div>
                        <div class="font-semibold text-sm">{{ owner.first_name }} {{ owner.last_name }}</div>
                        {% if owner.phone %}<div class="text-xs text-muted">{{ owner.phone }}</div>{% endif %}
                        {% if owner.email %}<div class="text-xs text-muted">{{ owner.email }}</div>{% endif %}
                    </div>
                </div>
            </a>
        </div>
        {% endif %}

        {# Next Appointment Card #}
        <div class="glass-card" style="padding:1rem;">
            <h3 class="font-semibold mb-2" style="font-size:0.9rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" style="margin-right:4px;vertical-align:text-bottom;"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.5"/></svg>
                Nächster Termin
            </h3>
            {% if next_appointment %}
                {% set nc = next_appointment.treatment_color ?? '#4f7cff' %}
                {% set is_today = next_appointment.start_at|date('Y-m-d') == 'now'|date('Y-m-d') %}
                <a href="/kalender" class="d-flex align-items-center gap-2 text-decoration-none p-2 rounded-2"
                   style="background:{{ nc }}12;border:1px solid {{ nc }}30;transition:background .15s;"
                   onmouseenter="this.style.background='{{ nc }}25'" onmouseleave="this.style.background='{{ nc }}12'">
                    <div class="flex-shrink-0 d-flex flex-column align-items-center justify-content-center rounded-2"
                         style="width:42px;height:42px;background:{{ nc }}22;border:1.5px solid {{ nc }}55;">
                        <div style="font-size:.58rem;font-weight:700;color:{{ nc }};line-height:1;text-transform:uppercase;">{{ next_appointment.start_at|date('D') }}</div>
                        <div style="font-size:1rem;font-weight:800;color:{{ nc }};line-height:1.15;">{{ next_appointment.start_at|date('d') }}</div>
                        <div style="font-size:.55rem;color:{{ nc }};opacity:.8;">{{ next_appointment.start_at|date('M') }}</div>
                    </div>
                    <div class="flex-grow-1 min-width-0">
                        <div class="d-flex align-items-center gap-1 mb-1">
                            <span class="fw-600" style="font-size:.82rem;color:var(--bs-body-color);">
                                {{ next_appointment.start_at|date('d.m.Y') }}
                            </span>
                            {% if is_today %}<span class="badge ms-1" style="background:{{ nc }};font-size:.58rem;">Heute</span>{% endif %}
                        </div>
                        <div style="font-size:.75rem;color:var(--bs-secondary-color);">
                            {{ next_appointment.start_at|date('H:i') }} Uhr
                            {% if next_appointment.treatment_type_name %} · {{ next_appointment.treatment_type_name }}{% endif %}
                        </div>
                    </div>
                </a>
            {% else %}
                <div class="d-flex align-items-center gap-2 text-muted" style="font-size:.8rem;padding:.5rem 0;">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" class="opacity-40"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.5"/></svg>
                    Kein Termin geplant
                </div>
                <a href="/kalender" class="btn btn-secondary btn-sm w-100 mt-2" style="font-size:.75rem;">
                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24" class="me-1"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    Termin eintragen
                </a>
            {% endif %}
        </div>

        {# Delete #}
        <form action="/patienten/{{ patient.id }}/loeschen" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-danger w-full" data-confirm="Patient wirklich löschen? Alle Daten werden entfernt.">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m5 0V4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2"/></svg>
                {{ t('common.delete') }}
            </button>
        </form>
    </div>

    {# Right: Akte #}
    <div style="flex:1;min-width:0;max-width:100%;overflow:hidden;display:flex;flex-direction:column;gap:1rem;">

        {# Akte mit Tabs #}
        <div class="glass-card">
            <h3 class="font-semibold mb-4" style="font-size:0.95rem;">Akte</h3>
            
            <!-- Tabs Navigation -->
            <ul class="nav nav-tabs" id="akteTabs" role="tablist" style="border-bottom:1px solid var(--glass-border);margin-bottom:1rem;">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="neuer-eintrag-tab" data-bs-toggle="tab" data-bs-target="#neuer-eintrag" type="button" role="tab" aria-controls="neuer-eintrag" aria-selected="true">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="margin-right:4px;vertical-align:text-bottom;"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        Neuer Akteneintrag
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="hausaufgaben-tab" data-bs-toggle="tab" data-bs-target="#hausaufgaben" type="button" role="tab" aria-controls="hausaufgaben" aria-selected="false">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="margin-right:4px;vertical-align:text-bottom;"><path stroke="currentColor" stroke-width="2" d="M9 11l3 3L22 4"/><path stroke="currentColor" stroke-width="2" d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                        Hausaufgaben
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="portal-checks-tab" data-bs-toggle="tab" data-bs-target="#portal-checks" type="button" role="tab" aria-controls="portal-checks" aria-selected="false">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="margin-right:4px;vertical-align:text-bottom;"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Portal-Checkliste
                        {% if portal_check_notifications|length > 0 %}
                        <span class="badge" style="font-size:0.6rem;background:rgba(34,197,94,0.15);color:#22c55e;border:1px solid rgba(34,197,94,0.3);margin-left:4px;">{{ portal_check_notifications|length }}</span>
                        {% endif %}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="befunde-tab" data-bs-toggle="tab" data-bs-target="#befunde" type="button" role="tab" aria-controls="befunde" aria-selected="false">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="margin-right:4px;vertical-align:text-bottom;"><path stroke="currentColor" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg>
                        Befundbögen
                        {% if befunde_count is defined and befunde_count > 0 %}
                        <span class="badge" style="background:rgba(79,124,255,0.15);color:var(--bs-primary);border:1px solid rgba(79,124,255,0.3);font-size:.6rem;margin-left:3px;">{{ befunde_count }}</span>
                        {% endif %}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="historie-tab" data-bs-toggle="tab" data-bs-target="#historie" type="button" role="tab" aria-controls="historie" aria-selected="false">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="margin-right:4px;vertical-align:text-bottom;"><path stroke="currentColor" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Historie
                    </button>
                </li>
            </ul>
            
            <!-- Tab Content -->
            <div class="tab-content" id="akteTabsContent">
                <!-- Neuer Eintrag Tab -->
                <div class="tab-pane fade show active" id="neuer-eintrag" role="tabpanel" aria-labelledby="neuer-eintrag-tab">
                    <form id="show-timeline-form" action="/patienten/{{ patient.id }}/timeline-json" method="POST" enctype="multipart/form-data" data-patient-id="{{ patient.id }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                        <div class="form-grid form-grid-2" style="margin-bottom:0.75rem;">
                            <div class="form-group">
                                <label class="form-label">{{ t('patients.entry_type') }}</label>
                                <select name="type" class="form-control">
                                    <option value="note">📝 Notiz</option>
                                    <option value="treatment">💊 Behandlung</option>
                                    <option value="photo">📷 Foto</option>
                                    <option value="document">📄 Dokument</option>
                                    <option value="other">📌 Sonstiges</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">{{ t('patients.entry_date') }}</label>
                                <input type="datetime-local" name="entry_date" class="form-control" value="{{ 'now'|date('Y-m-d\\TH:i') }}">
                            </div>
                        </div>
                        <div class="form-group mb-2">
                            <label class="form-label">{{ t('patients.entry_title') }}</label>
                            <input type="text" name="title" class="form-control" placeholder="{{ t('patients.entry_title_placeholder') }}">
                        </div>
                        <div class="form-group mb-3">
                            <label class="form-label">{{ t('patients.entry_content') }}</label>
                            <textarea name="content" class="form-control" rows="4" placeholder="{{ t('patients.entry_content_placeholder') }}"></textarea>
                        </div>
                        <div class="form-group mb-3">
                            <label class="form-label">{{ t('patients.attachment') }} ({{ t('common.optional') }})</label>
                            <input type="file" name="attachment" class="form-control" accept="image/*,.pdf,.doc,.docx,.xls,.xlsx">
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            {{ t('patients.add_entry') }}
                        </button>
                    </form>
                </div>
                
                <!-- Hausaufgaben Tab -->
                <div class="tab-pane fade" id="hausaufgaben" role="tabpanel" aria-labelledby="hausaufgaben-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3" style="flex-wrap:wrap;gap:0.5rem;">
                        <h5 style="font-size:0.9rem;color:var(--text-muted);margin:0;">Hausaufgaben für {{ patient.name }}</h5>
                        <div class="flex gap-2" style="flex-wrap:wrap;">
                            <button class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-plan-meta" id="btn-plan-meta">
                                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                Therapieplan
                            </button>
                            <a href="/patienten/{{ patient.id }}/hausaufgaben/pdf" target="_blank" class="btn btn-secondary btn-sm">
                                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>
                                PDF
                            </a>
                            {% if owner and owner.email %}
                            <form action="/patienten/{{ patient.id }}/hausaufgaben/email" method="POST" style="margin:0;" onsubmit="return confirm('Hausaufgaben per E-Mail an {{ owner.email }} senden?');">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-secondary btn-sm">
                                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="22,6 12,13 2,6"/></svg>
                                    E-Mail senden
                                </button>
                            </form>
                            {% endif %}
                            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-add-homework">
                                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                Hausaufgabe hinzufügen
                            </button>
                        </div>
                    </div>

                    <div id="homework-list">
                        <div class="text-center py-4" style="color:var(--text-muted);">
                            <div class="spinner-border spinner-border-sm me-2"></div>
                            Lade Hausaufgaben...
                        </div>
                    </div>
                </div>
                
                <!-- Portal-Checkliste Tab -->
                <div class="tab-pane fade" id="portal-checks" role="tabpanel" aria-labelledby="portal-checks-tab">
                    {% if portal_check_notifications is defined and portal_check_notifications|length > 0 %}
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <p class="small mb-0" style="color:var(--text-muted);">
                            Aufgaben und Übungen, die der Besitzer im Portal abgehakt hat. Diese Einträge erscheinen <strong>nicht</strong> in der Timeline.
                        </p>
                        <span class="badge" style="background:rgba(34,197,94,0.12);color:#22c55e;border:1px solid rgba(34,197,94,0.25);font-size:0.7rem;">
                            {{ portal_check_notifications|length }} Einträge
                        </span>
                    </div>
                    <div style="display:flex;flex-direction:column;gap:0.5rem;">
                        {% for n in portal_check_notifications %}
                        <div style="display:flex;align-items:center;gap:0.75rem;padding:0.65rem 0.9rem;border-radius:10px;background:var(--glass-bg, rgba(255,255,255,0.04));border:1px solid var(--glass-border, rgba(255,255,255,0.08));">
                            <div style="width:28px;height:28px;border-radius:8px;background:{% if n.type == 'homework' %}rgba(34,197,94,0.12){% else %}rgba(79,124,255,0.12){% endif %};display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                {% if n.type == 'homework' %}
                                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                {% else %}
                                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="#4f7cff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                {% endif %}
                            </div>
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:0.85rem;font-weight:600;">{{ n.task_title }}</div>
                                <div style="font-size:0.75rem;color:var(--text-muted);">
                                    {{ n.owner_name }}
                                    · {{ n.type == 'homework' ? 'Hausaufgabe' : 'Übung' }}
                                    · <span title="{{ n.created_at }}">{{ n.created_at|date('d.m.Y H:i') }}</span>
                                </div>
                            </div>
                            <span style="font-size:0.68rem;padding:2px 8px;border-radius:6px;background:rgba(34,197,94,0.1);color:#22c55e;border:1px solid rgba(34,197,94,0.2);white-space:nowrap;">
                                ✓ Abgehakt
                            </span>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <div class="text-center py-5" style="color:var(--text-muted);">
                        <svg width="40" height="40" fill="none" viewBox="0 0 24 24" style="opacity:0.2;margin-bottom:12px;"><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <p style="font-size:0.9rem;">Noch keine abgehakten Aufgaben im Besitzerportal.</p>
                        <p style="font-size:0.8rem;opacity:0.6;">Sobald der Besitzer eine Aufgabe oder Übung abhakt, erscheint sie hier.</p>
                    </div>
                    {% endif %}
                </div>

                <!-- Befundbögen Tab -->
                <div class="tab-pane fade" id="befunde" role="tabpanel" aria-labelledby="befunde-tab">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 style="font-size:0.9rem;color:var(--text-muted);margin:0;">Befundbögen für {{ patient.name }}</h5>
                        <a href="/patienten/{{ patient.id }}/befunde/neu" class="btn btn-sm btn-primary">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" style="margin-right:4px;vertical-align:text-bottom;"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            Neuer Befundbogen
                        </a>
                    </div>
                    <div id="befunde-list-container">
                        <div class="text-center py-3" style="color:var(--text-muted);font-size:.85rem;">
                            <span class="spinner-border spinner-border-sm me-2"></span> Lade Befundbögen...
                        </div>
                    </div>
                </div>

                <!-- Historie Tab -->
                <div class="tab-pane fade" id="historie" role="tabpanel" aria-labelledby="historie-tab">
                    {% if timeline %}
                        <div class="timeline">
                            {% for entry in timeline %}
                                <div class="timeline-item">
                                    <div class="timeline-dot timeline-dot-{{ entry.type }}"></div>
                                    <div class="timeline-card">
                                        <div class="timeline-meta">
                                            <div class="flex items-center gap-2">
                                                <span class="text-xs" style="color:{% if entry.type == 'payment' %}#22c55e{% else %}var(--text-muted){% endif %};">
                                                    {% if entry.type == 'note' %}📝
                                                    {% elseif entry.type == 'treatment' %}💊
                                                    {% elseif entry.type == 'photo' %}📷
                                                    {% elseif entry.type == 'document' %}📄
                                                    {% elseif entry.type == 'payment' %}
                                                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" style="vertical-align:middle;"><rect x="2" y="5" width="20" height="14" rx="2" stroke="#22c55e" stroke-width="2"/><path d="M2 10h20" stroke="#22c55e" stroke-width="2"/><path d="M6 15h4" stroke="#22c55e" stroke-width="2" stroke-linecap="round"/></svg>
                                                    {% else %}📌{% endif %}
                                                </span>
                                                {% if entry.status_badge %}
                                                    <span class="badge" style="font-size:0.65rem;{% if entry.type == 'payment' %}background:rgba(34,197,94,0.15);color:#22c55e;border:1px solid #22c55e;{% else %}background:var(--bs-primary-bg-subtle,rgba(79,124,255,0.15));color:var(--bs-primary);{% endif %}">{{ entry.status_badge }}</span>
                                                {% endif %}
                                                <span class="timeline-date" style="{% if entry.type == 'payment' %}color:#22c55e;font-weight:600;{% endif %}">{{ entry.entry_date|datetime_de }}</span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                {% if entry.can_edit %}
                                                    <button class="btn btn-xs btn-outline-secondary timeline-edit-btn" data-entry-id="{{ entry.id }}">
                                                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                    </button>
                                                {% endif %}
                                                {% if entry.can_delete %}
                                                    <form method="POST" action="/patienten/{{ patient.id }}/timeline/{{ entry.id }}/loeschen" style="display:inline;" onsubmit="return confirm('{{ t('common.confirm_delete') }}');">
                                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                                        <button type="submit" class="btn btn-xs btn-outline-danger">
                                                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                                        </button>
                                                    </form>
                                                {% endif %}
                                            </div>
                                        </div>
                                        {% if entry.title %}
                                            <h5 class="timeline-title">{{ entry.title }}</h5>
                                        {% endif %}
                                        {% if entry.content %}
                                            <div class="timeline-content">{{ entry.content|nl2br }}</div>
                                        {% endif %}
                                        {% if entry.attachment %}
                                            <div class="timeline-attachment">
                                                <a href="/patienten/{{ patient.id }}/dokumente/{{ entry.attachment }}" class="btn btn-sm btn-outline-secondary" target="_blank">
                                                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" points="7 10 12 15 17 10"/><line stroke="currentColor" stroke-width="2" x1="12" y1="15" x2="12" y2="3"/></svg>
                                                    {{ entry.attachment }}
                                                </a>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="empty-state" style="text-align:center;padding:3rem 1rem;">
                            <div class="empty-state-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg></div>
                            <div class="empty-state-title">Noch keine Einträge</div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

{# Hausaufgaben Modal #}
<div class="modal fade" id="modal-add-homework" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Hausaufgabe hinzufügen</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
            </div>
            <form id="homework-form" action="/api/patients/{{ patient.id }}/homework" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label class="form-label">Hausaufgabe auswählen</label>
                        <select name="homework_template_id" id="homework-template-select" class="form-control">
                            <option value="">— Vordefinierte Hausaufgabe —</option>
                            <option value="custom">— Eigene Hausaufgabe —</option>
                        </select>
                    </div>
                    
                    <div id="custom-homework" style="display:none;">
                        <div class="form-group mb-3">
                            <label class="form-label">Titel der Hausaufgabe</label>
                            <input type="text" name="title" class="form-control" placeholder="z.B. tägliche Spaziergänge">
                        </div>
                        <div class="form-group mb-3">
                            <label class="form-label">Beschreibung</label>
                            <textarea name="description" class="form-control" rows="3" placeholder="Detaillierte Anweisungen für den Besitzer..."></textarea>
                        </div>
                        <div class="form-group mb-3">
                            <label class="form-label">Kategorie</label>
                            <select name="category" class="form-control">
                                <option value="bewegung">🏃 Bewegung</option>
                                <option value="dehnung">🤸 Dehnung</option>
                                <option value="massage">💆 Massage</option>
                                <option value="kalt_warm">🌡️ Kalt/Warm-Anwendungen</option>
                                <option value="medikamente">💊 Medikamente</option>
                                <option value="fuetterung">🍽️ Fütterung</option>
                                <option value="beobachtung">👁️ Beobachtung</option>
                                <option value="sonstiges">📌 Sonstiges</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">Häufigkeit</label>
                        <select name="frequency" class="form-control">
                            <option value="daily">Täglich</option>
                            <option value="twice_daily">2x täglich</option>
                            <option value="three_times_daily">3x täglich</option>
                            <option value="weekly">Wöchentlich</option>
                            <option value="as_needed">Bei Bedarf</option>
                        </select>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">Dauer</label>
                        <div class="input-group">
                            <input type="number" name="duration_value" class="form-control" min="1" value="10">
                            <select name="duration_unit" class="form-control">
                                <option value="minutes">Minuten</option>
                                <option value="hours">Stunden</option>
                                <option value="days">Tage</option>
                                <option value="weeks">Wochen</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">Startdatum</label>
                        <input type="date" name="start_date" class="form-control" value="{{ "now"|date("Y-m-d") }}">
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">Enddatum (optional)</label>
                        <input type="date" name="end_date" class="form-control" placeholder="Kein Ende">
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">Notizen für den Therapeuten</label>
                        <textarea name="therapist_notes" class="form-control" rows="2" placeholder="Interne Notizen..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Hausaufgabe zuweisen</button>
                </div>
            </form>
        </div>
    </div>
</div>

{# Plan-Meta Modal (Therapieplan-Details für PDF) #}
<div class="modal fade" id="modal-plan-meta" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Therapieplan – Details für PDF</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
            </div>
            <div class="modal-body">
                <p style="font-size:0.82rem;color:var(--text-muted);margin-bottom:1rem;">Diese Angaben erscheinen im Hausaufgaben-PDF und werden pro Patient gespeichert.</p>
                <div class="form-group mb-3">
                    <label class="form-label">Physiotherapeutische Grundsätze</label>
                    <textarea id="pm-grundsaetze" class="form-control" rows="2" placeholder="z.B. Schmerzfreiheit, Stabilisierung/Mobilisierung der Bewegungsabläufe..."></textarea>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Kurzfristige Ziele (innerhalb 3 Behandlungen)</label>
                    <textarea id="pm-kurzziele" class="form-control" rows="2" placeholder="z.B. Schmerzfreiheit, Mobilisierung"></textarea>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Langfristige Ziele (Endziele)</label>
                    <textarea id="pm-langziele" class="form-control" rows="2" placeholder="z.B. Mobilisierung/Stabilisierung der Rückenmuskulatur..."></textarea>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Therapiemittel</label>
                    <input type="text" id="pm-therapiemittel" class="form-control" placeholder="z.B. Wärme, Massage, PNF">
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Beachte / Wichtige Hinweise</label>
                    <textarea id="pm-beachte" class="form-control" rows="3" placeholder="z.B. WICHTIG! Aufwärmphasen sind bei älteren Patienten..."></textarea>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Wiedervorstellung</label>
                    <input type="date" id="pm-wiedervorstellung" class="form-control">
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Therapeut/in (erscheint im PDF)</label>
                    <input type="text" id="pm-therapeut" class="form-control" placeholder="z.B. Eileen Wenzel (Physiotherapeutin / TFA)">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn btn-primary" id="btn-save-plan-meta">Speichern</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    let patientId = {{ patient.id }};
    let homeworkTemplates = [];
    
    // Hausaufgaben-Templates laden
    async function loadHomeworkTemplates() {
        try {
            const response = await fetch('/api/homework/templates');
            homeworkTemplates = await response.json();
            
            const select = document.getElementById('homework-template-select');
            if (select) {
                select.innerHTML = '<option value="">— Vordefinierte Hausaufgabe —</option><option value="custom">— Eigene Hausaufgabe —</option>';
                
                homeworkTemplates.forEach(template => {
                    const option = document.createElement('option');
                    option.value = template.id;
                    option.textContent = `${template.category_emoji} ${template.title}`;
                    select.appendChild(option);
                });
            }
        } catch (error) {
            console.error('Fehler beim Laden der Hausaufgaben-Templates:', error);
        }
    }
    
    // Hausaufgaben für Patienten laden
    async function loadPatientHomework() {
        try {
            const response = await fetch(`/api/patients/${patientId}/homework`);
            const homework = await response.json();
            
            const container = document.getElementById('homework-list');
            if (container) {
                if (homework.length === 0) {
                    container.innerHTML = `
                        <div class="text-center py-4" style="color:var(--text-muted);">
                            <svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="margin:0 auto 1rem;opacity:0.4;"><path stroke="currentColor" stroke-width="1.5" d="M9 11l3 3L22 4"/><path stroke="currentColor" stroke-width="1.5" d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                            <div style="font-size:0.9rem;margin-bottom:0.5rem;">Noch keine Hausaufgaben zugewiesen</div>
                            <div style="font-size:0.8rem;opacity:0.7;">Klicke auf "Hausaufgabe hinzufügen" um zu beginnen</div>
                        </div>
                    `;
                    return;
                }
                
                container.innerHTML = homework.map(hw => `
                    <div class="homework-item" data-id="${hw.id}" style="border:1px solid var(--glass-border);border-radius:8px;padding:1rem;margin-bottom:0.75rem;background:var(--glass-bg);">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h6 style="margin:0;font-size:0.9rem;font-weight:600;">
                                    ${hw.category_emoji} ${hw.title}
                                </h6>
                                <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.25rem;">
                                    ${hw.frequency_display} • ${hw.duration_display}
                                </div>
                            </div>
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-outline-secondary" onclick="editHomework(${hw.id})" style="padding:0.25rem 0.5rem;font-size:0.75rem;">
                                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteHomework(${hw.id})" style="padding:0.25rem 0.5rem;font-size:0.75rem;">
                                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                </button>
                            </div>
                        </div>
                        <div style="font-size:0.85rem;line-height:1.4;color:var(--text-secondary);margin-bottom:0.5rem;">
                            ${hw.description}
                        </div>
                        <div style="font-size:0.8rem;color:var(--text-muted);">
                            <div>📅 ${hw.start_date} ${hw.end_date ? 'bis ' + hw.end_date : ''}</div>
                            ${hw.therapist_notes ? '<div>📝 ' + hw.therapist_notes + '</div>' : ''}
                        </div>
                        ${hw.status === 'completed' ? '<div class="badge bg-success" style="font-size:0.7rem;margin-top:0.5rem;">✓ Erledigt</div>' : ''}
                    </div>
                `).join('');
            }
            
        } catch (error) {
            console.error('Fehler beim Laden der Hausaufgaben:', error);
            const container = document.getElementById('homework-list');
            if (container) {
                container.innerHTML = `
                    <div class="text-center py-4" style="color:var(--text-danger);">
                        <div style="font-size:0.9rem;">Fehler beim Laden der Hausaufgaben</div>
                    </div>
                `;
            }
        }
    }
    
    // Template-Auswahl-Handler
    document.getElementById('homework-template-select')?.addEventListener('change', function() {
        const customDiv = document.getElementById('custom-homework');
        if (this.value === 'custom') {
            customDiv.style.display = 'block';
        } else if (this.value) {
            const template = homeworkTemplates.find(t => t.id == this.value);
            if (template) {
                customDiv.style.display = 'none';
            }
        } else {
            customDiv.style.display = 'none';
        }
    });
    
    // Hausaufgaben-Formular-Handler
    document.getElementById('homework-form')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        
        try {
            const response = await fetch(`/api/patients/${patientId}/homework`, {
                method: 'POST',
                body: formData
            });
            
            if (response.ok) {
                bootstrap.Modal.getInstance(document.getElementById('modal-add-homework')).hide();
                this.reset();
                loadPatientHomework();
                
                // Erfolgsmeldung anzeigen
                const alert = document.createElement('div');
                alert.className = 'alert alert-success alert-dismissible fade show';
                alert.innerHTML = `
                    Hausaufgabe erfolgreich zugewiesen!
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                document.querySelector('.glass-card').prepend(alert);
                
                setTimeout(() => alert.remove(), 5000);
            } else {
                throw new Error('Fehler beim Speichern');
            }
        } catch (error) {
            console.error('Fehler:', error);
            alert('Fehler beim Speichern der Hausaufgabe');
        }
    });
    
    // Hausaufgabe löschen
    window.deleteHomework = async function(id) {
        if (!confirm('Hausaufgabe wirklich löschen?')) return;
        
        try {
            const response = await fetch(`/api/patients/${patientId}/homework/${id}`, {
                method: 'DELETE',
                headers: {
                    'X-CSRF-Token': '{{ csrf_token }}'
                }
            });
            
            if (response.ok) {
                loadPatientHomework();
            } else {
                throw new Error('Fehler beim Löschen');
            }
        } catch (error) {
            console.error('Fehler:', error);
            alert('Fehler beim Löschen der Hausaufgabe');
        }
    };
    
    // ── Plan-Meta laden und speichern ──────────────────────────────────────
    async function loadPlanMeta() {
        try {
            const res = await fetch(`/api/patients/${patientId}/homework/plan-meta`);
            const meta = await res.json();
            if (meta && typeof meta === 'object' && meta.id) {
                document.getElementById('pm-grundsaetze').value    = meta.physiotherapeutische_grundsaetze || '';
                document.getElementById('pm-kurzziele').value      = meta.kurzfristige_ziele || '';
                document.getElementById('pm-langziele').value      = meta.langfristige_ziele || '';
                document.getElementById('pm-therapiemittel').value = meta.therapiemittel || '';
                document.getElementById('pm-beachte').value        = meta.beachte_hinweise || '';
                document.getElementById('pm-wiedervorstellung').value = meta.wiedervorstellung_date || '';
                document.getElementById('pm-therapeut').value      = meta.therapist_name || '';
            }
        } catch (e) { console.error('Plan-Meta Ladefehler:', e); }
    }

    document.getElementById('modal-plan-meta')?.addEventListener('show.bs.modal', loadPlanMeta);

    document.getElementById('btn-save-plan-meta')?.addEventListener('click', async function() {
        const btn = this;
        btn.disabled = true;
        btn.textContent = 'Speichern…';
        try {
            const body = new FormData();
            body.append('_csrf_token', '{{ csrf_token }}');
            body.append('physiotherapeutische_grundsaetze', document.getElementById('pm-grundsaetze').value);
            body.append('kurzfristige_ziele', document.getElementById('pm-kurzziele').value);
            body.append('langfristige_ziele', document.getElementById('pm-langziele').value);
            body.append('therapiemittel', document.getElementById('pm-therapiemittel').value);
            body.append('beachte_hinweise', document.getElementById('pm-beachte').value);
            body.append('wiedervorstellung_date', document.getElementById('pm-wiedervorstellung').value);
            body.append('therapist_name', document.getElementById('pm-therapeut').value);

            const res = await fetch(`/api/patients/${patientId}/homework/plan-meta`, { method: 'POST', body });
            const data = await res.json();
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('modal-plan-meta'))?.hide();
            } else {
                alert('Fehler beim Speichern: ' + (data.error || 'Unbekannter Fehler'));
            }
        } catch (e) {
            alert('Fehler: ' + e.message);
        } finally {
            btn.disabled = false;
            btn.textContent = 'Speichern';
        }
    });

    // Initialisierung
    loadHomeworkTemplates();
    loadPatientHomework();

    // Tab-Wechsel-Handler
    document.getElementById('hausaufgaben-tab')?.addEventListener('shown.bs.tab', function() {
        loadPatientHomework();
    });

    // Befundbögen Tab — lazy load
    let befundeLoaded = false;
    document.getElementById('befunde-tab')?.addEventListener('shown.bs.tab', function() {
        if (befundeLoaded) return;
        befundeLoaded = true;
        loadBefundboegen();
    });

    function loadBefundboegen() {
        const container = document.getElementById('befunde-list-container');
        if (!container) return;
        fetch('/api/patienten/{{ patient.id }}/befunde', {
            headers: { 'Accept': 'application/json' }
        })
        .then(r => r.json())
        .then(data => {
            const items = data.items ?? [];
            if (items.length === 0) {
                container.innerHTML = `
                    <div style="text-align:center;padding:2rem 1rem;color:var(--text-muted);">
                        <svg width="36" height="36" fill="none" viewBox="0 0 24 24" style="opacity:.2;margin-bottom:10px;display:block;margin-inline:auto;"><path stroke="currentColor" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg>
                        <p style="font-size:.85rem;">Noch keine Befundbögen vorhanden.</p>
                    </div>`;
                return;
            }
            const statusColor = { versendet:'#22c55e', abgeschlossen:'var(--bs-primary)', entwurf:'#6c757d' };
            let html = '<div style="display:flex;flex-direction:column;gap:.5rem;">';
            items.forEach(b => {
                const color = statusColor[b.status] ?? '#6c757d';
                const label = { versendet:'Versendet', abgeschlossen:'Abgeschlossen', entwurf:'Entwurf' }[b.status] ?? b.status;
                html += `<div style="display:flex;align-items:center;gap:.75rem;padding:.6rem .9rem;border-radius:10px;background:var(--glass-bg,rgba(255,255,255,.04));border:1px solid var(--glass-border,rgba(255,255,255,.08));">
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:.82rem;font-weight:700;font-family:monospace;color:var(--text-muted);">BF-${String(b.id).padStart(4,'0')}</div>
                        <div style="font-size:.88rem;font-weight:600;">${b.datum ? new Date(b.datum).toLocaleDateString('de-DE') : '—'}</div>
                        ${b.ersteller_name ? `<div style="font-size:.75rem;color:var(--text-muted);">${b.ersteller_name}</div>` : ''}
                    </div>
                    <span style="font-size:.65rem;padding:2px 8px;border-radius:6px;background:${color}22;color:${color};border:1px solid ${color}44;white-space:nowrap;">${label}</span>
                    <a href="/patienten/{{ patient.id }}/befunde/${b.id}" class="btn btn-xs btn-outline-secondary" style="font-size:.75rem;padding:3px 8px;white-space:nowrap;">Ansehen</a>
                </div>`;
            });
            html += '</div>';
            container.innerHTML = html;
        })
        .catch(() => {
            container.innerHTML = `<a href="/patienten/{{ patient.id }}/befunde" class="btn btn-sm btn-outline-secondary">Alle Befundbögen anzeigen</a>`;
        });
    }
});
</script>

