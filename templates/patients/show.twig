<script>
/* ── Invoice creation modal: positions + total ── */
(function () {
    var container  = document.getElementById('modal-positions-container');
    var addBtn     = document.getElementById('modal-add-position');
    var totalEl    = document.getElementById('modal-total-gross');
    var tmpl       = document.getElementById('modal-position-row-template');

    function calcTotal() {
        var total = 0;
        container.querySelectorAll('.modal-position-row').forEach(function (row) {
            var qty   = parseFloat(row.querySelector('.pos-qty').value)   || 0;
            var price = parseFloat(row.querySelector('.pos-price').value) || 0;
            var tax   = parseFloat(row.querySelector('.pos-tax').value)   || 0;
            total += qty * price * (1 + tax / 100);
        });
        totalEl.textContent = total.toFixed(2).replace('.', ',') + ' €';
    }

    function updateRemoveButtons() {
        var rows = container.querySelectorAll('.modal-position-row');
        rows.forEach(function (row) {
            row.querySelector('.remove-modal-position').style.visibility = rows.length > 1 ? 'visible' : 'hidden';
        });
    }

    function bindRow(row) {
        row.querySelectorAll('input').forEach(function (inp) {
            inp.addEventListener('input', calcTotal);
        });
        row.querySelector('.remove-modal-position').addEventListener('click', function () {
            row.remove();
            updateRemoveButtons();
            calcTotal();
        });
    }

    if (container && addBtn && tmpl) {
        bindRow(container.querySelector('.modal-position-row'));
        calcTotal();

        addBtn.addEventListener('click', function () {
            var clone = tmpl.content.cloneNode(true);
            var row   = clone.querySelector('.modal-position-row');
            bindRow(row);
            container.appendChild(row);
            updateRemoveButtons();
            calcTotal();
            row.querySelector('input[type="text"]').focus();
        });
    }
})();

/* ── Auto-open modal from ?open= query param (BS5) ── */
(function () {
    var openParam = new URLSearchParams(window.location.search).get('open');
    if (openParam === 'invoice') {
        var el = document.getElementById('modal-create-invoice');
        if (el) bootstrap.Modal.getOrCreateInstance(el).show();
    } else if (openParam === 'edit') {
        var el2 = document.getElementById('modal-edit-patient');
        if (el2) bootstrap.Modal.getOrCreateInstance(el2).show();
    }
    if (openParam) { history.replaceState(null, '', window.location.pathname); }
})();

/* ── Hausaufgaben JavaScript ── */
(function() {
    let patientId = {{ patient.id }};
    let homeworkTemplates = [];
    
    // Hausaufgaben-Templates laden
    async function loadHomeworkTemplates() {
        try {
            const response = await fetch('/api/homework/templates');
            homeworkTemplates = await response.json();
            
            const select = document.getElementById('homework-template-select');
            select.innerHTML = '<option value="">— Vordefinierte Hausaufgabe —</option><option value="custom">— Eigene Hausaufgabe —</option>';
            
            homeworkTemplates.forEach(template => {
                const option = document.createElement('option');
                option.value = template.id;
                option.textContent = `${template.category_emoji} ${template.title}`;
                select.appendChild(option);
            });
        } catch (error) {
            console.error('Fehler beim Laden der Hausaufgaben-Templates:', error);
        }
    }
    
    // Hausaufgaben für Patienten laden
    async function loadPatientHomework() {
        try {
            const response = await fetch(`/api/patients/${patientId}/homework`);
            const homework = await response.json();
            
            const container = document.getElementById('homework-list');
            
            if (homework.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-4" style="color:var(--text-muted);">
                        <svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="margin:0 auto 1rem;opacity:0.4;"><path stroke="currentColor" stroke-width="1.5" d="M9 11l3 3L22 4"/><path stroke="currentColor" stroke-width="1.5" d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                        <div style="font-size:0.9rem;margin-bottom:0.5rem;">Noch keine Hausaufgaben zugewiesen</div>
                        <div style="font-size:0.8rem;opacity:0.7;">Klicke auf "Hausaufgabe hinzufügen" um zu beginnen</div>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = homework.map(hw => `
                <div class="homework-item" data-id="${hw.id}" style="border:1px solid var(--glass-border);border-radius:8px;padding:1rem;margin-bottom:0.75rem;background:var(--glass-bg);">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 style="margin:0;font-size:0.9rem;font-weight:600;">
                                ${hw.category_emoji} ${hw.title}
                            </h6>
                            <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.25rem;">
                                ${hw.frequency_display} • ${hw.duration_display}
                            </div>
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-outline-secondary" onclick="editHomework(${hw.id})" style="padding:0.25rem 0.5rem;font-size:0.75rem;">
                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteHomework(${hw.id})" style="padding:0.25rem 0.5rem;font-size:0.75rem;">
                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            </button>
                        </div>
                    </div>
                    <div style="font-size:0.85rem;line-height:1.4;color:var(--text-secondary);margin-bottom:0.5rem;">
                        ${hw.description}
                    </div>
                    <div style="font-size:0.8rem;color:var(--text-muted);">
                        <div>📅 ${hw.start_date} ${hw.end_date ? 'bis ' + hw.end_date : ''}</div>
                        ${hw.therapist_notes ? '<div>📝 ' + hw.therapist_notes + '</div>' : ''}
                    </div>
                    ${hw.status === 'completed' ? '<div class="badge bg-success" style="font-size:0.7rem;margin-top:0.5rem;">✓ Erledigt</div>' : ''}
                </div>
            `).join('');
            
        } catch (error) {
            console.error('Fehler beim Laden der Hausaufgaben:', error);
            document.getElementById('homework-list').innerHTML = `
                <div class="text-center py-4" style="color:var(--text-danger);">
                    <div style="font-size:0.9rem;">Fehler beim Laden der Hausaufgaben</div>
                </div>
            `;
        }
    }
    
    // Template-Auswahl-Handler
    document.getElementById('homework-template-select')?.addEventListener('change', function() {
        const customDiv = document.getElementById('custom-homework');
        if (this.value === 'custom') {
            customDiv.style.display = 'block';
        } else if (this.value) {
            // Template-Daten laden und Formular ausfüllen
            const template = homeworkTemplates.find(t => t.id == this.value);
            if (template) {
                customDiv.style.display = 'none';
                // Formular mit Template-Daten füllen (wird später implementiert)
            }
        } else {
            customDiv.style.display = 'none';
        }
    });
    
    // Hausaufgaben-Formular-Handler
    document.getElementById('homework-form')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        
        try {
            const response = await fetch(`/api/patients/${patientId}/homework`, {
                method: 'POST',
                body: formData
            });
            
            if (response.ok) {
                bootstrap.Modal.getInstance(document.getElementById('modal-add-homework')).hide();
                this.reset();
                loadPatientHomework();
                
                // Erfolgsmeldung anzeigen
                const alert = document.createElement('div');
                alert.className = 'alert alert-success alert-dismissible fade show';
                alert.innerHTML = `
                    Hausaufgabe erfolgreich zugewiesen!
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                document.querySelector('.glass-card').prepend(alert);
                
                setTimeout(() => alert.remove(), 5000);
            } else {
                throw new Error('Fehler beim Speichern');
            }
        } catch (error) {
            console.error('Fehler:', error);
            alert('Fehler beim Speichern der Hausaufgabe');
        }
    });
    
    // Hausaufgabe löschen
    window.deleteHomework = async function(id) {
        if (!confirm('Hausaufgabe wirklich löschen?')) return;
        
        try {
            const response = await fetch(`/api/patients/${patientId}/homework/${id}`, {
                method: 'DELETE',
                headers: {
                    'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.getAttribute('content')
                }
            });
            
            if (response.ok) {
                loadPatientHomework();
            } else {
                throw new Error('Fehler beim Löschen');
            }
        } catch (error) {
            console.error('Fehler:', error);
            alert('Fehler beim Löschen der Hausaufgabe');
        }
    };
    
    // Initialisierung
    if (document.getElementById('homework-list')) {
        loadHomeworkTemplates();
        loadPatientHomework();
        
        // Tab-Wechsel-Handler
        document.getElementById('hausaufgaben-tab')?.addEventListener('shown.bs.tab', function() {
            loadPatientHomework();
        });
    }
})();

/* ── Datei-Viewer ── */
(function () {
    var overlay = document.getElementById('fileviewer-overlay');
    var fvBody  = document.getElementById('fv-body');
    var fvName  = document.getElementById('fv-filename');
    var fvDl    = document.getElementById('fv-download');
    var fvClose = document.getElementById('fv-close');
    var imgExts = ['jpg','jpeg','png','gif','webp'];

    function ext(f) { return (f.split('.').pop() || '').toLowerCase(); }

    function openViewer(src, filename) {
        fvName.textContent = filename;
        fvDl.href = src; fvDl.download = filename;
        fvBody.innerHTML = '';
        var e = ext(filename);
        if (imgExts.includes(e)) {
            var img = document.createElement('img');
            img.src = src; img.alt = filename;
            img.style.cssText = 'max-width:100%;max-height:100%;object-fit:contain;border-radius:4px;';
            fvBody.appendChild(img);
        } else if (e === 'pdf') {
            var frame = document.createElement('iframe');
            frame.src = src + '#toolbar=1&view=FitH';
            frame.style.cssText = 'width:100%;height:100%;border:none;';
            frame.setAttribute('title', filename);
            fvBody.appendChild(frame);
        } else {
            fvBody.innerHTML = '<div style="text-align:center;color:rgba(255,255,255,0.7);padding:3rem;">' +
                '<svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="margin:0 auto 1rem;display:block;opacity:0.5;"><path stroke="currentColor" stroke-width="1.5" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>' +
                '<div style="font-size:1rem;font-weight:600;margin-bottom:0.5rem;">' + filename + '</div>' +
                '<div style="font-size:0.85rem;margin-bottom:1.5rem;opacity:0.6;">Dieser Dateityp kann nicht direkt angezeigt werden.</div>' +
                '<a href="' + src + '" download="' + filename + '" style="background:var(--accent,#4f7cff);color:#fff;padding:0.6rem 1.4rem;border-radius:8px;text-decoration:none;font-size:0.875rem;">Herunterladen</a>' +
                '</div>';
        }
        overlay.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeViewer() {
        overlay.style.display = 'none';
        fvBody.innerHTML = '';
        document.body.style.overflow = '';
    }

    document.querySelectorAll('[data-lightbox]').forEach(function (el) {
        el.addEventListener('click', function (e) {
            e.preventDefault();
            openViewer(el.dataset.lightbox, el.dataset.filename);
        });
    });

    fvClose.addEventListener('click', closeViewer);
    overlay.addEventListener('click', function (e) { if (e.target === overlay) closeViewer(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeViewer(); });
})();

/* ── Inline-Toast für show.twig (kein patient-modal) ── */
function _showTlToast(msg, type) {
    if (typeof _hwShowToast === 'function') { _hwShowToast(msg, type); return; }
    var t = document.createElement('div');
    var bg = type === 'success' ? '#198754' : '#dc3545';
    t.style.cssText = 'position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;background:'+bg+';color:#fff;padding:0.75rem 1.25rem;border-radius:8px;font-size:0.85rem;box-shadow:0 4px 20px rgba(0,0,0,0.3);transition:opacity .4s;';
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(function(){ t.style.opacity='0'; setTimeout(function(){ t.remove(); }, 400); }, 2800);
}

/* ── Timeline-Formular AJAX (show.twig) ── */
(function () {
    if (!document.getElementById('pd-spin-style')) {
        var s = document.createElement('style');
        s.id = 'pd-spin-style';
        s.textContent = '@keyframes spin{to{transform:rotate(360deg)}}';
        document.head.appendChild(s);
    }
    var form = document.getElementById('show-timeline-form');
    if (!form) return;
    form.addEventListener('submit', function (e) {
        e.preventDefault();
        var btn = form.querySelector('[type=submit]');
        var origHtml = btn ? btn.innerHTML : '';
        var spinSvg = '<svg width="13" height="13" fill="none" viewBox="0 0 24 24" style="vertical-align:text-bottom;animation:spin 0.8s linear infinite"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" opacity="0.25"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M12 2a10 10 0 0 1 10 10"/></svg>';
        if (btn) { btn.disabled = true; btn.innerHTML = spinSvg + ' Speichern…'; }

        fetch(form.action, { method: 'POST', body: new FormData(form) })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.ok) {
                    _showTlToast('✓ Eintrag gespeichert', 'success');
                    form.reset();
                    window.location.reload();
                } else {
                    _showTlToast('Fehler beim Speichern.', 'error');
                    if (btn) { btn.disabled = false; btn.innerHTML = origHtml; }
                }
            })
            .catch(function () {
                _showTlToast('Netzwerkfehler beim Speichern.', 'error');
                if (btn) { btn.disabled = false; btn.innerHTML = origHtml; }
            });
    });
})();
</script>
{% endblock %}
