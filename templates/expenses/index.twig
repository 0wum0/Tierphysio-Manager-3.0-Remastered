{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Ausgaben</h1>
    <a href="/ausgaben/neu" class="btn btn-primary">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" style="vertical-align:-2px;margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Neue Ausgabe
    </a>
</div>

{# ── KPI CARDS ────────────────────────────────────────────────────── #}
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100" style="border-left:3px solid #10b981;">
            <div class="card-body p-3">
                <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">
                    <svg width="11" height="11" fill="none" viewBox="0 0 24 24" style="vertical-align:-1px;margin-right:3px;"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 2v20M17 5H9.5a2.5 2.5 0 0 1 0-5H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3.5a2.5 2.5 0 0 1 0-5H17z"/></svg>
                    Gesamt
                </div>
                <div class="fw-bold" style="font-size:1.3rem;color:#10b981;">{{ stats.total_all|money }}</div>
                <div style="font-size:.72rem;color:var(--text-muted);margin-top:.2rem;">{{ stats.count }} Ausgabe{{ stats.count != 1 ? 'n' : '' }}</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100" style="border-left:3px solid #3b82f6;">
            <div class="card-body p-3">
                <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">
                    <svg width="11" height="11" fill="none" viewBox="0 0 24 24" style="vertical-align:-1px;margin-right:3px;"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/></svg>
                    Dieser Monat
                </div>
                <div class="fw-bold" style="font-size:1.3rem;color:#3b82f6;">{{ stats.total_month|money }}</div>
                <div style="font-size:.72rem;color:var(--text-muted);margin-top:.2rem;">{{ stats.count_month }} diesen Monat</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100" style="border-left:3px solid #8b5cf6;">
            <div class="card-body p-3">
                <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">
                    <svg width="11" height="11" fill="none" viewBox="0 0 24 24" style="vertical-align:-1px;margin-right:3px;"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                    Dieses Jahr
                </div>
                <div class="fw-bold" style="font-size:1.3rem;color:#8b5cf6;">{{ stats.total_year|money }}</div>
                <div style="font-size:.72rem;color:var(--text-muted);margin-top:.2rem;">Seit Jahresanfang</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100" style="border-left:3px solid #f59e0b;">
            <div class="card-body p-3">
                <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">
                    <svg width="11" height="11" fill="none" viewBox="0 0 24 24" style="vertical-align:-1px;margin-right:3px;"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 2v20M17 5H9.5a2.5 2.5 0 0 1 0-5H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3.5a2.5 2.5 0 0 1 0-5H17z"/></svg>
                    Rechnungen (Einnahmen)
                </div>
                <div class="fw-bold" style="font-size:1.3rem;color:#f59e0b;">{{ invoice_stats.revenue_total|money }}</div>
                <div style="font-size:.72rem;color:var(--text-muted);margin-top:.2rem;">Bezahlte Rechnungen</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100" style="border-left:3px solid #22c55e;">
            <div class="card-body p-3">
                <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">
                    <svg width="11" height="11" fill="none" viewBox="0 0 24 24" style="vertical-align:-1px;margin-right:3px;"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 2v20M17 5H9.5a2.5 2.5 0 0 1 0-5H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3.5a2.5 2.5 0 0 1 0-5H17z"/></svg>
                    Netto Umsatz
                </div>
                {% set netProfit = invoice_stats.revenue_total - stats.total_all %}
                <div class="fw-bold" style="font-size:1.3rem;color:{{ netProfit >= 0 ? '#22c55e' : '#ef4444' }};">{{ netProfit|money }}</div>
                <div style="font-size:.72rem;color:var(--text-muted);margin-top:.2rem;">Rechnungen - Ausgaben</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card h-100" style="border-left:3px solid #6b7280;">
            <div class="card-body p-3">
                <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">
                    <svg width="11" height="11" fill="none" viewBox="0 0 24 24" style="vertical-align:-1px;margin-right:3px;"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2zm0 0V9a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10m9-11v-6a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2zm0 0v10a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2z"/></svg>
                    Nach Kategorie
                </div>
                <div class="fw-bold" style="font-size:1.1rem;color:#6b7280;">{{ stats.categories|length }} Kategorien</div>
                <div style="font-size:.72rem;color:var(--text-muted);margin-top:.2rem;">Top: {{ stats.categories[0].category ?? '—' }}</div>
            </div>
        </div>
    </div>
</div>

{# ── FILTER & SEARCH ──────────────────────────────────────────────── #}
<div class="card mb-4">
    <div class="card-body">
        <form action="/ausgaben" method="GET" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small text-muted">Kategorie</label>
                <select name="category" class="form-select">
                    <option value="">Alle Kategorien</option>
                    {% for cat in categories %}
                    <option value="{{ cat }}" {{ category == cat ? 'selected' : '' }}>{{ cat }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small text-muted">Suche</label>
                <input type="text" name="search" class="form-control" placeholder="Beschreibung, Lieferant, Notizen..." value="{{ search }}">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secondary w-100">Filtern</button>
            </div>
            <div class="col-md-3">
                {% if category or search %}
                <a href="/ausgaben" class="btn btn-outline-secondary w-100">Zurücksetzen</a>
                {% endif %}
            </div>
        </form>
    </div>
</div>

{# ── EXPENSES TABLE ─────────────────────────────────────────────────── #}
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" style="font-size:0.9rem;">
                <thead class="table-light">
                    <tr>
                        <th>Datum</th>
                        <th>Beschreibung</th>
                        <th>Kategorie</th>
                        <th>Lieferant</th>
                        <th class="text-end">Bruttobetrag</th>
                        <th class="text-center">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for expense in expenses %}
                    <tr>
                        <td>{{ expense.date|date_de }}</td>
                        <td>
                            <div class="fw-semibold d-flex align-items-center gap-2">
                                <span>{{ expense.description }}</span>
                                {% if expense.receipt_file %}
                                <a href="/ausgaben/{{ expense.id }}/beleg" target="_blank"
                                   class="text-info text-decoration-none"
                                   title="Beleg ansehen: {{ expense.receipt_original_name ?? expense.receipt_file }}">
                                    <i class="bi bi-paperclip"></i>
                                </a>
                                {% endif %}
                            </div>
                            {% if expense.notes %}
                            <div class="text-muted small text-truncate" style="max-width:200px;">{{ expense.notes }}</div>
                            {% endif %}
                        </td>
                        <td><span class="badge bg-secondary">{{ expense.category }}</span></td>
                        <td>{{ expense.supplier ?? '—' }}</td>
                        <td class="text-end fw-semibold">{{ expense.amount_gross|money }}</td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a href="/ausgaben/{{ expense.id }}/bearbeiten" class="btn btn-secondary" title="Bearbeiten">
                                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5a2.121 2.121 0 0 1-3-3L18.5 2.5z"/></svg>
                                </a>
                                <a href="/ausgaben/{{ expense.id }}/pdf" class="btn btn-secondary" title="PDF">
                                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                                </a>
                                <form action="/ausgaben/{{ expense.id }}/loeschen" method="POST" style="margin:0;" onsubmit="return confirm('Ausgabe wirklich löschen?');">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                    <button type="submit" class="btn btn-danger" title="Löschen">
                                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Keine Ausgaben gefunden.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% if pagination.last_page > 1 %}
    <div class="card-footer">
        {% include 'partials/pagination.twig' with {'pagination': pagination} only %}
    </div>
    {% endif %}
</div>

{% endblock %}
