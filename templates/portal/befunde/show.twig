{% extends '@owner-portal/portal_layout.twig' %}
{% set active_nav = 'befunde' %}
{% block content %}

<div class="mb-3 d-flex justify-content-between align-items-center">
    <a href="/portal/befunde" class="small text-secondary text-decoration-none">← Meine Befundbögen</a>
    <a href="/portal/befunde/{{ befundbogen.id }}/pdf" target="_blank" class="portal-btn portal-btn-secondary portal-btn-sm">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>
        Als PDF herunterladen
    </a>
</div>
<h1 class="portal-page-title">{{ page_title }}</h1>

<div class="row g-4">
    {# ── Left: meta ── #}
    <div class="col-lg-3">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="fw-700 mb-3 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">Befundbogen</h6>
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Nummer</div>
                    <div class="fw-700" style="font-family:monospace;">BF-{{ '%04d'|format(befundbogen.id) }}</div>
                </div>
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Datum der Untersuchung</div>
                    <div class="fw-600">{{ befundbogen.datum|date('d.m.Y') }}</div>
                </div>
                {% if befundbogen.naechster_termin %}
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Nächster Termin</div>
                    <div class="fw-600 text-primary">{{ befundbogen.naechster_termin|date('d.m.Y') }}</div>
                </div>
                {% endif %}
                {% if befundbogen.ersteller_name %}
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Behandler</div>
                    <div>{{ befundbogen.ersteller_name }}</div>
                </div>
                {% endif %}
            </div>
        </div>

        {% if patient %}
        <div class="card">
            <div class="card-body">
                <h6 class="fw-700 mb-2 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">Patient</h6>
                <div class="fw-700">{{ patient.name }}</div>
                {% if patient.species %}<div class="text-xs text-muted">{{ patient.species }}{% if patient.breed %} · {{ patient.breed }}{% endif %}</div>{% endif %}
                {% if patient.birth_date %}<div class="text-xs text-muted mt-1">Geb.: {{ patient.birth_date|date('d.m.Y') }}</div>{% endif %}
            </div>
        </div>
        {% endif %}
    </div>

    {# ── Right: sections ── #}
    <div class="col-lg-9">

        {% macro portal_section(title, fields, felder) %}
            {% set hasAny = false %}
            {% for key, lbl in fields %}{% if felder[key] is defined and felder[key] is not empty %}{% set hasAny = true %}{% endif %}{% endfor %}
            {% if hasAny %}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">{{ title }}</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0" style="row-gap:.6rem;">
                        {% for key, lbl in fields %}
                            {% if felder[key] is defined and felder[key] is not empty %}
                            <dt class="col-sm-4 text-muted" style="font-size:.83rem;font-weight:600;">{{ lbl }}</dt>
                            <dd class="col-sm-8 mb-0" style="font-size:.9rem;">
                                {% if felder[key] is iterable %}{{ felder[key]|join(', ') }}{% else %}{{ felder[key] }}{% endif %}
                            </dd>
                            {% endif %}
                        {% endfor %}
                    </dl>
                </div>
            </div>
            {% endif %}
        {% endmacro %}

        {{ _self.portal_section('Anamnese & Vorgeschichte', {
            'hauptbeschwerde':    'Hauptbeschwerde',
            'seit_wann':          'Seit wann / Verlauf',
            'vorerkrankungen':    'Vorerkrankungen / OPs',
            'medikamente':        'Medikamente',
            'allergien':          'Allergien',
            'ernaehrung':         'Ernährung',
            'bewegung':           'Bewegung',
            'haltung':            'Haltung',
            'bisherige_therapien':'Bisherige Therapien'
        }, felder) }}

        {{ _self.portal_section('Allgemeinbefund', {
            'allgemeinbefinden':  'Allgemeinbefinden',
            'ernaehrungszustand': 'Ernährungszustand',
            'temperament':        'Temperament',
            'koerpertemperatur':  'Körpertemperatur (°C)',
            'koerperhaltung':     'Körperhaltung',
            'gangbild':           'Gangbild',
            'lahmheitsgrad':      'Lahmheitsgrad (0–5)'
        }, felder) }}

        {{ _self.portal_section('Bewegungsapparat & Muskulatur', {
            'betroffene_regionen':   'Betroffene Regionen',
            'muskeltonus':           'Muskeltonus',
            'triggerpunkte':         'Triggerpunkte / Verspannungen',
            'schmerz_nrs':           'Schmerzskala NRS (0–10)',
            'gelenke_befund':        'Gelenkbefund',
            'neurologischer_status': 'Neurologischer Status'
        }, felder) }}

        {{ _self.portal_section('Naturheilkundliche Behandlung', {
            'konstitutionstyp':       'Konstitutionstyp',
            'energetischer_eindruck': 'Energetischer Eindruck',
            'bachblueten_emotionen':  'Bach-Blüten Emotionen',
            'bachblueten_auswahl':    'Bach-Blüten Mischung',
            'bachblueten_dosierung':  'Dosierung',
            'homoeopathie_mittel':    'Homöopathisches Mittel',
            'homoeopathie_potenz':    'Potenz',
            'homoeopathie_dauer':     'Wiederholung / Dauer',
            'phytotherapie':          'Phytotherapie / Kräuter',
            'schuesslersalze':        'Schüssler Salze',
            'weitere_naturheilmittel':'Weitere Naturheilmittel'
        }, felder) }}

        {{ _self.portal_section('Physiotherapeutische Maßnahmen', {
            'pt_methoden':      'Angewandte Methoden',
            'therapieziele':    'Therapieziele',
            'hausaufgaben':     'Hausaufgaben / Heimübungen',
            'therapiefrequenz': 'Frequenz',
            'therapiedauer':    'Dauer',
            'kontrolltermin':   'Kontrolltermin'
        }, felder) }}

        {{ _self.portal_section('Verlauf & Notizen', {
            'verlauf_notizen': 'Verlaufsnotizen'
        }, felder) }}

        {% if befundbogen.notizen %}
        <div class="card mb-4">
            <div class="card-header"><h5 class="card-title mb-0">Allgemeine Notizen</h5></div>
            <div class="card-body" style="white-space:pre-wrap;font-size:.9rem;">{{ befundbogen.notizen }}</div>
        </div>
        {% endif %}

    </div>
</div>
{% endblock %}
