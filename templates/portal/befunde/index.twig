{% extends '@owner-portal/portal_layout.twig' %}
{% set active_nav = 'befunde' %}
{% block content %}
<h1 class="portal-page-title">{{ page_title }}</h1>

{% if befunde|length > 0 %}
<div class="row g-3">
    {% for b in befunde %}
    <div class="col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span style="font-family:monospace;font-size:.8rem;font-weight:700;color:var(--bs-secondary-color,#6c757d);">
                        BF-{{ '%04d'|format(b.id) }}
                    </span>
                    <span class="badge {% if b.status == 'versendet' %}bg-success{% else %}bg-primary{% endif %}">
                        {{ b.status == 'versendet' ? 'Versendet' : 'Abgeschlossen' }}
                    </span>
                </div>
                <h6 class="fw-700 mb-1">{{ b.patient_name }}</h6>
                {% if b.patient_species %}<div class="text-xs text-muted mb-2">{{ b.patient_species }}</div>{% endif %}
                <div class="text-sm text-muted mb-3">
                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24" class="me-1" style="vertical-align:-1px;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/></svg>
                    {{ b.datum|date('d.m.Y') }}
                </div>
                <div class="d-flex gap-2">
                    <a href="/portal/befunde/{{ b.id }}" class="btn btn-sm btn-outline-primary flex-fill">Ansehen</a>
                    <a href="/portal/befunde/{{ b.id }}/pdf" target="_blank" class="btn btn-sm btn-outline-secondary">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>
                        PDF
                    </a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="card">
    <div class="card-body text-center py-5">
        <svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="opacity:.15;margin-bottom:16px;"><path stroke="currentColor" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg>
        <h5 class="text-muted">Keine Befundbögen vorhanden</h5>
        <p class="text-muted">Ihr Tierphysiotherapeut hat noch keine Befundbögen für Sie freigegeben.</p>
    </div>
</div>
{% endif %}
{% endblock %}
