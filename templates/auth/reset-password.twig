<!DOCTYPE html>
<html lang="de" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Neues Passwort setzen</title>
    <link rel="stylesheet" href="/themes/smart-tierphysio/css/smartapp.min.css">
    <link rel="stylesheet" href="/themes/smart-tierphysio/webfonts/smartadmin/sa-icons.css">
    <script src="/themes/smart-tierphysio/scripts/core/saveloadscript.js"></script>
    <style>
        body { display:flex; align-items:center; justify-content:center; min-height:100vh; background:var(--bs-body-bg); }
        .login-wrap { width:100%; max-width:420px; padding:1rem; }
        .login-card { background:var(--bs-tertiary-bg); border:1px solid var(--bs-border-color); border-radius:16px; padding:2rem; box-shadow:0 8px 32px rgba(0,0,0,.18); }
        .btn-login { width:100%; padding:.7rem 1rem; font-size:.95rem; font-weight:600; border-radius:10px; border:none; background:var(--bs-primary); color:#fff; cursor:pointer; transition:background .2s; }
        .btn-login:hover { background:color-mix(in srgb,var(--bs-primary) 85%,white); }
        .login-footer { text-align:center; margin-top:1.5rem; font-size:.78rem; color:var(--bs-secondary-color); }
    </style>
</head>
<body>
<div class="login-wrap">
    <div class="text-center mb-4">
        <div style="font-size:1.8rem;font-weight:700;background:linear-gradient(90deg,#6EA8FE,#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Neues Passwort</div>
        <div style="font-size:.8rem;color:var(--bs-secondary-color);">Wähle ein sicheres Passwort mit mindestens 8 Zeichen.</div>
    </div>

    <div class="login-card">
        {% if flash.error is defined %}
        <div class="alert alert-danger mb-3" style="font-size:.85rem;">{{ flash.error }}</div>
        {% endif %}

        <form action="/reset-password/{{ token }}" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="form-floating mb-3">
                <input type="password" id="password" name="password" class="form-control"
                       placeholder="••••••••" minlength="8" required autofocus>
                <label for="password">Neues Passwort</label>
            </div>
            <div class="form-floating mb-4">
                <input type="password" id="password_confirm" name="password_confirm" class="form-control"
                       placeholder="••••••••" minlength="8" required>
                <label for="password_confirm">Passwort bestätigen</label>
            </div>
            <button type="submit" class="btn-login">Passwort speichern</button>
        </form>
    </div>

    <div class="login-footer">
        <a href="/login" style="color:var(--bs-primary);text-decoration:none;">← Zurück zum Login</a>
    </div>
</div>
<script src="/themes/smart-tierphysio/scripts/vendors/bootstrap.bundle.min.js"></script>
</body>
</html>
