<!DOCTYPE html>
<html lang="{{ current_locale }}" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>{{ page_title }} — {{ company_name ?: app_name }}</title>
    <link rel="stylesheet" href="/themes/smart-tierphysio/css/smartapp.min.css">
    <link rel="stylesheet" href="/themes/smart-tierphysio/webfonts/smartadmin/sa-icons.css">
    <style>
        body { display:flex; align-items:center; justify-content:center; min-height:100vh; background:var(--bs-body-bg); }
        .login-wrap { width:100%; max-width:420px; padding:1rem; }
        .login-brand { text-align:center; margin-bottom:2rem; }
        .login-brand-name {
            background:linear-gradient(90deg,#6EA8FE,#a78bfa);
            -webkit-background-clip:text; -webkit-text-fill-color:transparent;
            font-size:1.8rem; font-weight:700; letter-spacing:-0.02em; margin-bottom:.2rem;
        }
        .login-brand-sub { font-size:.8rem; color:var(--bs-secondary-color); }
        .login-card {
            background:var(--bs-tertiary-bg); border:1px solid var(--bs-border-color);
            border-radius:16px; padding:2rem; box-shadow:0 8px 32px rgba(0,0,0,.18);
        }
        .btn-login {
            width:100%; padding:.7rem 1rem; font-size:.95rem; font-weight:600;
            border-radius:10px; border:none; background:var(--bs-primary); color:#fff;
            cursor:pointer; transition:background .2s, box-shadow .2s, transform .1s;
            display:flex; align-items:center; justify-content:center; gap:.5rem;
        }
        .btn-login:hover {
            background:color-mix(in srgb, var(--bs-primary) 85%, white);
            box-shadow:0 0 18px 4px color-mix(in srgb, var(--bs-primary) 45%, transparent);
            transform:translateY(-1px);
        }
        .form-floating label { font-size:.85rem; }
        .login-footer { text-align:center; margin-top:1.5rem; font-size:.78rem; color:var(--bs-secondary-color); }
        @keyframes tp-paw-pulse {
            0%   { transform:scale(1);    filter:drop-shadow(0 0 0px #6EA8FE); }
            50%  { transform:scale(1.18); filter:drop-shadow(0 0 12px #a78bfa); }
            100% { transform:scale(1);    filter:drop-shadow(0 0 0px #6EA8FE); }
        }
    </style>
</head>
<body>

<div class="login-wrap">

    <div class="login-brand">
        <div class="mx-auto mb-2" style="animation:tp-paw-pulse 2s ease-in-out infinite;display:inline-flex;">
            <svg width="52" height="52" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <linearGradient id="lgPaw" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#6EA8FE"/>
                        <stop offset="100%" stop-color="#a78bfa"/>
                    </linearGradient>
                </defs>
                <ellipse fill="url(#lgPaw)" cx="9" cy="3.5" rx="2" ry="2.5"/>
                <ellipse fill="url(#lgPaw)" cx="15" cy="3.5" rx="2" ry="2.5"/>
                <ellipse fill="url(#lgPaw)" cx="4.5" cy="8" rx="2" ry="2.5"/>
                <ellipse fill="url(#lgPaw)" cx="19.5" cy="8" rx="2" ry="2.5"/>
                <path fill="url(#lgPaw)" d="M12 10c-3.5 0-6.5 2-6.5 5.5 0 2 1 3.5 2.5 4.5h8c1.5-1 2.5-2.5 2.5-4.5C18.5 12 15.5 10 12 10z"/>
            </svg>
        </div>
        <div class="login-brand-name">Passwort zurücksetzen</div>
        <div class="login-brand-sub">Wir senden dir einen Link zum Zurücksetzen deines Passworts.</div>
    </div>

    <div class="login-card">

        {% if flash.error is defined %}
        <div class="alert alert-danger py-2 mb-4" style="font-size:.85rem;">{{ flash.error }}</div>
        {% endif %}
        {% if flash.success is defined %}
        <div class="alert alert-success py-2 mb-4" style="font-size:.85rem;">{{ flash.success }}</div>
        {% endif %}

        <form action="/passwort-vergessen" method="POST" autocomplete="on">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

            <div class="form-floating mb-4">
                <input type="email" id="email" name="email" class="form-control"
                       placeholder="name@praxis.de" autocomplete="email" required autofocus>
                <label for="email">E-Mail-Adresse</label>
            </div>

            <button type="submit" class="btn-login">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24">
                    <path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                          d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zM22 6l-10 7L2 6"/>
                </svg>
                Reset-Link anfordern
            </button>

            <div class="text-center mt-3">
                <a href="/login"
                   style="font-size:.82rem;color:var(--bs-secondary-color);text-decoration:none;">
                    ← Zurück zum Login
                </a>
            </div>
        </form>

    </div>

    <div class="login-footer">
        &copy; {{ "now"|date("Y") }} {{ app_name }}
    </div>

</div>

<script src="/themes/smart-tierphysio/scripts/vendors/bootstrap.bundle.min.js"></script>
</body>
</html>
