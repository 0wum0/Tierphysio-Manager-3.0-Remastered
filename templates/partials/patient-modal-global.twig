function isMobile() { return /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent); }

window.openViewer = function(src, filename) {
    fvNameEl.textContent = filename;
    fvDl.href = src; fvDl.download = filename;
    if (fvOpenEl) fvOpenEl.href = src;
    fvBody2.innerHTML = '';
    var ext = (filename.split('.').pop()||'').toLowerCase();
    if (imgExts.includes(ext)) { var img=document.createElement('img'); img.src=src; img.alt=filename; img.style.cssText='max-width:100%;max-height:100%;object-fit:contain;border-radius:4px;'; fvBody2.appendChild(img); }
    else if (videoExts.includes(ext)) { var vid=document.createElement('video'); vid.src=src; vid.controls=true; vid.style.cssText='max-width:100%;max-height:100%;border-radius:6px;background:#000;'; fvBody2.style.background='#000'; fvBody2.appendChild(vid); }
    else if (ext==='pdf') {
        if (isMobile()) fvBody2.innerHTML='<div style="text-align:center;color:rgba(255,255,255,0.85);padding:2rem;"><a href="'+src+'" target="_blank" style="background:#4f7cff;color:#fff;padding:0.65rem 1.4rem;border-radius:8px;text-decoration:none;">Öffnen</a></div>';
        else { var fr=document.createElement('iframe'); fr.src=src; fr.style.cssText='width:100%;height:100%;border:none;'; fr.title=filename; fvBody2.appendChild(fr); }
    } else { fvBody2.innerHTML='<div style="text-align:center;color:rgba(255,255,255,0.7);padding:3rem;"><a href="'+src+'" download="'+esc(filename)+'" style="background:#4f7cff;color:#fff;padding:0.6rem 1.4rem;border-radius:8px;text-decoration:none;">Herunterladen</a></div>'; }
    fvOverlay.style.display='flex'; document.body.style.overflow='hidden';
};
