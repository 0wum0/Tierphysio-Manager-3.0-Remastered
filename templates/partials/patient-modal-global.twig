{# ═══════════════════════════════════════════════════════════
   GLOBAL PATIENT DETAIL MODAL
   Eingebunden in layout.twig — steht auf jeder Seite bereit.
   Geöffnet via: window._gsOpenPatient(id)
   ═══════════════════════════════════════════════════════════ #}

{# ── Patient Detail Modal ─────────────────────────────────── #}
<div class="modal fade" id="modal-patient-detail" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">

        <div id="pd-header" style="padding:0.6rem 1rem;border-bottom:1px solid var(--glass-border);flex-shrink:0;display:flex;align-items:center;gap:0.65rem;min-width:0;">
            <div id="pd-photo" style="width:38px;height:38px;border-radius:50%;overflow:hidden;flex-shrink:0;background:var(--bg-elevated);display:flex;align-items:center;justify-content:center;">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" style="opacity:0.3;"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </div>
            <div style="min-width:0;flex-shrink:1;flex-grow:0;">
                <div style="display:flex;align-items:center;gap:0.35rem;">
                    <span id="pd-name" style="font-size:0.95rem;font-weight:700;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:160px;"></span>
                    <span id="pd-badge" class="badge" style="display:none;flex-shrink:0;"></span>
                </div>
                <div id="pd-species" style="font-size:0.72rem;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:160px;"></div>
            </div>
            <div style="display:flex;gap:0.35rem;align-items:center;flex-shrink:0;margin-left:auto;">
                {# Desktop: Buttons direkt anzeigen #}
                <div class="pd-header-buttons-desktop" style="display:flex;gap:0.35rem;align-items:center;">
                    <button id="pd-new-apt-btn" type="button" class="btn btn-secondary btn-sm" style="flex-shrink:0;padding:0.3rem 0.6rem;" title="Neuen Termin erstellen">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="14" x2="12" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="10" y1="16" x2="14" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        <span class="d-none d-sm-inline">Termin</span>
                    </button>
                    <button id="pd-invoice-btn" type="button" class="btn btn-secondary btn-sm" style="flex-shrink:0;padding:0.3rem 0.6rem;">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                        <span class="d-none d-sm-inline">Rechnung</span>
                    </button>
                    <button id="pd-pdf-btn" type="button" class="btn btn-secondary btn-sm" onclick="exportPatientPDF()" style="flex-shrink:0;padding:0.3rem 0.6rem;">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        <span class="d-none d-sm-inline">Akte als PDF</span>
                    </button>
                    <a id="pd-vet-report-btn" href="#" target="_blank" class="btn btn-secondary btn-sm" style="flex-shrink:0;padding:0.3rem 0.6rem;" title="Tierarztbericht erstellen">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;">
                            <ellipse cx="6"   cy="5.5" rx="2"   ry="2.5"/>
                            <ellipse cx="12"  cy="4"   rx="2"   ry="2.5"/>
                            <ellipse cx="18"  cy="5.5" rx="2"   ry="2.5"/>
                            <ellipse cx="3.5" cy="11"  rx="1.7" ry="2.2"/>
                            <path d="M12 9c-3.5 0-7 2.5-7 5.5 0 2 1.2 3.5 3 4 .8.2 1.6.5 2.5.5h3c.9 0 1.7-.3 2.5-.5 1.8-.5 3-2 3-4C19 11.5 15.5 9 12 9z"/>
                        </svg>
                        <span class="d-none d-sm-inline">Tierarztbericht</span>
                    </a>
                    <button id="pd-plan-btn" type="button" class="btn btn-secondary btn-sm" style="flex-shrink:0;padding:0.3rem 0.6rem;" title="Therapieplan">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="2"/><line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="2"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="10 9 9 9 8 9"/></svg>
                        <span class="d-none d-sm-inline">Therapieplan</span>
                    </button>
                    <button id="pd-homework-btn" type="button" class="btn btn-secondary btn-sm" style="flex-shrink:0;padding:0.3rem 0.6rem;" title="Hausaufgabe hinzufügen">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/><line x1="12" y1="19" x2="12" y2="21" stroke="currentColor" stroke-width="2"/><line x1="8" y1="19" x2="16" y2="19" stroke="currentColor" stroke-width="2"/></svg>
                        <span class="d-none d-sm-inline">Hausaufgabe</span>
                    </button>
                    <button id="pd-progress-btn" type="button" class="btn btn-secondary btn-sm" style="flex-shrink:0;padding:0.3rem 0.6rem;" title="Fortschritt">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M18 20V10"/><path stroke="currentColor" stroke-width="2" d="M12 20V4"/><path stroke="currentColor" stroke-width="2" d="M6 20v-6"/></svg>
                        <span class="d-none d-sm-inline">Fortschritt</span>
                    </button>
                    <button id="pd-edit-btn" type="button" class="btn btn-primary btn-sm" style="flex-shrink:0;padding:0.3rem 0.6rem;">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        <span class="d-none d-sm-inline">Bearbeiten</span>
                    </button>
                    <button id="pd-delete-btn" type="button" class="btn btn-danger btn-sm" style="flex-shrink:0;padding:0.3rem 0.6rem;" onclick="deletePatient()">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 11v6M14 11v6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 6V4h6v2"/></svg>
                        <span class="d-none d-sm-inline">Löschen</span>
                    </button>
                </div>

                {# Mobile: Dropdown-Menü #}
                <div class="pd-header-buttons-mobile" style="display:none;position:relative;">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-toggle="dropdown" style="padding:0.3rem 0.6rem;">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" style="min-width:160px;">
                        <li><button id="pd-new-apt-btn-mobile" type="button" class="dropdown-item" style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;font-size:0.85rem;">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="14" x2="12" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="10" y1="16" x2="14" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            Termin
                        </button></li>
                        <li><button id="pd-invoice-btn-mobile" type="button" class="dropdown-item" style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;font-size:0.85rem;">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                            Rechnung
                        </button></li>
                        <li><button id="pd-pdf-btn-mobile" type="button" class="dropdown-item" onclick="exportPatientPDF()" style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;font-size:0.85rem;">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            Akte als PDF
                        </button></li>
                        <li><a id="pd-vet-report-btn-mobile" href="#" target="_blank" class="dropdown-item" style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;font-size:0.85rem;">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                                <ellipse cx="6"   cy="5.5" rx="2"   ry="2.5"/>
                                <ellipse cx="12"  cy="4"   rx="2"   ry="2.5"/>
                                <ellipse cx="18"  cy="5.5" rx="2"   ry="2.5"/>
                                <ellipse cx="3.5" cy="11"  rx="1.7" ry="2.2"/>
                                <path d="M12 9c-3.5 0-7 2.5-7 5.5 0 2 1.2 3.5 3 4 .8.2 1.6.5 2.5.5h3c.9 0 1.7-.3 2.5-.5 1.8-.5 3-2 3-4C19 11.5 15.5 9 12 9z"/>
                            </svg>
                            Tierarztbericht
                        </a></li>
                        <li><button id="pd-plan-btn-mobile" type="button" class="dropdown-item" style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;font-size:0.85rem;">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="2"/><line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="2"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="10 9 9 9 8 9"/></svg>
                            Therapieplan
                        </button></li>
                        <li><button id="pd-homework-btn-mobile" type="button" class="dropdown-item" style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;font-size:0.85rem;">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/><line x1="12" y1="19" x2="12" y2="21" stroke="currentColor" stroke-width="2"/><line x1="8" y1="19" x2="16" y2="19" stroke="currentColor" stroke-width="2"/></svg>
                            Hausaufgabe hinzufügen
                        </button></li>
                        <li><button id="pd-progress-btn-mobile" type="button" class="dropdown-item" style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;font-size:0.85rem;">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M18 20V10"/><path stroke="currentColor" stroke-width="2" d="M12 20V4"/><path stroke="currentColor" stroke-width="2" d="M6 20v-6"/></svg>
                            Fortschritt
                        </button></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><button id="pd-edit-btn-mobile" type="button" class="dropdown-item" style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;font-size:0.85rem;">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            Bearbeiten
                        </button></li>
                        <li><button id="pd-delete-btn-mobile" type="button" class="dropdown-item text-danger" onclick="deletePatient()" style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;font-size:0.85rem;">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 11v6M14 11v6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 6V4h6v2"/></svg>
                            Löschen
                        </button></li>
                    </ul>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen" style="flex-shrink:0;"></button>
        </div>

        <div id="pd-loading" style="display:flex;align-items:center;justify-content:center;padding:3rem;flex:1;">
            <div style="width:32px;height:32px;border:3px solid var(--glass-border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;"></div>
        </div>

        <div id="pd-body" style="display:none;overflow-y:auto;flex:1;padding:1.5rem 1.25rem;flex-direction:column;gap:1.5rem;">

            <div class="pd-info-card" style="flex-shrink:0;">
                <div id="pd-photo-full" class="pd-info-photo">
                    <svg width="36" height="36" fill="none" viewBox="0 0 24 24" style="opacity:0.2;"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </div>
                <div class="pd-info-divider"></div>
                <div class="pd-info-col">
                    <div class="pd-info-col-label">Patient</div>
                    <div id="pd-details" class="pd-info-grid"></div>
                </div>
                <div class="pd-info-divider"></div>
                <div class="pd-info-col">
                    <div class="pd-info-col-label">Besitzer</div>
                    <div id="pd-owner"></div>
                </div>
            </div>

            <div class="pd-entry-section">
                <div class="pd-section-label">Neuer Akte-Eintrag</div>
                <form id="pd-timeline-form" method="POST" enctype="multipart/form-data" class="pd-entry-form">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <div class="pd-form-grid4">
                        <div class="pd-field">
                            <label class="pd-label">Typ</label>
                            <select name="type" class="pd-select" data-no-cs>
                                <option value="note">📝 Notiz</option>
                                <option value="treatment">💊 Behandlung</option>
                                <option value="photo">📷 Foto</option>
                                <option value="document">📄 Dokument</option>
                                <option value="other">📌 Sonstiges</option>
                            </select>
                        </div>
                        <div class="pd-field">
                            <label class="pd-label">Behandlungsart</label>
                            <select name="treatment_type_id" id="pd-treatment-type" class="pd-select" data-no-cs>
                                <option value="">— keine —</option>
                            </select>
                        </div>
                        <div class="pd-field">
                            <label class="pd-label">Datum</label>
                            <input type="datetime-local" name="entry_date" class="pd-input" value="{{ 'now'|date('Y-m-d\\TH:i') }}">
                        </div>
                        <div class="pd-field">
                            <label class="pd-label">Status</label>
                            <select name="status_badge" class="pd-select" data-no-cs>
                                <option value="">— kein —</option>
                                <option value="Schmerzfrei">Schmerzfrei</option>
                                <option value="In Behandlung">In Behandlung</option>
                                <option value="Kontrolltermin">Kontrolltermin</option>
                                <option value="Notfall">Notfall</option>
                                <option value="Gebessert">Gebessert</option>
                                <option value="Entlassen">Entlassen</option>
                            </select>
                        </div>
                    </div>
                    <div class="pd-field">
                        <label class="pd-label">Titel</label>
                        <input type="text" name="title" class="pd-input" placeholder="Kurzer Titel...">
                    </div>
                    <div class="pd-field">
                        <label class="pd-label">Inhalt</label>
                        <div id="pd-quill-editor"></div>
                        <input type="hidden" name="content" id="pd-content-input">
                    </div>
                    <div class="pd-form-footer">
                        <div class="pd-field" style="flex:1;min-width:0;">
                            <label class="pd-label">Anhang</label>
                            <input type="file" name="attachment" id="pd-attachment" class="pd-file" accept="image/*,video/*,application/pdf,.doc,.docx">
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm pd-submit-btn">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            Speichern
                        </button>
                    </div>
                </form>
            </div>

            <div id="pd-appointments-section" style="display:none;">
                <div style="border-top:1px solid var(--glass-border);padding-top:1rem;"></div>
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.6rem;">
                    <div style="font-size:0.7rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;">Termine</div>
                    <a href="/kalender" style="font-size:0.72rem;color:var(--accent,#4f7cff);text-decoration:none;">Alle im Kalender →</a>
                </div>
                <div id="pd-appointments-list" style="display:flex;flex-direction:column;gap:0.4rem;"></div>
            </div>

            {# ── TherapyCare Pro: Fortschritt ── #}
            <div id="pd-tcp-progress-section" style="display:none;">
                <div style="border-top:1px solid var(--glass-border);padding-top:1rem;"></div>
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.6rem;">
                    <div style="font-size:0.7rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;">Therapiefortschritt</div>
                    <a id="pd-tcp-progress-link" href="#" style="font-size:0.72rem;color:var(--accent,#4f7cff);text-decoration:none;">Vollansicht →</a>
                </div>
                <div id="pd-tcp-progress-list" style="display:flex;flex-direction:column;gap:0.35rem;"></div>
            </div>

            {# ── TherapyCare Pro: Naturheilkunde ── #}
            <div id="pd-tcp-natural-section" style="display:none;">
                <div style="border-top:1px solid var(--glass-border);padding-top:1rem;margin-top:0.25rem;"></div>
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.6rem;">
                    <div style="font-size:0.7rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;">Naturheilkunde</div>
