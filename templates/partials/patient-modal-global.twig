function _loadPlans(patientId) {
    var container = document.getElementById('hw-plans-list');
    if (!container) return;
    fetch('/api/patients/' + patientId + '/plans', { headers: { 'Accept': 'application/json' } })
        .then(function(r) { return r.json().then(function(d){ return {ok:r.ok,d:d}; }); })
        .then(function(res) {
            container = document.getElementById('hw-plans-list');
            if (!container) return;
            if (!res.ok || !Array.isArray(res.d)) {
                var msg = (res.d && res.d.error) ? res.d.error : JSON.stringify(res.d);
                if (container) container.innerHTML = '<div class="alert alert-danger">API-Fehler: ' + _hwEsc(msg) + '</div>';
                return;
            }
            var plans = res.d;
            if (!plans.length) {
                container.innerHTML =
                    '<div class="text-center py-5" style="color:var(--bs-secondary-color);">' +
                    '<svg width="48" height="48" fill="none" viewBox="0 0 24 24" style="opacity:0.35;display:block;margin:0 auto 1rem;">' +
                    '<path stroke="currentColor" stroke-width="1.5" d="M9 11l3 3L22 4"/>' +
                    '<path stroke="currentColor" stroke-width="1.5" d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>' +
                    '<div style="font-size:0.9rem;font-weight:600;margin-bottom:0.4rem;">Noch keine Hausaufgabenpl&auml;ne vorhanden</div>' +
                    '<div style="font-size:0.8rem;opacity:0.7;">Klicke auf &bdquo;Neuer Hausaufgabenplan&ldquo; um zu beginnen</div></div>';
                return;
            }
            container.innerHTML = plans.map(function(plan) {
                var taskRows = (plan.tasks || []).map(function(t) {
                    return '<tr>' +
                        '<td style="padding:0.3rem 0.5rem;font-size:0.8rem;">' + _hwEsc(t.title) + '</td>' +
                        '<td style="padding:0.3rem 0.5rem;font-size:0.8rem;color:var(--bs-secondary-color);">' + _hwEsc(t.frequency||'') + '</td>' +
                        '<td style="padding:0.3rem 0.5rem;font-size:0.8rem;color:var(--bs-secondary-color);">' + _hwEsc(t.duration||'') + '</td>' +
                        '<td style="padding:0.3rem 0.5rem;font-size:0.8rem;color:var(--bs-secondary-color);">' + _hwEsc(t.description||'') + '</td></tr>';
                }).join('');
                var badge = plan.status === 'active'
                    ? '<span class="badge bg-success ms-2" style="font-size:0.7rem;">Aktiv</span>'
                    : '<span class="badge bg-secondary ms-2" style="font-size:0.7rem;">Archiviert</span>';
                return '<div class="card mb-3">' +
                    '<div class="card-header d-flex align-items-center justify-content-between py-2 px-3"><div>' +
                    '<span class="fw-600">&#x1F4C5; Hausaufgabenplan vom ' + _hwFmtDate(plan.plan_date) + '</span>' + badge +
                    (plan.therapist_name ? '<span class="text-muted ms-2" style="font-size:0.8rem;">&middot; ' + _hwEsc(plan.therapist_name) + '</span>' : '') +
                    (plan.next_appointment ? '<span class="text-muted ms-2" style="font-size:0.8rem;">&middot; Wiedervorstellung: ' + _hwEsc(plan.next_appointment) + '</span>' : '') +
                    '</div><div class="d-flex gap-1">' +
                    '<a href="/portal-admin/hausaufgaben/' + plan.id + '/pdf" target="_blank" class="btn btn-xs btn-outline-secondary" style="font-size:0.75rem;padding:0.2rem 0.5rem;">' +
                    '<svg width="11" height="11" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg> PDF</a>' +
                    '<button class="btn btn-xs btn-outline-danger" style="font-size:0.75rem;padding:0.2rem 0.5rem;" onclick="_deletePlan(' + plan.id + ')">' +
                    '<svg width="11" height="11" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg></button>' +
                    '</div></div>' +
                    (taskRows ?
                        '<div class="card-body p-0"><table class="table table-sm mb-0"><thead><tr>' +
                        '<th style="padding:0.3rem 0.5rem;font-size:0.75rem;">Aufgabe</th>' +
                        '<th style="padding:0.3rem 0.5rem;font-size:0.75rem;">H&auml;ufigkeit</th>' +
                        '<th style="padding:0.3rem 0.5rem;font-size:0.75rem;">Dauer</th>' +
                        '<th style="padding:0.3rem 0.5rem;font-size:0.75rem;">Beschreibung</th>' +
                        '</tr></thead><tbody>' + taskRows + '</tbody></table></div>' : '') +
                    (plan.general_notes ? '<div class="card-footer py-2 px-3" style="font-size:0.8rem;color:var(--bs-secondary-color);">&#x1F4DD; ' + _hwEsc(plan.general_notes) + '</div>' : '') +
                    '</div>';
            }).join('');
        })
        .catch(function(err) {
            var c = document.getElementById('hw-plans-list');
            if (c) c.innerHTML = '<div class="alert alert-danger">Fehler beim Laden: ' + _hwEsc(String(err.message||err)) + '</div>';
        });
}

window._deletePlan = function(planId) {
    if (!confirm('Hausaufgabenplan wirklich l\u00f6schen?')) return;
    if (!currentPatientData) return;
    var patientId = currentPatientData.patient.id;
    fetch('/api/patients/' + patientId + '/plans/' + planId, {
        method: 'DELETE',
        headers: { 'X-CSRF-Token': '{{ csrf_token }}', 'Accept': 'application/json' }
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (d.success) { _loadPlans(patientId); }
        else { alert(d.error || 'Fehler beim L\u00f6schen'); }
    })
    .catch(function() { alert('Fehler beim L\u00f6schen'); });
};

