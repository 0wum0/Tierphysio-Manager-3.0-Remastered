                ttSel.innerHTML = '<option value="">— keine —</option>';
                data.treatment_types.forEach(function(tt){
                    var opt=document.createElement('option'); opt.value=tt.id; opt.textContent=tt.name; opt.dataset.color=tt.color; ttSel.appendChild(opt);
                });
            }
            /* ── Rechnungs-Badge im Modal-Header (neben Name) ── */
            var existingBadge = document.getElementById('pd-invoice-badge');
            if (existingBadge) existingBadge.remove();
            if (data.invoice_stats && (data.invoice_stats.open_count > 0 || data.invoice_stats.paid_count > 0)) {
                var ib = document.createElement('a');
                ib.id = 'pd-invoice-badge';
                ib.style.cssText = 'flex-shrink:0;padding:0.2rem 0.5rem;border-radius:5px;font-size:0.68rem;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:0.25rem;white-space:nowrap;';
                if (data.invoice_stats.open_count > 0) {
                    ib.href = '/rechnungen?search=' + encodeURIComponent(p.name || '');
                    ib.style.background = 'rgba(220,53,69,0.18)';
                    ib.style.color = '#ff6b6b';
                    ib.style.border = '1.5px solid #dc3545';
                    ib.classList.add('invoice-badge-pulse');
                    ib.textContent = data.invoice_stats.open_count + ' Rechnung' + (data.invoice_stats.open_count !== 1 ? 'en' : '') + ' offen';
                } else {
                    ib.href = '/rechnungen?search=' + encodeURIComponent(p.name || '');
                    ib.style.background = 'rgba(25,135,84,0.15)';
                    ib.style.color = '#2dbe6c';
                    ib.style.border = '1.5px solid #198754';
                    ib.textContent = '✓ Bezahlt';
                }
                /* Insert after the status badge, inside the name row */
                var nameRow = document.querySelector('#pd-header #pd-badge');
                if (nameRow && nameRow.parentNode) {
                    nameRow.parentNode.insertBefore(ib, nameRow.nextSibling);
                }
            }

            /* ── Tierarztbericht-Button href setzen ── */
            var vetReportBtn = document.getElementById('pd-vet-report-btn');
            if (vetReportBtn) { vetReportBtn.href = '/patienten/' + patientId + '/tierarztbericht'; }

            currentPatientData = data;
            renderTimeline(data.timeline, patientId);
            renderAppointments(data.appointments || [], data.patient);
            loadVetReportHistory(patientId);
            loadTcpData(patientId);
            pdLoading.style.display = 'none';
            pdBody.style.display    = 'flex';
        })
        .catch(function() {
            pdLoading.innerHTML = '<div style="color:var(--text-muted);font-size:0.85rem;">Fehler beim Laden.</div>';
        });
}

/* ── Appointments section ─────────────────────────────────── */
var aptStatusLabels = {
    scheduled:  { label: 'Geplant',       color: '#6c757d' },
    confirmed:  { label: 'Bestätigt',     color: '#0d6efd' },
    completed:  { label: 'Abgeschlossen', color: '#198754' },
    cancelled:  { label: 'Abgesagt',      color: '#dc3545' },
    noshow:     { label: 'Nicht ersch.',  color: '#fd7e14' },
};

function renderAppointments(appointments, patient) {
    var sec  = document.getElementById('pd-appointments-section');
    var list = document.getElementById('pd-appointments-list');
    if (!sec || !list) return;

    if (!appointments || appointments.length === 0) {
        sec.style.display = 'none';
        return;
    }

    sec.style.display = '';
    var html = '';
    appointments.forEach(function(a) {
        var statusInfo = aptStatusLabels[a.status] || { label: a.status, color: '#6c757d' };
        var dotColor   = a.color || statusInfo.color;
        var dateStr    = a.all_day ? fmtDate(a.start_at) : fmtDateTime(a.start_at);
        var isPast     = new Date(a.start_at.replace(' ','T')) < new Date();
        html += '<div style="display:flex;align-items:center;gap:0.55rem;padding:0.45rem 0.6rem;border-radius:7px;background:var(--bg-elevated,rgba(255,255,255,0.04));border:1px solid var(--glass-border);">';
        html += '<div style="width:8px;height:8px;border-radius:50%;flex-shrink:0;background:'+esc(dotColor)+';'+(isPast?'opacity:0.45;':'')+'"></div>';
        html += '<div style="flex:1;min-width:0;">';
        html += '<div style="font-size:0.8rem;font-weight:600;color:var(--text-primary);'+(isPast?'opacity:0.6;':'')+'white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">'+esc(a.title)+'</div>';
        html += '<div style="font-size:0.7rem;color:var(--text-muted);">'+esc(dateStr);
        if (a.treatment_type_name) html += ' · '+esc(a.treatment_type_name);
        html += '</div></div>';
        html += '<span style="font-size:0.62rem;font-weight:700;padding:0.1rem 0.45rem;border-radius:999px;flex-shrink:0;background:'+esc(statusInfo.color)+'22;color:'+esc(statusInfo.color)+';border:1px solid '+esc(statusInfo.color)+'44;">'+esc(statusInfo.label)+'</span>';
        html += '</div>';
    });
    list.innerHTML = html;
}

/* ── Tierarztbericht-Verlauf laden & anzeigen ──────────────── */
function loadVetReportHistory(patientId) {
    var sec  = document.getElementById('pd-vetreport-section');
    var list = document.getElementById('pd-vetreport-list');
    if (!sec || !list) return;

    sec.style.display = 'none';
    list.innerHTML    = '';

    fetch('/patienten/' + patientId + '/tierarztbericht/verlauf')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var reports = data.reports || [];
            if (reports.length === 0) return;

            sec.style.display = '';
            var html = '';
            reports.forEach(function(r) {
                var date = r.created_at ? r.created_at.substring(0, 10).split('-').reverse().join('.') : '—';
                var time = r.created_at ? r.created_at.substring(11, 16) : '';
                var by   = r.created_by_name ? ' · ' + esc(r.created_by_name) : '';
                html += '<div style="display:flex;align-items:center;gap:0.5rem;padding:0.4rem 0.6rem;border-radius:7px;background:var(--bg-elevated,rgba(255,255,255,0.04));border:1px solid var(--glass-border);">';
                html += '<svg width="13" height="13" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;opacity:0.5;"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>';
                html += '<div style="flex:1;min-width:0;">';
                html += '<div style="font-size:0.78rem;font-weight:600;color:var(--text-primary);">Tierarztbericht ' + esc(date) + ' ' + esc(time) + '</div>';
                html += '<div style="font-size:0.68rem;color:var(--text-muted);">Erstellt' + by + '</div>';
                html += '</div>';
                html += '<a href="/patienten/' + patientId + '/tierarztbericht/' + r.id + '/download" target="_blank" title="Öffnen" style="flex-shrink:0;color:var(--accent,#4f7cff);font-size:0.72rem;text-decoration:none;padding:0.2rem 0.45rem;border:1px solid var(--glass-border);border-radius:5px;">Öffnen</a>';
                html += '<button onclick="deleteVetReport(' + patientId + ',' + r.id + ',this)" title="Löschen" style="flex-shrink:0;background:none;border:none;cursor:pointer;color:var(--text-muted);padding:0.2rem 0.3rem;opacity:0.6;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.6">';
                html += '<svg width="12" height="12" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" d="M19 6l-1 14H6L5 6"/><path stroke="currentColor" stroke-width="2" d="M10 11v6M14 11v6"/></svg>';
                html += '</button>';
                html += '</div>';
            });
            list.innerHTML = html;
        })
        .catch(function() { /* Tabelle noch nicht migriert – ignorieren */ });
}

function deleteVetReport(patientId, reportId, btn) {
    if (!confirm('Diesen Bericht wirklich löschen?')) return;
    if (btn) btn.disabled = true;
    fetch('/patienten/' + patientId + '/tierarztbericht/' + reportId, { method: 'DELETE' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.ok) {
                loadVetReportHistory(patientId);
            } else {
                alert('Löschen fehlgeschlagen: ' + (data.error || 'Unbekannter Fehler'));
                if (btn) btn.disabled = false;
            }
        })
        .catch(function() {
            alert('Netzwerkfehler beim Löschen.');
            if (btn) btn.disabled = false;
        });
}

