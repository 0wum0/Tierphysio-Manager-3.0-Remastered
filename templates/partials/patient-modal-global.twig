/* ── Invoice Modal Logic ──────────────────────────────────── */
var invoiceModalEl   = null;
var invoiceFormData  = null;

function openInvoiceModal(patientId, ownerId) {
    invoiceModalEl = document.getElementById('modal-invoice-create');
    if (!invoiceModalEl) return;

    var loadingEl = document.getElementById('im-loading');
    var bodyEl    = document.getElementById('im-body');
    loadingEl.style.display = 'flex';
    bodyEl.style.display    = 'none';

    /* Hide patient modal, show invoice modal */
    bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-patient-detail')).hide();
    bootstrap.Modal.getOrCreateInstance(invoiceModalEl).show();

    fetch('/api/invoice-form-data', {headers:{'X-Requested-With':'XMLHttpRequest'}})
        .then(function(r){return r.json();})
        .then(function(d) {
            invoiceFormData = d;
            buildInvoiceForm(d, patientId, ownerId);
            loadingEl.style.display = 'none';
            bodyEl.style.display    = 'block';
        })
        .catch(function(){ loadingEl.innerHTML = '<span style="color:red">Fehler beim Laden.</span>'; });
}

function buildInvoiceForm(d, prePatientId, preOwnerId) {
    var form = document.getElementById('im-form');
    /* Reset */
    form.reset();

    /* Next invoice number */
    form.querySelector('[name="invoice_number"]').value = d.next_number || '';
    /* Dates */
    form.querySelector('[name="issue_date"]').value = d.issue_date || '';
    form.querySelector('[name="due_date"]').value   = d.due_date   || '';

    /* Kleinunternehmer */
    var ku = !!d.kleinunternehmer;
    form.querySelectorAll('.im-tax-col').forEach(function(el){ el.style.display = ku ? 'none' : ''; });
    form.querySelectorAll('[name="position_tax_rate[]"]').forEach(function(el){ if(ku) el.value='0'; });
    var kuNote = document.getElementById('im-ku-note');
    if (kuNote) kuNote.style.display = ku ? '' : 'none';
    /* Store for new rows */
    form.dataset.defaultTax = ku ? '0' : (d.default_tax_rate || '19');
    form.dataset.kleinunternehmer = ku ? '1' : '0';

    /* Owner select — plain, always pre-selected from patient file */
    var ownerSel = form.querySelector('[name="owner_id"]');
    ownerSel.innerHTML = '<option value="">— Tierhalter wählen —</option>';
    d.owners.forEach(function(o) {
        var opt = new Option(o.last_name + ', ' + o.first_name, o.id);
        ownerSel.appendChild(opt);
    });
    if (preOwnerId) ownerSel.value = preOwnerId;

    /* Patient select — plain, filtered by owner */
    var patientSel = form.querySelector('[name="patient_id"]');
    rebuildPatientSelect(patientSel, d.patients, preOwnerId, prePatientId);

    /* Filter patients when owner changes */
    ownerSel.onchange = function() {
        rebuildPatientSelect(patientSel, d.patients, this.value, null);
    };

    /* Positions: reset to 1 row */
    var container = document.getElementById('im-positions-container');
    container.innerHTML = '';
    addImPosition(form);

    imRecalc();
    initImPaymentToggle(form);

    /* Add-position button */
    var addBtn = document.getElementById('im-add-position');
    if (addBtn) {
        addBtn.onclick = function() { addImPosition(form); };
    }
}

function rebuildPatientSelect(sel, patients, ownerId, prePatientId) {
    sel.innerHTML = '<option value="">— Kein Patient —</option>';
    var filtered = ownerId
        ? patients.filter(function(p){ return String(p.owner_id) === String(ownerId); })
        : patients;
    if (!filtered.length && ownerId) filtered = patients;
    filtered.forEach(function(p) {
        var opt = new Option(p.name + ' (' + (p.species||'') + ')', p.id);
        sel.appendChild(opt);
    });
    if (prePatientId) sel.value = prePatientId;
    else if (filtered.length === 1) sel.value = filtered[0].id;
}

function addImPosition(form) {
    var d    = invoiceFormData;
    var ku   = form.dataset.kleinunternehmer === '1';
    var defTax = form.dataset.defaultTax || '19';

    var row = document.createElement('div');
    row.className = 'im-position-row';

    /* Treatment type options */
    var ttOpts = '<option value="" selected>— keine —</option>';
    (d.treatment_types||[]).forEach(function(tt){
        ttOpts += '<option value="'+tt.id+'" data-price="'+(tt.price||'')+'" data-color="'+(tt.color||'')+'">'+esc(tt.name)+'</option>';
    });

    row.innerHTML =
        '<input type="text"   name="position_description[]"     class="form-control im-field-desc" placeholder="Beschreibung" required>'+
        '<select             name="position_treatment_type[]"   class="form-control im-tt-sel im-field-tt" style="font-size:0.83rem;">'+ttOpts+'</select>'+
        '<input type="number" name="position_quantity[]"        class="form-control im-qty im-field-qty"   value="1"    min="0.01" step="0.01" style="text-align:right;">'+
        '<input type="number" name="position_price[]"          class="form-control im-price im-field-price" value="0.00" min="0"    step="0.01" style="text-align:right;">'+
        (ku ? '' : '<input type="number" name="position_tax_rate[]" class="form-control im-tax im-tax-col im-field-tax" value="'+defTax+'" min="0" step="0.01" style="text-align:right;">')+
        '<button type="button" class="btn btn-danger btn-icon btn-sm im-remove" title="Entfernen">'+
            '<svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>'+
        '</button>';

    row.querySelector('.im-remove').addEventListener('click', function(){ row.remove(); imRecalc(); });
    row.querySelector('.im-qty')?.addEventListener('input', imRecalc);
    row.querySelector('.im-price')?.addEventListener('input', imRecalc);
    row.querySelector('.im-tax')?.addEventListener('input', imRecalc);
    var ttSel = row.querySelector('.im-tt-sel');
    if (ttSel) ttSel.addEventListener('change', function(){
        var opt = this.options[this.selectedIndex];
        if (!opt || !opt.value) return;
        var descInput  = row.querySelector('[name="position_description[]"]');
        var priceInput = row.querySelector('.im-price');
        if (descInput && !descInput.value) descInput.value = opt.textContent.trim();
        if (priceInput && opt.dataset.price && parseFloat(opt.dataset.price) > 0) {
            priceInput.value = parseFloat(opt.dataset.price).toFixed(2);
            imRecalc();
        }
    });

    document.getElementById('im-positions-container').appendChild(row);
}

function imRecalc() {
    var net = 0, tax = 0;
    document.querySelectorAll('.im-position-row').forEach(function(row){
        var qty   = parseFloat(row.querySelector('.im-qty')?.value  || 0);
        var price = parseFloat(row.querySelector('.im-price')?.value || 0);
        var taxR  = parseFloat(row.querySelector('.im-tax')?.value  || 0);
        var lineNet = qty * price;
        net += lineNet;
        tax += lineNet * (taxR / 100);
    });
    var fmt = function(v){ return v.toFixed(2).replace('.', ',') + ' €'; };
    var netEl   = document.getElementById('im-total-net');
    var taxEl   = document.getElementById('im-total-tax');
    var grossEl = document.getElementById('im-total-gross');
    if (netEl)   netEl.textContent   = fmt(net);
    if (taxEl)   taxEl.textContent   = fmt(tax);
    if (grossEl) grossEl.textContent = fmt(net + tax);
}

function initImPaymentToggle(form) {
    var lblR  = document.getElementById('im-lbl-rechnung');
    var lblB  = document.getElementById('im-lbl-bar');
    var fStat = document.getElementById('im-field-status');
    var fDue  = document.getElementById('im-field-due');
    var btn   = form.querySelector('[type="submit"]');

    function update() {
        var isCash = form.querySelector('[name="payment_method"]:checked')?.value === 'bar';
        lblR.style.border     = isCash ? '2px solid var(--glass-border)' : '2px solid var(--accent)';
        lblR.style.background = isCash ? '' : 'rgba(99,102,241,0.08)';
        lblB.style.border     = isCash ? '2px solid var(--accent)' : '2px solid var(--glass-border)';
        lblB.style.background = isCash ? 'rgba(99,102,241,0.08)' : '';
        fStat.style.display   = isCash ? 'none' : '';
        fDue.style.display    = isCash ? 'none' : '';
        if (btn) btn.innerHTML = isCash
            ? '<svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg> Quittung erstellen'
            : '<svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 3 7 8 15 8"/></svg> Speichern';
    }
    var splitArrow = document.getElementById('im-split-arrow');
    function updateSendBtn() {
        var isCash = form.querySelector('[name="payment_method"]:checked')?.value === 'bar';
        if (splitArrow) splitArrow.style.display = isCash ? 'none' : '';
    }
    form.querySelectorAll('[name="payment_method"]').forEach(function(r){
        r.onchange = function() { update(); updateSendBtn(); };
    });
    update();
    updateSendBtn();
}

/* ── Custom fixed split-dropdown for invoice modal ─────────── */
(function(){
    var arrowBtn  = document.getElementById('im-split-arrow');
    var splitMenu = document.getElementById('im-split-menu');
    var sendBtn   = document.getElementById('im-save-send-btn');
    var saveBtn   = document.getElementById('im-save-btn');
    var flag      = document.getElementById('im-send-email-flag');

    if (arrowBtn && splitMenu) {
        arrowBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            var rect = arrowBtn.getBoundingClientRect();
            var menuW = 230;
            splitMenu.style.top  = (rect.bottom + 4) + 'px';
            splitMenu.style.left = Math.max(4, rect.right - menuW) + 'px';
            splitMenu.style.display = splitMenu.style.display === 'none' ? 'block' : 'none';
        });
        document.addEventListener('click', function() {
            if (splitMenu) splitMenu.style.display = 'none';
        });
        splitMenu.addEventListener('click', function(e) { e.stopPropagation(); });
    }

    if (sendBtn) {
        sendBtn.addEventListener('click', function() {
            if (splitMenu) splitMenu.style.display = 'none';
            if (flag) flag.value = '1';
            var form = document.getElementById('im-form');
            if (form) form.requestSubmit();
        });
    }

    if (saveBtn) {
        saveBtn.addEventListener('click', function() {
            if (flag) flag.value = '0';
        });
    }
})();

