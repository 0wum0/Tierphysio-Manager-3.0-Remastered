        '<div class="modal-footer">' +
        '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>' +
        '<button type="button" class="btn btn-primary" id="cp-save-btn">' +
        '<svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" points="17 21 17 13 7 13 7 21"/></svg>' +
        ' Plan speichern</button>' +
        '</div>' +
        '</div></div>';
    document.body.appendChild(modalEl);
    var modal = new bootstrap.Modal(modalEl);
    modal.show();

    fetch('/api/patients/' + p.id + '/homework/plan-meta', { headers: { 'Accept': 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(meta) {
            var el = document.getElementById('cp-next-apt');
            if (el && meta && meta.wiedervorstellung_date) el.value = meta.wiedervorstellung_date;
        }).catch(function(){});

    _loadCpTemplates();

    document.getElementById('cp-save-btn').addEventListener('click', function() {
        var btn = this;
        btn.disabled = true;
        btn.textContent = 'Speichert\u2026';
        var fd = new FormData(document.getElementById('create-plan-form'));
        /* Collect task rows which live outside the <form> element */
        var container = document.getElementById('cp-tasks-container');
        if (container) {
            container.querySelectorAll('[name="task_title[]"]').forEach(function(el,i) { fd.append('task_title[]', el.value); });
            container.querySelectorAll('[name="task_description[]"]').forEach(function(el) { fd.append('task_description[]', el.value); });
            container.querySelectorAll('[name="task_frequency[]"]').forEach(function(el) { fd.append('task_frequency[]', el.value); });
            container.querySelectorAll('[name="task_duration[]"]').forEach(function(el) { fd.append('task_duration[]', el.value); });
            container.querySelectorAll('[name="task_notes[]"]').forEach(function(el) { fd.append('task_notes[]', el.value); });
        }
        fetch('/api/patients/' + p.id + '/plans', { method: 'POST', body: fd, headers: { 'Accept': 'application/json' } })
            .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, d: d }; }); })
            .then(function(res) {
                if (res.ok && res.d.success) {
                    bootstrap.Modal.getInstance(modalEl).hide();
                    _loadPlans(p.id);
                    if (res.d.portal_invite_sent) {
                        _hwShowToast('&#x2709; Besitzerportal-Einladung per E-Mail gesendet.', 'success');
                    } else if (res.d.portal_invite_error) {
                        _hwShowToast('Plan gespeichert. E-Mail fehlgeschlagen: ' + _hwEsc(res.d.portal_invite_error), 'warning');
                    }
                } else {
                    throw new Error(res.d.error || 'Fehler beim Speichern');
                }
            })
            .catch(function(err) {
                alert('Fehler: ' + err.message);
                btn.disabled = false;
                btn.textContent = 'Plan speichern';
            });
    });
    modalEl.addEventListener('hidden.bs.modal', function() { this.remove(); });
};

function _loadCpTemplates() {
    if (_hwTemplates.length) { _fillCpTemplateChecklist(); return; }
    fetch('/api/homework/templates', { headers: { 'Accept': 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(tpls) {
            _hwTemplates = Array.isArray(tpls) ? tpls : [];
            _fillCpTemplateChecklist();
        })
        .catch(function(){
            var cl = document.getElementById('cp-template-checklist');
            if (cl) cl.innerHTML = '<div class="text-muted" style="font-size:0.82rem;padding:0.5rem;">Keine Vorlagen verf\u00fcgbar</div>';
        });
}

function _fillCpTemplateChecklist() {
    var cl = document.getElementById('cp-template-checklist');
    if (!cl) return;
    if (!_hwTemplates.length) {
        cl.innerHTML = '<div class="text-muted" style="font-size:0.82rem;padding:0.5rem;">Keine Vorlagen verf\u00fcgbar</div>';
        return;
    }
    cl.innerHTML = _hwTemplates.map(function(t) {
        var emoji = t.category_emoji || '\uD83D\uDCCC';
        var dur = t.duration_value ? (t.duration_value + ' ' + (t.duration_unit||'')) : '';
        return '<label style="display:flex;align-items:center;gap:0.6rem;padding:0.35rem 0.5rem;border-radius:4px;cursor:pointer;font-size:0.83rem;" ' +
            'onmouseover="this.style.background=\'var(--bs-secondary-bg)\'" onmouseout="this.style.background=\'\'">'+
            '<input type="checkbox" class="cp-tpl-cb form-check-input flex-shrink-0" style="margin:0;" ' +
            'data-title="' + _hwEsc(t.title) + '" ' +
            'data-description="' + _hwEsc(t.description||'') + '" ' +
            'data-frequency="' + _hwEsc(t.frequency||'') + '" ' +
            'data-duration="' + _hwEsc(dur) + '" ' +
            'data-notes="' + _hwEsc(t.therapist_notes||'') + '">' +
            '<span>' + emoji + ' <strong>' + _hwEsc(t.title) + '</strong>' +
            (t.frequency ? ' <span style="color:var(--bs-secondary-color);">&middot; ' + _hwEsc(t.frequency) + '</span>' : '') +
            (dur ? ' <span style="color:var(--bs-secondary-color);">&middot; ' + _hwEsc(dur) + '</span>' : '') +
            '</span></label>';
    }).join('');
}

var _cpTaskIdx = 0;
window._cpAddTask = function(title, description, frequency, duration, notes) {
    var idx = _cpTaskIdx++;
    var container = document.getElementById('cp-tasks-container');
    if (!container) return;
    var row = document.createElement('div');
    row.className = 'card mb-2';
    row.id = 'cp-task-' + idx;
    row.innerHTML =
        '<div class="card-body py-2 px-3"><div class="d-flex gap-2 align-items-start"><div style="flex:1;">' +
        '<div class="row g-2 mb-2">' +
        '<div class="col-md-6"><input type="text" name="task_title[]" class="form-control form-control-sm" placeholder="Aufgabentitel *" value="' + _hwEsc(title||'') + '"></div>' +
        '<div class="col-md-3"><input type="text" name="task_frequency[]" class="form-control form-control-sm" placeholder="H\u00e4ufigkeit" value="' + _hwEsc(frequency||'') + '"></div>' +
        '<div class="col-md-3"><input type="text" name="task_duration[]" class="form-control form-control-sm" placeholder="Dauer" value="' + _hwEsc(duration||'') + '"></div>' +
        '</div><div class="row g-2">' +
        '<div class="col-md-8"><textarea name="task_description[]" class="form-control form-control-sm" rows="2" placeholder="Beschreibung / Anleitung f\u00fcr den Besitzer\u2026">' + _hwEsc(description||'') + '</textarea></div>' +
        '<div class="col-md-4"><textarea name="task_notes[]" class="form-control form-control-sm" rows="2" placeholder="Interne Notiz (optional)">' + _hwEsc(notes||'') + '</textarea></div>' +
        '</div></div>' +
        '<button type="button" class="btn btn-sm btn-outline-danger flex-shrink-0" onclick="document.getElementById(\'cp-task-' + idx + '\').remove()" style="margin-top:0.1rem;">' +
        '<svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></button>' +
        '</div></div>';
    container.appendChild(row);
};

window._cpAddSelectedTemplates = function() {
    var checkboxes = document.querySelectorAll('#cp-template-checklist .cp-tpl-cb:checked');
    if (!checkboxes.length) { return; }
    checkboxes.forEach(function(cb) {
        _cpAddTask(cb.dataset.title, cb.dataset.description, cb.dataset.frequency, cb.dataset.duration, cb.dataset.notes);
        cb.checked = false;
    });
};

/* ── Global click delegator for [data-patient-id] cards ──────
   Covers patients/index, owners/show and any future page.      */
document.addEventListener('click', function(e) {
    /* Skip if the click came from inside a modal or from an interactive element */
    if (e.target.closest('.modal')) return;
    if (e.target.closest('select, input, button, textarea, a, label')) return;
    var el = e.target.closest('[data-patient-id]');
    if (el && !e.defaultPrevented) {
        e.preventDefault();
        openPatientModal(el.dataset.patientId);
    }
});
document.addEventListener('keydown', function(e) {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    if (e.target.closest('.modal')) return;
    var el = e.target.closest('[data-patient-id]');
    if (el) { e.preventDefault(); openPatientModal(el.dataset.patientId); }
});

/* ── TherapyCare Pro: Modal-Daten laden ──────────────────── */
function loadTcpData(patientId) {
    var secProgress = document.getElementById('pd-tcp-progress-section');
    var secNatural  = document.getElementById('pd-tcp-natural-section');
    var secReports  = document.getElementById('pd-tcp-reports-section');
    var listProgress = document.getElementById('pd-tcp-progress-list');
    var listNatural  = document.getElementById('pd-tcp-natural-list');
    var listReports  = document.getElementById('pd-tcp-reports-list');
    var linkProgress = document.getElementById('pd-tcp-progress-link');
    var linkNatural  = document.getElementById('pd-tcp-natural-link');
    var linkReports  = document.getElementById('pd-tcp-reports-link');

    if (!secProgress) return; /* plugin not active */

    /* reset */
    secProgress.style.display = 'none';
    secNatural.style.display  = 'none';
    secReports.style.display  = 'none';
    if (linkProgress) linkProgress.href = '/patienten/' + patientId + '/fortschritt';
    if (linkNatural)  linkNatural.href  = '/patienten/' + patientId + '/naturheilkunde';
    if (linkReports)  linkReports.href  = '/patienten/' + patientId + '/berichte';

    fetch('/api/tcp/patienten/' + patientId + '/modal-data', {headers:{'X-Requested-With':'XMLHttpRequest'}})
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.ok) return;

            /* ── Fortschritt ── */
            var latest = data.latest || [];
            if (latest.length > 0) {
                var html = '';
                latest.forEach(function(e) {
                    var color = esc(e.category_color || e.color || '#4f7cff');
                    var pct   = Math.round(((e.score - (e.scale_min || 1)) / ((e.scale_max || 10) - (e.scale_min || 1))) * 100);
                    var date  = e.entry_date ? e.entry_date.substring(0,10).split('-').reverse().join('.') : '';
                    html += '<div style="display:flex;align-items:center;gap:0.5rem;padding:0.4rem 0.6rem;border-radius:7px;background:var(--bg-elevated,rgba(255,255,255,0.04));border:1px solid var(--glass-border);">';
                    html += '<div style="width:8px;height:8px;border-radius:50%;flex-shrink:0;background:' + color + ';"></div>';
                    html += '<div style="flex:1;min-width:0;">';
                    html += '<div style="font-size:0.78rem;font-weight:600;color:var(--text-primary);">' + esc(e.category_name || '') + '</div>';
                    html += '<div style="height:4px;background:var(--glass-border);border-radius:999px;margin-top:3px;"><div style="height:100%;width:' + pct + '%;background:' + color + ';border-radius:999px;"></div></div>';
                    html += '</div>';
                    html += '<div style="display:flex;flex-direction:column;align-items:flex-end;flex-shrink:0;">';
                    html += '<span style="font-size:0.82rem;font-weight:700;color:' + color + ';">' + esc(String(e.score)) + '</span>';
                    html += '<span style="font-size:0.65rem;color:var(--text-muted);">' + esc(date) + '</span>';
                    html += '</div>';
                    html += '</div>';
                });
                listProgress.innerHTML = html;
                secProgress.style.display = '';
            }

            /* ── Naturheilkunde ── */
            var natural = data.natural || [];
            if (natural.length > 0) {
                var html2 = '';
                var shown = natural.slice(0, 3);
                shown.forEach(function(e) {
                    var date2 = e.entry_date ? e.entry_date.substring(0,10).split('-').reverse().join('.') : '';
                    html2 += '<div style="display:flex;align-items:center;gap:0.5rem;padding:0.4rem 0.6rem;border-radius:7px;background:var(--bg-elevated,rgba(255,255,255,0.04));border:1px solid var(--glass-border);">';
                    html2 += '<svg width="12" height="12" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;opacity:0.5;"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M12 2a10 10 0 010 20M12 2C6.5 2 2 6.5 2 12m10-10c2 4 3 8 0 10"/></svg>';
                    html2 += '<div style="flex:1;min-width:0;">';
                    html2 += '<div style="font-size:0.78rem;font-weight:600;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(e.type_name || e.custom_type || '') + '</div>';
                    if (e.notes) html2 += '<div style="font-size:0.68rem;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(e.notes) + '</div>';
                    html2 += '</div>';
                    html2 += '<span style="font-size:0.65rem;color:var(--text-muted);flex-shrink:0;">' + esc(date2) + '</span>';
                    html2 += '</div>';
                });
                if (natural.length > 3) {
                    html2 += '<div style="font-size:0.7rem;color:var(--text-muted);text-align:center;padding:0.2rem;">+' + (natural.length - 3) + ' weitere</div>';
                }
                listNatural.innerHTML = html2;
                secNatural.style.display = '';
            }

            /* ── Therapieberichte ── */
            var reports = data.reports || [];
            if (reports.length > 0) {
                var html3 = '';
                var shownR = reports.slice(0, 3);
                shownR.forEach(function(r) {
                    var date3 = r.created_at ? r.created_at.substring(0,10).split('-').reverse().join('.') : '';
                    html3 += '<div style="display:flex;align-items:center;gap:0.5rem;padding:0.4rem 0.6rem;border-radius:7px;background:var(--bg-elevated,rgba(255,255,255,0.04));border:1px solid var(--glass-border);">';
                    html3 += '<svg width="12" height="12" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;opacity:0.5;"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>';
                    html3 += '<div style="flex:1;min-width:0;">';
                    html3 += '<div style="font-size:0.78rem;font-weight:600;color:var(--text-primary);">' + esc(r.title || 'Therapiebericht') + '</div>';
                    html3 += '<div style="font-size:0.68rem;color:var(--text-muted);">' + esc(date3) + '</div>';
                    html3 += '</div>';
                    html3 += '<a href="/patienten/' + patientId + '/berichte/' + r.id + '/download" target="_blank" style="flex-shrink:0;color:var(--accent,#4f7cff);font-size:0.72rem;text-decoration:none;padding:0.2rem 0.45rem;border:1px solid var(--glass-border);border-radius:5px;">Öffnen</a>';
                    html3 += '</div>';
                });
                if (reports.length > 3) {
                    html3 += '<div style="font-size:0.7rem;color:var(--text-muted);text-align:center;padding:0.2rem;">+' + (reports.length - 3) + ' weitere</div>';
                }
                listReports.innerHTML = html3;
                secReports.style.display = '';
            }
        })
        .catch(function() { /* TCP-Plugin nicht aktiv oder Tabellen noch nicht migriert – ignorieren */ });
}

/* ── Responsive Patient Modal Header ─────────────────────────── */
(function() {
    /* CSS für responsive Header */
    var style = document.createElement('style');
    style.textContent = `
        @media (max-width: 768px) {
            .pd-header-buttons-desktop {
                display: none !important;
            }
            .pd-header-buttons-mobile {
                display: block !important;
            }
        }
        @media (min-width: 769px) {
            .pd-header-buttons-desktop {
                display: flex !important;
            }
            .pd-header-buttons-mobile {
                display: none !important;
            }
        }
    `;
    document.head.appendChild(style);

    /* Mobile Buttons mit Desktop-Buttons verknüpfen */
    function wireMobileButton(mobileId, desktopId) {
        var mobileBtn = document.getElementById(mobileId);
        var desktopBtn = document.getElementById(desktopId);
        if (mobileBtn && desktopBtn) {
            mobileBtn.addEventListener('click', function(e) {
                e.preventDefault();
                desktopBtn.click();
            });
        }
    }

    /* Event-Listener für mobile Buttons */
    document.addEventListener('DOMContentLoaded', function() {
        wireMobileButton('pd-new-apt-btn-mobile', 'pd-new-apt-btn');
        wireMobileButton('pd-invoice-btn-mobile', 'pd-invoice-btn');
        wireMobileButton('pd-pdf-btn-mobile', 'pd-pdf-btn');
        wireMobileButton('pd-edit-btn-mobile', 'pd-edit-btn');
        wireMobileButton('pd-delete-btn-mobile', 'pd-delete-btn');

        /* Für den Link (Tierarztbericht) href kopieren */
        var mobileLink = document.getElementById('pd-vet-report-btn-mobile');
        var desktopLink = document.getElementById('pd-vet-report-btn');
        if (mobileLink && desktopLink) {
            mobileLink.addEventListener('click', function(e) {
                e.preventDefault();
                if (desktopLink.href) {
                    window.open(desktopLink.href, '_blank');
                }
            });
        }
    });
})();

