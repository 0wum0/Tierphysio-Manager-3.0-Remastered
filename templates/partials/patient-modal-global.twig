                                <button type="button" id="im-save-send-btn" style="display:flex;align-items:center;gap:0.5rem;width:100%;padding:0.55rem 1rem;background:none;border:none;cursor:pointer;color:var(--bs-body-color);font-size:0.875rem;">✉ Speichern &amp; E-Mail senden</button>
