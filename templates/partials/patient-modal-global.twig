/* --- TCP Fortschritt --- */
function loadTcpData(patientId) {
    if (_tcpLoaded) return;
    _tcpLoaded = true;
    var listEl      = document.getElementById('pd-fortschritt-list');
    var naturalSec  = document.getElementById('pd-natural-section');
    var naturalList = document.getElementById('pd-natural-list');
    var tcpRepSec   = document.getElementById('pd-tcp-reports-section');
    var tcpRepList  = document.getElementById('pd-tcp-reports-list');
    var linkProg    = document.getElementById('pd-tcp-progress-link');
    var linkNat     = document.getElementById('pd-tcp-natural-link');
    var linkRep     = document.getElementById('pd-tcp-reports-link');
    if (linkProg) linkProg.href = '/patienten/'+patientId+'/fortschritt';
    if (linkNat)  linkNat.href  = '/patienten/'+patientId+'/naturheilkunde';
    if (linkRep)  linkRep.href  = '/patienten/'+patientId+'/berichte';

    fetch('/api/tcp/patienten/'+patientId+'/modal-data', {headers:{'X-Requested-With':'XMLHttpRequest'}})
        .then(function(r){return r.json();})
        .then(function(data) {
            if (!data.ok) return;
            /* Fortschritt */
            var latest = data.latest || [];
            if (latest.length) {
                var maxV = Math.max.apply(null, latest.map(function(e){ return e.scale_max || 10; }));
                var html = '';
                latest.forEach(function(e) {
                    var color = esc(e.category_color || e.color || '#4f7cff');
                    var pct   = Math.round(((e.score - (e.scale_min||1)) / ((e.scale_max||10)-(e.scale_min||1)))*100);
                    var date  = e.entry_date ? e.entry_date.substring(0,10).split('-').reverse().join('.') : '';
                    html += '<div style="display:flex;align-items:center;gap:0.6rem;padding:0.5rem 0.65rem;border-radius:8px;background:var(--bs-secondary-bg);border:1px solid var(--bs-border-color);margin-bottom:0.4rem;">';
                    html += '<div style="width:10px;height:10px;border-radius:50%;flex-shrink:0;background:'+color+';"></div>';
                    html += '<div style="flex:1;min-width:0;"><div style="font-size:0.8rem;font-weight:600;">'+esc(e.category_name||'')+'</div><div class="tcp-progress-bar"><div class="tcp-progress-bar-fill" style="width:'+pct+'%;background:'+color+';"></div></div></div>';
                    html += '<div style="text-align:right;flex-shrink:0;"><div style="font-size:0.85rem;font-weight:700;color:'+color+';">'+esc(String(e.score))+'</div><div style="font-size:0.65rem;color:var(--bs-secondary-color);">'+esc(date)+'</div></div>';
                    html += '</div>';
                });
                listEl.innerHTML = html;
            } else {
                listEl.innerHTML = '<div style="text-align:center;padding:1.5rem;color:var(--bs-secondary-color);font-size:0.85rem;">Noch keine Fortschrittsdaten vorhanden.</div>';
            }
            /* Naturheilkunde */
            var natural = data.natural || [];
            if (natural.length && naturalSec && naturalList) {
                naturalSec.style.display = '';
                var hn = '';
                natural.slice(0,4).forEach(function(e) {
                    var date2 = e.entry_date ? e.entry_date.substring(0,10).split('-').reverse().join('.') : '';
                    hn += '<div style="display:flex;align-items:center;gap:0.5rem;padding:0.4rem 0.6rem;border-radius:7px;background:var(--bs-secondary-bg);border:1px solid var(--bs-border-color);margin-bottom:0.3rem;">';
                    hn += '<svg width="12" height="12" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;opacity:0.5;"><path stroke="currentColor" stroke-width="2" d="M12 2a10 10 0 010 20M12 2C6.5 2 2 6.5 2 12"/></svg>';
                    hn += '<div style="flex:1;min-width:0;font-size:0.8rem;font-weight:600;">'+esc(e.type_name||e.custom_type||'')+'</div>';
                    hn += '<span style="font-size:0.68rem;color:var(--bs-secondary-color);">'+esc(date2)+'</span>';
                    hn += '</div>';
                });
                naturalList.innerHTML = hn;
            }
            /* TCP Berichte */
            var reports = data.reports || [];
            if (reports.length && tcpRepSec && tcpRepList) {
                tcpRepSec.style.display = '';
                var hr = '';
                reports.slice(0,4).forEach(function(r) {
                    var date3 = r.created_at ? r.created_at.substring(0,10).split('-').reverse().join('.') : '';
                    hr += '<div style="display:flex;align-items:center;gap:0.5rem;padding:0.4rem 0.6rem;border-radius:7px;background:var(--bs-secondary-bg);border:1px solid var(--bs-border-color);margin-bottom:0.3rem;">';
                    hr += '<svg width="12" height="12" fill="none" viewBox="0 0 24 24" style="flex-shrink:0;opacity:0.5;"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>';
                    hr += '<div style="flex:1;min-width:0;font-size:0.8rem;font-weight:600;">'+esc(r.title||'Therapiebericht')+' <span style="font-size:0.68rem;color:var(--bs-secondary-color);">'+esc(date3)+'</span></div>';
                    hr += '<a href="/patienten/'+patientId+'/berichte/'+r.id+'/download" target="_blank" class="btn btn-sm btn-outline-secondary" style="font-size:0.72rem;">Öffnen</a>';
                    hr += '</div>';
                });
                tcpRepList.innerHTML = hr;
            }
        })
        .catch(function() { /* TCP Plugin nicht aktiv */ });
}

