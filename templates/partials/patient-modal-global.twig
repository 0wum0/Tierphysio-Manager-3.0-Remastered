function _hwEsc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function _hwFmtDate(d){if(!d)return '';var parts=String(d).split('-');return parts.length===3?parts[2]+'.'+parts[1]+'.'+parts[0]:d;}

window.openHomeworkModal = function() {
    if (!currentPatientData) return;
    var p = currentPatientData.patient;
    var old=document.getElementById('modal-patient-homework'); if(old){try{bootstrap.Modal.getInstance(old)?.dispose();}catch(e){}old.remove();}
    var modalEl=document.createElement('div');
    modalEl.className='modal fade'; modalEl.id='modal-patient-homework'; modalEl.tabIndex=-1; modalEl.setAttribute('aria-hidden','true');
    modalEl.innerHTML='<div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">'
        +'<div class="modal-header"><h3 class="modal-title">📋 Hausaufgabenpläne — '+_hwEsc(p.name)+'</h3><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>'
        +'<div class="modal-body">'
        +'<div class="d-flex justify-content-between align-items-center mb-3">'
        +'<span style="font-size:0.82rem;color:var(--bs-secondary-color);">Alle Therapiepläne für diesen Patienten</span>'
        +'<button class="btn btn-primary btn-sm" onclick="openCreatePlanModal()">+ Neuer Hausaufgabenplan</button>'
        +'</div>'
        +'<div id="hw-plans-list"><div class="text-center py-5 text-muted"><div class="pd-spinner" style="margin:0 auto 1rem;"></div>Lade Pläne…</div></div>'
        +'</div></div></div>';
    document.body.appendChild(modalEl);
    var modal=new bootstrap.Modal(modalEl); modal.show();
    _loadPlans(p.id);
    modalEl.addEventListener('hidden.bs.modal',function(){this.remove();});
};

function _loadPlans(patientId) {
    var container=document.getElementById('hw-plans-list'); if(!container) return;
    fetch('/api/patients/'+patientId+'/plans',{headers:{'Accept':'application/json'}})
        .then(function(r){return r.json().then(function(d){return{ok:r.ok,d:d};});})
        .then(function(res){
            container=document.getElementById('hw-plans-list'); if(!container) return;
            if(!res.ok||!Array.isArray(res.d)){container.innerHTML='<div class="alert alert-danger">API-Fehler</div>';return;}
            var plans=res.d;
            if(!plans.length){container.innerHTML='<div class="text-center py-5 text-muted">Noch keine Pläne vorhanden.<br><br><button class="btn btn-primary btn-sm" onclick="openCreatePlanModal()">Ersten Plan erstellen</button></div>';return;}
            container.innerHTML=plans.map(function(plan){
                var badge=plan.status==='active'?'<span class="badge text-bg-success ms-2" style="font-size:0.68rem;">Aktiv</span>':'<span class="badge text-bg-secondary ms-2" style="font-size:0.68rem;">Archiviert</span>';
                var taskRows=(plan.tasks||[]).map(function(t){'<div style="padding:0.3rem 0.5rem;font-size:0.78rem;border-bottom:1px solid var(--bs-border-color);">📋 '+_hwEsc(t.title)+' — '+_hwEsc(t.frequency||'')+(t.duration?' ('+_hwEsc(t.duration)+')':"")+'</div>';}).join('');
                return '<div class="card mb-3"><div class="card-header d-flex align-items-center justify-content-between py-2 px-3"><div><span class="fw-600">📅 Plan vom '+_hwFmtDate(plan.plan_date)+'</span>'+badge+(plan.therapist_name?'<span class="text-muted ms-2" style="font-size:0.78rem;">· '+_hwEsc(plan.therapist_name)+'</span>':'')+'</div><div class="d-flex gap-1"><a href="/portal-admin/hausaufgaben/'+plan.id+'/pdf" target="_blank" class="btn btn-sm btn-outline-secondary" style="font-size:0.72rem;">PDF</a><button class="btn btn-sm btn-outline-danger" style="font-size:0.72rem;" onclick="_deletePlan('+plan.id+')">Löschen</button></div></div>'+(taskRows?'<div class="card-body p-0">'+taskRows+'</div>':'')+(plan.general_notes?'<div class="card-footer py-2 px-3" style="font-size:0.78rem;color:var(--bs-secondary-color);">📝 '+_hwEsc(plan.general_notes)+'</div>':'')+'</div>';
            }).join('');
        })
        .catch(function(){var c=document.getElementById('hw-plans-list');if(c)c.innerHTML='<div class="alert alert-danger">Fehler beim Laden der Pläne.</div>';});
}

window._deletePlan = function(planId) {
    if (!confirm('Plan wirklich löschen?')||!currentPatientData) return;
    var patientId=currentPatientData.patient.id;
    fetch('/api/patients/'+patientId+'/plans/'+planId,{method:'DELETE',headers:{'X-CSRF-Token':'{{ csrf_token }}','Accept':'application/json'}})
        .then(function(r){return r.json();}).then(function(d){if(d.success){_loadPlans(patientId);_hwLoaded=false;}else{alert(d.error||'Fehler');}}).catch(function(){alert('Fehler');});
};

var _cpTaskIdx=0;
window._cpAddTask=function(title,description,frequency,duration,notes){
    var idx=_cpTaskIdx++; var container=document.getElementById('cp-tasks-container'); if(!container)return;
    var row=document.createElement('div'); row.className='card mb-2'; row.id='cp-task-'+idx;
    row.innerHTML='<div class="card-body py-2 px-3"><div class="d-flex gap-2 align-items-start"><div style="flex:1;">'
        +'<div class="row g-2 mb-2"><div class="col-md-6"><input type="text" name="task_title[]" class="form-control form-control-sm" placeholder="Aufgabentitel *" value="'+_hwEsc(title||'')+'"></div>'
        +'<div class="col-md-3"><input type="text" name="task_frequency[]" class="form-control form-control-sm" placeholder="Häufigkeit" value="'+_hwEsc(frequency||'')+'"></div>'
        +'<div class="col-md-3"><input type="text" name="task_duration[]" class="form-control form-control-sm" placeholder="Dauer" value="'+_hwEsc(duration||'')+'"></div></div>'
        +'<div class="row g-2"><div class="col-md-8"><textarea name="task_description[]" class="form-control form-control-sm" rows="2" placeholder="Beschreibung…">'+_hwEsc(description||'')+'</textarea></div>'
        +'<div class="col-md-4"><textarea name="task_notes[]" class="form-control form-control-sm" rows="2" placeholder="Interne Notiz">'+_hwEsc(notes||'')+'</textarea></div></div></div>'
        +'<button type="button" class="btn btn-sm btn-outline-danger flex-shrink-0" onclick="document.getElementById(\'cp-task-'+idx+'\').remove()" style="margin-top:0.1rem;">✕</button>'
        +'</div></div>';
    container.appendChild(row);
};

window._cpAddSelectedTemplates=function(){
    document.querySelectorAll('#cp-template-checklist .cp-tpl-cb:checked').forEach(function(cb){
        _cpAddTask(cb.dataset.title,cb.dataset.description,cb.dataset.frequency,cb.dataset.duration,cb.dataset.notes);
        cb.checked=false;
    });
};

window.openCreatePlanModal=function(){
    if(!currentPatientData)return;
    var p=currentPatientData.patient; var today=new Date().toISOString().split('T')[0];
    var old=document.getElementById('modal-create-plan'); if(old){try{bootstrap.Modal.getInstance(old)?.dispose();}catch(e){}old.remove();}
    var modalEl=document.createElement('div'); modalEl.className='modal fade'; modalEl.id='modal-create-plan'; modalEl.tabIndex=-1; modalEl.setAttribute('aria-hidden','true');
    modalEl.innerHTML='<div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">'
        +'<div class="modal-header"><h3 class="modal-title">Neuer Hausaufgabenplan — '+_hwEsc(p.name)+'</h3><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>'
        +'<div class="modal-body">'
        +'<form id="create-plan-form"><input type="hidden" name="_csrf_token" value="{{ csrf_token }}">'
        +'<div class="row g-3 mb-3">'
        +'<div class="col-md-4"><label class="form-label">Datum</label><input type="date" name="plan_date" class="form-control" value="'+today+'"></div>'
        +'<div class="col-md-4"><label class="form-label">Therapeut</label><input type="text" name="therapist_name" class="form-control" value="{{ current_user.name ?? "" }}"></div>'
        +'<div class="col-md-4"><label class="form-label">Wiedervorstellung</label><input type="date" name="next_appointment" class="form-control" id="cp-next-apt"></div>'
        +'</div>'
        +'<div class="row g-3 mb-3">'
        +'<div class="col-md-6"><label class="form-label">Physiotherapeutische Grundsätze</label><textarea name="physio_principles" class="form-control" rows="3" placeholder="Grundlagen und Prinzipien…"></textarea></div>'
        +'<div class="col-md-6"><label class="form-label">Therapiemittel</label><textarea name="therapy_means" class="form-control" rows="3" placeholder="Verwendete Therapiemittel…"></textarea></div>'
        +'</div>'
        +'<div class="row g-3 mb-3">'
        +'<div class="col-md-6"><label class="form-label">Kurzfristige Ziele</label><textarea name="short_term_goals" class="form-control" rows="2" placeholder="Ziele für die nächsten 2–4 Wochen…"></textarea></div>'
        +'<div class="col-md-6"><label class="form-label">Langfristige Ziele</label><textarea name="long_term_goals" class="form-control" rows="2" placeholder="Langfristige Therapieziele…"></textarea></div>'
        +'</div>'
        +'<div class="mb-3"><label class="form-label">Allgemeine Hinweise</label><textarea name="general_notes" class="form-control" rows="2" placeholder="Wichtige Hinweise für den Besitzer…"></textarea></div>'
        +'</form>'
        +'<hr>'
        +'<div class="d-flex align-items-center justify-content-between mb-2"><h6 class="mb-0 fw-600">Vorlagen</h6>'
        +'<div class="d-flex gap-2"><button type="button" class="btn btn-primary btn-sm" onclick="_cpAddSelectedTemplates()">Ausgewählte hinzufügen</button>'
        +'<button type="button" class="btn btn-outline-secondary btn-sm" onclick="_cpAddTask(\'\',\'\',\'\',\'\',\'\')">+ Leere Zeile</button></div></div>'
        +'<div id="cp-template-checklist" style="max-height:200px;overflow-y:auto;border:1px solid var(--bs-border-color);border-radius:6px;padding:0.5rem;margin-bottom:1rem;"><div class="text-muted" style="font-size:0.82rem;padding:0.5rem;">Lade Vorlagen…</div></div>'
        +'<div class="d-flex align-items-center justify-content-between mb-2"><h6 class="mb-0 fw-600">Aufgaben</h6></div>'
        +'<div id="cp-tasks-container"></div>'
        +'</div>'
        +'<div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button><button type="button" class="btn btn-primary" id="cp-save-btn">Plan speichern</button></div>'
        +'</div></div>';
    document.body.appendChild(modalEl);
    var modal=new bootstrap.Modal(modalEl); modal.show();
    _loadCpTemplates();
    fetch('/api/patients/'+p.id+'/homework/plan-meta',{headers:{'Accept':'application/json'}}).then(function(r){return r.json();}).then(function(meta){var el=document.getElementById('cp-next-apt');if(el&&meta&&meta.wiedervorstellung_date)el.value=meta.wiedervorstellung_date;}).catch(function(){});
    document.getElementById('cp-save-btn').addEventListener('click',function(){
        var btn=this; btn.disabled=true; btn.textContent='Speichert…';
        var fd=new FormData(document.getElementById('create-plan-form'));
        var container=document.getElementById('cp-tasks-container');
        if(container){container.querySelectorAll('[name="task_title[]"]').forEach(function(el){fd.append('task_title[]',el.value);});container.querySelectorAll('[name="task_description[]"]').forEach(function(el){fd.append('task_description[]',el.value);});container.querySelectorAll('[name="task_frequency[]"]').forEach(function(el){fd.append('task_frequency[]',el.value);});container.querySelectorAll('[name="task_duration[]"]').forEach(function(el){fd.append('task_duration[]',el.value);});container.querySelectorAll('[name="task_notes[]"]').forEach(function(el){fd.append('task_notes[]',el.value);});}
        fetch('/api/patients/'+p.id+'/plans',{method:'POST',body:fd,headers:{'Accept':'application/json'}})
            .then(function(r){return r.json().then(function(d){return{ok:r.ok,d:d};});})
            .then(function(res){if(res.ok&&res.d.success){bootstrap.Modal.getInstance(modalEl).hide();_hwLoaded=false;loadHwPlans(p.id);}else{throw new Error(res.d.error||'Fehler');}})
            .catch(function(err){alert('Fehler: '+err.message);btn.disabled=false;btn.textContent='Plan speichern';});
    });
    modalEl.addEventListener('hidden.bs.modal',function(){this.remove();});
};

function _loadCpTemplates(){
    if(_hwTemplates.length){_fillCpTemplateChecklist();return;}
    fetch('/api/homework/templates',{headers:{'Accept':'application/json'}}).then(function(r){return r.json();}).then(function(tpls){_hwTemplates=Array.isArray(tpls)?tpls:[];_fillCpTemplateChecklist();}).catch(function(){var cl=document.getElementById('cp-template-checklist');if(cl)cl.innerHTML='<div class="text-muted" style="font-size:0.82rem;padding:0.5rem;">Keine Vorlagen verfügbar</div>';});
}
function _fillCpTemplateChecklist(){
    var cl=document.getElementById('cp-template-checklist'); if(!cl) return;
    if(!_hwTemplates.length){cl.innerHTML='<div class="text-muted" style="font-size:0.82rem;padding:0.5rem;">Keine Vorlagen verfügbar</div>';return;}
    cl.innerHTML=_hwTemplates.map(function(t){var emoji=t.category_emoji||'📌';var dur=t.duration_value?(t.duration_value+' '+(t.duration_unit||'')):'';return'<label style="display:flex;align-items:center;gap:0.6rem;padding:0.35rem 0.5rem;border-radius:4px;cursor:pointer;font-size:0.83rem;"><input type="checkbox" class="cp-tpl-cb form-check-input" style="margin:0;" data-title="'+_hwEsc(t.title)+'" data-description="'+_hwEsc(t.description||'')+'" data-frequency="'+_hwEsc(t.frequency||'')+'" data-duration="'+_hwEsc(dur)+'" data-notes="'+_hwEsc(t.therapist_notes||'')+'">'+'<span>'+emoji+' <strong>'+_hwEsc(t.title)+'</strong>'+(t.frequency?' <span style="color:var(--bs-secondary-color);">· '+_hwEsc(t.frequency)+'</span>':'')+(dur?' <span style="color:var(--bs-secondary-color);">· '+_hwEsc(dur)+'</span>':'')+'</span></label>';}).join('');
}

/* ═══════════════════════════════════════════════════════
   GLOBAL EXPORTS
═══════════════════════════════════════════════════════ */
window._gsOpenPatient   = openPatientModal;
window.showPatientModal = openPatientModal;

})();
</script>
