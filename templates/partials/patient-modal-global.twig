/* --- Hausaufgabenpläne --- */
var _hwTemplates = [];
function loadHwPlans(patientId) {
    if (_hwLoaded) return;
    _hwLoaded = true;
    var container = document.getElementById('pd-hw-plans-list');
    fetch('/api/patients/'+patientId+'/plans', {headers:{'Accept':'application/json'}})
        .then(function(r){return r.json().then(function(d){return {ok:r.ok,d:d};});})
        .then(function(res) {
            if (!res.ok || !Array.isArray(res.d)) { container.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--bs-secondary-color);font-size:0.85rem;">Noch keine Pläne vorhanden.</div>'; return; }
            var plans = res.d;
            if (!plans.length) { container.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--bs-secondary-color);font-size:0.85rem;">Noch keine Hausaufgabenpläne vorhanden.<br><br><button class="btn btn-primary btn-sm" onclick="openCreatePlanModal()">Ersten Plan erstellen</button></div>'; return; }
            var html = '';
            plans.forEach(function(plan) {
                var badge = plan.status==='active' ? '<span class="badge text-bg-success ms-2" style="font-size:0.68rem;">Aktiv</span>' : '<span class="badge text-bg-secondary ms-2" style="font-size:0.68rem;">Archiviert</span>';
                var taskRows = (plan.tasks||[]).map(function(t) {
                    return '<div style="font-size:0.78rem;padding:0.3rem 0.5rem;border-bottom:1px solid var(--bs-border-color);">📋 '+esc(t.title)+(t.frequency?' — '+esc(t.frequency):'')+(t.duration?' ('+esc(t.duration)+')':"")+'</div>';
                }).join('');
                html += '<div style="border:1px solid var(--bs-border-color);border-radius:10px;margin-bottom:0.75rem;overflow:hidden;">';
                html += '<div style="padding:0.65rem 0.85rem;background:var(--bs-secondary-bg);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.35rem;">';
                html += '<div><span class="fw-600" style="font-size:0.85rem;">📅 Plan vom '+(plan.plan_date ? new Date(plan.plan_date).toLocaleDateString('de-DE') : '—')+'</span>'+badge+(plan.therapist_name?'<span class="text-muted ms-2" style="font-size:0.75rem;">· '+esc(plan.therapist_name)+'</span>':'')+'</div>';
                html += '<div class="d-flex gap-1"><a href="/portal-admin/hausaufgaben/'+plan.id+'/pdf" target="_blank" class="btn btn-sm btn-outline-secondary" style="font-size:0.72rem;">PDF</a><button class="btn btn-sm btn-outline-danger" style="font-size:0.72rem;" onclick="_deletePlan('+plan.id+')">Löschen</button></div>';
                html += '</div>';
                if (taskRows) html += '<div>'+taskRows+'</div>';
                if (plan.general_notes) html += '<div style="padding:0.4rem 0.85rem;font-size:0.78rem;color:var(--bs-secondary-color);">📝 '+esc(plan.general_notes)+'</div>';
                html += '</div>';
            });
            container.innerHTML = html;
        })
        .catch(function() { container.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--bs-secondary-color);font-size:0.85rem;">Pläne konnten nicht geladen werden.</div>'; });
}

/* ═══════════════════════════════════════════════════════
   OPEN PATIENT MODAL (main entry point)
═══════════════════════════════════════════════════════ */
function openPatientModal(patientId) {
    resetModal();
    bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-patient-detail')).show();
    initQuill();

    fetch('/patienten/'+patientId+'/json')
        .then(function(r){return r.json();})
        .then(function(data) {
            var p = data.patient;
            var o = data.owner;

            /* Header */
            document.getElementById('pd-name').textContent = p.name || '';
            if (p.status) {
                var badge = document.getElementById('pd-badge');
                badge.textContent  = p.status;
                badge.className    = 'badge badge-'+(p.status||'').toLowerCase().replace(/ /g,'_');
                badge.style.display = '';
            }
            document.getElementById('pd-species').textContent = [p.species,p.breed].filter(Boolean).join(' · ');

            /* Photo */
            if (p.photo) {
                var imgH = document.createElement('img');
                imgH.src = '/patienten/'+patientId+'/foto/'+p.photo;
                imgH.style.cssText = 'width:100%;height:100%;object-fit:cover;';
                var ph = document.getElementById('pd-photo');
                ph.innerHTML = ''; ph.appendChild(imgH);
                var imgF = document.createElement('img');
                imgF.src = imgH.src; imgF.alt = p.name||'';
                var pf = document.getElementById('pd-photo-full');
                pf.innerHTML = ''; pf.appendChild(imgF);
            }

            /* Info grid */
            function detail(label, value) { return value ? '<div><span>'+esc(label)+'</span><div>'+esc(value)+'</div></div>' : ''; }
            document.getElementById('pd-details').innerHTML =
                detail('Tierart', p.species) + detail('Rasse', p.breed) +
                detail('Geschlecht', p.gender) + detail('Geb.', p.birth_date ? fmtDate(p.birth_date) : null) +
                detail('Farbe', p.color) + detail('Chip-Nr.', p.chip_number) +
                (p.notes ? '<div style="grid-column:1/-1;border-top:1px solid var(--bs-border-color);padding-top:0.4rem;margin-top:0.1rem;"><span>Notizen</span><div style="font-size:0.78rem;line-height:1.5;color:var(--bs-secondary-color);">'+esc(p.notes)+'</div></div>' : '');

            /* Owner */
            if (o) {
                var knr = 'Kunden-Nr. '+String(o.id).padStart(4,'0');
                document.getElementById('pd-owner').innerHTML =
                    '<a href="/tierhalter/'+o.id+'" class="pd-owner-link">'
                    +'<div class="pd-owner-avatar">'+esc((o.first_name||'').charAt(0)+(o.last_name||'').charAt(0))+'</div>'
                    +'<div><div class="pd-owner-name">'+esc(o.first_name+' '+o.last_name)+' <span style="font-size:0.68rem;color:var(--bs-primary);background:rgba(79,124,255,0.1);padding:1px 6px;border-radius:999px;">'+esc(knr)+'</span></div>'
                    +(o.phone?'<div class="pd-owner-meta">'+esc(o.phone)+'</div>':'')
                    +(o.email?'<div class="pd-owner-meta">'+esc(o.email)+'</div>':'')
                    +'</div></a>';
            } else {
                document.getElementById('pd-owner').innerHTML = '<span style="color:var(--bs-secondary-color);font-size:0.82rem;">Kein Besitzer</span>';
            }

            /* Treatment types for entry form */
            var ttSel = document.getElementById('pd-treatment-type');
            if (ttSel && data.treatment_types) {
                ttSel.innerHTML = '<option value="">— keine —</option>';
                data.treatment_types.forEach(function(tt) {
                    var opt = document.createElement('option');
                    opt.value = tt.id; opt.textContent = tt.name; opt.dataset.color = tt.color;
                    ttSel.appendChild(opt);
                });
            }

            /* Timeline form action */
            var pdForm = document.getElementById('pd-timeline-form');
            if (pdForm) { pdForm.action='/patienten/'+patientId+'/timeline'; pdForm.dataset.patientId=patientId; }

            /* Befund new link */
            var bfnl = document.getElementById('pd-befunde-new-link');
            if (bfnl) bfnl.href = '/patienten/'+patientId+'/befunde/neu';

            /* Vet report links */
            var vrl = document.getElementById('pd-vet-report-btn');
            if (vrl) vrl.href = '/patienten/'+patientId+'/tierarztbericht';
            var vrn = document.getElementById('pd-vr-new-link');
            if (vrn) vrn.href = '/patienten/'+patientId+'/tierarztbericht';

            /* Rechnungs-Badge */
            var existBadge = document.getElementById('pd-invoice-badge');
            if (existBadge) existBadge.remove();
            if (data.invoice_stats && (data.invoice_stats.open_count > 0 || data.invoice_stats.paid_count > 0)) {
                var ib = document.createElement('span');
                ib.id = 'pd-invoice-badge';
                ib.style.cssText = 'flex-shrink:0;padding:0.15rem 0.45rem;border-radius:5px;font-size:0.65rem;font-weight:700;cursor:pointer;white-space:nowrap;';
                if (data.invoice_stats.open_count > 0) {
                    ib.style.background='rgba(220,53,69,0.18)'; ib.style.color='#ff6b6b'; ib.style.border='1.5px solid #dc3545';
                    ib.textContent = data.invoice_stats.open_count+' offen';
                } else {
                    ib.style.background='rgba(25,135,84,0.15)'; ib.style.color='#2dbe6c'; ib.style.border='1.5px solid #198754';
                    ib.textContent = '✓ Bezahlt';
                }
                var nameEl = document.getElementById('pd-name');
                if (nameEl && nameEl.parentNode) nameEl.parentNode.insertBefore(ib, document.getElementById('pd-badge').nextSibling);
            }

            currentPatientData = data;

            /* Render initial tab data */
            renderTimeline(data.timeline, patientId);
            renderAppointments(data.appointments || [], data.patient);

            /* Show body */
            document.getElementById('pd-loading').style.display = 'none';
            document.getElementById('pd-body').style.display    = 'flex';
        })
        .catch(function() {
            document.getElementById('pd-loading').innerHTML = '<div style="color:var(--bs-secondary-color);font-size:0.85rem;">Fehler beim Laden der Patientendaten.</div>';
        });
}

