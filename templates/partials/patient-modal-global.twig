{# ═══════════════════════════════════════════════════════════
   GLOBAL PATIENT DETAIL MODAL — v2.0
   Eingebunden in layout.twig — steht auf jeder Seite bereit.
   Geöffnet via: window._gsOpenPatient(id) / window.showPatientModal(id)

   TABS IM MODAL:
   - Akte          (Timeline + neuer Eintrag)
   - Hausaufgaben
   - Befundbögen
   - Therapiebericht
   - Fortschritt   (TCP)
   - Portal-Check  (TCP)
   ═══════════════════════════════════════════════════════════ #}

{# ── Inline CSS für Modal-spezifische Styles ──────────────── #}
<style>
/* ── Mobile Header-Dropdown ─────────────────────────── */
.pd-header-actions {
    display: none;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
    margin-left: auto;
}
@media (min-width: 900px) {
    .pd-header-actions {
        display: flex !important;
        flex-direction: row;
        flex-wrap: nowrap;
        position: static;
        background: transparent;
        border: none;
        box-shadow: none;
        padding: 0;
        min-width: 0;
    }
    .pd-mobile-menu-btn { display: none !important; }
}
.pd-header-actions.mobile-open {
    display: flex !important;
    flex-direction: column;
    align-items: stretch;
    position: absolute;
    top: 52px;
    right: 8px;
    z-index: 200;
    background: var(--bs-tertiary-bg, #1e2228);
    border: 1px solid var(--bs-border-color, rgba(255,255,255,0.15));
    border-radius: 10px;
    padding: 0.35rem;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    min-width: 200px;
    gap: 0.2rem;
}
.pd-header-actions.mobile-open .btn {
    font-size: 0.8rem;
    justify-content: flex-start;
    text-align: left;
    width: 100%;
}
.pd-mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px; height: 32px;
    border: 1px solid var(--bs-border-color, rgba(255,255,255,0.2));
    border-radius: 8px;
    background: transparent;
    color: var(--bs-body-color);
    cursor: pointer;
    flex-shrink: 0;
    margin-left: auto;
}
.pd-btn-label { font-size: 0.8rem; white-space: nowrap; }
@media (min-width: 900px) and (max-width: 1100px) {
    .pd-btn-label { display: none; }
}

/* ── Modal Tab Navigation ───────────────────────────── */
#pd-tab-nav {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: nowrap !important;
    overflow-x: auto !important;
    overflow-y: hidden !important;
    width: 100% !important;
    flex-shrink: 0 !important;
    border-bottom: 1px solid var(--bs-border-color, rgba(255,255,255,0.12));
    background: var(--bs-body-bg);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    position: relative;
    z-index: 10;
}
#pd-tab-nav::-webkit-scrollbar { display: none; }
#pd-tab-nav .pd-tab,
#pd-tab-nav button {
    display: flex !important;
    flex-direction: row !important;
    flex-shrink: 0 !important;
    width: auto !important;
    min-width: max-content !important;
    align-items: center !important;
    gap: 0.35rem;
    padding: 0.6rem 0.9rem;
    border: none;
    background: transparent;
    color: var(--bs-secondary-color, rgba(255,255,255,0.5));
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    white-space: nowrap !important;
    touch-action: manipulation;
}
#pd-tab-nav .pd-tab:hover { color: var(--bs-body-color); }
#pd-tab-nav .pd-tab.active {
    color: var(--bs-primary, #4f7cff);
    border-bottom-color: var(--bs-primary, #4f7cff);
    font-weight: 600;
}
.pd-tab-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 16px;
    height: 16px;
    border-radius: 8px;
    background: var(--bs-primary, #4f7cff);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    padding: 0 4px;
}

/* ── Tab Panels ─────────────────────────────────────── */
.pd-tab-panel { display: none; }
.pd-tab-panel.active { display: block; }

/* ── Info Card im Modal ─────────────────────────────── */
.pd-info-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--bs-secondary-bg, rgba(255,255,255,0.04));
    border-radius: 10px;
    padding: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
}
.pd-info-photo {
    width: 90px;
    aspect-ratio: 3/4;
    border-radius: 10px;
    overflow: hidden;
    background: var(--bs-tertiary-bg, rgba(255,255,255,0.08));
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    align-self: stretch;
}
.pd-info-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
.pd-info-divider {
    width: 1px; background: var(--bs-border-color, rgba(255,255,255,0.1));
    align-self: stretch; flex-shrink: 0; margin: 0 0.25rem;
}
@media (max-width: 560px) { .pd-info-divider { display: none; } }
.pd-info-col { min-width: 0; flex: 1; }
.pd-info-col-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--bs-secondary-color); margin-bottom: 0.4rem; }
.pd-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.25rem 1rem; font-size: 0.78rem; }
.pd-info-grid > div span:first-child { color: var(--bs-secondary-color); display: block; font-size: 0.68rem; }
.pd-owner-link { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: inherit; }
.pd-owner-avatar { width: 32px; height: 32px; border-radius: 50%; background: rgba(79,124,255,0.2); color: var(--bs-primary); font-size: 0.7rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.pd-owner-name { font-weight: 600; font-size: 0.82rem; }
.pd-owner-meta { font-size: 0.72rem; color: var(--bs-secondary-color); }

/* ── Entry Form ─────────────────────────────────────── */
.pd-entry-section { margin-bottom: 1.25rem; }
.pd-section-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--bs-secondary-color); margin-bottom: 0.6rem; }
.pd-entry-form { display: flex; flex-direction: column; gap: 0.6rem; }
.pd-form-grid4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem; }
@media (max-width: 600px) { .pd-form-grid4 { grid-template-columns: 1fr 1fr; } }
.pd-field label.pd-label { font-size: 0.72rem; color: var(--bs-secondary-color); display: block; margin-bottom: 3px; }
.pd-input, .pd-select { width: 100%; font-size: 0.82rem; }
.pd-file { font-size: 0.8rem; }
.pd-form-footer { display: flex; gap: 0.75rem; align-items: flex-end; flex-wrap: wrap; }
.pd-submit-btn { flex-shrink: 0; }

/* ── Timeline ───────────────────────────────────────── */
.timeline { display: flex; flex-direction: column; gap: 0.5rem; }
.timeline-item { display: flex; gap: 0.75rem; position: relative; }
.timeline-dot { width: 10px; height: 10px; border-radius: 50%; border: 2px solid var(--bs-border-color); background: var(--bs-body-bg); flex-shrink: 0; margin-top: 0.35rem; }
.timeline-dot-note     { border-color: #4f7cff; background: rgba(79,124,255,0.3); }
.timeline-dot-treatment{ border-color: #22c55e; background: rgba(34,197,94,0.3); }
.timeline-dot-photo    { border-color: #f59e0b; background: rgba(245,158,11,0.3); }
.timeline-dot-document { border-color: #a855f7; background: rgba(168,85,247,0.3); }
.timeline-dot-other    { border-color: #94a3b8; background: rgba(148,163,184,0.3); }
.timeline-card { flex: 1; min-width: 0; background: var(--bs-secondary-bg, rgba(255,255,255,0.04)); border: 1px solid var(--bs-border-color, rgba(255,255,255,0.08)); border-radius: 8px; padding: 0.6rem 0.75rem; }
.timeline-meta { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.3rem; flex-wrap: wrap; gap: 0.25rem; }
.timeline-date { font-size: 0.68rem; color: var(--bs-secondary-color); }
.timeline-author { font-size: 0.68rem; color: var(--bs-secondary-color); }
.timeline-title { font-weight: 600; font-size: 0.82rem; margin-bottom: 0.25rem; }
.timeline-content { font-size: 0.8rem; line-height: 1.55; color: var(--bs-body-color); }
.ql-view p { margin: 0 0 0.25rem; }
.ql-view ul, .ql-view ol { padding-left: 1.25rem; margin: 0 0 0.25rem; }

/* ── Therapiebericht Tab ────────────────────────────── */
.vr-card { display: flex; align-items: center; gap: 0.65rem; padding: 0.6rem 0.85rem; border-radius: 8px; background: var(--bs-secondary-bg, rgba(255,255,255,0.04)); border: 1px solid var(--bs-border-color, rgba(255,255,255,0.08)); margin-bottom: 0.4rem; }
.vr-card:last-child { margin-bottom: 0; }

/* ── Fortschritt Tab (TCP) ──────────────────────────── */
.tcp-progress-bar { height: 6px; background: var(--bs-tertiary-bg, rgba(255,255,255,0.1)); border-radius: 999px; margin-top: 4px; overflow: hidden; }
.tcp-progress-bar-fill { height: 100%; border-radius: 999px; }

/* ── Befundbögen Tab ────────────────────────────────── */
.bf-card { display: flex; align-items: center; gap: 0.65rem; padding: 0.6rem 0.85rem; border-radius: 8px; background: var(--bs-secondary-bg, rgba(255,255,255,0.04)); border: 1px solid var(--bs-border-color, rgba(255,255,255,0.08)); margin-bottom: 0.4rem; }

/* ── Spin ───────────────────────────────────────────── */
@keyframes spin { to { transform: rotate(360deg); } }
.pd-spinner { width: 32px; height: 32px; border: 3px solid var(--bs-border-color, rgba(255,255,255,0.12)); border-top-color: var(--bs-primary, #4f7cff); border-radius: 50%; animation: spin 0.8s linear infinite; }
</style>

{# ── Patient Detail Modal ─────────────────────────────── #}
<div class="modal fade" id="modal-patient-detail" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" style="--bs-modal-height: 92vh;">
        <div class="modal-content" style="display: flex; flex-direction: column; max-height: 92vh;">

            {# ── Header ─────────────────────────────────────────── #}
            <div id="pd-header" style="padding: 0.6rem 0.85rem; border-bottom: 1px solid var(--bs-border-color, rgba(255,255,255,0.12)); flex-shrink: 0; display: flex; align-items: center; gap: 0.55rem; position: relative;">

                {# Foto mini #}
                <div id="pd-photo" style="width: 36px; height: 36px; border-radius: 50%; overflow: hidden; background: var(--bs-tertiary-bg); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg width="20" height="20" fill="none" viewBox="0 0 24 24" style="opacity: 0.3;"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </div>

                {# Name + Badge #}
                <div style="min-width: 0; flex-shrink: 1; flex-grow: 0; max-width: 180px;">
                    <div style="display: flex; align-items: center; gap: 0.3rem; flex-wrap: wrap;">
                        <span id="pd-name" style="font-size: 0.9rem; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"></span>
                        <span id="pd-badge" class="badge" style="display: none; font-size: 0.6rem;"></span>
                    </div>
                    <div id="pd-species" style="font-size: 0.68rem; color: var(--bs-secondary-color); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"></div>
                </div>

                {# ── Action Buttons (Desktop: inline row, Mobile: dropdown) ── #}

                {# Mobile toggle button #}
                <button type="button" class="pd-mobile-menu-btn" id="pd-mobile-menu-btn" aria-label="Aktionen" >
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5" fill="currentColor"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/><circle cx="12" cy="19" r="1.5" fill="currentColor"/></svg>
                </button>

                {# Action buttons #}
                <div class="pd-header-actions" id="pd-header-actions">
                    <button id="pd-new-apt-btn" type="button" class="btn btn-secondary btn-sm" style="padding: 0.3rem 0.55rem;" title="Neuer Termin">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="14" x2="12" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="10" y1="16" x2="14" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        <span class="pd-btn-label">Termin</span>
                    </button>
                    <button id="pd-invoice-btn" type="button" class="btn btn-secondary btn-sm" style="padding: 0.3rem 0.55rem;">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="14 2 14 8 20 8"/></svg>
                        <span class="pd-btn-label">Rechnung</span>
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" onclick="exportPatientPDF()" style="padding: 0.3rem 0.55rem;">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        <span class="pd-btn-label">PDF</span>
                    </button>
                    <a id="pd-vet-report-btn" href="#" target="_blank" class="btn btn-secondary btn-sm" style="padding: 0.3rem 0.55rem;" title="Tierarztbericht">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink: 0;"><ellipse cx="6" cy="5.5" rx="2" ry="2.5"/><ellipse cx="12" cy="4" rx="2" ry="2.5"/><ellipse cx="18" cy="5.5" rx="2" ry="2.5"/><ellipse cx="3.5" cy="11" rx="1.7" ry="2.2"/><path d="M12 9c-3.5 0-7 2.5-7 5.5 0 2 1.2 3.5 3 4 .8.2 1.6.5 2.5.5h3c.9 0 1.7-.3 2.5-.5 1.8-.5 3-2 3-4C19 11.5 15.5 9 12 9z"/></svg>
                        <span class="pd-btn-label">Tier-Bericht</span>
                    </a>
                    <button id="pd-edit-btn" type="button" class="btn btn-primary btn-sm" style="padding: 0.3rem 0.55rem;">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        <span class="pd-btn-label">Bearbeiten</span>
                    </button>
                    <button id="pd-delete-btn" type="button" class="btn btn-danger btn-sm" onclick="deletePatient()" style="padding: 0.3rem 0.55rem;">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 11v6M14 11v6"/></svg>
                        <span class="pd-btn-label">Löschen</span>
                    </button>
                </div>

                {# Close #}
                <button type="button" class="btn-close ms-1" data-bs-dismiss="modal" aria-label="Schließen" style="flex-shrink: 0;"></button>
            </div>

            {# ── Loading ─────────────────────────────────────────── #}
            <div id="pd-loading" style="display: flex; align-items: center; justify-content: center; padding: 3rem; flex: 1;">
                <div class="pd-spinner"></div>
            </div>

            {# ── Body (hidden until data loaded) ──────────────────── #}
            <div id="pd-body" style="display: none; flex: 1; flex-direction: column; min-height: 0; overflow: hidden;">

                {# ── Tab Navigation ── #}
                <div class="pd-tabs" id="pd-tab-nav" style="display:flex!important;flex-direction:row!important;flex-wrap:nowrap!important;overflow-x:auto!important;overflow-y:hidden!important;width:100%!important;flex-shrink:0!important;-webkit-overflow-scrolling:touch;">
                    <button class="pd-tab active" data-pd-tab="akte">
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg>
                        Akte
                    </button>
                    <button class="pd-tab" data-pd-tab="hausaufgaben" >
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M9 11l3 3L22 4"/><path stroke="currentColor" stroke-width="2" d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                        Hausaufgaben
                    </button>
                    <button class="pd-tab" data-pd-tab="befunde" id="pd-tab-btn-befunde" >
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg>
                        Befundbögen
                        <span class="pd-tab-badge" id="pd-befunde-count" style="display: none;">0</span>
                    </button>
                    <button class="pd-tab" data-pd-tab="therapiebericht" id="pd-tab-btn-vr" >
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><ellipse cx="6" cy="5.5" rx="2" ry="2.5"/><ellipse cx="12" cy="4" rx="2" ry="2.5"/><ellipse cx="18" cy="5.5" rx="2" ry="2.5"/><path d="M12 9c-3.5 0-7 2.5-7 5.5 0 2 1.2 3.5 3 4 .8.2 1.6.5 2.5.5h3c.9 0 1.7-.3 2.5-.5 1.8-.5 3-2 3-4C19 11.5 15.5 9 12 9z"/></svg>
                        Tierarztbericht
                        <span class="pd-tab-badge" id="pd-vr-count" style="display: none;">0</span>
                    </button>
                    <button class="pd-tab" data-pd-tab="fortschritt" id="pd-tab-btn-tcp" >
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                        Fortschritt
                    </button>
                    <button class="pd-tab" data-pd-tab="portal" id="pd-tab-btn-portal" >
                        <svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Portal
                        <span class="pd-tab-badge" id="pd-portal-count" style="display: none;">0</span>
                    </button>
                </div>

                {# ── Scrollable panel container ── #}
                <div style="flex: 1; overflow-y: auto; overflow-x: hidden; min-height: 0;">
                    <div style="padding: 1.25rem;">

                        {# Patient Info Card — shown in all tabs #}
                        <div class="pd-info-card">
                            <div id="pd-photo-full" class="pd-info-photo">
                                <svg width="36" height="36" fill="none" viewBox="0 0 24 24" style="opacity: 0.2;"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                            </div>
                            <div class="pd-info-divider"></div>
                            <div class="pd-info-col">
                                <div class="pd-info-col-label">Patient</div>
                                <div id="pd-details" class="pd-info-grid"></div>
                            </div>
                            <div class="pd-info-divider"></div>
                            <div class="pd-info-col">
                                <div class="pd-info-col-label">Besitzer</div>
                                <div id="pd-owner"></div>
                            </div>
                        </div>

                        {# ══════════════════════════════════════════════
                           TAB: AKTE
                        ══════════════════════════════════════════════ #}
                        <div class="pd-tab-panel active" id="pd-panel-akte">

                            {# Neuer Eintrag #}
                            <div class="pd-entry-section">
                                <div class="pd-section-label">Neuer Akteneintrag</div>
                                <form id="pd-timeline-form" method="POST" enctype="multipart/form-data" class="pd-entry-form">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                    <div class="pd-form-grid4">
                                        <div class="pd-field">
                                            <label class="pd-label">Typ</label>
                                            <select name="type" class="pd-select form-select form-select-sm" data-no-cs>
                                                <option value="note">📝 Notiz</option>
