function buildInvoiceForm(d, prePatientId, preOwnerId) {
    var form=document.getElementById('im-form'); if(!form) return;
    form.reset();
    form.querySelector('[name="invoice_number"]').value = d.next_number||'';
    form.querySelector('[name="issue_date"]').value     = d.issue_date||'';
    form.querySelector('[name="due_date"]').value       = d.due_date||'';
    var ku=!!d.kleinunternehmer;
    form.querySelectorAll('.im-tax-col').forEach(function(el){el.style.display=ku?'none':'';});
    var kuNote=document.getElementById('im-ku-note'); if(kuNote) kuNote.style.display=ku?'':'none';
    form.dataset.defaultTax=ku?'0':(d.default_tax_rate||'19'); form.dataset.ku=ku?'1':'0';
    var ownerSel=form.querySelector('[name="owner_id"]'); ownerSel.innerHTML='<option value="">— Tierhalter —</option>';
    d.owners.forEach(function(o){var opt=new Option(o.last_name+', '+o.first_name,o.id);ownerSel.appendChild(opt);});
    if(preOwnerId) ownerSel.value=preOwnerId;
    var patSel=form.querySelector('[name="patient_id"]'); patSel.innerHTML='<option value="">— kein —</option>';
    (d.patients||[]).forEach(function(p){var opt=new Option(p.name+' ('+p.species+')',p.id);opt.dataset.owner=p.owner_id;patSel.appendChild(opt);});
    if(prePatientId) patSel.value=prePatientId;
    // Speichere treatment_types für addImPosition
    window._imTreatmentTypes = d.treatment_types || [];
    var container=document.getElementById('im-positions-container'); container.innerHTML='';
    addImPosition(form); imRecalc();
    initImPaymentToggle(form);
    var addBtn=document.getElementById('im-add-position'); if(addBtn) addBtn.onclick=function(){addImPosition(form);};
}

function addImPosition(form) {
    var d=window._imFormData||(window._imFormData={}); // fallback
    var ku=form.dataset.ku==='1'; var defTax=form.dataset.defaultTax||'19';
    var treatmentTypes = window._imTreatmentTypes || [];
    var row=document.createElement('div');
    row.style.cssText='display:grid;grid-template-columns:2fr 80px 100px '+(ku?'0px':'70px')+' auto;gap:0.4rem;margin-bottom:0.4rem;align-items:center;';
    
    // Build treatment type select options
    var treatmentOptions = '<option value="">— Manuell eingeben —</option>';
    treatmentTypes.forEach(function(tt){
        var price = parseFloat(tt.price) || 0;
        var priceStr = price > 0 ? ' ('+price.toFixed(2).replace('.',',')+' €)' : '';
        treatmentOptions += '<option value="'+tt.id+'" data-price="'+price+'" data-name="'+(tt.name||'')+'">'+tt.name+priceStr+'</option>';
    });
    
    row.innerHTML='<select name="position_treatment_type_id[]" class="form-select form-select-sm im-treatment-type" style="font-size:0.8rem;">'+treatmentOptions+'</select>'
        +'<input type="number" name="position_quantity[]" class="form-control form-control-sm im-qty" value="1" min="0.01" step="0.01" style="text-align:right;">'
        +'<input type="number" name="position_price[]" class="form-control form-control-sm im-price" value="0.00" min="0" step="0.01" style="text-align:right;">'
        +(ku?'':'<input type="number" name="position_tax_rate[]" class="form-control form-control-sm im-tax im-tax-col" value="'+defTax+'" min="0" step="0.01" style="text-align:right;">')
        +'<button type="button" class="btn btn-danger btn-sm im-del" style="padding:0.2rem 0.4rem;"><svg width="12" height="12" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2"/></svg></button>';
    
    // Treatment type change handler - auto-fill description and price
    var treatmentSelect = row.querySelector('.im-treatment-type');
    var descInput = document.createElement('input');
    descInput.type = 'text';
    descInput.name = 'position_description[]';
    descInput.className = 'form-control form-control-sm im-desc';
    descInput.placeholder = 'Beschreibung';
    descInput.required = true;
    descInput.style.display = 'none'; // Hidden, value will be set from treatment
    
    treatmentSelect.addEventListener('change', function(){
        var selectedOption = this.options[this.selectedIndex];
        var price = parseFloat(selectedOption.dataset.price) || 0;
        var name = selectedOption.dataset.name || '';
        var descInput = row.querySelector('.im-desc');
        var priceInput = row.querySelector('.im-price');
        
        if(descInput) descInput.value = name;
        if(priceInput) priceInput.value = price.toFixed(2);
        imRecalc();
    });
    
    row.querySelector('.im-qty')?.addEventListener('input',imRecalc);
    row.querySelector('.im-price')?.addEventListener('input',imRecalc);
    row.querySelector('.im-tax')?.addEventListener('input',imRecalc);
    row.querySelector('.im-del').addEventListener('click',function(){row.remove();imRecalc();});
    
    // Add hidden description input
    row.appendChild(descInput);
    document.getElementById('im-positions-container').appendChild(row);
}

function imRecalc() {
    var net=0,tax=0;
    document.querySelectorAll('#im-positions-container [name="position_quantity[]"]').forEach(function(el,i){
        var row=el.closest('div'); if(!row) return;
        var qty=parseFloat(el.value)||0, price=parseFloat(row.querySelector('.im-price')?.value)||0, taxR=parseFloat(row.querySelector('.im-tax')?.value)||0;
        net+=qty*price; tax+=qty*price*(taxR/100);
    });
    var fmt=function(v){return v.toFixed(2).replace('.',',')+' €';};
    var n=document.getElementById('im-total-net'), t=document.getElementById('im-total-tax'), g=document.getElementById('im-total-gross');
    if(n) n.textContent=fmt(net); if(t) t.textContent=fmt(tax); if(g) g.textContent=fmt(net+tax);
}

function initImPaymentToggle(form) {
    var lblR=document.getElementById('im-lbl-rechnung'), lblB=document.getElementById('im-lbl-bar');
    var fStat=document.getElementById('im-field-status'), fDue=document.getElementById('im-field-due');
    function update(){
        var isCash=form.querySelector('[name="payment_method"]:checked')?.value==='bar';
        if(lblR){lblR.style.border=isCash?'2px solid var(--bs-border-color)':'2px solid var(--bs-primary)';lblR.style.background=isCash?'':'rgba(79,124,255,0.08)';}
        if(lblB){lblB.style.border=isCash?'2px solid var(--bs-primary)':'2px solid var(--bs-border-color)';lblB.style.background=isCash?'rgba(79,124,255,0.08)':'';}
        if(fStat) fStat.style.display=isCash?'none':'';
        if(fDue)  fDue.style.display=isCash?'none':'';
    }
    form.querySelectorAll('[name="payment_method"]').forEach(function(r){r.onchange=update;});
    update();
}

