function openTimelineEditModal(entry, patientId) {
    initTeQuill();
    setTimeout(function() {
        document.getElementById('te-entry-id').value   = entry.id;
        document.getElementById('te-patient-id').value = patientId || (currentPatientData ? currentPatientData.patient.id : '');
        var tySel=document.getElementById('te-type'); for(var i=0;i<tySel.options.length;i++) tySel.options[i].selected=tySel.options[i].value===(entry.type||'note');
        var ttSel=document.getElementById('te-treatment-type'); ttSel.innerHTML='<option value="">— keine —</option>';
        if (currentPatientData && currentPatientData.treatment_types) {
            currentPatientData.treatment_types.forEach(function(tt){ var o=document.createElement('option'); o.value=tt.id; o.textContent=tt.name; o.selected=parseInt(entry.treatment_type_id)===parseInt(tt.id); ttSel.appendChild(o); });
        }
        if (entry.entry_date) {
            var d=new Date(entry.entry_date.replace(' ','T'));
            var pad=function(n){return String(n).padStart(2,'0');};
            document.getElementById('te-date').value=d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate())+'T'+pad(d.getHours())+':'+pad(d.getMinutes());
        }
        var stSel=document.getElementById('te-status'); for(var i=0;i<stSel.options.length;i++) stSel.options[i].selected=stSel.options[i].value===(entry.status_badge||'');
        document.getElementById('te-title').value=entry.title||'';
        if (teQuill) { if(entry.content) teQuill.clipboard.dangerouslyPasteHTML(entry.content); else teQuill.setContents([]); }
        bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-timeline-edit')).show();
    },100);
}

