/* ═══════════════════════════════════════════════════════
   TIMELINE FORM SUBMIT (AJAX)
═══════════════════════════════════════════════════════ */
function initQuill() {
    loadQuill(function() {
        if (quillEditor) return;
        var el = document.getElementById('pd-quill-editor');
        if (!el || el.children.length > 1) return; // already initialized
        quillEditor = new Quill(el, {
            theme: 'snow',
            placeholder: 'Notizen, Befunde, Behandlungsschritte...',
            modules: { toolbar: [['bold','italic','underline','strike'],[{list:'ordered'},{list:'bullet'}],['blockquote'],[{color:[]}],['clean']] }
        });
    });
}

document.addEventListener('submit', function(e) {
    var form = e.target;
    if (form.id !== 'pd-timeline-form') return;
    e.preventDefault();
    var hidden = document.getElementById('pd-content-input');
    if (hidden && quillEditor) hidden.value = quillEditor.root.innerHTML;
    var patientId = form.dataset.patientId;
    if (!patientId) return;
    var btn = form.querySelector('[type=submit]');
    var origHtml = btn ? btn.innerHTML : '';
    var fileInput = document.getElementById('pd-attachment');
    var file = fileInput && fileInput.files && fileInput.files[0];
    var isVideo = file && file.type.startsWith('video/');

    var progressWrap = document.getElementById('pd-upload-progress');
    var uploadBar   = document.getElementById('pd-upload-bar');
    var uploadLabel = document.getElementById('pd-upload-label');
    function setProgress(pct, label) { progressWrap.style.display=''; uploadBar.style.width=pct+'%'; if(label && uploadLabel) uploadLabel.textContent=label; }
    function hideProgress() { progressWrap.style.display='none'; uploadBar.style.width='0%'; }

    if (btn) { btn.disabled=true; btn.innerHTML='<span class="pd-spinner" style="width:13px;height:13px;border-width:2px;display:inline-block;vertical-align:middle;"></span> Speichern…'; }

    function submitEntry(uploadedFilename) {
        var fd = new FormData(form);
        if (uploadedFilename) { fd.delete('attachment'); fd.append('uploaded_filename', uploadedFilename); }
        fetch('/patienten/'+patientId+'/timeline-json', {method:'POST',body:fd})
            .then(function(r){return r.json();})
            .then(function(data) {
                if (data.ok) {
                    renderTimeline(data.timeline, patientId);
                    form.reset(); if(quillEditor) quillEditor.setContents([]);
                    hideProgress(); _hwShowToast('✓ Eintrag gespeichert','success');
                } else { _hwShowToast('Fehler beim Speichern.','error'); }
            })
            .catch(function(){ _hwShowToast('Netzwerkfehler.','error'); })
            .finally(function(){ if(btn){btn.disabled=false;btn.innerHTML=origHtml;} });
    }

    if (isVideo) {
        setProgress(0,'Video wird hochgeladen…');
        var xhr = new XMLHttpRequest();
        xhr.open('POST','/patienten/'+patientId+'/attachment-upload',true);
        xhr.upload.addEventListener('progress', function(ev){ if(ev.lengthComputable) setProgress(Math.round(ev.loaded/ev.total*100),'Video '+Math.round(ev.loaded/ev.total*100)+'%'); });
        xhr.addEventListener('load', function(){
            if (xhr.status===200) { try { var resp=JSON.parse(xhr.responseText); if(resp.ok){setProgress(100,'Speichern…');submitEntry(resp.filename);return;} } catch(ex){} }
            hideProgress(); if(btn){btn.disabled=false;btn.innerHTML=origHtml;} alert('Upload fehlgeschlagen.');
        });
        xhr.addEventListener('error', function(){ hideProgress(); if(btn){btn.disabled=false;btn.innerHTML=origHtml;} });
        var fd2=new FormData(); fd2.append('_csrf_token',form.querySelector('[name="_csrf_token"]').value); fd2.append('attachment',file);
        xhr.send(fd2);
    } else {
        submitEntry(null);
    }
},true);

