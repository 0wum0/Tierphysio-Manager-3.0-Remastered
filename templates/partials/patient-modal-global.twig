{# ── Global Patient Modal JS ───────────────────────────── #}
<script>
(function () {
'use strict';

/* ═══════════════════════════════════════════════════════
   HELPERS
═══════════════════════════════════════════════════════ */
var quillLoaded = false;
function loadQuill(cb) {
    if (window.Quill) { cb(); return; }
    if (quillLoaded) { var t = setInterval(function(){ if(window.Quill){ clearInterval(t); cb(); } }, 50); return; }
    quillLoaded = true;
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js';
    s.onload = cb;
    document.head.appendChild(s);
    var l = document.createElement('link');
    l.rel = 'stylesheet';
    l.href = 'https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css';
    document.head.appendChild(l);
}

function esc(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function fmtDate(str) {
    if (!str) return '—';
    var d = new Date(str.replace(' ','T'));
    return isNaN(d) ? str : d.toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric'});
}
function fmtDateTime(str) {
    if (!str) return '—';
    var d = new Date(str.replace(' ','T'));
    if (isNaN(d)) return str;
    return d.toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric'}) + ' ' + d.toLocaleTimeString('de-DE',{hour:'2-digit',minute:'2-digit'});
}
function typeIcon(t) {
    return {note:'📝',treatment:'💊',photo:'📷',document:'📄',other:'📌'}[t] || '📌';
}

var imgExts   = ['jpg','jpeg','png','gif','webp'];
var videoExts = ['mp4','webm','ogg','mov','avi','mkv','m4v'];

/* state */
var currentPatientData = null;
var quillEditor = null;
var teQuill = null;

/* ═══════════════════════════════════════════════════════
   MOBILE MENU TOGGLE
═══════════════════════════════════════════════════════ */
var mobileMenuBtn = document.getElementById('pd-mobile-menu-btn');
var headerActions = document.getElementById('pd-header-actions');

if (mobileMenuBtn) {
    mobileMenuBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        headerActions.classList.toggle('mobile-open');
    });
}
document.addEventListener('click', function() {
    if (headerActions) headerActions.classList.remove('mobile-open');
});
if (headerActions) headerActions.addEventListener('click', function(e) { e.stopPropagation(); });

/* ═══════════════════════════════════════════════════════
   TAB SYSTEM
═══════════════════════════════════════════════════════ */
var _currentTab = 'akte';

function switchTab(tabName) {
    _currentTab = tabName;
    document.querySelectorAll('.pd-tab').forEach(function(btn) {
        btn.classList.toggle('active', btn.getAttribute('data-pd-tab') === tabName);
    });
    document.querySelectorAll('.pd-tab-panel').forEach(function(panel) {
        panel.classList.toggle('active', panel.id === 'pd-panel-' + tabName);
    });
    /* lazy load tab data */
    if (currentPatientData) {
        var pid = currentPatientData.patient.id;
        if (tabName === 'befunde')          loadBefundboegen(pid);
        if (tabName === 'therapiebericht')  loadVetReports(pid);
        if (tabName === 'fortschritt')      loadTcpData(pid);
        if (tabName === 'portal')           loadPortalChecks(pid);
        if (tabName === 'hausaufgaben')     loadHwPlans(pid);
    }
}

document.querySelectorAll('.pd-tab').forEach(function(btn) {
    btn.addEventListener('click', function() { switchTab(btn.getAttribute('data-pd-tab')); });
});

/* ═══════════════════════════════════════════════════════
   TOAST
═══════════════════════════════════════════════════════ */
function _hwShowToast(msg, type) {
    var t = document.createElement('div');
    var bg = type === 'success' ? '#198754' : type === 'warning' ? '#f59e0b' : '#dc3545';
    t.style.cssText = 'position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;background:'+bg+';color:#fff;padding:0.75rem 1.25rem;border-radius:8px;font-size:0.85rem;max-width:380px;box-shadow:0 4px 20px rgba(0,0,0,0.3);';
    t.innerHTML = msg;
    document.body.appendChild(t);
    setTimeout(function(){ t.style.opacity='0'; t.style.transition='opacity 0.4s'; setTimeout(function(){ t.remove(); },400); },4000);
}
window._hwShowToast = _hwShowToast;

/* ═══════════════════════════════════════════════════════
   RESET MODAL
═══════════════════════════════════════════════════════ */
function resetModal() {
    var pdLoading = document.getElementById('pd-loading');
    var pdBody    = document.getElementById('pd-body');
    pdLoading.style.display = 'flex';
    pdBody.style.display    = 'none';
    document.getElementById('pd-name').textContent    = '';
    document.getElementById('pd-badge').style.display = 'none';
    document.getElementById('pd-species').textContent = '';
    document.getElementById('pd-photo').innerHTML = '<svg width="20" height="20" fill="none" viewBox="0 0 24 24" style="opacity:0.3;"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';
    document.getElementById('pd-photo-full').innerHTML = '<svg width="36" height="36" fill="none" viewBox="0 0 24 24" style="opacity:0.2;"><path stroke="currentColor" stroke-width="1.5" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';
    document.getElementById('pd-details').innerHTML = '';
    document.getElementById('pd-owner').innerHTML   = '';
    document.getElementById('pd-timeline').innerHTML = '';
    if (document.getElementById('pd-timeline-search')) document.getElementById('pd-timeline-search').value = '';
    /* reset tab content */
    document.getElementById('pd-hw-plans-list').innerHTML  = '<div style="text-align:center;padding:2rem;color:var(--bs-secondary-color);"><div class="pd-spinner" style="margin:0 auto 1rem;"></div>Lade…</div>';
    document.getElementById('pd-befunde-list').innerHTML   = '<div style="text-align:center;padding:2rem;color:var(--bs-secondary-color);"><div class="pd-spinner" style="margin:0 auto 1rem;"></div>Lade…</div>';
    document.getElementById('pd-vr-list').innerHTML        = '<div style="text-align:center;padding:2rem;color:var(--bs-secondary-color);"><div class="pd-spinner" style="margin:0 auto 1rem;"></div>Lade…</div>';
    document.getElementById('pd-fortschritt-list').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--bs-secondary-color);font-size:0.85rem;">Keine Fortschrittsdaten vorhanden.</div>';
    document.getElementById('pd-portal-list').innerHTML    = '<div style="text-align:center;padding:2rem;color:var(--bs-secondary-color);font-size:0.85rem;">Noch keine abgehakten Aufgaben.</div>';
    /* badge count reset */
    ['pd-befunde-count','pd-vr-count','pd-portal-count'].forEach(function(id) { var el=document.getElementById(id); if(el){el.style.display='none'; el.textContent='0';} });
    /* switch back to akte tab */
    switchTab('akte');
    /* reset flags */
    _befundeLoaded = false;
    _vrLoaded      = false;
    _tcpLoaded     = false;
    _portalLoaded  = false;
    _hwLoaded      = false;
}

var _befundeLoaded = false, _vrLoaded = false, _tcpLoaded = false, _portalLoaded = false, _hwLoaded = false;

/* ═══════════════════════════════════════════════════════
   TIMELINE RENDER
═══════════════════════════════════════════════════════ */
function renderTimeline(timeline, patientId) {
    var container = document.getElementById('pd-timeline');
    if (!timeline || !timeline.length) {
        container.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--bs-secondary-color);font-size:0.85rem;">Noch keine Einträge</div>';
        return;
    }
    var html = '';
    timeline.forEach(function(e) {
        var ep = encodeURIComponent(JSON.stringify(e));
        var hasAttach = e.attachment;
        var ext = hasAttach ? (e.attachment.split('.').pop() || '').toLowerCase() : '';
        var isImg   = imgExts.includes(ext);
        var isVideo = videoExts.includes(ext);
        var src = hasAttach ? '/patienten/'+patientId+'/dokumente/'+encodeURIComponent(e.attachment) : '';
        var attachHtml = '';
        if (hasAttach) {
            if (isImg) attachHtml = '<div class="mt-2"><a href="'+src+'" data-lightbox-modal="'+src+'" data-filename="'+esc(e.attachment)+'" style="cursor:pointer;display:inline-block;"><img src="'+src+'" style="max-height:100px;max-width:100%;border-radius:6px;border:1px solid var(--bs-border-color);display:block;"></a></div>';
            else if (isVideo) attachHtml = '<div class="mt-2"><a href="'+src+'" data-lightbox-modal="'+src+'" data-filename="'+esc(e.attachment)+'" style="cursor:pointer;display:inline-block;position:relative;"><video src="'+src+'" style="max-height:120px;max-width:100%;border-radius:6px;display:block;background:#000;" preload="metadata"></video><div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.35);border-radius:6px;"><svg width="36" height="36" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="11" fill="rgba(0,0,0,0.55)"/><polygon points="10,8 18,12 10,16" fill="white"/></svg></div></a></div>';
            else attachHtml = '<div class="mt-2"><a href="'+src+'" data-lightbox-modal="'+src+'" data-filename="'+esc(e.attachment)+'" class="btn btn-secondary btn-sm" style="font-size:0.78rem;">📎 '+esc(e.attachment)+'</a></div>';
        }
        html += '<div class="timeline-item" data-entry-id="'+e.id+'">';
        html += '<div class="timeline-dot timeline-dot-'+esc(e.type)+'"></div>';
        html += '<div class="timeline-card">';
        html += '<div class="timeline-meta">';
        html += '<div style="display:flex;align-items:center;gap:0.4rem;flex-wrap:wrap;">';
        html += '<span style="font-size:0.78rem;">'+typeIcon(e.type)+'</span>';
        if (e.status_badge) html += '<span class="badge text-bg-primary" style="font-size:0.62rem;">'+esc(e.status_badge)+'</span>';
        html += '<span class="timeline-date">'+fmtDateTime(e.entry_date)+'</span>';
        if (e.treatment_type_name) html += '<span style="padding:0.1rem 0.45rem;border-radius:999px;font-size:0.62rem;font-weight:600;background:'+esc(e.treatment_type_color)+'22;color:'+esc(e.treatment_type_color)+';border:1px solid '+esc(e.treatment_type_color)+'44;">'+esc(e.treatment_type_name)+'</span>';
        html += '</div>';
        html += '<div style="display:flex;align-items:center;gap:0.25rem;">';
        if (e.user_name) html += '<span class="timeline-author">'+esc(e.user_name)+'</span>';
        html += '<button type="button" class="tl-edit-btn btn btn-sm" data-entry=\''+ep+'\' style="width:24px;height:24px;padding:0;color:var(--bs-secondary-color);" title="Bearbeiten"><svg width="12" height="12" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>';
        html += '<button type="button" class="tl-del-btn btn btn-sm" data-entry-id="'+e.id+'" style="width:24px;height:24px;padding:0;color:var(--bs-secondary-color);" title="Löschen"><svg width="12" height="12" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg></button>';
        html += '</div></div>';
        if (e.title)   html += '<div class="timeline-title">'+esc(e.title)+'</div>';
        if (e.content) html += '<div class="timeline-content ql-view">'+e.content+'</div>';
        html += attachHtml;
        html += '</div></div>';
    });
    container.innerHTML = html;

    container.querySelectorAll('[data-lightbox-modal]').forEach(function(el) {
        el.addEventListener('click', function(e) { e.preventDefault(); openViewer(el.dataset.lightboxModal, el.dataset.filename); });
    });
    container.querySelectorAll('.tl-edit-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            try { var entry = JSON.parse(decodeURIComponent(btn.dataset.entry)); openTimelineEditModal(entry, currentPatientData.patient.id); }
            catch(e) { console.error(e); }
        });
    });
    container.querySelectorAll('.tl-del-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            if (!confirm('Eintrag wirklich löschen?')) return;
            var csrf = document.getElementById('te-csrf')?.value || '';
            var fd = new FormData(); fd.append('_csrf_token', csrf);
            fetch('/patienten/'+currentPatientData.patient.id+'/timeline/'+btn.dataset.entryId+'/delete-json', {method:'POST',body:fd})
                .then(function(r){return r.json();})
                .then(function(data){ if(data.ok){ renderTimeline(data.timeline, currentPatientData.patient.id); _hwShowToast('Eintrag gelöscht','success'); } });
        });
    });
}

/* ═══════════════════════════════════════════════════════
   APPOINTMENTS
═══════════════════════════════════════════════════════ */
function renderAppointments(appointments, patient) {
    var sec  = document.getElementById('pd-appointments-section');
    var list = document.getElementById('pd-appointments-list');
    if (!sec || !list || !appointments || !appointments.length) { if(sec) sec.style.display='none'; return; }
    sec.style.display = '';
    var aptStatusMap = { scheduled:{label:'Geplant',color:'#6c757d'}, confirmed:{label:'Bestätigt',color:'#0d6efd'}, completed:{label:'Abgeschlossen',color:'#198754'}, cancelled:{label:'Abgesagt',color:'#dc3545'}, noshow:{label:'Nicht ersch.',color:'#fd7e14'} };
    var html = '';
    appointments.forEach(function(a) {
        var si = aptStatusMap[a.status] || {label:a.status,color:'#6c757d'};
        var dc = a.color || si.color;
        html += '<div style="display:flex;align-items:center;gap:0.55rem;padding:0.4rem 0.6rem;border-radius:7px;background:var(--bs-secondary-bg);border:1px solid var(--bs-border-color);">';
        html += '<div style="width:8px;height:8px;border-radius:50%;flex-shrink:0;background:'+esc(dc)+'"></div>';
        html += '<div style="flex:1;min-width:0;"><div style="font-size:0.8rem;font-weight:600;">'+esc(a.title)+'</div><div style="font-size:0.7rem;color:var(--bs-secondary-color);">'+esc(fmtDateTime(a.start_at))+(a.treatment_type_name?' · '+esc(a.treatment_type_name):'')+'</div></div>';
        html += '<span style="font-size:0.65rem;padding:2px 8px;border-radius:999px;background:'+esc(dc)+'22;color:'+esc(dc)+';border:1px solid '+esc(dc)+'44;">'+esc(si.label)+'</span>';
        html += '</div>';
    });
    list.innerHTML = html;
}

/* ═══════════════════════════════════════════════════════
   LAZY LOADERS FOR TABS
═══════════════════════════════════════════════════════ */

/* --- Befundbögen --- */
function loadBefundboegen(patientId) {
    if (_befundeLoaded) return;
    _befundeLoaded = true;
    var container = document.getElementById('pd-befunde-list');
    var countEl   = document.getElementById('pd-befunde-count');
    fetch('/api/patienten/'+patientId+'/befunde', {headers:{'Accept':'application/json'}})
        .then(function(r){return r.json();})
        .then(function(data) {
            var items = data.items ?? [];
            if (countEl && items.length) { countEl.textContent = items.length; countEl.style.display = ''; }
            if (!items.length) { container.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--bs-secondary-color);font-size:0.85rem;">Noch keine Befundbögen vorhanden.</div>'; return; }
            var statusColor = {versendet:'#22c55e', abgeschlossen:'var(--bs-primary)', entwurf:'#6c757d'};
            var statusLabel = {versendet:'Versendet', abgeschlossen:'Abgeschlossen', entwurf:'Entwurf'};
            var html = '';
            items.forEach(function(b) {
                var c = statusColor[b.status] ?? '#6c757d';
                var l = statusLabel[b.status] ?? b.status;
                html += '<div class="bf-card">';
                html += '<div style="min-width:0;flex:1;"><div style="font-family:monospace;font-size:0.72rem;color:var(--bs-secondary-color);">BF-'+String(b.id).padStart(4,'0')+'</div>';
                html += '<div style="font-size:0.85rem;font-weight:600;">'+esc(b.datum ? new Date(b.datum).toLocaleDateString('de-DE') : '—')+'</div>';
                if (b.ersteller_name) html += '<div style="font-size:0.72rem;color:var(--bs-secondary-color);">'+esc(b.ersteller_name)+'</div>';
                html += '</div>';
                html += '<span style="font-size:0.65rem;padding:2px 8px;border-radius:6px;background:'+esc(c)+'22;color:'+esc(c)+';border:1px solid '+esc(c)+'44;white-space:nowrap;">'+esc(l)+'</span>';
                html += '<a href="/patienten/'+patientId+'/befunde/'+b.id+'" class="btn btn-sm btn-outline-secondary" style="font-size:0.75rem;padding:3px 8px;white-space:nowrap;">Ansehen</a>';
                html += '</div>';
            });
            container.innerHTML = html;
        })
        .catch(function() { container.innerHTML = '<a href="/patienten/'+patientId+'/befunde" class="btn btn-sm btn-outline-secondary">Alle Befundbögen anzeigen</a>'; });
}

/* --- Tierarztberichte --- */
function loadVetReports(patientId) {
    if (_vrLoaded) return;
    _vrLoaded = true;
    var container = document.getElementById('pd-vr-list');
    var countEl   = document.getElementById('pd-vr-count');
    fetch('/patienten/'+patientId+'/tierarztbericht/verlauf')
        .then(function(r){return r.json();})
        .then(function(data) {
            var reports = data.reports || [];
            if (countEl && reports.length) { countEl.textContent = reports.length; countEl.style.display = ''; }
            if (!reports.length) { container.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--bs-secondary-color);font-size:0.85rem;">Noch keine Tierarztberichte vorhanden.<br><br><a href="/patienten/'+patientId+'/tierarztbericht" target="_blank" class="btn btn-primary btn-sm">Ersten Bericht erstellen</a></div>'; return; }
            var html = '';
            reports.forEach(function(r) {
                var date = r.created_at ? r.created_at.substring(0,10).split('-').reverse().join('.') : '—';
                var time = r.created_at ? r.created_at.substring(11,16) : '';
