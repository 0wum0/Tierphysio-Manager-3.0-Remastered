{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% set active_nav = 'dashboard' %}

{% block head %}
<style>
    /* KPI-Karten: das gesamte Card ist klickbar (entire-card link pattern).
       Praxis-Dashboard nutzt eigene Regeln in app.css — dieser Scope ist auf
       die Hundeschul-Dashboard-spezifische Klasse `kpi-link` begrenzt. */
    .kpi-link { display:block; text-decoration:none; color:inherit; transition:transform .12s ease, box-shadow .12s ease; }
    .kpi-link:hover { transform:translateY(-1px); box-shadow:0 6px 20px rgba(0,0,0,0.12); text-decoration:none; color:inherit; }
    .kpi-link .card { height:100%; }
    .kpi-label { text-transform:uppercase; font-size:.72rem; letter-spacing:.05em; color:var(--bs-secondary-color); margin-bottom:.25rem; }
    .kpi-value { font-weight:700; font-size:1.6rem; line-height:1.1; }
    .kpi-sub   { font-size:.78rem; color:var(--bs-secondary-color); margin-top:.25rem; }
</style>
{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Hundeschul-Übersicht</h1>
        <p class="page-subtitle">{{ 'now'|date('l, d. F Y') }}</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        {% if features.dogschool_courses ?? false %}
        <a href="/kurse/neu" class="btn btn-primary btn-sm">+ Neuer Kurs</a>
        {% endif %}
        {% if features.dogschool_leads ?? false %}
        <a href="/interessenten/neu" class="btn btn-outline-primary btn-sm">+ Interessent</a>
        {% endif %}
        {% if features.dogschool_packages ?? false %}
        <a href="/pakete" class="btn btn-outline-primary btn-sm">Paket verkaufen</a>
        {% endif %}
    </div>
</div>

{# ══════════════════════════════════════════════════════════
   KURS-KPIs (immer sichtbar — Kernbestandteil der Hundeschule)
   Klickbar: Kurse-Liste ggf. mit Status-Filter, Warteliste direkt.
   ══════════════════════════════════════════════════════════ #}
<div class="row g-3 mb-3">
    <div class="col-md-6 col-lg-3">
        <a href="/kurse?status=active" class="kpi-link">
            <div class="card"><div class="card-body">
                <div class="kpi-label">Aktive Kurse</div>
                <div class="kpi-value">{{ stats.active_courses }}</div>
                <div class="kpi-sub">Liste öffnen →</div>
            </div></div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        <a href="/kurse" class="kpi-link">
            <div class="card"><div class="card-body">
                <div class="kpi-label">Freie Plätze</div>
                <div class="kpi-value" style="color:#22c55e;">{{ stats.free_spots_total }}</div>
                <div class="kpi-sub">über alle Kurse</div>
            </div></div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        <a href="/kurse?status=full" class="kpi-link">
            <div class="card"><div class="card-body">
                <div class="kpi-label">Volle Kurse</div>
                <div class="kpi-value" style="color:#fbbf24;">{{ stats.full_courses }}</div>
                <div class="kpi-sub">ausgebucht</div>
            </div></div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        {% if features.dogschool_waitlist ?? false %}
        <a href="/warteliste" class="kpi-link">
            <div class="card"><div class="card-body">
                <div class="kpi-label">Warteliste</div>
                <div class="kpi-value">{{ stats.waitlist_total }}</div>
                <div class="kpi-sub">wartende Anmeldungen →</div>
            </div></div>
        </a>
        {% else %}
        <div class="card h-100"><div class="card-body">
            <div class="kpi-label">Warteliste</div>
            <div class="kpi-value">{{ stats.waitlist_total }}</div>
        </div></div>
        {% endif %}
    </div>
</div>

{# ══════════════════════════════════════════════════════════
   FINANZ-KPIs (nur wenn dogschool_invoicing aktiv)
   Klickbar: direkt gefilterte Hundeschul-Rechnungsliste.
   Filter-Defaults:
     - Offen    → status=open
     - Überfällig → status=overdue  (Controller behandelt overdue auch als open+abgelaufen,
                    List-Filter zeigt beides via status=overdue weil markOverdueAutomatic
                    regelmäßig via Cron läuft)
     - Bezahlt  → status=paid + Zeitraum dieses Monats / Jahr
   ══════════════════════════════════════════════════════════ #}
{% if invoice_stats %}
{# Deutsche Monatsnamen — PHP date('M') liefert sonst englische 3-Letter-Abk.
   die je nach Server-Locale uneinheitlich sind. Hardcoded-Array garantiert
   konsistente Beschriftung unabhängig von der Locale des Servers. #}
{% set de_months = ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'] %}
{% set current_month_name = de_months[('now'|date('n')) - 1] %}
{% set current_year       = 'now'|date('Y') %}

<div class="row g-3 mb-3">
    <div class="col-md-6 col-lg-3">
        <a href="/hundeschule/rechnungen?status=open" class="kpi-link">
            <div class="card"><div class="card-body">
                <div class="kpi-label">Offene Rechnungen</div>
                <div class="kpi-value" style="color:#60a5fa;">{{ invoice_stats.open_count }}</div>
                <div class="kpi-sub">{{ invoice_stats.open_amount|number_format(2, ',', '.') }} € offen</div>
            </div></div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        <a href="/hundeschule/rechnungen?status=overdue" class="kpi-link">
            <div class="card"><div class="card-body">
                <div class="kpi-label">Überfällig</div>
                <div class="kpi-value" style="color:#ef4444;">{{ invoice_stats.overdue_count }}</div>
                <div class="kpi-sub">{{ invoice_stats.overdue_amount|number_format(2, ',', '.') }} € fällig</div>
            </div></div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        <a href="/hundeschule/rechnungen?status=paid&from={{ 'now'|date('Y-m-01') }}&to={{ 'now'|date('Y-m-d') }}" class="kpi-link">
            <div class="card"><div class="card-body">
                <div class="kpi-label">Einnahmen {{ current_month_name }}</div>
                <div class="kpi-value" style="color:#22c55e;">{{ invoice_stats.paid_amount_month|number_format(2, ',', '.') }} €</div>
                <div class="kpi-sub">
                    {{ invoice_stats.paid_count_month }}
                    {{ invoice_stats.paid_count_month == 1 ? 'bezahlte Rechnung' : 'bezahlte Rechnungen' }}
                </div>
            </div></div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        <a href="/hundeschule/rechnungen?status=paid&from={{ 'now'|date('Y-01-01') }}&to={{ 'now'|date('Y-m-d') }}" class="kpi-link">
            <div class="card"><div class="card-body">
                <div class="kpi-label">Einnahmen {{ current_year }}</div>
                <div class="kpi-value" style="color:#22c55e;">{{ invoice_stats.paid_amount_year|number_format(2, ',', '.') }} €</div>
                <div class="kpi-sub">
                    {{ invoice_stats.paid_count_year }}
                    {{ invoice_stats.paid_count_year == 1 ? 'bezahlte Rechnung' : 'bezahlte Rechnungen' }}
                </div>
            </div></div>
        </a>
    </div>
</div>

{# Zusätzliche Zeile: Gesamt-Rechnungsvolumen (alle Zeiten, ohne Status-Filter).
   Gibt dem Trainer auf einen Blick sein komplettes geschäftliches Volumen —
   unabhängig davon, ob manuell oder übers Portal entstanden. #}
<div class="row g-3 mb-3">
    <div class="col-md-6 col-lg-4">
        <a href="/hundeschule/rechnungen" class="kpi-link">
            <div class="card"><div class="card-body">
                <div class="kpi-label">Rechnungen gesamt</div>
                <div class="kpi-value">{{ invoice_stats.total_count }}</div>
                <div class="kpi-sub">alle Rechnungen anzeigen →</div>
            </div></div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card"><div class="card-body">
            <div class="kpi-label">Rechnungsvolumen gesamt</div>
            <div class="kpi-value" style="color:#22c55e;">{{ invoice_stats.total_amount|number_format(2, ',', '.') }} €</div>
            <div class="kpi-sub">über alle Zeiträume (brutto, ohne Stornos)</div>
        </div></div>
    </div>
    <div class="col-md-6 col-lg-4">
        <a href="/hundeschule/rechnungen/erstellen" class="kpi-link">
            <div class="card"><div class="card-body" style="display:flex;align-items:center;gap:.75rem;">
                <div style="width:40px;height:40px;border-radius:10px;background:rgba(124,58,237,.14);display:flex;align-items:center;justify-content:center;">
                    <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </div>
                <div>
                    <div class="kpi-label" style="margin-bottom:.15rem;">Schnellaktion</div>
                    <div style="font-weight:600;">Neue Rechnung erstellen</div>
                </div>
            </div></div>
        </a>
    </div>
</div>
{% endif %}

{# ══════════════════════════════════════════════════════════
   ANFRAGEN / LEADS (feature-gegated, beide optional)
   ══════════════════════════════════════════════════════════ #}
{% if (features.dogschool_online_booking ?? false) or (features.dogschool_leads ?? false) %}
<div class="row g-3 mb-4">
    {% if features.dogschool_online_booking ?? false %}
    <div class="col-md-6">
        <a href="/anfragen" class="kpi-link">
            <div class="card"><div class="card-body">
                <div class="kpi-label">Neue Buchungsanfragen</div>
                <div class="kpi-value" style="color:#a78bfa;">{{ new_booking_requests }}</div>
                <div class="kpi-sub">aus Online-Buchung — Details öffnen →</div>
            </div></div>
        </a>
    </div>
    {% endif %}
    {% if features.dogschool_leads ?? false %}
    <div class="col-md-6">
        <a href="/interessenten" class="kpi-link">
            <div class="card"><div class="card-body">
                <div class="kpi-label">Aktive Interessenten</div>
                <div class="kpi-value" style="color:#60a5fa;">{{ active_leads }}</div>
                <div class="kpi-sub">Status „neu" oder „kontaktiert" →</div>
            </div></div>
        </a>
    </div>
    {% endif %}
</div>
{% endif %}

<div class="row g-3">
    {# ── Heute ── #}
    <div class="col-lg-6">
        <div class="card mb-3">
            <div class="card-header px-4 py-3">
                <span class="fw-semibold">Heute ({{ today_sessions|length }})</span>
            </div>
            <div class="card-body px-0 py-0">
                {% if today_sessions|length == 0 %}
                    <div class="text-center py-4" style="color:var(--bs-secondary-color);font-size:0.9rem;">Keine Termine heute.</div>
                {% else %}
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Zeit</th><th>Kurs</th><th>Teilnehmer</th><th></th></tr></thead>
                        <tbody>
                        {% for s in today_sessions %}
                            <tr>
                                <td class="fw-semibold">{{ s.start_time|slice(0, 5) }}</td>
                                <td>
                                    <a href="/kurse/{{ s.course_id }}" style="color:var(--bs-body-color);text-decoration:none;font-weight:500;">{{ s.course_name }}</a>
                                    {% if s.topic %}<div class="small" style="color:var(--bs-secondary-color);">{{ s.topic }}</div>{% endif %}
                                    {% if s.location %}<div class="small" style="color:var(--bs-secondary-color);">{{ s.location }}</div>{% endif %}
                                </td>
                                <td>{{ s.enrolled_count }}/{{ s.max_participants }}</td>
                                <td class="text-end">
                                    {% if features.dogschool_attendance ?? false %}
                                    <a href="/anwesenheit/session/{{ s.id }}" class="btn btn-sm btn-link">Anwesenheit</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Nächste 7 Tage ── #}
    <div class="col-lg-6">
        <div class="card mb-3">
            <div class="card-header px-4 py-3">
                <span class="fw-semibold">Nächste 7 Tage</span>
            </div>
            <div class="card-body px-0 py-0">
                {% if upcoming_sessions|length == 0 %}
                    <div class="text-center py-4" style="color:var(--bs-secondary-color);font-size:0.9rem;">Keine anstehenden Termine.</div>
                {% else %}
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Datum</th><th>Zeit</th><th>Kurs</th><th>Teilnehmer</th></tr></thead>
                        <tbody>
                        {% for s in upcoming_sessions|slice(0, 15) %}
                            <tr>
                                <td class="small">{{ s.session_date|date('D, d.m.') }}</td>
                                <td>{{ s.start_time|slice(0, 5) }}</td>
                                <td><a href="/kurse/{{ s.course_id }}" style="color:var(--bs-body-color);text-decoration:none;">{{ s.course_name }}</a></td>
                                <td>{{ s.enrolled_count }}/{{ s.max_participants }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Offene Anwesenheiten ── #}
    {% if features.dogschool_attendance ?? false %}
    <div class="col-12">
        <div class="card">
            <div class="card-header px-4 py-3">
                <span class="fw-semibold">Anwesenheit noch offen ({{ open_sessions|length }})</span>
            </div>
            <div class="card-body px-0 py-0">
                {% if open_sessions|length == 0 %}
                    <div class="text-center py-4" style="color:var(--bs-secondary-color);font-size:0.9rem;">Keine offenen Einträge.</div>
                {% else %}
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Datum</th><th>Kurs</th><th>Zeit</th><th></th></tr></thead>
                        <tbody>
                        {% for s in open_sessions %}
                            <tr>
                                <td>{{ s.session_date|date('d.m.Y') }}</td>
                                <td>{{ s.course_name }}</td>
                                <td>{{ s.start_time|slice(0, 5) }}</td>
                                <td class="text-end"><a href="/anwesenheit/session/{{ s.id }}" class="btn btn-sm btn-primary">Jetzt markieren</a></td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
