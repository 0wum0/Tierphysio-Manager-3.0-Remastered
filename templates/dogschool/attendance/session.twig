{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% set active_nav = 'attendance' %}

{% block content %}
<div class="page-header">
    <div>
        <a href="/anwesenheit" class="btn btn-link btn-sm mb-2">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="vertical-align:-2px;"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            Übersicht
        </a>
        <h1 class="page-title">Anwesenheit: {{ session.course_name }}</h1>
        <p class="page-subtitle">
            Einheit {{ session.session_number }} ·
            {{ session.session_date|date('d.m.Y') }} ·
            {{ session.start_time|slice(0, 5) }} Uhr
        </p>
    </div>
    <a href="/kurse/{{ session.course_id }}" class="btn btn-secondary btn-sm">Zum Kurs</a>
</div>

<form method="POST" action="/anwesenheit/session/{{ session.id }}">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    <div class="card">
        <div class="card-body px-0 py-0">
            {% if rows|length == 0 %}
                <div class="text-center py-5" style="color:var(--bs-secondary-color);">
                    Keine aktiven Teilnehmer. Schreibe zuerst Hunde in den Kurs ein.
                </div>
            {% else %}
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Hund</th>
                            <th>Halter</th>
                            <th style="width:200px;">Status</th>
                            <th>Notiz</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for r in rows %}
                        <tr>
                            <td>
                                <a href="/patienten/{{ r.patient_id }}" style="color:var(--bs-body-color);text-decoration:none;font-weight:600;">{{ r.patient_name }}</a>
                                {% if r.patient_breed %}<div class="small" style="color:var(--bs-secondary-color);">{{ r.patient_breed }}</div>{% endif %}
                            </td>
                            <td class="small" style="color:var(--bs-secondary-color);">{{ r.owner_first_name }} {{ r.owner_last_name }}</td>
                            <td>
                                <select name="attendance[{{ r.enrollment_id }}]" class="form-select form-select-sm">
                                    {% for key, label in statuses %}
                                    <option value="{{ key }}" {% if (r.attendance_status|default('present')) == key %}selected{% endif %}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </td>
                            <td>
                                <input type="text" name="notes[{{ r.enrollment_id }}]" value="{{ r.attendance_notes|default('') }}" class="form-control form-control-sm" placeholder="Optional">
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    </div>

    {% if rows|length > 0 %}
    <div class="d-flex justify-content-end gap-2 mt-3">
        <button type="submit" class="btn btn-primary">Anwesenheit speichern</button>
    </div>
    {% endif %}
</form>
{% endblock %}
