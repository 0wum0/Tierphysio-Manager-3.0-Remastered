<!DOCTYPE html>
<html lang="de" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Buchungsanfrage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #0f172a; color: #e2e8f0; padding: 40px 20px; }
        .booking-card { max-width: 720px; margin: 0 auto; }
        .honeypot { position:absolute;left:-9999px;opacity:0;pointer-events:none; }
    </style>
</head>
<body>
    <div class="booking-card">
        <div class="text-center mb-4">
            <h1>Buchungsanfrage</h1>
            <p class="text-secondary">Gib deine Daten ein und wir melden uns zeitnah bei dir zurück.</p>
        </div>

        {% if session_flash.error %}
        <div class="alert alert-danger">{{ session_flash.error }}</div>
        {% endif %}

        <form action="/buchung" method="POST" class="card">
            <div class="card-body p-4">
                {# Honeypot — unsichtbar für echte User #}
                <input type="text" name="website" class="honeypot" tabindex="-1" autocomplete="off">

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Vorname *</label>
                        <input type="text" name="first_name" required class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Nachname *</label>
                        <input type="text" name="last_name" required class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">E-Mail *</label>
                        <input type="email" name="email" required class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Telefon</label>
                        <input type="tel" name="phone" class="form-control">
                    </div>
                </div>

                <hr class="my-4">
                <h5 class="mb-3">Dein Hund</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name des Hundes</label>
                        <input type="text" name="dog_name" class="form-control">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Rasse</label>
                        <input type="text" name="dog_breed" class="form-control">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Alter (Monate)</label>
                        <input type="number" name="dog_age_months" min="0" class="form-control">
                    </div>
                </div>

                <hr class="my-4">
                <h5 class="mb-3">Interesse an</h5>
                <div class="mb-3">
                    <select name="requested_for" class="form-select mb-3">
                        <option value="course">Kursbuchung</option>
                        <option value="trial">Probetraining</option>
                        <option value="consultation">Beratungsgespräch</option>
                    </select>
                    {% if courses|length > 0 %}
                    <label class="form-label">Konkreter Kurs (optional)</label>
                    <select name="course_id" class="form-select">
                        <option value="">— unabhängig vom Kurs —</option>
                        {% for c in courses %}
                        <option value="{{ c.id }}">
                            {{ c.name }}{% if c.start_date %} (ab {{ c.start_date|date('d.m.Y') }}){% endif %}
                            – {{ c.enrolled }}/{{ c.max_participants }} Plätze
                        </option>
                        {% endfor %}
                    </select>
                    {% endif %}
                </div>

                <div class="mb-3">
                    <label class="form-label">Nachricht (optional)</label>
                    <textarea name="message" rows="3" class="form-control" placeholder="Was wäre dein Anliegen?"></textarea>
                </div>

                {# DSGVO-Einwilligung — explizite Checkbox inkl. Link zur
                   Datenschutzerklärung. Pflichtfeld, damit keine Anfrage
                   ohne aktive Zustimmung zustande kommt. #}
                <div class="form-check mb-3 mt-2">
                    <input class="form-check-input" type="checkbox" name="gdpr_consent"
                           id="gdpr_consent" value="1" required>
                    <label class="form-check-label small text-secondary" for="gdpr_consent">
                        Ich habe die
                        <a href="/datenschutz" target="_blank" rel="noopener"
                           class="text-info text-decoration-underline">Datenschutzerklärung</a>
                        gelesen und willige in die Verarbeitung meiner Daten zum Zweck der
                        Kontaktaufnahme ein (DSGVO Art. 6 Abs. 1 lit. a). Meine Einwilligung
                        kann ich jederzeit widerrufen.
                        <span class="text-danger">*</span>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100">Anfrage senden</button>
            </div>
        </form>
    </div>
</body>
</html>
