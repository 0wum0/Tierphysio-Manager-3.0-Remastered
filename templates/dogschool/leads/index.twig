{% extends 'layouts/base.twig' %}
{% set active_nav = 'leads' %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Interessenten</h1>
        <p class="page-subtitle">{{ pagination.total }} Einträge</p>
    </div>
    <a href="/interessenten/neu" class="btn btn-primary">+ Neuer Interessent</a>
</div>

<div class="row g-3 mb-3">
    {% for key, label in status_list %}{% if key != '' %}
    <div class="col"><div class="card"><div class="card-body py-2">
        <div class="small" style="color:var(--bs-secondary-color);">{{ label }}</div>
        <div class="fw-bold" style="font-size:1.25rem;">{{ counts[key] ?? 0 }}</div>
    </div></div></div>
    {% endif %}{% endfor %}
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="GET" action="/interessenten" class="d-flex gap-2 align-items-end flex-wrap">
            <input type="text" name="q" value="{{ filter_q }}" placeholder="Name, E-Mail, Hund…" class="form-control form-control-sm" style="flex:1 1 240px;">
            <select name="status" class="form-select form-select-sm" style="width:auto;">
                {% for key, label in status_list %}
                <option value="{{ key }}" {% if filter_status == key %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
            <button type="submit" class="btn btn-secondary btn-sm">Filtern</button>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>Name</th><th>Kontakt</th><th>Hund</th><th>Interesse</th><th>Status</th><th>Follow-up</th><th></th></tr>
            </thead>
            <tbody>
            {% for l in pagination.items %}
                <tr>
                    <td><a href="/interessenten/{{ l.id }}" style="color:var(--bs-body-color);text-decoration:none;font-weight:600;">{{ l.first_name }} {{ l.last_name }}</a></td>
                    <td class="small">
                        {% if l.email %}{{ l.email }}<br>{% endif %}
                        {% if l.phone %}{{ l.phone }}{% endif %}
                    </td>
                    <td>{{ l.dog_name }}{% if l.dog_breed %} <span class="small" style="color:var(--bs-secondary-color);">({{ l.dog_breed }})</span>{% endif %}</td>
                    <td class="small">{{ l.interest|default('–') }}</td>
                    <td>
                        {% set sc = {'new':'#60a5fa','contacted':'#fbbf24','trial_scheduled':'#a78bfa','trial_done':'#a78bfa','converted':'#22c55e','lost':'#ef4444','archived':'#64748b'}[l.status] ?? '#64748b' %}
                        <span class="badge" style="background:{{ sc }}22;color:{{ sc }};border:1px solid {{ sc }}44;">{{ status_list[l.status] ?? l.status }}</span>
                    </td>
                    <td class="small">{{ l.next_followup_at ? l.next_followup_at|date('d.m.Y H:i') : '–' }}</td>
                    <td class="text-end"><a href="/interessenten/{{ l.id }}" class="btn btn-sm btn-link">Öffnen</a></td>
                </tr>
            {% else %}
                <tr><td colspan="7" class="text-center py-4" style="color:var(--bs-secondary-color);">Keine Einträge.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
