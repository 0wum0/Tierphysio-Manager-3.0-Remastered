{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% set active_nav = 'training_plans' %}

{% block content %}
<div class="page-header">
    <div>
        <a href="/trainingsplaene" class="btn btn-link btn-sm mb-2">← Alle Pläne</a>
        <h1 class="page-title">{{ plan.name }}</h1>
        <p class="page-subtitle">
            {{ plan.duration_weeks }} Wochen · {{ plan.sessions_per_week }}×/Woche ·
            {{ plan.difficulty }}{% if plan.target_audience %} · {{ plan.target_audience }}{% endif %}
        </p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modal-assign">Hund zuweisen</button>
        {% if not plan.is_system %}
            <a href="/trainingsplaene/{{ plan.id }}/bearbeiten" class="btn btn-secondary">Bearbeiten</a>
        {% endif %}
    </div>
</div>

{% if plan.description %}
<div class="card mb-3"><div class="card-body">{{ plan.description|nl2br }}</div></div>
{% endif %}

<div class="card mb-3">
    <div class="card-header px-4 py-3 d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Curriculum ({{ plan.exercises|length }} Übungen)</span>
        {% if not plan.is_system %}
        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modal-add-exercise">+ Übung</button>
        {% endif %}
    </div>
    <div class="card-body px-0 py-0">
    {% if plan.curriculum is empty %}
        <div class="text-center py-4" style="color:var(--bs-secondary-color);">Noch keine Übungen zugeordnet.</div>
    {% else %}
        {% for week, sessions in plan.curriculum %}
            <div class="px-4 py-3" style="border-top:1px solid var(--bs-border-color);">
                <h6 style="font-size:0.85rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--bs-secondary-color);">Woche {{ week }}</h6>
                {% for session, exs in sessions %}
                <div class="mb-2">
                    <div class="small mb-1" style="color:var(--bs-secondary-color);">Einheit {{ session }}</div>
                    {% for ex in exs %}
                        {% set cat_color = categories[ex.category][1]|default('#60a5fa') %}
                        <div class="d-flex align-items-center gap-2 p-2 mb-1 rounded" style="background:rgba(255,255,255,0.02);border:1px solid {{ cat_color }}22;">
                            <div style="width:4px;height:28px;background:{{ cat_color }};border-radius:2px;"></div>
                            <div style="flex:1;">
                                <div class="fw-semibold">{{ ex.exercise_name }}</div>
                                <div class="small" style="color:var(--bs-secondary-color);">
                                    {{ categories[ex.category][0]|default(ex.category) }} · {{ ex.difficulty }} · {{ ex.duration_minutes }} Min
                                </div>
                            </div>
                            {% if not plan.is_system %}
                            <form action="/trainingsplaene/{{ plan.id }}/uebungen/{{ ex.id }}/entfernen" method="POST" style="margin:0;">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-sm btn-link" style="color:#ef4444;" onclick="return confirm('Entfernen?');">×</button>
                            </form>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
                {% endfor %}
            </div>
        {% endfor %}
    {% endif %}
    </div>
</div>

{# ── Modal: Zuweisen ── #}
<div class="modal fade" id="modal-assign" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/trainingsplaene/{{ plan.id }}/zuweisen" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="modal-header">
                    <h5 class="modal-title">Plan einem Hund zuweisen</h5>
                    <button type="button" class="modal-close" data-bs-dismiss="modal">×</button>
                </div>
                <div class="modal-body">
                    {% if plan.is_template %}
                    <div class="alert alert-info" style="font-size:0.85rem;">
                        Dies ist eine Vorlage — eine individuelle Kopie wird für den Hund angelegt.
                    </div>
                    {% endif %}
                    <div class="mb-3">
                        <label class="form-label">Hund (Patient-ID)</label>
                        <input type="number" name="patient_id" required class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Startdatum</label>
                        <input type="date" name="start_date" value="{{ 'now'|date('Y-m-d') }}" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notizen (optional)</label>
                        <textarea name="notes" rows="2" class="form-control"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Zuweisen</button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ── Modal: Übung hinzufügen ── #}
{% if not plan.is_system %}
<div class="modal fade" id="modal-add-exercise" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/trainingsplaene/{{ plan.id }}/uebungen" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="modal-header">
                    <h5 class="modal-title">Übung hinzufügen</h5>
                    <button type="button" class="modal-close" data-bs-dismiss="modal">×</button>
                </div>
                <div class="modal-body">
                    <div class="mb-2"><label class="form-label small">Übungs-ID</label>
                        <input type="number" name="exercise_id" required class="form-control form-control-sm">
                        <div class="form-text"><a href="/uebungen" target="_blank">→ Übungen-Katalog öffnen</a></div>
                    </div>
                    <div class="row g-2">
                        <div class="col-6"><label class="form-label small">Woche</label><input type="number" name="week_number" value="1" min="1" class="form-control form-control-sm"></div>
                        <div class="col-6"><label class="form-label small">Einheit</label><input type="number" name="session_number" value="1" min="1" class="form-control form-control-sm"></div>
                        <div class="col-6"><label class="form-label small">Wiederholungen</label><input type="number" name="target_repetitions" class="form-control form-control-sm"></div>
                        <div class="col-6"><label class="form-label small">Dauer (Min)</label><input type="number" name="target_duration_minutes" class="form-control form-control-sm"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Hinzufügen</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
