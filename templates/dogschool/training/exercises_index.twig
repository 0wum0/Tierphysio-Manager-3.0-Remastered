{% extends active_theme_layout ?? 'layouts/base.twig' %}
{% set active_nav = 'exercises' %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Übungen-Katalog</h1>
        <p class="page-subtitle">{{ exercises|length }} Übungen verfügbar</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modal-new-exercise">+ Eigene Übung</button>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="GET" action="/uebungen" class="d-flex gap-2 align-items-end flex-wrap">
            <input type="text" name="q" value="{{ filter_q }}" placeholder="Suche…" class="form-control form-control-sm" style="flex:1 1 240px;">
            <select name="category" class="form-select form-select-sm" style="width:auto;">
                <option value="">Alle Kategorien</option>
                {% for key, info in categories %}
                <option value="{{ key }}" {% if filter_category == key %}selected{% endif %}>{{ info[0] }}</option>
                {% endfor %}
            </select>
            <button type="submit" class="btn btn-secondary btn-sm">Filtern</button>
        </form>
    </div>
</div>

<div class="row g-3">
{% for ex in exercises %}
    {% set cat_color = categories[ex.category][1]|default('#60a5fa') %}
    {% set diff_color = {'easy':'#22c55e','medium':'#60a5fa','hard':'#f97316','expert':'#ef4444'}[ex.difficulty] ?? '#64748b' %}
    <div class="col-md-6 col-lg-4">
        <div class="card h-100" style="border-left:3px solid {{ cat_color }};">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <h6 style="font-size:0.95rem;margin-bottom:0.25rem;">
                        <a href="/uebungen/{{ ex.id }}" style="color:var(--bs-body-color);text-decoration:none;">{{ ex.name }}</a>
                    </h6>
                    <code class="small" style="font-size:0.7rem;color:var(--bs-secondary-color);">#{{ ex.id }}</code>
                </div>
                <div class="d-flex gap-1 mb-2 flex-wrap">
                    <span class="badge" style="background:{{ cat_color }}22;color:{{ cat_color }};border:1px solid {{ cat_color }}44;">{{ categories[ex.category][0]|default(ex.category) }}</span>
                    <span class="badge" style="background:{{ diff_color }}22;color:{{ diff_color }};border:1px solid {{ diff_color }}44;">{{ ex.difficulty }}</span>
                    <span class="badge bg-secondary">{{ ex.duration_minutes }} Min</span>
                </div>
                <p class="small mb-0" style="color:var(--bs-secondary-color);">{{ ex.description|slice(0, 140) }}{% if ex.description|length > 140 %}…{% endif %}</p>
            </div>
        </div>
    </div>
{% else %}
    <div class="col-12"><div class="card"><div class="card-body text-center py-5" style="color:var(--bs-secondary-color);">Keine Übungen gefunden.</div></div></div>
{% endfor %}
</div>

<div class="modal fade" id="modal-new-exercise" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form action="/uebungen" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="modal-header"><h5 class="modal-title">Neue Übung anlegen</h5><button type="button" class="modal-close" data-bs-dismiss="modal">×</button></div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-8"><label class="form-label">Name</label><input type="text" name="name" required class="form-control"></div>
                        <div class="col-md-4"><label class="form-label">Kategorie</label>
                            <select name="category" class="form-select">
                                {% for key, info in categories %}<option value="{{ key }}">{{ info[0] }}</option>{% endfor %}
                            </select></div>
                        <div class="col-md-4"><label class="form-label">Schwierigkeit</label>
                            <select name="difficulty" class="form-select">
                                <option value="easy">Einfach</option><option value="medium" selected>Mittel</option>
                                <option value="hard">Schwer</option><option value="expert">Experte</option>
                            </select></div>
                        <div class="col-md-4"><label class="form-label">Dauer (Min)</label><input type="number" name="duration_minutes" value="10" class="form-control"></div>
                        <div class="col-md-4"><label class="form-label">Min. Alter (Monate)</label><input type="number" name="min_age_months" class="form-control"></div>
                        <div class="col-12"><label class="form-label">Kurzbeschreibung</label><textarea name="description" rows="2" class="form-control"></textarea></div>
                        <div class="col-12"><label class="form-label">Anleitung / Aufbau</label><textarea name="instructions" rows="5" class="form-control"></textarea></div>
                        <div class="col-md-8"><label class="form-label">Benötigtes Equipment</label><input type="text" name="required_equipment" class="form-control"></div>
                        <div class="col-md-4"><label class="form-label">Video-URL (YouTube)</label><input type="url" name="video_url" class="form-control"></div>
                    </div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button><button type="submit" class="btn btn-primary">Anlegen</button></div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
