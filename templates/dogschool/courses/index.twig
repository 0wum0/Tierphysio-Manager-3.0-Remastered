{% extends 'layouts/base.twig' %}
{% set active_nav = 'courses' %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Kurse</h1>
        <p class="page-subtitle">{{ pagination.total }} {% if pagination.total == 1 %}Kurs{% else %}Kurse{% endif %}</p>
    </div>
    <a href="/kurse/neu" class="btn btn-primary">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Neuer Kurs
    </a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="GET" action="/kurse" class="d-flex flex-wrap gap-2 align-items-end">
            <div style="flex: 1 1 240px;">
                <label class="form-label" style="font-size:0.8rem;">Suche</label>
                <input type="text" name="q" value="{{ filter_q|default('') }}" placeholder="Kursname, Ort, Beschreibung…" class="form-control form-control-sm">
            </div>
            <div style="width: 220px;">
                <label class="form-label" style="font-size:0.8rem;">Status</label>
                <select name="status" class="form-select form-select-sm">
                    {% for key, label in status_list %}
                    <option value="{{ key }}" {% if filter_status == key %}selected{% endif %}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <button type="submit" class="btn btn-secondary btn-sm">Filtern</button>
                {% if filter_q or filter_status %}
                <a href="/kurse" class="btn btn-link btn-sm">Zurücksetzen</a>
                {% endif %}
            </div>
        </form>
    </div>
</div>

{% if pagination.items|length == 0 %}
    <div class="card">
        <div class="card-body text-center py-5" style="color:var(--bs-secondary-color);">
            <svg width="40" height="40" fill="none" viewBox="0 0 24 24" style="opacity:0.3;margin-bottom:12px;"><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <div style="font-size:0.95rem;margin-bottom:4px;">
                {% if filter_q or filter_status %}Keine Kurse passen zum Filter.{% else %}Noch keine Kurse angelegt.{% endif %}
            </div>
            <div style="font-size:0.85rem;opacity:0.7;margin-bottom:16px;">Lege deinen ersten Kurs an, um Teilnehmer einzuschreiben.</div>
            <a href="/kurse/neu" class="btn btn-primary btn-sm">Neuen Kurs anlegen</a>
        </div>
    </div>
{% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Kurs</th>
                        <th>Art</th>
                        <th>Start</th>
                        <th>Teilnehmer</th>
                        <th>Warteliste</th>
                        <th>Status</th>
                        <th style="width:80px;"></th>
                    </tr>
                </thead>
                <tbody>
                {% for c in pagination.items %}
                    <tr>
                        <td>
                            <a href="/kurse/{{ c.id }}" class="fw-semibold" style="color:var(--bs-body-color);text-decoration:none;">
                                {{ c.name }}
                            </a>
                            {% if c.location %}<div class="small" style="color:var(--bs-secondary-color);">{{ c.location }}</div>{% endif %}
                        </td>
                        <td>{{ type_list[c.type] ?? c.type }}</td>
                        <td>{{ c.start_date ? c.start_date|date('d.m.Y') : '–' }}</td>
                        <td>
                            <span class="fw-semibold">{{ c.enrolled_count ?? 0 }}</span>
                            <span style="color:var(--bs-secondary-color);">/ {{ c.max_participants }}</span>
                        </td>
                        <td>
                            {% if (c.waitlist_count ?? 0) > 0 %}
                                <span class="badge" style="background:rgba(251,191,36,0.15);color:#fbbf24;border:1px solid rgba(251,191,36,0.3);">{{ c.waitlist_count }}</span>
                            {% else %}
                                <span style="color:var(--bs-secondary-color);">–</span>
                            {% endif %}
                        </td>
                        <td>
                            {% set badge_color = {
                                'active':    '#22c55e',
                                'full':      '#fbbf24',
                                'completed': '#64748b',
                                'draft':     '#94a3b8',
                                'paused':    '#f97316',
                                'cancelled': '#ef4444'
                            }[c.status] ?? '#64748b' %}
                            <span class="badge" style="background:{{ badge_color }}22;color:{{ badge_color }};border:1px solid {{ badge_color }}44;">
                                {{ status_list[c.status] ?? c.status }}
                            </span>
                        </td>
                        <td class="text-end">
                            <a href="/kurse/{{ c.id }}" class="btn btn-sm btn-link">Öffnen</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if pagination.last_page > 1 %}
    <nav class="mt-3 d-flex justify-content-center">
        <ul class="pagination pagination-sm mb-0">
            {% for p in 1..pagination.last_page %}
                <li class="page-item {% if p == pagination.page %}active{% endif %}">
                    <a class="page-link" href="/kurse?page={{ p }}{% if filter_q %}&q={{ filter_q }}{% endif %}{% if filter_status %}&status={{ filter_status }}{% endif %}">{{ p }}</a>
                </li>
            {% endfor %}
        </ul>
    </nav>
    {% endif %}
{% endif %}
{% endblock %}
