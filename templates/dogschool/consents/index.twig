{% extends 'layouts/base.twig' %}
{% set active_nav = 'consents' %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Einwilligungen</h1>
        <p class="page-subtitle">Teilnahmebedingungen, Foto-/Video-Einverständnis, Haftungsausschlüsse</p>
    </div>
    <a href="/einwilligungen/neu" class="btn btn-primary">+ Neue Einwilligung</a>
</div>

<div class="card">
    <div class="card-body px-0 py-0">
        {% if consents|length == 0 %}
            <div class="text-center py-5" style="color:var(--bs-secondary-color);">Noch keine Vorlagen angelegt.</div>
        {% else %}
            <table class="table table-hover mb-0">
                <thead><tr><th>Name</th><th>Typ</th><th>Version</th><th>Pflicht</th><th>Status</th><th></th></tr></thead>
                <tbody>
                {% for c in consents %}
                    <tr>
                        <td><a href="/einwilligungen/{{ c.id }}" style="color:var(--bs-body-color);text-decoration:none;font-weight:600;">{{ c.name }}</a></td>
                        <td><span class="badge bg-secondary">{{ c.type }}</span></td>
                        <td>{{ c.version }}</td>
                        <td>{% if c.is_required %}<span class="badge" style="background:#ef444422;color:#ef4444;border:1px solid #ef444444;">Pflicht</span>{% else %}optional{% endif %}</td>
                        <td>{% if c.is_active %}<span class="badge" style="background:#22c55e22;color:#22c55e;border:1px solid #22c55e44;">aktiv</span>{% else %}inaktiv{% endif %}</td>
                        <td class="text-end"><a href="/einwilligungen/{{ c.id }}" class="btn btn-sm btn-link">Öffnen</a></td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
