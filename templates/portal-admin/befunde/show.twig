{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="/portal-admin/befunde" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            Alle Befundbögen
        </a>
        <h1 class="page-title">{{ page_title }}</h1>
        <span class="badge {% if befundbogen.status == 'versendet' %}bg-success{% elseif befundbogen.status == 'abgeschlossen' %}bg-primary{% else %}bg-secondary{% endif %}">
            {{ befundbogen.status|capitalize }}
        </span>
    </div>
    <div class="flex gap-2">
        <a href="/patienten/{{ patient.id }}/befunde/{{ befundbogen.id }}/bearbeiten" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Bearbeiten
        </a>
        <a href="/patienten/{{ patient.id }}/befunde/{{ befundbogen.id }}/pdf" target="_blank" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>
            PDF
        </a>
        {% if owner and owner.email %}
        <form method="POST" action="/portal-admin/befunde/{{ befundbogen.id }}/senden"
              onsubmit="return confirm('Befundbogen per E-Mail an {{ owner.email }} senden?');">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-primary btn-sm">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline stroke="currentColor" stroke-width="2" points="22,6 12,13 2,6"/></svg>
                Per E-Mail senden
            </button>
        </form>
        {% endif %}
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-3">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="fw-700 mb-3 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">Info</h6>
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Befundbogen-Nr.</div>
                    <div class="fw-700" style="font-family:monospace;">BF-{{ '%04d'|format(befundbogen.id) }}</div>
                </div>
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Datum</div>
                    <div class="fw-600">{{ befundbogen.datum|date('d.m.Y') }}</div>
                </div>
                {% if befundbogen.naechster_termin %}
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Nächster Termin</div>
                    <div class="fw-600">{{ befundbogen.naechster_termin|date('d.m.Y') }}</div>
                </div>
                {% endif %}
                {% if befundbogen.ersteller_name %}
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Erstellt von</div>
                    <div>{{ befundbogen.ersteller_name }}</div>
                </div>
                {% endif %}
                {% if befundbogen.pdf_sent_at %}
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Versendet</div>
                    <div class="text-sm text-success">{{ befundbogen.pdf_sent_at|date('d.m.Y H:i') }}</div>
                    {% if befundbogen.pdf_sent_to %}<div class="text-xs text-muted">{{ befundbogen.pdf_sent_to }}</div>{% endif %}
                </div>
                {% endif %}
                {% if befundbogen.notizen %}
                <hr>
                <div class="text-xs text-muted mb-1">Notizen</div>
                <div class="text-sm" style="white-space:pre-wrap;">{{ befundbogen.notizen }}</div>
                {% endif %}
            </div>
        </div>
        {% if patient %}
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="fw-700 mb-2 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">Patient</h6>
                <a href="/patienten/{{ patient.id }}" class="fw-700 text-decoration-none">{{ patient.name }}</a>
                {% if patient.species %}<div class="text-xs text-muted">{{ patient.species }}{% if patient.breed %} · {{ patient.breed }}{% endif %}</div>{% endif %}
            </div>
        </div>
        {% endif %}
        {% if owner %}
        <div class="card">
            <div class="card-body">
                <h6 class="fw-700 mb-2 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">Tierhalter</h6>
                <a href="/tierhalter/{{ owner.id }}" class="fw-700 text-decoration-none">{{ owner.first_name }} {{ owner.last_name }}</a>
                {% if owner.phone %}<div class="text-xs text-muted">{{ owner.phone }}</div>{% endif %}
                {% if owner.email %}<div class="text-xs text-muted">{{ owner.email }}</div>{% endif %}
            </div>
        </div>
        {% endif %}
    </div>

    <div class="col-lg-9">
        {% macro field_row(label, value) %}
            {% if value is not empty %}
            <dt class="col-sm-4 text-muted fw-600" style="font-size:.8rem;">{{ label }}</dt>
            <dd class="col-sm-8 mb-0" style="font-size:.9rem;">
                {% if value is iterable %}{{ value|join(', ') }}{% else %}{{ value }}{% endif %}
            </dd>
            {% endif %}
        {% endmacro %}

        {% macro section_card(title, fields, felder) %}
            {% set hasAny = false %}
            {% for key, lbl in fields %}{% if felder[key] is defined and felder[key] is not empty %}{% set hasAny = true %}{% endif %}{% endfor %}
            {% if hasAny %}
            <div class="card mb-4">
                <div class="card-header"><h5 class="card-title mb-0">{{ title }}</h5></div>
                <div class="card-body">
                    <dl class="row mb-0" style="row-gap:.5rem;">
                        {% for key, lbl in fields %}
                            {% if felder[key] is defined and felder[key] is not empty %}
                            <dt class="col-sm-4 text-muted fw-600" style="font-size:.8rem;">{{ lbl }}</dt>
                            <dd class="col-sm-8 mb-0" style="font-size:.9rem;">{% if felder[key] is iterable %}{{ felder[key]|join(', ') }}{% else %}{{ felder[key] }}{% endif %}</dd>
                            {% endif %}
                        {% endfor %}
                    </dl>
                </div>
            </div>
            {% endif %}
        {% endmacro %}

        {{ _self.section_card('Anamnese & Vorgeschichte', {
            'hauptbeschwerde':'Hauptbeschwerde','seit_wann':'Seit wann','vorerkrankungen':'Vorerkrankungen / OPs',
            'medikamente':'Medikamente','allergien':'Allergien','ernaehrung':'Ernährung',
            'bewegung':'Bewegung','haltung':'Haltung','bisherige_therapien':'Bisherige Therapien'
        }, felder) }}

        {{ _self.section_card('Allgemeinbefund', {
            'allgemeinbefinden':'Allgemeinbefinden','ernaehrungszustand':'Ernährungszustand','temperament':'Temperament',
            'koerpertemperatur':'Körpertemperatur','koerperhaltung':'Körperhaltung','gangbild':'Gangbild','lahmheitsgrad':'Lahmheitsgrad'
        }, felder) }}

        {{ _self.section_card('Bewegungsapparat & Muskulatur', {
            'betroffene_regionen':'Betroffene Regionen','muskeltonus':'Muskeltonus','triggerpunkte':'Triggerpunkte',
            'schmerz_nrs':'Schmerzskala NRS','gelenke_befund':'Gelenkbefund','neurologischer_status':'Neurologischer Status'
        }, felder) }}

        {{ _self.section_card('Naturheilkundliche Diagnostik', {
            'konstitutionstyp':'Konstitutionstyp','energetischer_eindruck':'Energetischer Eindruck',
            'bachblueten_emotionen':'Bach-Blüten Emotionen','bachblueten_auswahl':'Bach-Blüten Mischung',
            'bachblueten_dosierung':'Dosierung','homoeopathie_mittel':'Homöopathisches Mittel',
            'homoeopathie_potenz':'Potenz','homoeopathie_dauer':'Wiederholung','phytotherapie':'Phytotherapie',
            'schuesslersalze':'Schüssler Salze','weitere_naturheilmittel':'Weitere Mittel'
        }, felder) }}

        {{ _self.section_card('Physiotherapeutische Maßnahmen', {
            'pt_methoden':'Angewandte Methoden','therapieziele':'Therapieziele','hausaufgaben':'Hausaufgaben',
            'therapiefrequenz':'Frequenz','therapiedauer':'Dauer','kontrolltermin':'Kontrolltermin'
        }, felder) }}

        {{ _self.section_card('Verlauf & Notizen', {'verlauf_notizen':'Verlaufsnotizen'}, felder) }}

        {% if felder is empty %}
        <div class="card">
            <div class="card-body text-center py-4 text-muted">Keine Felder ausgefüllt.</div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
