{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/apexcharts@3/dist/apexcharts.min.js"></script>
<script>
/* ── Dashboard Chart Data (server-rendered) ── */
var _dashChartWeekly  = {{ chart_weekly  is defined and chart_weekly  is not empty ? chart_weekly|json_encode|replace({'</': '<\/'})|raw : '{"labels":[],"paid":[],"open":[],"overdue":[],"draft":[]}' }};
var _dashChartMonthly = {{ chart_monthly is defined and chart_monthly is not empty ? chart_monthly|json_encode|replace({'</': '<\/'})|raw : '{"labels":[],"paid":[],"open":[],"overdue":[],"draft":[]}' }};
var _dPatientSpecies   = {{ patients_by_species|default({})|json_encode|replace({'</': '<\/'})|raw }};
var _dApptType        = {{ appointments_by_type|default({})|json_encode|replace({'</': '<\/'})|raw }};
var _dRevPayment      = {{ revenue_by_payment|default({})|json_encode|replace({'</': '<\/'})|raw }};
var _dWeekday         = {{ appointments_weekday|default({})|json_encode|replace({'</': '<\/'})|raw }};
var _dTopOwners       = {{ top_owners|default({})|json_encode|replace({'</': '<\/'})|raw }};
var _dForecast        = {{ revenue_forecast|default({})|json_encode|replace({'</': '<\/'})|raw }};
var _dInvoiceInflow   = {{ invoice_inflow|default({})|json_encode|replace({'</': '<\/'})|raw }};
</script>
<script>
(function(){
    'use strict';

    var isDark     = document.documentElement.getAttribute('data-bs-theme') === 'dark';
    var textColor  = isDark ? '#94a3b8' : '#6b7280';
    var gridColor  = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';
    var bgCard     = isDark ? '#1e2a3a' : '#ffffff';

    /* ── Revenue Stacked Bar Chart (by status) ───────────────── */
    var cWeekly  = _dashChartWeekly;
    var cMonthly = _dashChartMonthly;

    /* Status colors: bezahlt=grün, offen=gelb, überfällig=rot, entwurf=grau */
    var statusColors  = ['#22c55e', '#f59e0b', '#ef4444', '#94a3b8'];
    var statusLabels  = ['Bezahlt', 'Offen', 'Überfällig', 'Entwurf'];
    var statusKeys    = ['paid', 'open', 'overdue', 'draft'];

    function buildSeries(d) {
        return statusKeys.map(function(k, i) {
            return { name: statusLabels[i], data: (d[k] || []).map(Number) };
        });
    }

    var _revenueChart = null;

    function initRevenueChart() {
        var revenueEl = document.getElementById('dash-revenue-chart');
        if (!revenueEl) return;
        /* destroy previous instance if re-initialising */
        if (_revenueChart) { try { _revenueChart.destroy(); } catch(e){} _revenueChart = null; }
        /* clear any previous ApexCharts inner HTML */
        revenueEl.innerHTML = '';
        try {
            _revenueChart = new ApexCharts(revenueEl, {
                chart: {
                    type: 'bar',
                    height: 280,
                    stacked: true,
                    toolbar: { show: false },
                    background: 'transparent',
                    fontFamily: 'inherit',
                    animations: { enabled: true, easing: 'easeinout', speed: 500 },
                    zoom: { enabled: false }
                },
                series: buildSeries(cWeekly),
                xaxis: {
                    categories: cWeekly.labels || [],
                    labels: { style: { colors: textColor, fontSize: '11px' }, rotate: -30 },
                    axisBorder: { show: false },
                    axisTicks: { show: false }
                },
                yaxis: {
                    labels: {
                        style: { colors: textColor, fontSize: '11px' },
                        formatter: function(v) {
                            return v >= 1000 ? (v/1000).toFixed(1)+'k €' : v.toFixed(0)+' €';
                        }
                    }
                },
                colors: statusColors,
                plotOptions: {
                    bar: {
                        columnWidth: '60%',
                        borderRadius: 2,
                        borderRadiusApplication: 'end'
                    }
                },
                grid: { borderColor: gridColor, strokeDashArray: 4, padding: { left: 4, right: 4 } },
                dataLabels: { enabled: false },
                tooltip: {
                    theme: isDark ? 'dark' : 'light',
                    x: { show: true },
                    y: { formatter: function(v) { return Number(v).toFixed(2).replace('.',',') + ' €'; } },
                    shared: true,
                    intersect: false
                },
                legend: {
                    show: true,
                    position: 'top',
                    horizontalAlign: 'right',
                    fontSize: '11px',
                    labels: { colors: textColor },
                    markers: { size: 7, shape: 'circle' }
                },
                noData: { text: 'Keine Daten vorhanden', style: { color: textColor } }
            });
            _revenueChart.render();
        } catch(e) {
            console.error('Revenue chart init failed:', e);
        }
    }

    /* Weekly / monthly toggle — use event delegation so it survives re-inits */
    document.addEventListener('click', function(e) {
        var btn = e.target.closest('#btn-weekly, #btn-monthly');
        if (!btn || !_revenueChart) return;
        var isWeekly = btn.id === 'btn-weekly';
        var d = isWeekly ? cWeekly : cMonthly;
        _revenueChart.updateOptions({ xaxis: { categories: d.labels || [] } }, false, false);
        _revenueChart.updateSeries(buildSeries(d));
        document.getElementById('btn-weekly')?.classList.toggle('active', isWeekly);
        document.getElementById('btn-monthly')?.classList.toggle('active', !isWeekly);
    });

    /* Re-init when SmartAdmin panel-collapse is toggled open */
    document.addEventListener('click', function(e) {
        var btn = e.target.closest('[data-action="panel-collapse"]');
        if (!btn) return;
        if (btn.closest('#panel-revenue-chart')) setTimeout(initRevenueChart, 350);
    });

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRevenueChart);
    } else {
        initRevenueChart();
    }

    /* ── Patient Sparkline ──────────────────────────────────── */
    var sparkEl = document.getElementById('dash-patient-sparkline');
    if (sparkEl) {
        var pLabels = {{ patient_trend.labels|json_encode|replace({'</': '<\/'})|raw }};
        var pData   = {{ patient_trend.data|json_encode|replace({'</': '<\/'})|raw }};
        new ApexCharts(sparkEl, {
            chart: {
                type: 'area',
                height: 60,
                sparkline: { enabled: true },
                background: 'transparent',
                animations: { enabled: true, speed: 400 }
            },
            series: [{ data: pData }],
            xaxis: { categories: pLabels },
            colors: ['#4f7cff'],
            fill: {
                type: 'gradient',
                gradient: { opacityFrom: 0.4, opacityTo: 0.0 }
            },
            stroke: { curve: 'smooth', width: 2 },
            tooltip: {
                theme: isDark ? 'dark' : 'light',
                x: { show: true },
                y: { formatter: function(v) { return v + ' Patient' + (v !== 1 ? 'en' : ''); } }
            }
        }).render();
    }

    /* ── Bezahlungsrate Radialbar ───────────────────────────── */
    var radialEl = document.getElementById('dash-paid-radial');
    if (radialEl) {
        var paidCount  = {{ stats.paid_count ?? 0 }};
        var openCount  = {{ stats.open_count ?? 0 }};
        var ovdCount   = {{ stats.overdue_count ?? 0 }};
        var totalInv   = paidCount + openCount + ovdCount;
        var paidPct    = totalInv > 0 ? Math.round((paidCount / totalInv) * 100) : 0;
        new ApexCharts(radialEl, {
            chart: {
                type: 'radialBar',
                height: 120,
                background: 'transparent',
                sparkline: { enabled: true },
                animations: { enabled: true, speed: 500 }
            },
            series: [paidPct],
            colors: ['#22c55e'],
            plotOptions: {
                radialBar: {
                    startAngle: -135,
                    endAngle: 135,
                    hollow: { size: '55%' },
                    track: { background: isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)', strokeWidth: '100%' },
                    dataLabels: {
                        name: { show: false },
                        value: {
                            fontSize: '18px',
                            fontWeight: 700,
                            color: '#22c55e',
                            offsetY: 6,
                            formatter: function(v) { return v + '%'; }
                        }
                    }
                }
            },
            stroke: { lineCap: 'round' },
            tooltip: { enabled: false }
        }).render();
    }

    /* ── Patienten + Tierhalter Bar ──────────────────────────────────── */
    var ownersEl = document.getElementById('dash-owners-bar');
    if (ownersEl) {
        var pLabels2 = {{ patient_trend.labels|json_encode|replace({'</': '<\/'})|raw }};
        var pData2   = {{ patient_trend.data|json_encode|replace({'</': '<\/'})|raw }};
        new ApexCharts(ownersEl, {
            chart: {
                type: 'bar',
                height: 60,
                sparkline: { enabled: true },
                background: 'transparent',
                animations: { enabled: true, speed: 400 }
            },
            series: [{ name: 'Neue Patienten', data: pData2 }],
            xaxis: { categories: pLabels2 },
            colors: ['#a855f7'],
            plotOptions: { bar: { borderRadius: 2, columnWidth: '60%' } },
            tooltip: {
                theme: isDark ? 'dark' : 'light',
                y: { formatter: function(v) { return v + ' neu'; } }
            }
        }).render();
    }

    /* ── Rechnungseingang 30 Tage (Area + Bar combo) ──────────── */
    var inflowEl = document.getElementById('dash-invoice-inflow');
    if (inflowEl && _dInvoiceInflow.labels) {
        try {
            new ApexCharts(inflowEl, {
                chart: { type: 'area', height: 220, toolbar: { show: false }, background: 'transparent', fontFamily: 'inherit', animations: { enabled: true, speed: 400 }, zoom: { enabled: false } },
                series: [
                    { name: 'Betrag (€)', type: 'area', data: (_dInvoiceInflow.amounts || []).map(Number) },
                    { name: 'Anzahl', type: 'line', data: (_dInvoiceInflow.counts || []).map(Number) }
                ],
                xaxis: { categories: _dInvoiceInflow.labels || [], labels: { style: { colors: textColor, fontSize: '10px' }, rotate: -45, rotateAlways: false, hideOverlappingLabels: true }, axisBorder: { show: false }, axisTicks: { show: false }, tickAmount: 10 },
                yaxis: [
                    { labels: { style: { colors: textColor, fontSize: '11px' }, formatter: function(v){ return v >= 1000 ? (v/1000).toFixed(1)+'k €' : v.toFixed(0)+' €'; } } },
                    { opposite: true, labels: { style: { colors: textColor, fontSize: '11px' }, formatter: function(v){ return Math.round(v)+'x'; } } }
                ],
                colors: ['#4f7cff', '#f59e0b'],
                fill: { type: ['gradient','solid'], gradient: { shadeIntensity: 1, opacityFrom: 0.35, opacityTo: 0.02, stops: [0,95] } },
                stroke: { curve: 'smooth', width: [2, 2] },
                grid: { borderColor: gridColor, strokeDashArray: 4 },
                dataLabels: { enabled: false },
                tooltip: { theme: isDark ? 'dark' : 'light', shared: true, intersect: false, y: [ { formatter: function(v){ return Number(v).toFixed(2).replace('.',',')+' €'; } }, { formatter: function(v){ return Math.round(v)+' Rechnungen'; } } ] },
                legend: { show: true, position: 'top', horizontalAlign: 'right', fontSize: '11px', labels: { colors: textColor } },
                noData: { text: 'Keine Daten', style: { color: textColor } }
            }).render();
        } catch(e) { console.error('inflow chart:', e); }
    }

    /* ── Umsatz-Prognose (Line: Ist + Forecast) ───────────────── */
    var forecastEl = document.getElementById('dash-forecast');
    if (forecastEl && _dForecast.labels) {
        try {
            new ApexCharts(forecastEl, {
                chart: { type: 'line', height: 260, toolbar: { show: false }, background: 'transparent', fontFamily: 'inherit', animations: { enabled: true, speed: 500 }, zoom: { enabled: false } },
                series: [
                    { name: 'Ist-Umsatz', data: (_dForecast.actual || []).map(function(v){ return v === null ? null : Number(v); }) },
                    { name: 'Prognose', data: (_dForecast.forecast || []).map(function(v){ return v === null ? null : Number(v); }) }
                ],
                xaxis: { categories: _dForecast.labels || [], labels: { style: { colors: textColor, fontSize: '11px' } }, axisBorder: { show: false }, axisTicks: { show: false } },
                yaxis: { labels: { style: { colors: textColor, fontSize: '11px' }, formatter: function(v){ return v >= 1000 ? (v/1000).toFixed(1)+'k €' : (v||0).toFixed(0)+' €'; } } },
                colors: ['#22c55e', '#a855f7'],
                stroke: { curve: 'smooth', width: [3, 2.5], dashArray: [0, 6] },
                markers: { size: [4, 5], colors: ['#22c55e','#a855f7'], strokeColors: bgCard, strokeWidth: 2 },
                fill: { type: ['gradient','solid'], gradient: { shadeIntensity:1, opacityFrom:0.25, opacityTo:0.02, stops:[0,95] }, opacity: [1, 0.7] },
                grid: { borderColor: gridColor, strokeDashArray: 4 },
                dataLabels: { enabled: false },
                tooltip: { theme: isDark ? 'dark' : 'light', shared: true, intersect: false, y: { formatter: function(v){ return v === null ? '—' : Number(v).toFixed(2).replace('.',',')+' €'; } } },
                legend: { show: true, position: 'top', horizontalAlign: 'right', fontSize: '11px', labels: { colors: textColor } },
                annotations: { xaxis: [{ x: (_dForecast.labels || [])[(_dForecast.actual||[]).length - 1], borderColor: '#a855f7', strokeDashArray: 4, label: { text: 'Prognose', style: { color: '#fff', background: '#a855f7', fontSize: '10px' } } }] },
                noData: { text: 'Keine Daten', style: { color: textColor } }
            }).render();
        } catch(e) { console.error('forecast chart:', e); }
    }

    /* ── Donut: Einnahmen nach Zahlungsart ────────────────────── */
    var donutPayEl = document.getElementById('dash-donut-payment');
    if (donutPayEl && _dRevPayment.data) {
        try {
            new ApexCharts(donutPayEl, {
                chart: { type: 'donut', height: 160, background: 'transparent', fontFamily: 'inherit', animations: { enabled: true, speed: 400 } },
                series: (_dRevPayment.data || []).map(Number),
                labels: _dRevPayment.labels || [],
                colors: _dRevPayment.colors || ['#4f7cff','#22c55e'],
                plotOptions: { pie: { donut: { size: '60%', labels: { show: true, total: { show: true, label: 'Gesamt', fontSize: '11px', color: textColor, formatter: function(w){ var s = w.globals.seriesTotals.reduce(function(a,b){return a+b;},0); return s >= 1000 ? (s/1000).toFixed(1)+'k €' : s.toFixed(0)+' €'; } } } } } },
                dataLabels: { enabled: false },
                legend: { show: true, position: 'bottom', fontSize: '11px', labels: { colors: textColor } },
                tooltip: { theme: isDark ? 'dark' : 'light', y: { formatter: function(v){ return Number(v).toFixed(2).replace('.',',')+' €'; } } },
                noData: { text: 'Keine Daten', style: { color: textColor } }
            }).render();
        } catch(e) { console.error('donut payment:', e); }
    }

    /* ── Donut: Termine nach Behandlungsart ─────────────────── */
    var donutApptEl = document.getElementById('dash-donut-appt-type');
    if (donutApptEl && _dApptType.data) {
        try {
            var apptColors = (_dApptType.colors || []).length ? _dApptType.colors : ['#4f7cff','#22c55e','#f59e0b','#ef4444','#a855f7','#06b6d4','#ec4899','#84cc16'];
            new ApexCharts(donutApptEl, {
                chart: { type: 'donut', height: 160, background: 'transparent', fontFamily: 'inherit', animations: { enabled: true, speed: 400 } },
                series: (_dApptType.data || []).map(Number),
                labels: _dApptType.labels || [],
                colors: apptColors,
                plotOptions: { pie: { donut: { size: '60%', labels: { show: true, total: { show: true, label: 'Termine', fontSize: '11px', color: textColor, formatter: function(w){ return w.globals.seriesTotals.reduce(function(a,b){return a+b;},0)+''; } } } } } },
                dataLabels: { enabled: false },
                legend: { show: true, position: 'bottom', fontSize: '11px', labels: { colors: textColor } },
                tooltip: { theme: isDark ? 'dark' : 'light', y: { formatter: function(v){ return v+' Termine'; } } },
                noData: { text: 'Keine Daten', style: { color: textColor } }
            }).render();
        } catch(e) { console.error('donut appt:', e); }
    }

    /* ── Terminauslastung nach Wochentag (Bar) ───────────────── */
    var weekdayEl = document.getElementById('dash-weekday');
    if (weekdayEl && _dWeekday.data) {
        try {
            var wdMax = Math.max.apply(null, _dWeekday.data || [1]);
            var wdColors = (_dWeekday.data || []).map(function(v){
                var ratio = wdMax > 0 ? v / wdMax : 0;
                if (ratio >= 0.8) return '#ef4444';
                if (ratio >= 0.5) return '#f59e0b';
                return '#22c55e';
            });
            new ApexCharts(weekdayEl, {
                chart: { type: 'bar', height: 220, toolbar: { show: false }, background: 'transparent', fontFamily: 'inherit', animations: { enabled: true, speed: 400 } },
                series: [{ name: 'Termine', data: (_dWeekday.data || []).map(Number) }],
                xaxis: { categories: _dWeekday.labels || [], labels: { style: { colors: textColor, fontSize: '12px' } }, axisBorder: { show: false }, axisTicks: { show: false } },
                yaxis: { labels: { style: { colors: textColor, fontSize: '11px' }, formatter: function(v){ return Math.round(v)+''; } } },
                colors: wdColors,
                plotOptions: { bar: { distributed: true, columnWidth: '55%', borderRadius: 4, borderRadiusApplication: 'end' } },
                grid: { borderColor: gridColor, strokeDashArray: 4 },
                dataLabels: { enabled: true, style: { fontSize: '11px', colors: [textColor] }, formatter: function(v){ return v > 0 ? v : ''; } },
                legend: { show: false },
                tooltip: { theme: isDark ? 'dark' : 'light', y: { formatter: function(v){ return v+' Termine'; } } },
                noData: { text: 'Keine Daten', style: { color: textColor } }
            }).render();
        } catch(e) { console.error('weekday chart:', e); }
    }

    /* ── Top Tierhalter Horizontal Bar ─────────────────────────── */
    var topOwnersEl = document.getElementById('dash-top-owners');
    if (topOwnersEl && _dTopOwners.data) {
        try {
            new ApexCharts(topOwnersEl, {
                chart: { type: 'bar', height: 220, toolbar: { show: false }, background: 'transparent', fontFamily: 'inherit', animations: { enabled: true, speed: 400 } },
                series: [{ name: 'Umsatz', data: (_dTopOwners.data || []).map(Number) }],
                xaxis: { categories: _dTopOwners.labels || [], labels: { style: { colors: textColor, fontSize: '11px' } } },
                yaxis: { labels: { style: { colors: textColor, fontSize: '10px' }, formatter: function(v){ return v >= 1000 ? (v/1000).toFixed(1)+'k €' : v.toFixed(0)+' €'; } } },
                colors: ['#4f7cff'],
                plotOptions: { bar: { horizontal: true, borderRadius: 4, borderRadiusApplication: 'end', barHeight: '55%' } },
                grid: { borderColor: gridColor, strokeDashArray: 4 },
                dataLabels: { enabled: false },
                tooltip: { theme: isDark ? 'dark' : 'light', y: { formatter: function(v){ return Number(v).toFixed(2).replace('.',',')+' €'; } } },
                noData: { text: 'Keine Daten', style: { color: textColor } }
            }).render();
        } catch(e) { console.error('top owners chart:', e); }
    }

    /* ── Patienten nach Tierart Donut ────────────────────────────── */
    var speciesEl = document.getElementById('dash-patient-species');
    if (speciesEl && _dPatientSpecies.data) {
        try {
            var speciesColors = ['#4f7cff','#22c55e','#f59e0b','#ef4444','#a855f7','#06b6d4','#ec4899','#84cc16','#f97316','#64748b'];
            new ApexCharts(speciesEl, {
                chart: { type: 'donut', height: 220, background: 'transparent', fontFamily: 'inherit', animations: { enabled: true, speed: 400 } },
                series: (_dPatientSpecies.data || []).map(Number),
                labels: _dPatientSpecies.labels || [],
                colors: speciesColors,
                plotOptions: { pie: { donut: { size: '55%', labels: { show: true, total: { show: true, label: 'Patienten', fontSize: '11px', color: textColor, formatter: function(w){ return w.globals.seriesTotals.reduce(function(a,b){return a+b;},0)+''; } } } } } },
                dataLabels: { enabled: false },
                legend: { show: true, position: 'bottom', fontSize: '11px', labels: { colors: textColor }, formatter: function(label, opts){ return label + ' (' + opts.w.globals.series[opts.seriesIndex] + ')'; } },
                tooltip: { theme: isDark ? 'dark' : 'light', y: { formatter: function(v){ return v+' Patienten'; } } },
                noData: { text: 'Keine Daten', style: { color: textColor } }
            }).render();
        } catch(e) { console.error('species chart:', e); }
    }

})();

/* ── Sortable drag & drop with server-side persistence ── */
(function() {
    var grid = document.getElementById('dashboard-grid');
    if (!grid || typeof Sortable === 'undefined') return;

    Sortable.create(grid, {
        handle: '.panel-hdr h2',
        animation: 200,
        ghostClass: 'panel-selected',
        onEnd: function() {
            var order = Array.from(grid.querySelectorAll('[data-panel-id]'))
                            .map(function(el) { return el.getAttribute('data-panel-id'); });
            fetch('/api/dashboard/layout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ layout: order })
            });
        }
    });
})();

/* ── Dashboard panel position reset ── */
function resetPanelState() {
    if (!confirm('Dashboard-Layout zurücksetzen?')) return;
    fetch('/api/dashboard/layout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ layout: null })
    }).then(function() { location.reload(); });
}
</script>
{% endblock %}
