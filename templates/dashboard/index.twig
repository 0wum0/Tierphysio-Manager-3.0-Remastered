{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}

{# ── Page Header ─────────────────────────────────────────── #}
<div class="page-header">
    <div>
        <h1 class="page-title">
            🐾 {{ t('dashboard.welcome') }}, {{ current_user.name|split(' ')|first }}!
        </h1>
        <p class="page-subtitle">{{ 'now'|date('l, d. F Y') }}</p>
    </div>
    <div class="d-flex gap-2 flex-wrap align-items-center">
        <a href="/patienten" class="btn btn-outline-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            {% if is_trainer ?? false %}Neuen Hund{% else %}{{ t('dashboard.new_patient') }}{% endif %}
        </a>
        <a href="/rechnungen/erstellen" class="btn btn-primary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            {{ t('dashboard.new_invoice') }}
        </a>
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="resetPanelState()" title="Dashboard-Layout zurücksetzen">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="1 4 1 10 7 10"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M3.51 15a9 9 0 1 0 .49-4.95"/></svg>
        </button>
    </div>
</div>

{# ════════════════════════════════════════════════════════════════
   MODULAR DASHBOARD — server-persisted panel order per user
   saved_layout = array of panel IDs in saved order (from DB)
   Panels are sorted server-side via Twig, then Sortable.js enables
   drag & drop. onEnd → POST /api/dashboard/layout → DB save.
   Same order on every device because it's stored server-side.
   ════════════════════════════════════════════════════════════════ #}

{# Build ordered panel list: saved order first, then any new panels appended #}
{% set all_panels = ['panel-appointments', 'panel-birthdays', 'panel-kpi-revenue', 'panel-revenue-chart', 'panel-activity-kpis', 'panel-mini-charts', 'panel-quick-actions', 'panel-invoice-inflow', 'panel-forecast', 'panel-donuts', 'panel-weekday', 'panel-top-owners', 'panel-patient-species'] %}
{% for w in plugin_widgets %}{% set all_panels = all_panels|merge([w.id]) %}{% endfor %}
{% set ordered_panels = saved_layout ?? all_panels %}
{% for id in all_panels %}{% if id not in ordered_panels %}{% set ordered_panels = ordered_panels|merge([id]) %}{% endif %}{% endfor %}
{% set widget_map = {} %}
{% for w in plugin_widgets %}{% set widget_map = widget_map|merge({(w.id): w}) %}{% endfor %}

<div class="main-content" id="js-dashboard">
    <div id="dashboard-grid" class="row g-3">

    {% for panel_id in ordered_panels %}

        {# ── Panel: Appointments (Today + Upcoming) ── #}
        {% if panel_id == 'panel-appointments' %}
        <div class="col-12" data-panel-id="panel-appointments">
            <div class="panel" id="panel-appointments">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-primary me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#calendar"></use></svg>
                        Terminvorschau
                        <small class="text-muted fw-normal ms-2" style="font-size:.75rem;">Heute &amp; kommende Termine</small>
                    </h2>
                    <div class="panel-toolbar ms-auto d-flex align-items-center gap-2">
                        <a href="/kalender" class="btn btn-outline-primary btn-sm">Kalender öffnen</a>
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content p-0">

                        {# ── Heute ── #}
                        <div class="px-3 pt-3 pb-1 d-flex align-items-center gap-2">
                            <span class="badge" style="background:#4f7cff;font-size:.7rem;padding:.3em .65em;">Heute</span>
                            <span class="text-muted" style="font-size:.75rem;">{{ 'now'|date('d.m.Y') }}</span>
                            {% if today_appointments is not empty %}
                                <span class="ms-auto text-muted" style="font-size:.72rem;">{{ today_appointments|length }} Termin{{ today_appointments|length != 1 ? 'e' : '' }}</span>
                            {% endif %}
                        </div>

                        {% if today_appointments is empty %}
                            <div class="d-flex align-items-center gap-2 px-3 py-3 text-muted" style="font-size:.82rem;">
                                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="opacity-40"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.5"/></svg>
                                Keine Termine heute
                            </div>
                        {% else %}
                        <div class="row g-0 border-bottom mb-1">
                            {% for appt in today_appointments %}
                            {% set appt_color = appt.treatment_color ?? '#4f7cff' %}
                            {% set patient_url = appt.patient_id ? '/patienten/' ~ appt.patient_id : '/kalender' %}
                            <div class="col-12 col-sm-6 col-xl-3">
                                <a href="{{ patient_url }}" class="d-flex align-items-center gap-3 px-3 py-2 text-decoration-none border-end"
                                   style="min-height:68px;transition:background .15s;"
                                   onmouseenter="this.style.background='{{ appt_color }}12'" onmouseleave="this.style.background=''">
                                    <div class="flex-shrink-0 d-flex flex-column align-items-center justify-content-center rounded-2"
                                         style="width:46px;height:46px;background:{{ appt_color }}18;border:1.5px solid {{ appt_color }}55;">
                                        <div style="font-size:.58rem;font-weight:700;color:{{ appt_color }};line-height:1;text-transform:uppercase;">{{ appt.start_at|date('D') }}</div>
                                        <div style="font-size:1.05rem;font-weight:800;color:{{ appt_color }};line-height:1.15;">{{ appt.start_at|date('d') }}</div>
                                        <div style="font-size:.55rem;color:{{ appt_color }};opacity:.8;">{{ appt.start_at|date('M') }}</div>
                                    </div>
                                    <div class="flex-grow-1 min-width-0">
                                        <div class="fw-600 fs-sm text-truncate" style="color:var(--bs-body-color);">
                                            {{ appt.patient_name ?? appt.title ?? 'Termin' }}
                                        </div>
                                        <div class="d-flex align-items-center gap-2" style="font-size:.71rem;color:var(--bs-secondary-color);">
                                            <span style="font-weight:600;color:{{ appt_color }};">{{ appt.start_at|date('H:i') }} Uhr</span>
                                            {% if appt.treatment_type_name %}<span>· {{ appt.treatment_type_name }}</span>{% endif %}
                                            {% if appt.owner_name %}<span class="text-truncate">· {{ appt.owner_name }}</span>{% endif %}
                                        </div>
                                    </div>
                                    {% if appt.patient_id %}
                                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" class="flex-shrink-0 opacity-30"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                                    {% endif %}
                                </a>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}

                        {# ── Nächste Termine (folgende Tage) ── #}
                        {% if next_appointments is not empty %}
                        <div class="px-3 pt-2 pb-1 d-flex align-items-center gap-2">
                            <span class="badge bg-secondary" style="font-size:.7rem;padding:.3em .65em;">Kommend</span>
                            <span class="text-muted" style="font-size:.75rem;">nächste {{ next_appointments|length }} Termine</span>
                        </div>
                        <div class="row g-0">
                            {% for appt in next_appointments %}
                            {% set appt_color = appt.treatment_color ?? '#6c757d' %}
                            {% set patient_url = appt.patient_id ? '/patienten/' ~ appt.patient_id : '/kalender' %}
                            <div class="col-12 col-sm-6 col-xl-4">
                                <a href="{{ patient_url }}" class="d-flex align-items-center gap-3 px-3 py-2 text-decoration-none border-bottom border-end"
                                   style="min-height:60px;transition:background .15s;"
                                   onmouseenter="this.style.background='rgba(0,0,0,0.03)'" onmouseleave="this.style.background=''">
                                    <div class="flex-shrink-0 d-flex flex-column align-items-center justify-content-center rounded-2"
                                         style="width:40px;height:40px;background:{{ appt_color }}18;border:1px solid {{ appt_color }}40;">
                                        <div style="font-size:.6rem;font-weight:700;color:{{ appt_color }};line-height:1;text-transform:uppercase;">{{ appt.start_at|date('D') }}</div>
                                        <div style="font-size:.95rem;font-weight:800;color:{{ appt_color }};line-height:1.2;">{{ appt.start_at|date('d') }}</div>
                                        <div style="font-size:.55rem;color:{{ appt_color }};opacity:.8;">{{ appt.start_at|date('M') }}</div>
                                    </div>
                                    <div class="flex-grow-1 min-width-0">
                                        <div class="fw-600 fs-sm text-truncate" style="color:var(--bs-body-color);">
                                            {{ appt.patient_name ?? appt.title ?? 'Termin' }}
                                        </div>
                                        <div class="d-flex align-items-center gap-2" style="font-size:.71rem;color:var(--bs-secondary-color);">
                                            <span>{{ appt.start_at|date('H:i') }} Uhr</span>
                                            {% if appt.treatment_type_name %}<span>· {{ appt.treatment_type_name }}</span>{% endif %}
                                            {% if appt.owner_name %}<span class="text-truncate">· {{ appt.owner_name }}</span>{% endif %}
                                        </div>
                                    </div>
                                    {% if appt.patient_id %}
                                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" class="flex-shrink-0 opacity-30"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                                    {% endif %}
                                </a>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}

                        {% if today_appointments is empty and next_appointments is empty %}
                            <div class="d-flex align-items-center justify-content-center gap-2 py-4 text-muted">
                                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" class="opacity-50"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.5"/></svg>
                                <span class="fs-sm">Keine anstehenden Termine</span>
                            </div>
                        {% endif %}

                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Panel: KPI Revenue ── #}
        {% if panel_id == 'panel-kpi-revenue' %}
        <div class="col-12" data-panel-id="panel-kpi-revenue">
            <div class="panel" id="panel-kpi-revenue">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-primary me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#dollar-sign"></use></svg>
                        Umsatz-Übersicht
                    </h2>
                    <div class="panel-toolbar">
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                        <button class="btn btn-panel" data-action="panel-fullscreen" title="Vollbild"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#maximize-2"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content p-3">
                        <div class="row g-3">
                            <div class="col-6 col-sm-3">
                                <div class="d-flex flex-column p-3 rounded-3" style="border-left:3px solid #4f7cff;background:rgba(79,124,255,0.06);">
                                    <span class="stat-card-label mb-1">{{ t('dashboard.revenue_week') }}</span>
                                    <span class="stat-card-value fs-4">{{ stats.revenue_week|money }}</span>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="d-flex flex-column p-3 rounded-3" style="border-left:3px solid #a855f7;background:rgba(168,85,247,0.06);">
                                    <span class="stat-card-label mb-1">{{ t('dashboard.revenue_month') }}</span>
                                    <span class="stat-card-value fs-4">{{ stats.revenue_month|money }}</span>
                                    <span class="fs-nano mt-1">
                                        {% if stats.month_change > 0 %}<span class="trend-up">▲ {{ stats.month_change }}%</span>
                                        {% elseif stats.month_change < 0 %}<span class="trend-down">▼ {{ stats.month_change|abs }}%</span>
                                        {% else %}<span class="trend-flat">—</span>{% endif %}
                                        <span class="text-muted">{{ t('dashboard.vs_last_month') }}</span>
                                    </span>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="d-flex flex-column p-3 rounded-3" style="border-left:3px solid #06b6d4;background:rgba(6,182,212,0.06);">
                                    <span class="stat-card-label mb-1">{{ t('dashboard.revenue_year') }}</span>
                                    <span class="stat-card-value fs-4">{{ stats.revenue_year|money }}</span>
                                    <span class="fs-nano mt-1">
                                        {% if stats.year_change > 0 %}<span class="trend-up">▲ {{ stats.year_change }}%</span>
                                        {% elseif stats.year_change < 0 %}<span class="trend-down">▼ {{ stats.year_change|abs }}%</span>
                                        {% else %}<span class="trend-flat">—</span>{% endif %}
                                        <span class="text-muted">{{ t('dashboard.vs_last_year') }}</span>
                                    </span>
                                </div>
                            </div>
                            <div class="col-6 col-sm-3">
                                <div class="d-flex flex-column p-3 rounded-3" style="border-left:3px solid #22c55e;background:rgba(34,197,94,0.06);">
                                    <span class="stat-card-label mb-1">{{ t('dashboard.revenue_total') }}</span>
                                    <span class="stat-card-value fs-4">{{ stats.revenue_total|money }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Panel: Revenue Chart ── #}
        {% if panel_id == 'panel-revenue-chart' %}
        <div class="col-xl-8 col-lg-7 col-12" data-panel-id="panel-revenue-chart">
            <div class="panel h-100" id="panel-revenue-chart">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-primary me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#bar-chart-2"></use></svg>
                        {{ t('dashboard.chart_title') }}
                    </h2>
                    <div class="panel-toolbar ms-auto d-flex align-items-center gap-2">
                        <div class="btn-group btn-group-sm" role="group">
                            <button class="btn btn-outline-secondary active" id="btn-weekly">{{ t('dashboard.weekly') }}</button>
                            <button class="btn btn-outline-secondary" id="btn-monthly">{{ t('dashboard.monthly') }}</button>
                        </div>
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                        <button class="btn btn-panel" data-action="panel-fullscreen" title="Vollbild"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#maximize-2"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content p-2">
                        <div id="dash-revenue-chart" style="min-height:270px;"></div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Panel: Activity KPIs ── #}
        {% if panel_id == 'panel-activity-kpis' %}
        <div class="col-xl-4 col-lg-5 col-12" data-panel-id="panel-activity-kpis">
            <div class="panel h-100" id="panel-activity-kpis">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-info me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#activity"></use></svg>
                        Aktivität
                    </h2>
                    <div class="panel-toolbar">
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                        <button class="btn btn-panel" data-action="panel-fullscreen" title="Vollbild"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#maximize-2"></use></svg></button>
                    </div>
                </div>
                <div class="panel-container">
                    <div class="panel-content p-0">
                        <div class="list-group list-group-flush rounded-0">
                            <div class="list-group-item d-flex align-items-center justify-content-between px-3 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="stat-card-icon" style="--stat-color:#06b6d4;"><svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg></div>
                                    <span class="stat-card-label">{{ t('dashboard.open_invoices') }}</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-800 fs-4" style="color:#06b6d4;">{{ stats.open_count }}</span>
                                    <a href="/rechnungen?status=open" class="btn btn-outline-info btn-sm">→</a>
                                </div>
                            </div>
                            <div class="list-group-item d-flex align-items-center justify-content-between px-3 py-3{% if stats.overdue_count > 0 %} border-start border-danger border-3{% endif %}">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="stat-card-icon" style="--stat-color:{% if stats.overdue_count > 0 %}#ef4444{% else %}var(--bs-secondary-color){% endif %};"><svg width="15" height="15" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></div>
                                    <span class="stat-card-label">{{ t('dashboard.overdue_invoices') }}</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-800 fs-4" style="color:{% if stats.overdue_count > 0 %}#ef4444{% else %}var(--bs-secondary-color){% endif %};">{{ stats.overdue_count }}</span>
                                    <a href="/rechnungen?status=overdue" class="btn btn-outline-danger btn-sm">→</a>
                                </div>
                            </div>
                            <div class="list-group-item d-flex align-items-center justify-content-between px-3 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="stat-card-icon" style="--stat-color:#f59e0b;"><svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
                                    <div>
                                        <span class="stat-card-label d-block">{{ t('dashboard.new_patients') }}</span>
                                        <span class="fs-nano text-muted">letzte 30 Tage</span>
                                    </div>
                                </div>
                                <span class="fw-800 fs-4" style="color:#f59e0b;">{{ stats.new_patients }}</span>
                            </div>
                            <div class="list-group-item d-flex align-items-center justify-content-between px-3 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="stat-card-icon" style="--stat-color:#4f7cff;"><svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
                                    <span class="stat-card-label">{{ t('dashboard.total_patients') }}</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-800 fs-4" style="color:#4f7cff;">{{ stats.total_patients }}</span>
                                    <a href="/patienten" class="btn btn-outline-primary btn-sm">→</a>
                                </div>
                            </div>
                            <div class="list-group-item d-flex align-items-center justify-content-between px-3 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="stat-card-icon" style="--stat-color:#a855f7;"><svg width="15" height="15" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg></div>
                                    <span class="stat-card-label">{{ t('dashboard.total_owners') }}</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-800 fs-4" style="color:#a855f7;">{{ stats.total_owners }}</span>
                                    <a href="/tierhalter" class="btn btn-sm" style="background:rgba(168,85,247,0.12);color:#a855f7;border:1px solid rgba(168,85,247,0.25);">→</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Panel: Mini Charts ── #}
        {% if panel_id == 'panel-mini-charts' %}
        <div class="col-12" data-panel-id="panel-mini-charts">
            <div class="panel" id="panel-mini-charts">
                <div class="panel-hdr">
                    <h2>
                        <svg class="sa-icon sa-icon-success me-2"><use href="/themes/smart-tierphysio/icons/sprite.svg#pie-chart"></use></svg>
                        Kennzahlen
                    </h2>
                    <div class="panel-toolbar">
                        <button class="btn btn-panel" data-action="panel-collapse" title="Einklappen"><svg class="sa-icon"><use href="/themes/smart-tierphysio/icons/sprite.svg#minus"></use></svg></button>
                    </div>
