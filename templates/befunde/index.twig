{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="/patienten/{{ patient.id }}" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            {{ patient.name }}
        </a>
        <h1 class="page-title">{{ page_title }}</h1>
    </div>
    <a href="/patienten/{{ patient.id }}/befunde/neu" class="btn btn-primary btn-sm">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Neuer Befundbogen
    </a>
</div>

{% if befunde|length > 0 %}
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Nr.</th>
                    <th>Datum</th>
                    <th>Status</th>
                    <th>Erstellt von</th>
                    <th>Nächster Termin</th>
                    <th>Versendet</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for b in befunde %}
                <tr>
                    <td><span style="font-family:monospace;font-weight:700;">BF-{{ '%04d'|format(b.id) }}</span></td>
                    <td>{{ b.datum|date('d.m.Y') }}</td>
                    <td>
                        <span class="badge {% if b.status == 'versendet' %}bg-success{% elseif b.status == 'abgeschlossen' %}bg-primary{% else %}bg-secondary{% endif %}">
                            {{ b.status|capitalize }}
                        </span>
                    </td>
                    <td>{{ b.ersteller_name ?: '—' }}</td>
                    <td>{{ b.naechster_termin ? b.naechster_termin|date('d.m.Y') : '—' }}</td>
                    <td>
                        {% if b.pdf_sent_at %}
                            <span class="text-success" style="font-size:.8rem;">
                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24" class="me-1"><path stroke="currentColor" stroke-width="2" d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline stroke="currentColor" stroke-width="2" points="22 4 12 14.01 9 11.01"/></svg>
                                {{ b.pdf_sent_at|date('d.m.Y') }}
                            </span>
                        {% else %}—{% endif %}
                    </td>
                    <td class="text-end">
                        <a href="/patienten/{{ patient.id }}/befunde/{{ b.id }}" class="btn btn-sm btn-outline-secondary">
                            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
                            Ansehen
                        </a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% else %}
<div class="card">
    <div class="card-body">
        {% include 'components/_empty-state.twig' with {
            icon:  '<svg width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg>',
            title: 'Noch keine Befundbögen',
            text:  'Erstelle den ersten Befundbogen für ' ~ patient.name ~ '.',
            cta:   '<a href="/patienten/' ~ patient.id ~ '/befunde/neu" class="btn btn-primary"><svg width="14" height="14" fill="none" viewBox="0 0 24 24" class="me-1"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>Neuer Befundbogen</a>'
        } only %}
    </div>
</div>
{% endif %}
{% endblock %}
