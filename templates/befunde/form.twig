{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block styles %}
<link rel="stylesheet" href="/assets/css/befund-anatomy.css?v={{ 'now'|date('YmdHi') }}">
{% endblock %}

{% block content %}
{# Fallback: CSS direkt einbinden, falls das Theme den styles-Block nicht rendert #}
<link rel="stylesheet" href="/assets/css/befund-anatomy.css?v={{ 'now'|date('YmdHi') }}">
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="/patienten/{{ patient.id }}/befunde" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            Zurück
        </a>
        <h1 class="page-title">{{ page_title }}</h1>
    </div>
</div>

{% set is_edit = befundbogen is not null %}
{% set action = is_edit
    ? '/patienten/' ~ patient.id ~ '/befunde/' ~ befundbogen.id ~ '/aktualisieren'
    : '/patienten/' ~ patient.id ~ '/befunde/speichern' %}

<form method="POST" action="{{ action }}">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    <div class="row g-4">

        {# ── LEFT: Meta ──────────────────────────────────────── #}
        <div class="col-lg-3">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="fw-700 mb-3 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">Allgemein</h6>

                    <div class="mb-3">
                        <label class="form-label fw-600">Datum <span class="text-danger">*</span></label>
                        <input type="date" name="datum" class="form-control"
                               value="{{ is_edit ? befundbogen.datum : 'now'|date('Y-m-d') }}" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-600">Status</label>
                        <select name="status" class="form-select">
                            <option value="entwurf"       {{ (is_edit ? befundbogen.status : 'entwurf') == 'entwurf'       ? 'selected' : '' }}>Entwurf</option>
                            <option value="abgeschlossen" {{ (is_edit ? befundbogen.status : '') == 'abgeschlossen' ? 'selected' : '' }}>Abgeschlossen</option>
                            <option value="versendet"     {{ (is_edit ? befundbogen.status : '') == 'versendet'     ? 'selected' : '' }}>Versendet</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-600">Nächster Termin</label>
                        <input type="date" name="naechster_termin" class="form-control"
                               value="{{ is_edit ? befundbogen.naechster_termin : '' }}">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-600">Allgemeine Notizen</label>
                        <textarea name="notizen" class="form-control" rows="4"
                                  placeholder="Interne Bemerkungen...">{{ is_edit ? befundbogen.notizen : '' }}</textarea>
                    </div>

                    {# Patient info #}
                    <hr>
                    <h6 class="fw-700 mb-2 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">Patient</h6>
                    <div class="text-sm fw-600">{{ patient.name }}</div>
                    {% if patient.species %}<div class="text-xs text-muted">{{ patient.species }}{% if patient.breed %} · {{ patient.breed }}{% endif %}</div>{% endif %}
                    {% if owner %}
                    <div class="text-xs text-muted mt-1">{{ owner.first_name }} {{ owner.last_name }}</div>
                    {% if owner.email %}<div class="text-xs text-muted">{{ owner.email }}</div>{% endif %}
                    {% endif %}
                </div>
            </div>
        </div>

        {# ── RIGHT: Fields ───────────────────────────────────── #}
        <div class="col-lg-9">

            {# ── Anamnese ──────────────────────────────────────── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg>
                        Anamnese &amp; Vorgeschichte
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-600">Hauptbeschwerde</label>
                            <textarea name="hauptbeschwerde" class="form-control" rows="2" placeholder="Beschreibung der Hauptbeschwerde...">{{ felder.hauptbeschwerde ?? '' }}</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Seit wann / Verlauf</label>
                            <input type="text" name="seit_wann" class="form-control" placeholder="z.B. seit 3 Wochen, zunehmend" value="{{ felder.seit_wann ?? '' }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Vorerkrankungen / OPs</label>
                            <input type="text" name="vorerkrankungen" class="form-control" placeholder="z.B. Bandscheibenvorfall 2022" value="{{ felder.vorerkrankungen ?? '' }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Medikamente</label>
                            <input type="text" name="medikamente" class="form-control" placeholder="z.B. Carprofen 2x täglich" value="{{ felder.medikamente ?? '' }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Allergien</label>
                            <input type="text" name="allergien" class="form-control" placeholder="z.B. keine bekannt" value="{{ felder.allergien ?? '' }}">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-600">Ernährung</label>
                            <input type="text" name="ernaehrung" class="form-control" placeholder="z.B. Trockenfutter, 2x täglich" value="{{ felder.ernaehrung ?? '' }}">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-600">Bewegung</label>
                            <input type="text" name="bewegung" class="form-control" placeholder="z.B. 30 min Spaziergang täglich" value="{{ felder.bewegung ?? '' }}">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-600">Haltung</label>
                            <input type="text" name="haltung" class="form-control" placeholder="z.B. Wohnungshund, Garten" value="{{ felder.haltung ?? '' }}">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-600">Bisherige Therapien</label>
                            <textarea name="bisherige_therapien" class="form-control" rows="2" placeholder="z.B. Physiotherapie, Akupunktur...">{{ felder.bisherige_therapien ?? '' }}</textarea>
                        </div>
                    </div>
                </div>
            </div>

            {# ── Allgemeinbefund ────────────────────────────────── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                        Allgemeinbefund
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-600">Allgemeinbefinden</label>
                            <select name="allgemeinbefinden" class="form-select">
                                <option value="">— Bitte wählen —</option>
                                {% for opt in ['gut','mäßig','reduziert','schlecht'] %}
                                <option value="{{ opt }}" {{ (felder.allgemeinbefinden ?? '') == opt ? 'selected' : '' }}>{{ opt|capitalize }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-600">Ernährungszustand</label>
                            <select name="ernaehrungszustand" class="form-select">
                                <option value="">— Bitte wählen —</option>
                                {% for opt in ['ideal','übergewichtig','untergewichtig','kachektisch'] %}
                                <option value="{{ opt }}" {{ (felder.ernaehrungszustand ?? '') == opt ? 'selected' : '' }}>{{ opt|capitalize }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-600">Temperament</label>
                            <select name="temperament" class="form-select">
                                <option value="">— Bitte wählen —</option>
                                {% for opt in ['ruhig','ausgeglichen','nervös','aggressiv','ängstlich'] %}
                                <option value="{{ opt }}" {{ (felder.temperament ?? '') == opt ? 'selected' : '' }}>{{ opt|capitalize }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-600">Körpertemperatur (°C)</label>
                            <input type="text" name="koerpertemperatur" class="form-control" placeholder="z.B. 38,5" value="{{ felder.koerpertemperatur ?? '' }}">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-600">Körperhaltung</label>
                            <input type="text" name="koerperhaltung" class="form-control" placeholder="z.B. Hohlkreuz" value="{{ felder.koerperhaltung ?? '' }}">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-600">Gangbild</label>
                            <input type="text" name="gangbild" class="form-control" placeholder="z.B. lahmend links hinten" value="{{ felder.gangbild ?? '' }}">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-600">Lahmheitsgrad (0–5)</label>
                            <input type="number" name="lahmheitsgrad" class="form-control" min="0" max="5" placeholder="0" value="{{ felder.lahmheitsgrad ?? '' }}">
                        </div>
                    </div>
                </div>
            </div>

            {# ── Bewegungsapparat ───────────────────────────────── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path stroke="currentColor" stroke-width="2" d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="15" y1="9" x2="15.01" y2="9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        Bewegungsapparat &amp; Muskulatur
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-600">Betroffene Regionen</label>
                            <input type="text" name="betroffene_regionen" class="form-control" placeholder="z.B. LWS, linkes Hüftgelenk" value="{{ felder.betroffene_regionen ?? '' }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Muskeltonus</label>
                            <input type="text" name="muskeltonus" class="form-control" placeholder="z.B. hyerton paravertebral" value="{{ felder.muskeltonus ?? '' }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Triggerpunkte / Verspannungen</label>
                            <input type="text" name="triggerpunkte" class="form-control" placeholder="z.B. M. iliopsoas bds." value="{{ felder.triggerpunkte ?? '' }}">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-600">Schmerzskala NRS (0–10)</label>
                            <input type="number" name="schmerz_nrs" class="form-control" min="0" max="10" placeholder="0" value="{{ felder.schmerz_nrs ?? '' }}">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-600">Gelenkbefund</label>
                            <input type="text" name="gelenke_befund" class="form-control" placeholder="z.B. Erguss Knie re." value="{{ felder.gelenke_befund ?? '' }}">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-600">Neurologischer Status</label>
                            <textarea name="neurologischer_status" class="form-control" rows="2" placeholder="z.B. Propriozeption reduziert links hinten...">{{ felder.neurologischer_status ?? '' }}</textarea>
                        </div>
                    </div>
                </div>
            </div>

            {# ── Naturheilkunde ─────────────────────────────────── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        Naturheilkundliche Diagnostik
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-600">Konstitutionstyp / Miasma</label>
                            <input type="text" name="konstitutionstyp" class="form-control" value="{{ felder.konstitutionstyp ?? '' }}" placeholder="z.B. Sycose, Psora">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Energetischer Gesamteindruck</label>
                            <input type="text" name="energetischer_eindruck" class="form-control" value="{{ felder.energetischer_eindruck ?? '' }}" placeholder="z.B. erschöpft, lebendig">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-600">Bach-Blüten Emotionskategorien</label>
                            <div class="d-flex flex-wrap gap-2 mt-1">
                                {% set bachEmotions = ['Angst','Unsicherheit','Mangelndes Interesse','Einsamkeit','Überempfindlichkeit','Mutlosigkeit','Übermäßige Fürsorge'] %}
                                {% set selectedEmotions = felder.bachblueten_emotionen is defined ? (felder.bachblueten_emotionen is iterable ? felder.bachblueten_emotionen : [felder.bachblueten_emotionen]) : [] %}
                                {% for emo in bachEmotions %}
                                <label class="form-check-label d-flex align-items-center gap-1" style="cursor:pointer;">
                                    <input type="checkbox" name="bachblueten_emotionen[]" value="{{ emo }}" class="form-check-input"
                                        {{ emo in selectedEmotions ? 'checked' : '' }}>
                                    <span style="font-size:.85rem;">{{ emo }}</span>
                                </label>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Bach-Blüten Mischung</label>
                            <input type="text" name="bachblueten_auswahl" class="form-control" value="{{ felder.bachblueten_auswahl ?? '' }}" placeholder="z.B. Mimulus, Aspen, Rock Rose">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Bach-Blüten Dosierung</label>
                            <input type="text" name="bachblueten_dosierung" class="form-control" value="{{ felder.bachblueten_dosierung ?? '' }}" placeholder="z.B. 4x2 Tropfen täglich">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-600">Homöopathisches Mittel</label>
                            <input type="text" name="homoeopathie_mittel" class="form-control" value="{{ felder.homoeopathie_mittel ?? '' }}" placeholder="z.B. Arnica montana">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-600">Potenz</label>
                            <input type="text" name="homoeopathie_potenz" class="form-control" value="{{ felder.homoeopathie_potenz ?? '' }}" placeholder="z.B. C30">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-600">Wiederholung / Dauer</label>
                            <input type="text" name="homoeopathie_dauer" class="form-control" value="{{ felder.homoeopathie_dauer ?? '' }}" placeholder="z.B. 1x wöchentlich für 4 Wochen">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Phytotherapie / Kräuter</label>
                            <input type="text" name="phytotherapie" class="form-control" value="{{ felder.phytotherapie ?? '' }}" placeholder="z.B. Teufelskralle Tinktur">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Schüssler Salze</label>
                            <input type="text" name="schuesslersalze" class="form-control" value="{{ felder.schuesslersalze ?? '' }}" placeholder="z.B. Nr. 8 und Nr. 11">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-600">Weitere Naturheilmittel</label>
                            <input type="text" name="weitere_naturheilmittel" class="form-control" value="{{ felder.weitere_naturheilmittel ?? '' }}" placeholder="z.B. Akupunktur, Laser...">
                        </div>
                    </div>
                </div>
            </div>

            {# ── Physiotherapie ─────────────────────────────────── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path stroke="currentColor" stroke-width="2" d="M8 12h8M12 8v8"/></svg>
                        Physiotherapeutische Maßnahmen
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-600">Angewandte Methoden</label>
                            <textarea name="pt_methoden" class="form-control" rows="2" placeholder="z.B. Massage, TENS, Ultraschall, Manuelle Therapie...">{{ felder.pt_methoden ?? '' }}</textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-600">Therapieziele</label>
                            <textarea name="therapieziele" class="form-control" rows="2" placeholder="z.B. Schmerzreduktion, Verbesserung Beweglichkeit...">{{ felder.therapieziele ?? '' }}</textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-600">Hausaufgaben / Heimübungen</label>
                            <textarea name="hausaufgaben" class="form-control" rows="2" placeholder="z.B. 3x täglich Sit-to-Stand Übung...">{{ felder.hausaufgaben ?? '' }}</textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-600">Frequenz</label>
                            <input type="text" name="therapiefrequenz" class="form-control" value="{{ felder.therapiefrequenz ?? '' }}" placeholder="z.B. 1x wöchentlich">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-600">Dauer</label>
                            <input type="text" name="therapiedauer" class="form-control" value="{{ felder.therapiedauer ?? '' }}" placeholder="z.B. 45 Minuten">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-600">Kontrolltermin</label>
                            <input type="text" name="kontrolltermin" class="form-control" value="{{ felder.kontrolltermin ?? '' }}" placeholder="z.B. in 4 Wochen">
                        </div>
                    </div>
                </div>
            </div>

            {# ── Verlauf ────────────────────────────────────────── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Verlauf &amp; Notizen
                    </h5>
                </div>
                <div class="card-body">
                    <textarea name="verlauf_notizen" class="form-control" rows="4"
                              placeholder="Verlaufsbeobachtungen, Reaktionen auf Therapie...">{{ felder.verlauf_notizen ?? '' }}</textarea>
                </div>
            </div>

            {# ── Physio-Bereiche ─────────────────────────────────── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M4 6h16M4 12h16M4 18h10"/></svg>
                        Physio-Bereiche
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-2">Auswählen, welche Bereiche im Befund berücksichtigt werden:</p>
                    {% set physioOptions = ['Gangbild','Muskulatur','Gelenke','Beweglichkeit','Schmerzpunkte','Haltung','Neurologische Auffälligkeiten'] %}
                    {% set selectedBereiche = felder.physio_bereiche is defined ? (felder.physio_bereiche is iterable ? felder.physio_bereiche : [felder.physio_bereiche]) : [] %}
                    <div class="d-flex flex-wrap">
                        {% for opt in physioOptions %}
                        <label class="physio-bereich-chip">
                            <input type="checkbox" name="physio_bereiche[]" value="{{ opt }}" {{ opt in selectedBereiche ? 'checked' : '' }}>
                            <span>{{ opt }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>
            </div>

            {# ── Interaktive Anatomie ────────────────────────────── #}
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><circle cx="12" cy="7" r="3" stroke="currentColor" stroke-width="2"/><path stroke="currentColor" stroke-width="2" d="M6 22v-5a6 6 0 0 1 12 0v5"/></svg>
                        Interaktive Anatomie &amp; Markierungen
                    </h5>
                    <span class="badge bg-secondary">optional</span>
                </div>
                <div class="card-body" id="befund-anatomy">
                    <input type="hidden" name="anatomy_species"  value="{{ felder.anatomy_species ?? 'dog' }}">
                    <input type="hidden" name="anatomy_markers"  value='{{ (felder.anatomy_markers  is iterable ? felder.anatomy_markers  : []) | json_encode }}'>
                    <input type="hidden" name="anatomy_drawings" value='{{ (felder.anatomy_drawings is iterable ? felder.anatomy_drawings : []) | json_encode }}'>

                    <div class="anatomy-toolbar"></div>
                    <div class="anatomy-wrap">
                        <div class="anatomy-stage">
                            {# Server-side pre-rendered silhouette — immer sichtbar, JS fügt interaktives Overlay hinzu #}
                            {% set _sp = felder.anatomy_species ?? 'dog' %}
                            <svg class="anatomy-silhouette" viewBox="0 0 500 300" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" data-species="{{ _sp }}">
                                {% if _sp == 'dog' %}
                                <g fill="#7d9bb5" stroke="#3d5a72" stroke-width="2.5" stroke-linejoin="round">
                                    <ellipse cx="235" cy="168" rx="138" ry="58"/>
                                    <path d="M138 140 Q125 115 130 100 Q148 92 162 118 Q158 136 155 155" stroke-width="1"/>
                                    <ellipse cx="92" cy="132" rx="46" ry="42"/>
                                    <ellipse cx="57" cy="150" rx="22" ry="15"/>
                                    <path d="M72 98 Q55 72 65 58 Q82 50 96 78 Q100 95 92 102"/>
                                    <circle cx="78" cy="122" r="5" fill="#3d5a72" stroke="none"/>
                                    <ellipse cx="43" cy="148" rx="7" ry="5" fill="#3d5a72" stroke="none"/>
                                    <path d="M155 218 L148 272 Q152 276 156 272 L162 218"/>
                                    <path d="M195 222 L189 272 Q193 276 197 272 L202 222"/>
                                    <path d="M278 220 L272 272 Q276 276 280 272 L285 220"/>
                                    <path d="M320 218 L315 272 Q319 276 323 272 L327 218"/>
                                    <path d="M368 142 Q398 108 408 128 Q415 148 400 162" fill="none" stroke-width="5" stroke-linecap="round"/>
                                </g>
                                {% elseif _sp == 'cat' %}
                                <g fill="#7d9bb5" stroke="#3d5a72" stroke-width="2.5" stroke-linejoin="round">
                                    <ellipse cx="238" cy="172" rx="118" ry="50"/>
                                    <path d="M135 148 Q122 125 130 110 Q146 102 158 122 Q155 138 152 158" stroke-width="1"/>
                                    <circle cx="95" cy="140" r="40"/>
                                    <ellipse cx="66" cy="152" rx="18" ry="13"/>
                                    <polygon points="72,108 80,80 92,106"/>
                                    <polygon points="100,104 110,76 122,104"/>
                                    <ellipse cx="82" cy="132" rx="6" ry="7" fill="#3d5a72" stroke="none"/>
                                    <polygon points="60,147 66,142 72,147 66,153" fill="#3d5a72" stroke="none"/>
                                    <path d="M160 218 L154 268 Q158 272 162 268 L167 218"/>
                                    <path d="M198 222 L192 268 Q196 272 200 268 L205 222"/>
                                    <path d="M286 220 L281 268 Q285 272 289 268 L294 220"/>
                                    <path d="M322 218 L317 268 Q321 272 325 268 L330 218"/>
                                    <path d="M354 182 Q420 168 435 135 Q440 108 418 98" fill="none" stroke-width="7" stroke-linecap="round"/>
                                </g>
                                {% else %}
                                <g fill="#7d9bb5" stroke="#3d5a72" stroke-width="2.5" stroke-linejoin="round">
                                    <ellipse cx="248" cy="148" rx="148" ry="58"/>
                                    <ellipse cx="370" cy="138" rx="42" ry="35"/>
                                    <path d="M118 120 Q105 88 112 65 Q128 52 148 68 Q155 88 152 118"/>
                                    <ellipse cx="88" cy="95" rx="28" ry="42"/>
                                    <ellipse cx="72" cy="126" rx="18" ry="12"/>
                                    <ellipse cx="64" cy="128" rx="5" ry="4" fill="#3d5a72" stroke="none"/>
                                    <circle cx="88" cy="82" r="5" fill="#3d5a72" stroke="none"/>
                                    <polygon points="78,62 84,44 92,62"/>
                                    <polygon points="90,60 96,42 104,60"/>
                                    <path d="M112 68 Q118 80 122 98 Q128 110 132 120" fill="none" stroke-width="8" stroke-linecap="round"/>
                                    <path d="M142 198 L134 268 Q138 274 144 268 L152 198"/>
                                    <path d="M178 202 L170 268 Q174 274 180 268 L188 202"/>
                                    <path d="M318 200 L312 268 Q316 274 322 268 L330 200"/>
                                    <path d="M356 198 L350 268 Q354 274 360 268 L368 198"/>
                                    <path d="M392 145 Q428 128 438 155 Q445 175 430 188" fill="none" stroke-width="8" stroke-linecap="round"/>
                                </g>
                                {% endif %}
                            </svg>
                        </div>
                    </div>
                    <div class="anatomy-legend"></div>

                    <h6 class="fw-700 mt-3 mb-1 text-muted text-uppercase" style="font-size:.7rem;letter-spacing:.05em;">Markierungen</h6>
                    <div class="anatomy-marker-list"></div>
                </div>
            </div>

            {# ── KI-Unterstützung (Light) ────────────────────────── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M12 2l2.39 7.36H22l-6.19 4.5 2.39 7.36L12 16.72 5.8 21.22l2.39-7.36L2 9.36h7.61z"/></svg>
                        KI-Unterstützung
                    </h5>
                </div>
                <div class="card-body d-flex flex-wrap align-items-center gap-2">
                    <button type="button" id="befund-ki-strukturieren" class="btn btn-outline-primary btn-sm">Befund strukturieren</button>
                    <span class="text-muted small">Erstellt eine Zusammenfassung aus Notizen, Markierungen und Bereichen.</span>
                </div>
            </div>

            {# ── Vorlagen & Textbausteine ────────────────────────── #}
            {% if (vorlagen is defined and vorlagen|length > 0) or (textbausteine is defined and textbausteine|length > 0) %}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M9 12h6m-6 4h6M7 3h10a2 2 0 0 1 2 2v16l-7-4-7 4V5a2 2 0 0 1 2-2z"/></svg>
                        Vorlagen &amp; Textbausteine
                    </h5>
                </div>
                <div class="card-body">
                    {% if vorlagen is defined and vorlagen|length > 0 %}
                    <div class="mb-3">
                        <label class="form-label fw-600 small">Vorlage anwenden</label>
                        <select id="befund-vorlage-select" class="form-select form-select-sm">
                            <option value="">— Vorlage auswählen —</option>
                            {% for v in vorlagen %}
                            <option value="{{ v.id }}">{{ v.name }}{% if v.species %} ({{ v.species }}){% endif %}</option>
                            {% endfor %}
                        </select>
                    </div>
                    {% endif %}

                    {% if textbausteine is defined and textbausteine|length > 0 %}
                    <label class="form-label fw-600 small">Textbausteine einfügen in:</label>
                    <div class="d-flex flex-wrap gap-1 mb-2">
                        {% for tb in textbausteine %}
                        <div class="btn-group btn-group-sm">
                            <button type="button" class="btn btn-outline-secondary"
                                    data-baustein-insert
                                    data-baustein-target="textarea[name='verlauf_notizen']"
                                    data-baustein-text="{{ tb.content|e('html_attr') }}"
                                    title="In Verlaufsnotizen einfügen">
                                + {{ tb.title }}
                            </button>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            {# ── Actions ────────────────────────────────────────── #}
            <div class="d-flex gap-2 justify-content-end mb-4">
                <a href="/patienten/{{ patient.id }}/befunde" class="btn btn-secondary">Abbrechen</a>
                <button type="submit" name="status" value="entwurf" class="btn btn-secondary">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" class="me-1"><path stroke="currentColor" stroke-width="2" d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline stroke="currentColor" stroke-width="2" points="17 21 17 13 7 13 7 21"/><polyline stroke="currentColor" stroke-width="2" points="7 3 7 8 15 8"/></svg>
                    Als Entwurf speichern
                </button>
                <button type="submit" name="status" value="abgeschlossen" class="btn btn-primary">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" class="me-1"><path stroke="currentColor" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Abschließen &amp; Speichern
                </button>
            </div>

        </div>{# end col-lg-9 #}
    </div>{# end row #}
</form>

{# Fallback-CSS: Stage-Höhe + Kontrast in hellem und dunklem Theme #}
<style>
#befund-anatomy .anatomy-wrap { position: relative; width: 100%; max-width: 640px; margin: 0 auto; }
#befund-anatomy .anatomy-stage {
    position: relative; width: 100%; padding-top: 60%;
    background: #e8edf2; border-radius: 10px;
    border: 1px solid #c0cdd8; overflow: hidden;
    cursor: crosshair;
}
[data-bs-theme="dark"] #befund-anatomy .anatomy-stage,
body.dark #befund-anatomy .anatomy-stage {
    background: #1b2230;
    border-color: #2d3a4a;
}
#befund-anatomy .anatomy-stage svg { position: absolute; top: 0; right: 0; bottom: 0; left: 0; inset: 0; width: 100%; height: 100%; }
#befund-anatomy .anatomy-stage svg.anatomy-silhouette { z-index: 1; pointer-events: none; opacity: .95; }
#befund-anatomy .anatomy-stage svg.anatomy-overlay    { z-index: 2; }
</style>

{% endblock %}

{% block scripts %}
<script src="/assets/js/befund-anatomy.js?v={{ 'now'|date('YmdHi') }}"></script>
{% endblock %}
