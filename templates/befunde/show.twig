{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}
<div class="page-header">
    <div class="flex items-center gap-3">
        <a href="/patienten/{{ patient.id }}/befunde" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
            Zurück
        </a>
        <h1 class="page-title">{{ page_title }}</h1>
        <span class="badge {% if befundbogen.status == 'versendet' %}bg-success{% elseif befundbogen.status == 'abgeschlossen' %}bg-primary{% else %}bg-secondary{% endif %}">
            {{ befundbogen.status|capitalize }}
        </span>
    </div>
    <div class="flex gap-2">
        <a href="/patienten/{{ patient.id }}/befunde/{{ befundbogen.id }}/bearbeiten" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Bearbeiten
        </a>
        <a href="/patienten/{{ patient.id }}/befunde/{{ befundbogen.id }}/pdf" target="_blank" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline stroke="currentColor" stroke-width="2" points="14 2 14 8 20 8"/></svg>
            PDF
        </a>
        {% if owner and owner.email %}
        <form method="POST" action="/patienten/{{ patient.id }}/befunde/{{ befundbogen.id }}/senden"
              onsubmit="return confirm('Befundbogen per E-Mail an {{ owner.email }} senden?');">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-primary btn-sm">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline stroke="currentColor" stroke-width="2" points="22,6 12,13 2,6"/></svg>
                Per E-Mail senden
            </button>
        </form>
        {% endif %}
        <form method="POST" action="/patienten/{{ patient.id }}/befunde/{{ befundbogen.id }}/loeschen"
              onsubmit="return confirm('Befundbogen wirklich löschen?');">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-danger btn-sm">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m5 0V4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2"/></svg>
                Löschen
            </button>
        </form>
    </div>
</div>

<div class="row g-4">

    {# ── LEFT: Meta info ── #}
    <div class="col-lg-3">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="fw-700 mb-3 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">Info</h6>
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Befundbogen-Nr.</div>
                    <div class="fw-700" style="font-family:monospace;">BF-{{ '%04d'|format(befundbogen.id) }}</div>
                </div>
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Datum</div>
                    <div class="fw-600">{{ befundbogen.datum|date('d.m.Y') }}</div>
                </div>
                {% if befundbogen.naechster_termin %}
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Nächster Termin</div>
                    <div class="fw-600">{{ befundbogen.naechster_termin|date('d.m.Y') }}</div>
                </div>
                {% endif %}
                {% if befundbogen.ersteller_name %}
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Erstellt von</div>
                    <div>{{ befundbogen.ersteller_name }}</div>
                </div>
                {% endif %}
                {% if befundbogen.pdf_sent_at %}
                <div class="mb-2">
                    <div class="text-xs text-muted mb-1">Versendet am</div>
                    <div class="text-sm">{{ befundbogen.pdf_sent_at|date('d.m.Y H:i') }}</div>
                    {% if befundbogen.pdf_sent_to %}
                    <div class="text-xs text-muted">an {{ befundbogen.pdf_sent_to }}</div>
                    {% endif %}
                </div>
                {% endif %}
                {% if befundbogen.notizen %}
                <hr>
                <div class="text-xs text-muted mb-1">Allgemeine Notizen</div>
                <div class="text-sm" style="line-height:1.5;white-space:pre-wrap;">{{ befundbogen.notizen }}</div>
                {% endif %}
            </div>
        </div>

        {% if patient %}
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="fw-700 mb-2 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">Patient</h6>
                <a href="/patienten/{{ patient.id }}" class="text-decoration-none">
                    <div class="fw-700">{{ patient.name }}</div>
                </a>
                {% if patient.species %}<div class="text-xs text-muted">{{ patient.species }}{% if patient.breed %} · {{ patient.breed }}{% endif %}</div>{% endif %}
                {% if patient.birth_date %}<div class="text-xs text-muted">Geb.: {{ patient.birth_date|date('d.m.Y') }}</div>{% endif %}
            </div>
        </div>
        {% endif %}

        {% if owner %}
        <div class="card">
            <div class="card-body">
                <h6 class="fw-700 mb-2 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.05em;">Tierhalter</h6>
                <a href="/tierhalter/{{ owner.id }}" class="text-decoration-none">
                    <div class="fw-700">{{ owner.first_name }} {{ owner.last_name }}</div>
                </a>
                {% if owner.phone %}<div class="text-xs text-muted">{{ owner.phone }}</div>{% endif %}
                {% if owner.email %}<div class="text-xs text-muted">{{ owner.email }}</div>{% endif %}
            </div>
        </div>
        {% endif %}
    </div>

    {# ── RIGHT: Felder ── #}
    <div class="col-lg-9">

        {% macro section(title, icon, fields, felder) %}
            {% set hasAny = false %}
            {% for key, label in fields %}
                {% if felder[key] is defined and felder[key] is not empty %}
                    {% set hasAny = true %}
                {% endif %}
            {% endfor %}
            {% if hasAny %}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">{{ icon|raw }} {{ title }}</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0" style="row-gap:.5rem;">
                        {% for key, label in fields %}
                            {% if felder[key] is defined and felder[key] is not empty %}
                            <dt class="col-sm-4 text-muted fw-600" style="font-size:.8rem;">{{ label }}</dt>
                            <dd class="col-sm-8 mb-0" style="font-size:.9rem;">
                                {% if felder[key] is iterable %}
                                    {{ felder[key]|join(', ') }}
                                {% else %}
                                    {{ felder[key] }}
                                {% endif %}
                            </dd>
                            {% endif %}
                        {% endfor %}
                    </dl>
                </div>
            </div>
            {% endif %}
        {% endmacro %}

        {% set iconDoc %}<svg width="15" height="15" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg>{% endset %}
        {% set iconActivity %}<svg width="15" height="15" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>{% endset %}
        {% set iconMuscle %}<svg width="15" height="15" fill="none" viewBox="0 0 24 24" class="me-2"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path stroke="currentColor" stroke-width="2" d="M8 14s1.5 2 4 2 4-2 4-2"/></svg>{% endset %}
        {% set iconShield %}<svg width="15" height="15" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>{% endset %}
        {% set iconPlus %}<svg width="15" height="15" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path stroke="currentColor" stroke-width="2" d="M8 12h8M12 8v8"/></svg>{% endset %}
        {% set iconClock %}<svg width="15" height="15" fill="none" viewBox="0 0 24 24" class="me-2"><path stroke="currentColor" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>{% endset %}

        {{ _self.section('Anamnese & Vorgeschichte', iconDoc, {
            'hauptbeschwerde':    'Hauptbeschwerde',
            'seit_wann':          'Seit wann / Verlauf',
            'vorerkrankungen':    'Vorerkrankungen / OPs',
            'medikamente':        'Medikamente',
            'allergien':          'Allergien',
            'ernaehrung':         'Ernährung',
            'bewegung':           'Bewegung',
            'haltung':            'Haltung',
            'bisherige_therapien':'Bisherige Therapien'
        }, felder) }}

        {{ _self.section('Allgemeinbefund', iconActivity, {
            'allgemeinbefinden':  'Allgemeinbefinden',
            'ernaehrungszustand': 'Ernährungszustand',
            'temperament':        'Temperament',
            'koerpertemperatur':  'Körpertemperatur (°C)',
            'koerperhaltung':     'Körperhaltung',
            'gangbild':           'Gangbild',
            'lahmheitsgrad':      'Lahmheitsgrad (0–5)'
        }, felder) }}

        {{ _self.section('Bewegungsapparat & Muskulatur', iconMuscle, {
            'betroffene_regionen':   'Betroffene Regionen',
            'muskeltonus':           'Muskeltonus',
            'triggerpunkte':         'Triggerpunkte / Verspannungen',
            'schmerz_nrs':           'Schmerzskala NRS (0–10)',
            'gelenke_befund':        'Gelenkbefund',
            'neurologischer_status': 'Neurologischer Status'
        }, felder) }}

        {{ _self.section('Naturheilkundliche Diagnostik', iconShield, {
            'konstitutionstyp':       'Konstitutionstyp / Miasma',
            'energetischer_eindruck': 'Energetischer Gesamteindruck',
            'bachblueten_emotionen':  'Bach-Blüten Emotionen',
            'bachblueten_auswahl':    'Bach-Blüten Mischung',
            'bachblueten_dosierung':  'Bach-Blüten Dosierung',
            'homoeopathie_mittel':    'Homöopathisches Mittel',
            'homoeopathie_potenz':    'Potenz',
            'homoeopathie_dauer':     'Wiederholung / Dauer',
            'phytotherapie':          'Phytotherapie / Kräuter',
            'schuesslersalze':        'Schüssler Salze',
            'weitere_naturheilmittel':'Weitere Naturheilmittel'
        }, felder) }}

        {{ _self.section('Physiotherapeutische Maßnahmen', iconPlus, {
            'pt_methoden':      'Angewandte Methoden',
            'therapieziele':    'Therapieziele',
            'hausaufgaben':     'Hausaufgaben / Heimübungen',
            'therapiefrequenz': 'Frequenz',
            'therapiedauer':    'Dauer',
            'kontrolltermin':   'Kontrolltermin'
        }, felder) }}

        {{ _self.section('Verlauf & Notizen', iconClock, {
            'verlauf_notizen': 'Verlaufsnotizen'
        }, felder) }}

        {# ── Physio-Bereiche (read-only) ────────────────────────── #}
        {% if felder.physio_bereiche is defined and felder.physio_bereiche is not empty %}
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Physio-Bereiche</h5>
            </div>
            <div class="card-body">
                {% set bereiche = felder.physio_bereiche is iterable ? felder.physio_bereiche : [felder.physio_bereiche] %}
                {% for b in bereiche %}
                    <span class="badge bg-primary-subtle text-primary me-1 mb-1" style="font-size:.8rem;padding:.4rem .7rem;">{{ b }}</span>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# ── Anatomie-Markierungen (read-only) ──────────────────── #}
        {% if felder.anatomy_markers is defined and felder.anatomy_markers is not empty %}
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Anatomische Markierungen ({{ felder.anatomy_species|default('—') }})</h5>
            </div>
            <div class="card-body">
                {% set markers = felder.anatomy_markers is iterable ? felder.anatomy_markers : [] %}
                <dl class="row mb-0" style="row-gap:.4rem;">
                {% for m in markers %}
                    <dt class="col-sm-2">
                        <span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:{{ m.color|default('#ef4444') }};vertical-align:middle;"></span>
                    </dt>
                    <dd class="col-sm-10 mb-0" style="font-size:.9rem;">
                        {{ m.note|default('(ohne Notiz)') }}
                        <span class="text-muted small">· x={{ m.x|default('?') }}, y={{ m.y|default('?') }}</span>
                    </dd>
                {% endfor %}
                </dl>
            </div>
        </div>
        {% endif %}

        {% if felder is empty %}
        <div class="card">
            <div class="card-body text-center py-5 text-muted">
                <svg width="40" height="40" fill="none" viewBox="0 0 24 24" style="opacity:.2;margin-bottom:12px;"><path stroke="currentColor" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg>
                <p>Keine Felder ausgefüllt. <a href="/patienten/{{ patient.id }}/befunde/{{ befundbogen.id }}/bearbeiten">Jetzt bearbeiten</a></p>
            </div>
        </div>
        {% endif %}

    </div>
</div>
{% endblock %}
