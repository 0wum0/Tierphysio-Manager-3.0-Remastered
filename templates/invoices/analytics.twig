{% extends active_theme_layout ?? 'layouts/base.twig' %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <h1 class="page-title mb-0">Finanz-Analyse</h1>
        <p class="text-muted mb-0" style="font-size:.8rem;">Umsatzauswertung, Zahlungsverhalten & Prognose</p>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <a href="/rechnungen" class="btn btn-secondary btn-sm">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" points="15 18 9 12 15 6"/></svg>
            Rechnungen
        </a>
        <button class="btn btn-secondary btn-sm" id="btn-refresh">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="23 4 23 10 17 10"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            Aktualisieren
        </button>
    </div>
</div>

{# ── KPI Cards ── #}
<div class="row g-3 mb-4" id="kpi-row">
    <div class="col-6 col-md-4 col-xl-2"><div class="card h-100"><div class="card-body p-3">
        <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">Gesamtumsatz</div>
        <div class="fw-bold kpi-val" id="kpi-total" style="font-size:1.3rem;color:#4f7cff;">—</div>
        <div class="text-muted" id="kpi-total-sub" style="font-size:.72rem;margin-top:.2rem;">—</div>
    </div></div></div>
    <div class="col-6 col-md-4 col-xl-2"><div class="card h-100"><div class="card-body p-3">
        <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">Ø Rechnung</div>
        <div class="fw-bold kpi-val" id="kpi-avg" style="font-size:1.3rem;color:#8b5cf6;">—</div>
        <div class="text-muted" id="kpi-avg-sub" style="font-size:.72rem;margin-top:.2rem;">Max: —</div>
    </div></div></div>
    <div class="col-6 col-md-4 col-xl-2"><div class="card h-100"><div class="card-body p-3">
        <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">Offen</div>
        <div class="fw-bold kpi-val" id="kpi-open" style="font-size:1.3rem;color:#f59e0b;">—</div>
        <div class="text-muted" id="kpi-open-sub" style="font-size:.72rem;margin-top:.2rem;">—</div>
    </div></div></div>
    <div class="col-6 col-md-4 col-xl-2"><div class="card h-100"><div class="card-body p-3">
        <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">Überfällig</div>
        <div class="fw-bold kpi-val" id="kpi-overdue" style="font-size:1.3rem;color:#ef4444;">—</div>
        <div class="text-muted" id="kpi-overdue-sub" style="font-size:.72rem;margin-top:.2rem;">—</div>
    </div></div></div>
    <div class="col-6 col-md-4 col-xl-2"><div class="card h-100"><div class="card-body p-3">
        <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">Prognose nächsten Monat</div>
        <div class="fw-bold kpi-val" id="kpi-forecast" style="font-size:1.3rem;color:#10b981;">—</div>
        <div class="text-muted" style="font-size:.72rem;margin-top:.2rem;">Linear. Regression</div>
    </div></div></div>
    <div class="col-6 col-md-4 col-xl-2"><div class="card h-100"><div class="card-body p-3">
        <div class="text-muted small text-uppercase fw-semibold mb-1" style="font-size:.68rem;letter-spacing:.06em;">Wachstum YoY</div>
        <div class="fw-bold kpi-val" id="kpi-yoy" style="font-size:1.3rem;color:#06b6d4;">—</div>
        <div class="text-muted" style="font-size:.72rem;margin-top:.2rem;">Vorjahresvergleich</div>
    </div></div></div>
</div>

{# ── Tab Navigation ── #}
<ul class="nav nav-tabs mb-3" id="analytics-tabs">
    <li class="nav-item"><a class="nav-link active" data-atab="umsatz" href="#">📈 Umsatz</a></li>
    <li class="nav-item"><a class="nav-link" data-atab="besitzer" href="#">👥 Besitzer</a></li>
    <li class="nav-item"><a class="nav-link" data-atab="prognose" href="#">🔮 Prognose</a></li>
    <li class="nav-item"><a class="nav-link" data-atab="details" href="#">📊 Details</a></li>
</ul>

{# ══════════════════════════════════════════════════════ TAB: UMSATZ #}
<div id="atab-umsatz" class="atab-pane">

    <div class="row g-3 mb-3">
        {# Monthly Revenue Bar #}
        <div class="col-12 col-xl-8">
            <div class="card h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <div>
                            <div class="fw-semibold" style="font-size:.9rem;">Monatsumsatz (24 Monate)</div>
                            <div class="text-muted" style="font-size:.75rem;">Bezahlte Rechnungen</div>
                        </div>
                        <select class="form-select form-select-sm" id="month-range-select" style="width:auto;">
                            <option value="12">12 Monate</option>
                            <option value="24" selected>24 Monate</option>
                        </select>
                    </div>
                    <canvas id="chart-monthly" height="110"></canvas>
                </div>
            </div>
        </div>
        {# Quarterly #}
        <div class="col-12 col-xl-4">
            <div class="card h-100">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-1" style="font-size:.9rem;">Quartalsumsatz</div>
                    <div class="text-muted mb-2" style="font-size:.75rem;">Letzte 3 Jahre</div>
                    <canvas id="chart-quarterly" height="160"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        {# Yearly #}
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card h-100">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-1" style="font-size:.9rem;">Jahresumsatz</div>
                    <div class="text-muted mb-2" style="font-size:.75rem;">Alle Jahre</div>
                    <canvas id="chart-yearly" height="180"></canvas>
                </div>
            </div>
        </div>
        {# Status donut #}
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card h-100">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-1" style="font-size:.9rem;">Status-Verteilung</div>
                    <div class="text-muted mb-2" style="font-size:.75rem;">Alle Rechnungen</div>
                    <canvas id="chart-status-donut" height="180"></canvas>
                </div>
            </div>
        </div>
        {# Payment method #}
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card h-100">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-1" style="font-size:.9rem;">Zahlungsarten</div>
                    <div class="text-muted mb-2" style="font-size:.75rem;">Bezahlte Rechnungen</div>
                    <canvas id="chart-pay-method" height="180"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        {# Overdue aging #}
        <div class="col-12 col-md-6">
            <div class="card">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-1" style="font-size:.9rem;">Überfälligkeits-Analyse</div>
                    <div class="text-muted mb-2" style="font-size:.75rem;">Offene Beträge nach Alter</div>
                    <canvas id="chart-aging" height="140"></canvas>
                </div>
            </div>
        </div>
        {# Top positions #}
        <div class="col-12 col-md-6">
            <div class="card">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-2" style="font-size:.9rem;">Top-Leistungen nach Umsatz</div>
                    <div id="top-positions-list" style="font-size:.83rem;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════════════ TAB: BESITZER #}
<div id="atab-besitzer" class="atab-pane d-none">

    <div class="row g-3 mb-3">
        <div class="col-12">
            <div class="card">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-1" style="font-size:.9rem;">Umsatz pro Tierhalter (Top 15)</div>
                    <div class="text-muted mb-2" style="font-size:.75rem;">Bezahlt vs. ausstehend</div>
                    <canvas id="chart-owner-revenue" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        {# Fastest payers chart #}
        <div class="col-12 col-xl-6">
            <div class="card">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-1" style="font-size:.9rem;">Zahlungsgeschwindigkeit</div>
                    <div class="text-muted mb-2" style="font-size:.75rem;">Ø Tage von Rechnungsdatum bis Zahlung</div>
                    <canvas id="chart-pay-speed" height="160"></canvas>
                </div>
            </div>
        </div>
        {# Payment speed table #}
        <div class="col-12 col-xl-6">
            <div class="card">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="fw-semibold" style="font-size:.9rem;">Tierhalter-Ranking: Zahlungsverhalten</div>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="table table-sm mb-0" style="font-size:.8rem;" id="owner-speed-table">
                            <thead><tr>
                                <th>#</th>
                                <th>Tierhalter</th>
                                <th class="text-end">Ø Tage</th>
                                <th class="text-end">Rechnungen</th>
                                <th class="text-end">Gesamt</th>
                                <th class="text-center">Bewertung</th>
                            </tr></thead>
                            <tbody id="owner-speed-tbody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════════════ TAB: PROGNOSE #}
<div id="atab-prognose" class="atab-pane d-none">

    <div class="row g-3 mb-3">
        <div class="col-12">
            <div class="card">
                <div class="card-body p-3">
                    <div class="d-flex align-items-start justify-content-between mb-2">
                        <div>
                            <div class="fw-semibold" style="font-size:.9rem;">Umsatzprognose — nächste 6 Monate</div>
                            <div class="text-muted" style="font-size:.75rem;">Basis: Lineare Regression der letzten 18 Monate. Gestrichelte Linie = Prognose.</div>
                        </div>
                        <span class="badge bg-primary" id="forecast-trend-badge">—</span>
                    </div>
                    <canvas id="chart-forecast" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        {# Forecast table #}
        <div class="col-12 col-md-6">
            <div class="card h-100">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-2" style="font-size:.9rem;">Prognose-Tabelle</div>
                    <table class="table table-sm" style="font-size:.82rem;">
                        <thead><tr><th>Monat</th><th class="text-end">Erwarteter Umsatz</th><th class="text-end">Trend</th></tr></thead>
                        <tbody id="forecast-table-body"></tbody>
                    </table>
                </div>
            </div>
        </div>
        {# Forecast insights #}
        <div class="col-12 col-md-6">
            <div class="card h-100">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-3" style="font-size:.9rem;">Einschätzung & Empfehlungen</div>
                    <div id="forecast-insights" style="font-size:.85rem;line-height:1.7;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-4">
            <div class="card">
                <div class="card-body p-3 text-center">
                    <div class="text-muted small mb-1" style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;">Progn. Jahresumsatz</div>
                    <div class="fw-bold" id="forecast-annual" style="font-size:1.6rem;color:#10b981;">—</div>
                    <div class="text-muted" style="font-size:.72rem;">nächste 12 Monate (linear)</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card">
                <div class="card-body p-3 text-center">
                    <div class="text-muted small mb-1" style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;">Bestes Prognose-Monat</div>
                    <div class="fw-bold" id="forecast-best-month" style="font-size:1.4rem;color:#4f7cff;">—</div>
                    <div class="text-muted" id="forecast-best-val" style="font-size:.72rem;">—</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card">
                <div class="card-body p-3 text-center">
                    <div class="text-muted small mb-1" style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;">Wachstumsrate (6M)</div>
                    <div class="fw-bold" id="forecast-growth-rate" style="font-size:1.4rem;color:#8b5cf6;">—</div>
                    <div class="text-muted" style="font-size:.72rem;">Ø Monatswachstum</div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════════════ TAB: DETAILS #}
<div id="atab-details" class="atab-pane d-none">

    <div class="row g-3 mb-3">
        {# Revenue heatmap by month/year #}
        <div class="col-12">
            <div class="card">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-1" style="font-size:.9rem;">Umsatz-Heatmap (Monat × Jahr)</div>
                    <div class="text-muted mb-3" style="font-size:.75rem;">Hellere Felder = höherer Umsatz</div>
                    <div id="revenue-heatmap" style="overflow-x:auto;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-6">
            <div class="card">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-2" style="font-size:.9rem;">Ausstehende Forderungen (Aging)</div>
                    <div id="aging-detail-list" style="font-size:.83rem;"></div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="card">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-2" style="font-size:.9rem;">Schnellste & Langsamste Zahler</div>
                    <div id="payer-extremes" style="font-size:.83rem;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Loading overlay #}
<div id="analytics-loading" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9999;display:flex;align-items:center;justify-content:center;">
    <div style="background:var(--bs-body-bg,#1a1a2e);border-radius:12px;padding:2rem 3rem;text-align:center;">
        <div class="spinner-border text-primary mb-2" role="status"></div>
        <div style="font-size:.85rem;color:rgba(255,255,255,.7);">Lade Analyse-Daten…</div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
(function(){
'use strict';

/* ── Helpers ───────────────────────────────────────────────────── */
function fmt(val){
    if(val===null||val===undefined) return '—';
    return new Intl.NumberFormat('de-DE',{style:'currency',currency:'EUR',minimumFractionDigits:2}).format(parseFloat(val)||0);
}
function fmtShort(val){
    var n=parseFloat(val)||0;
    if(n>=1000) return (n/1000).toFixed(1).replace('.',',')+'k €';
    return fmt(n);
}
function el(id){ return document.getElementById(id); }

var _charts={};
function destroyChart(id){
    if(_charts[id]){ _charts[id].destroy(); delete _charts[id]; }
}

var COLORS={
    blue:'#4f7cff', purple:'#8b5cf6', green:'#22c55e', amber:'#f59e0b',
    red:'#ef4444', cyan:'#06b6d4', emerald:'#10b981', pink:'#ec4899',
    orange:'#f97316', lime:'#84cc16'
};
var PALETTE=Object.values(COLORS);
var GRID_COLOR='rgba(255,255,255,0.07)';
var TEXT_COLOR='rgba(255,255,255,0.55)';

var chartDefaults={
    responsive:true, maintainAspectRatio:true,
    plugins:{ legend:{ labels:{ color:TEXT_COLOR, boxWidth:10, font:{size:11} } }, tooltip:{ callbacks:{} } },
    scales:{
        x:{ grid:{color:GRID_COLOR}, ticks:{color:TEXT_COLOR,font:{size:10},maxRotation:45} },
        y:{ grid:{color:GRID_COLOR}, ticks:{ color:TEXT_COLOR, font:{size:10},
            callback:function(v){ return fmtShort(v); }
        }}
    }
};

/* ── Tab switching ─────────────────────────────────────────────── */
document.querySelectorAll('[data-atab]').forEach(function(link){
    link.addEventListener('click',function(e){
        e.preventDefault();
        document.querySelectorAll('[data-atab]').forEach(function(l){ l.classList.remove('active'); });
        document.querySelectorAll('.atab-pane').forEach(function(p){ p.classList.add('d-none'); });
        link.classList.add('active');
        var pane=el('atab-'+link.dataset.atab);
        if(pane) pane.classList.remove('d-none');
    });
});

/* ── Load data ─────────────────────────────────────────────────── */
var _data=null;

function load(){
    el('analytics-loading').style.display='flex';
    fetch('/api/rechnungen/analytics')
        .then(function(r){ return r.ok?r.json():Promise.reject(r.status); })
        .then(function(d){
            _data=d;
            el('analytics-loading').style.display='none';
            renderAll(d);
        })
        .catch(function(err){
            el('analytics-loading').style.display='none';
            console.error('Analytics load error:',err);
        });
}

el('btn-refresh').addEventListener('click', load);

/* ── Month range selector ───────────────────────────────────────── */
el('month-range-select').addEventListener('change',function(){
    if(!_data) return;
    var months=parseInt(this.value)||24;
    var slice=months;
    var labels=_data.by_month.labels.slice(-slice);
    var revenue=_data.by_month.revenue.slice(-slice);
    _charts['monthly'].data.labels=labels;
    _charts['monthly'].data.datasets[0].data=revenue;
    _charts['monthly'].update();
});

/* ══ RENDER ALL ════════════════════════════════════════════════ */
function renderAll(d){
    renderKpis(d);
    renderMonthly(d);
    renderQuarterly(d);
    renderYearly(d);
    renderStatusDonut(d);
    renderPayMethod(d);
    renderAging(d);
    renderTopPositions(d);
    renderOwnerRevenue(d);
    renderOwnerSpeed(d);
    renderOwnerTable(d);
    renderForecast(d);
    renderForecastTable(d);
    renderForecastInsights(d);
    renderHeatmap(d);
    renderAgingDetail(d);
    renderPayerExtremes(d);
}

/* ── KPIs ────────────────────────────────────────────────────── */
function renderKpis(d){
    var s=d.summary||{};
    el('kpi-total').textContent=fmt(s.paid);
    el('kpi-total-sub').textContent=(s.paid_count||0)+' bezahlte Rechnungen';
    el('kpi-avg').textContent=fmt(s.avg_invoice);
    el('kpi-avg-sub').textContent='Max: '+fmt(s.max_invoice);
    el('kpi-open').textContent=fmt(s.open);
    el('kpi-open-sub').textContent=(s.open_count||0)+' Rechnungen offen';
    el('kpi-overdue').textContent=fmt(s.overdue);
    el('kpi-overdue-sub').textContent=(s.overdue_count||0)+' überfällig';
    var next=d.forecast_next&&d.forecast_next[0];
    el('kpi-forecast').textContent=next?fmt(next.value):'—';
    if(d.yoy_growth!==null&&d.yoy_growth!==undefined){
        var g=parseFloat(d.yoy_growth);
        el('kpi-yoy').textContent=(g>0?'+':'')+g.toFixed(1)+'%';
        el('kpi-yoy').style.color=g>=0?'#10b981':'#ef4444';
    }
}

/* ── Monthly bar ─────────────────────────────────────────────── */
function renderMonthly(d){
    destroyChart('monthly');
    var ctx=el('chart-monthly').getContext('2d');
    var labels=d.by_month.labels;
    var revenue=d.by_month.revenue;
    _charts['monthly']=new Chart(ctx,{
        type:'bar',
        data:{
            labels:labels,
            datasets:[{
                label:'Umsatz (€)',
                data:revenue,
                backgroundColor:'rgba(79,124,255,0.7)',
                borderColor:'#4f7cff',
                borderWidth:1,
                borderRadius:4
            }]
        },
        options:Object.assign({},chartDefaults,{
            plugins:Object.assign({},chartDefaults.plugins,{
                tooltip:{ callbacks:{ label:function(ctx){ return ' '+fmt(ctx.parsed.y); } } }
            })
        })
    });
}

/* ── Quarterly bar ───────────────────────────────────────────── */
function renderQuarterly(d){
    destroyChart('quarterly');
    var ctx=el('chart-quarterly').getContext('2d');
    _charts['quarterly']=new Chart(ctx,{
        type:'bar',
        data:{
            labels:d.by_quarter.labels,
            datasets:[{
                label:'Umsatz (€)',
                data:d.by_quarter.revenue,
                backgroundColor:d.by_quarter.labels.map(function(l,i){ return PALETTE[i%PALETTE.length]+'bb'; }),
                borderColor:d.by_quarter.labels.map(function(l,i){ return PALETTE[i%PALETTE.length]; }),
                borderWidth:1, borderRadius:4
            }]
        },
        options:Object.assign({},chartDefaults,{
            plugins:Object.assign({},chartDefaults.plugins,{
                legend:{display:false},
                tooltip:{ callbacks:{ label:function(ctx){ return ' '+fmt(ctx.parsed.y); } } }
            })
        })
    });
}

/* ── Yearly bar ──────────────────────────────────────────────── */
function renderYearly(d){
    destroyChart('yearly');
    var ctx=el('chart-yearly').getContext('2d');
    _charts['yearly']=new Chart(ctx,{
        type:'bar',
        data:{
            labels:d.by_year.labels,
            datasets:[{
                label:'Jahresumsatz (€)',
                data:d.by_year.revenue,
                backgroundColor:'rgba(139,92,246,0.7)',
                borderColor:'#8b5cf6',
                borderWidth:1, borderRadius:4
            }]
        },
