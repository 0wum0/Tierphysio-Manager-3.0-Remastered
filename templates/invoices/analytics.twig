/* ── Forecast line chart ─────────────────────────────────────── */
function renderForecast(d){
    destroyChart('forecast');
    var ctx=el('chart-forecast').getContext('2d');
    var hist=d.forecast_history||[];
    var next=d.forecast_next||[];
    var histLabels=hist.map(function(h){ return h.month; });
    var histVals=hist.map(function(h){ return h.revenue; });
    var nextLabels=next.map(function(n){ return n.month; });
    var nextVals=next.map(function(n){ return n.value; });

    /* Overlap last historical point with first forecast */
    var lastHistVal=histVals[histVals.length-1]||0;
    var lastHistLabel=histLabels[histLabels.length-1]||'';
    var allLabels=histLabels.concat(nextLabels);

    var histDataPad=histVals.concat(Array(nextLabels.length).fill(null));
    var forecastDataPad=Array(histLabels.length-1).fill(null).concat([lastHistVal]).concat(nextVals);

    _charts['forecast']=new Chart(ctx,{
        type:'line',
        data:{
            labels:allLabels,
            datasets:[
                {
                    label:'Tatsächlicher Umsatz',
                    data:histDataPad,
                    borderColor:'#4f7cff',
                    backgroundColor:'rgba(79,124,255,.12)',
                    borderWidth:2,
                    pointRadius:3,
                    fill:true,
                    tension:0.3
                },
                {
                    label:'Prognose',
                    data:forecastDataPad,
                    borderColor:'#10b981',
                    backgroundColor:'rgba(16,185,129,.08)',
                    borderWidth:2,
                    borderDash:[6,4],
                    pointRadius:4,
                    pointBackgroundColor:'#10b981',
                    fill:true,
                    tension:0.3
                }
            ]
        },
        options:Object.assign({},chartDefaults,{
            plugins:Object.assign({},chartDefaults.plugins,{
                tooltip:{ callbacks:{ label:function(ctx){ return ' '+ctx.dataset.label+': '+fmt(ctx.parsed.y); } } }
            })
        })
    });

    /* Trend badge */
    if(next.length>=2){
        var first=parseFloat(next[0].value)||0;
        var last=parseFloat(next[next.length-1].value)||0;
        var trend=first>0?(last-first)/first*100:0;
        var badge=el('forecast-trend-badge');
        badge.textContent=(trend>=0?'▲ Steigend +':'▼ Fallend ')+Math.abs(trend).toFixed(1)+'% über 6M';
        badge.className='badge '+(trend>=0?'bg-success':'bg-danger');
    }

    /* Annual forecast */
    var annualSum=0;
    var recent=histVals.slice(-6);
    var slope=0;
    if(recent.length>=2){ slope=(recent[recent.length-1]-recent[0])/(recent.length-1); }
    for(var f=1;f<=12;f++){
        annualSum+=Math.max(0,(histVals[histVals.length-1]||0)+(slope*f));
    }
    el('forecast-annual').textContent=fmt(annualSum);

    /* Best forecast month */
    if(next.length){
        var best=next.reduce(function(a,b){ return parseFloat(a.value)>=parseFloat(b.value)?a:b; });
        el('forecast-best-month').textContent=best.month;
        el('forecast-best-val').textContent=fmt(best.value);
    }

    /* Growth rate */
    if(next.length>=2){
        var rates=[];
        for(var i=1;i<next.length;i++){
            var prev=parseFloat(next[i-1].value)||1;
            rates.push((parseFloat(next[i].value)-prev)/prev*100);
        }
        var avgRate=rates.reduce(function(a,b){return a+b;},0)/rates.length;
        el('forecast-growth-rate').textContent=(avgRate>=0?'+':'')+avgRate.toFixed(2)+'% / Monat';
        el('forecast-growth-rate').style.color=avgRate>=0?'#10b981':'#ef4444';
    }
}

/* ── Forecast table ──────────────────────────────────────────── */
function renderForecastTable(d){
    var tbody=el('forecast-table-body');
    var next=d.forecast_next||[];
    if(!next.length){ tbody.innerHTML='<tr><td colspan="3" class="text-muted text-center">Zu wenig Verlaufsdaten für eine Prognose</td></tr>'; return; }
    var baseVal=parseFloat((d.forecast_history||[]).slice(-1)[0]?.revenue)||0;
    var html='';
    next.forEach(function(n,i){
        var val=parseFloat(n.value)||0;
        var diff=val-baseVal;
        var pct=baseVal>0?diff/baseVal*100:0;
        html+='<tr>'
            +'<td>'+n.month+'</td>'
            +'<td class="text-end fw-semibold">'+fmt(val)+'</td>'
            +'<td class="text-end" style="color:'+(diff>=0?'#22c55e':'#ef4444')+';">'+(diff>=0?'+':'')+pct.toFixed(1)+'%</td>'
            +'</tr>';
        baseVal=val;
    });
    tbody.innerHTML=html;
}

/* ── Forecast insights ───────────────────────────────────────── */
function renderForecastInsights(d){
    var div=el('forecast-insights');
    var next=d.forecast_next||[];
    var hist=d.forecast_history||[];
    var s=d.summary||{};
    var insights=[];

    var totalForecast6=(next||[]).reduce(function(a,n){ return a+(parseFloat(n.value)||0); },0);
    var lastHist6=hist.slice(-6).reduce(function(a,h){ return a+(h.revenue||0); },0);
    var growth6=lastHist6>0?(totalForecast6-lastHist6)/lastHist6*100:0;

    if(growth6>10) insights.push({icon:'📈',color:'#22c55e',text:'Starkes Wachstum: Die Prognose zeigt +'+growth6.toFixed(1)+'% Umsatzwachstum in den nächsten 6 Monaten.'});
    else if(growth6<-5) insights.push({icon:'📉',color:'#ef4444',text:'Rückgang erwartet: Prognostizierter Umsatzrückgang von '+Math.abs(growth6).toFixed(1)+'% — mehr Neukunden oder Bestandspflege empfohlen.'});
    else insights.push({icon:'➡️',color:'#f59e0b',text:'Stabiler Umsatz: Die Prognose zeigt eine stabile Entwicklung mit '+growth6.toFixed(1)+'% Veränderung.'});

    var overdue=parseFloat(s.overdue)||0;
    var paid=parseFloat(s.paid)||1;
    if(overdue/paid>0.1) insights.push({icon:'⚠️',color:'#f59e0b',text:'Hoher Überfälligkeitsanteil: '+fmt(overdue)+' ('+((overdue/paid)*100).toFixed(1)+'% des Gesamtumsatzes) sind überfällig — Mahnwesen prüfen.'});

    var speeds=d.owner_speed||[];
    var slowPayers=speeds.filter(function(o){ return parseFloat(o.avg_days)>45; });
    if(slowPayers.length) insights.push({icon:'🐢',color:'#f97316',text:slowPayers.length+' Tierhalter zahlen im Schnitt über 45 Tage nach Rechnungsdatum. Frühzeitige Erinnerungen empfohlen.'});

    var fastPayers=speeds.filter(function(o){ return parseFloat(o.avg_days)<=7; });
    if(fastPayers.length) insights.push({icon:'⚡',color:'#22c55e',text:fastPayers.length+' Tierhalter zahlen sehr schnell (≤7 Tage) — ideale Stammkunden.'});

    if(!insights.length) insights.push({icon:'ℹ️',color:'#94a3b8',text:'Noch zu wenig Daten für detaillierte Einschätzungen. Mehr bezahlte Rechnungen mit Zahlungsdatum erfassen.'});

    div.innerHTML=insights.map(function(ins){
        return '<div class="d-flex gap-2 mb-3 p-2" style="background:rgba(255,255,255,.04);border-radius:8px;border-left:3px solid '+ins.color+';">'
            +'<span style="font-size:1.1rem;flex-shrink:0;">'+ins.icon+'</span>'
            +'<div style="color:rgba(255,255,255,.8);">'+ins.text+'</div>'
            +'</div>';
    }).join('');
}

/* ── Revenue heatmap ─────────────────────────────────────────── */
function renderHeatmap(d){
    var container=el('revenue-heatmap');
    var byMonth=d.by_month||{labels:[],revenue:[]};
    /* Build year×month matrix */
    var data={};
    var years=new Set();
    var monthNames=['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];
    byMonth.labels.forEach(function(label,i){
        var parts=label.split(' ');
        var mName=parts[0]; var yr=parts[1];
        if(!data[yr]) data[yr]={};
        var mIdx=monthNames.indexOf(mName);
        if(mIdx>=0) data[yr][mIdx]=byMonth.revenue[i]||0;
        years.add(yr);
    });
    var sortedYears=Array.from(years).sort();
    var maxVal=Math.max.apply(null,byMonth.revenue.map(function(v){return v||0;}));
    if(!sortedYears.length){ container.innerHTML='<div class="text-muted">Keine Daten</div>'; return; }

    var html='<table style="border-collapse:separate;border-spacing:3px;width:100%;font-size:.75rem;">';
    html+='<tr><th style="color:rgba(255,255,255,.4);font-weight:400;padding:2px 6px;">Jahr</th>';
    monthNames.forEach(function(m){ html+='<th style="color:rgba(255,255,255,.4);font-weight:400;text-align:center;min-width:48px;">'+m+'</th>'; });
    html+='</tr>';
    sortedYears.forEach(function(yr){
        html+='<tr><td style="color:rgba(255,255,255,.6);padding:2px 6px;font-weight:600;">'+yr+'</td>';
        for(var m=0;m<12;m++){
            var val=(data[yr]&&data[yr][m])||0;
            var intensity=maxVal>0?val/maxVal:0;
            var alpha=0.08+intensity*0.85;
            var bg='rgba(79,124,255,'+alpha.toFixed(2)+')';
            var textColor=intensity>0.5?'rgba(255,255,255,.95)':'rgba(255,255,255,.5)';
            html+='<td style="background:'+bg+';border-radius:4px;text-align:center;padding:5px 2px;color:'+textColor+';cursor:default;" title="'+monthNames[m]+' '+yr+': '+fmt(val)+'">'
                +(val>0?fmtShort(val):'—')
                +'</td>';
        }
        html+='</tr>';
    });
    html+='</table>';
    container.innerHTML=html;
}

/* ── Aging detail ────────────────────────────────────────────── */
function renderAgingDetail(d){
    var div=el('aging-detail-list');
    var ag=d.aging||{};
    var buckets=[
        {label:'1–30 Tage',amount:ag.d30||0,count:ag.c30||0,color:'#f59e0b'},
        {label:'31–60 Tage',amount:ag.d60||0,count:ag.c60||0,color:'#f97316'},
        {label:'61–90 Tage',amount:ag.d90||0,count:ag.c90||0,color:'#ef4444'},
        {label:'> 90 Tage', amount:ag.d90p||0,count:ag.c90p||0,color:'#b91c1c'},
    ];
    var total=(parseFloat(ag.d30)||0)+(parseFloat(ag.d60)||0)+(parseFloat(ag.d90)||0)+(parseFloat(ag.d90p)||0);
    if(!total){ div.innerHTML='<div class="text-muted text-center py-3">Keine offenen/überfälligen Forderungen</div>'; return; }
    var html='';
    buckets.forEach(function(b){
        var pct=total>0?Math.round((parseFloat(b.amount)||0)/total*100):0;
        html+='<div class="mb-3">'
            +'<div class="d-flex justify-content-between mb-1">'
            +'<span style="font-weight:600;color:'+b.color+';">'+b.label+'</span>'
            +'<span>'+fmt(b.amount)+' <span class="text-muted">('+b.count+' Rechnungen)</span></span>'
            +'</div>'
            +'<div style="height:6px;background:rgba(255,255,255,.08);border-radius:3px;">'
            +'<div style="height:6px;width:'+pct+'%;background:'+b.color+';border-radius:3px;"></div>'
            +'</div>'
            +'</div>';
    });
    html+='<div class="d-flex justify-content-between pt-2" style="border-top:1px solid rgba(255,255,255,.1);font-weight:700;font-size:.85rem;">'
        +'<span>Gesamt</span><span>'+fmt(total)+'</span></div>';
    div.innerHTML=html;
}

/* ── Payer extremes ──────────────────────────────────────────── */
function renderPayerExtremes(d){
    var div=el('payer-extremes');
    var speeds=d.owner_speed||[];
    if(!speeds.length){ div.innerHTML='<div class="text-muted text-center py-3">Keine Daten (noch keine bezahlten Rechnungen mit Zahlungsdatum)</div>'; return; }
    var sorted=[].concat(speeds).sort(function(a,b){ return (parseFloat(a.avg_days)||0)-(parseFloat(b.avg_days)||0); });
    var fastest=sorted.slice(0,5);
    var slowest=sorted.slice(-5).reverse();
    var html='<div class="mb-3"><div class="fw-semibold mb-2" style="color:#22c55e;font-size:.82rem;">⚡ Schnellste Zahler</div>';
    fastest.forEach(function(o,i){
        html+='<div class="d-flex justify-content-between align-items-center mb-1" style="font-size:.8rem;">'
            +'<span>'+(i+1)+'. <a href="/tierhalter/'+o.owner_id+'" style="color:inherit;">'+o.owner_name+'</a></span>'
            +'<span style="color:#22c55e;font-weight:600;">'+parseFloat(o.avg_days).toFixed(1)+' Tage</span>'
            +'</div>';
    });
    html+='</div><div><div class="fw-semibold mb-2" style="color:#ef4444;font-size:.82rem;">🐢 Langsamste Zahler</div>';
    slowest.forEach(function(o,i){
        html+='<div class="d-flex justify-content-between align-items-center mb-1" style="font-size:.8rem;">'
            +'<span>'+(i+1)+'. <a href="/tierhalter/'+o.owner_id+'" style="color:inherit;">'+o.owner_name+'</a></span>'
            +'<span style="color:#ef4444;font-weight:600;">'+parseFloat(o.avg_days).toFixed(1)+' Tage</span>'
            +'</div>';
    });
    html+='</div>';
    div.innerHTML=html;
}

