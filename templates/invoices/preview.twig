<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rechnung {{ invoice.invoice_number }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 9.5pt;
    color: #1a1a2e;
    background: #f0f2f5;
    min-height: 100vh;
  }

  /* ── Toolbar ─────────────────────────────────────── */
  .toolbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(20, 20, 40, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.5rem;
    color: #fff;
    font-size: 0.8rem;
  }
  .toolbar-title {
    font-weight: 600;
    letter-spacing: 0.02em;
    flex: 1;
  }
  .tb-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.9rem;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: background 0.15s;
  }
  .tb-btn-primary { background: #4f7cff; color: #fff; }
  .tb-btn-primary:hover { background: #3a6aee; }
  .tb-btn-secondary { background: rgba(255,255,255,0.12); color: #fff; }
  .tb-btn-secondary:hover { background: rgba(255,255,255,0.2); }

  /* ── Paper wrapper ───────────────────────────────── */
  .paper-wrap {
    margin: 80px auto 60px;
    max-width: 820px;
    padding: 0 20px;
  }

  /* ── A4 Page ─────────────────────────────────────── */
  .a4 {
    background: #fff;
    width: 100%;
    min-height: 1122px; /* A4 at 96dpi approx */
    box-shadow: 0 4px 40px rgba(0,0,0,0.18);
    border-radius: 3px;
    padding: 50px 55px 60px;
    position: relative;
  }

  /* ── Header band ─────────────────────────────────── */
  .inv-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-bottom: 20px;
    border-bottom: 3px solid #1a1a2e;
    margin-bottom: 28px;
  }
  .inv-logo img {
    max-height: 70px;
    max-width: 180px;
    object-fit: contain;
  }
  .inv-logo-placeholder {
    width: 120px;
    height: 50px;
    background: #eee;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8pt;
    color: #999;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Big "Rechnung" script heading */
  .inv-title-block {
    text-align: right;
  }
  .inv-title-script {
    font-size: 42pt;
    font-weight: 700;
    color: #1a1a2e;
    font-style: italic;
    letter-spacing: -0.5px;
    line-height: 1;
  }
  .inv-number-badge {
    display: inline-block;
    margin-top: 6px;
    font-size: 8.5pt;
    font-weight: 600;
    color: #666;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Two-column info row ─────────────────────────── */
  .inv-info-row {
    display: flex;
    gap: 32px;
    margin-bottom: 28px;
    align-items: flex-start;
  }
  .inv-sender-col {
    flex: 0 0 auto;
    min-width: 200px;
  }
  .inv-receiver-col {
    flex: 1;
  }
  .inv-meta-col {
    flex: 0 0 auto;
    min-width: 170px;
    text-align: right;
  }

  /* Small return address line */
  .return-address {
    font-size: 7pt;
    color: #888;
    border-bottom: 1px solid #ccc;
    padding-bottom: 3px;
    margin-bottom: 8px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Recipient address */
  .recipient-name {
    font-weight: 700;
    font-size: 11pt;
    margin-bottom: 2px;
  }
  .recipient-address {
    font-size: 9.5pt;
    line-height: 1.55;
    color: #333;
  }

  /* Meta table */
  .meta-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 8.5pt;
  }
  .meta-table td {
    padding: 2px 0;
    vertical-align: top;
  }
  .meta-table td:first-child {
    color: #888;
    white-space: nowrap;
    padding-right: 10px;
  }
  .meta-table td:last-child {
    font-weight: 600;
    text-align: right;
  }

  /* ── Subject line ─────────────────────────────────── */
  .inv-subject {
    font-size: 11pt;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .inv-intro {
    font-size: 9pt;
    color: #444;
    margin-bottom: 18px;
    line-height: 1.5;
  }

  /* ── Positions table ─────────────────────────────── */
  .pos-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 6px;
    font-size: 9pt;
  }
  .pos-table thead tr {
    background: #1a1a2e;
    color: #fff;
  }
  .pos-table thead th {
    padding: 7px 10px;
    font-weight: 600;
    font-size: 8pt;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .pos-table thead th:last-child,
  .pos-table thead th:nth-child(2),
  .pos-table thead th:nth-child(3),
  .pos-table thead th:nth-child(4) {
    text-align: right;
  }
  .pos-table tbody tr {
    border-bottom: 1px solid #eee;
  }
  .pos-table tbody tr:nth-child(even) {
    background: #f8f8fc;
  }
  .pos-table tbody td {
    padding: 8px 10px;
    vertical-align: top;
  }
  .pos-table tbody td:nth-child(2),
  .pos-table tbody td:nth-child(3),
  .pos-table tbody td:nth-child(4),
  .pos-table tbody td:nth-child(5) {
    text-align: right;
    white-space: nowrap;
  }

  /* ── Totals block ─────────────────────────────────── */
  .totals-wrap {
    display: flex;
    justify-content: flex-end;
    margin-top: 10px;
    margin-bottom: 28px;
  }
  .totals-table {
    min-width: 240px;
    border-collapse: collapse;
    font-size: 9pt;
  }
  .totals-table td {
    padding: 4px 10px;
    vertical-align: top;
  }
  .totals-table td:first-child {
    color: #666;
    white-space: nowrap;
  }
  .totals-table td:last-child {
    text-align: right;
    font-weight: 600;
    white-space: nowrap;
  }
  .totals-table .total-gross {
    border-top: 2px solid #1a1a2e;
    border-bottom: 2px solid #1a1a2e;
    background: #1a1a2e;
    color: #fff;
  }
  .totals-table .total-gross td {
    color: #fff;
    font-size: 11pt;
    font-weight: 800;
    padding: 6px 10px;
  }

  /* ── Closing text & IBAN ─────────────────────────── */
  .inv-closing {
    font-size: 9pt;
    color: #444;
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .inv-thankyou {
    font-size: 18pt;
    font-weight: 700;
    font-style: italic;
    color: #1a1a2e;
    margin-bottom: 20px;
  }

  /* ── Footer band ─────────────────────────────────── */
  .inv-footer {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    border-top: 2px solid #1a1a2e;
    padding: 12px 55px;
    display: flex;
    gap: 24px;
    justify-content: space-between;
    align-items: flex-start;
    background: #fff;
    border-radius: 0 0 3px 3px;
  }
  .inv-footer .footer-col {
    flex: 1;
  }
  .inv-footer .footer-col-label {
    font-size: 7pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #888;
    margin-bottom: 3px;
  }
  .inv-footer .footer-col-value {
    font-size: 8.5pt;
    color: #1a1a2e;
    line-height: 1.5;
  }

  /* ── Patient chip ─────────────────────────────────── */
  .patient-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: #f0f2ff;
    border: 1px solid #c8d4ff;
    border-radius: 20px;
    padding: 2px 10px 2px 6px;
    font-size: 8pt;
    color: #3a5adb;
    margin-bottom: 16px;
  }

  /* ── Notes ───────────────────────────────────────── */
  .inv-notes {
    font-size: 8.5pt;
    color: #555;
    line-height: 1.55;
    margin-bottom: 16px;
    padding: 10px 12px;
    background: #f8f8fc;
    border-left: 3px solid #c8d4ff;
    border-radius: 3px;
  }

  /* ── Print styles ─────────────────────────────────── */
  @media print {
    body { background: #fff; }
    .toolbar { display: none; }
    .paper-wrap { margin: 0; padding: 0; max-width: 100%; }
    .a4 {
      box-shadow: none;
      border-radius: 0;
      padding: 18mm 20mm 25mm;
      min-height: auto;
    }
    .inv-footer { position: fixed; bottom: 0; left: 20mm; right: 20mm; }
  }
</style>
</head>
<body>

{# ── Toolbar ───────────────────────────────────────── #}
<div class="toolbar">
  <span class="toolbar-title">
    Rechnung {{ invoice.invoice_number }}
    <span style="opacity:0.5;font-weight:400;margin-left:8px;">{{ invoice.issue_date|date_de }}</span>
  </span>
  <a href="/rechnungen/{{ invoice.id }}" class="tb-btn tb-btn-secondary">
    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 18 9 12 15 6"/></svg>
    Zurück
  </a>
  {% if invoice.status != 'paid' %}
  <a href="/rechnungen/{{ invoice.id }}/bearbeiten" class="tb-btn tb-btn-secondary">
    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
    Bearbeiten
  </a>
  {% endif %}
  <a href="/rechnungen/{{ invoice.id }}/pdf" class="tb-btn tb-btn-secondary" target="_blank">
    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    PDF
  </a>
  <button class="tb-btn tb-btn-primary" onclick="window.print()">
    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="6 9 6 2 18 2 18 9"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8" rx="1" stroke="currentColor" stroke-width="2"/></svg>
    Drucken
  </button>
</div>

{# ── A4 Paper ──────────────────────────────────────── #}
<div class="paper-wrap">
<div class="a4">

  {# ── HEADER ──────────────────────────────────────── #}
  <div class="inv-header">
    <div class="inv-logo">
      {% if settings.company_logo %}
        <img src="/storage/uploads/{{ settings.company_logo }}" alt="{{ settings.company_name ?? 'Logo' }}">
      {% else %}
        <div class="inv-logo-placeholder">Logo</div>
      {% endif %}
    </div>
    <div class="inv-title-block">
      <div class="inv-title-script">Rechnung</div>
      <div class="inv-number-badge">Nr. {{ invoice.invoice_number }}</div>
    </div>
  </div>

  {# ── INFO ROW: Sender | Recipient | Meta ─────────── #}
  <div class="inv-info-row">

    {# Sender #}
    <div class="inv-sender-col">
      <div style="font-weight:700;font-size:10pt;margin-bottom:6px;">
        {{ settings.company_name ?? 'Tierphysio Praxis' }}
      </div>
      <div style="font-size:8.5pt;line-height:1.6;color:#444;">
        {% if settings.company_street %}{{ settings.company_street }}<br>{% endif %}
        {% if settings.company_zip or settings.company_city %}{{ settings.company_zip }} {{ settings.company_city }}<br>{% endif %}
        {% if settings.company_phone %}<span style="color:#888;">Tel:</span> {{ settings.company_phone }}<br>{% endif %}
        {% if settings.company_email %}<span style="color:#888;">E-Mail:</span> {{ settings.company_email }}<br>{% endif %}
        {% if settings.company_website %}<span style="color:#888;">Web:</span> {{ settings.company_website }}{% endif %}
      </div>
    </div>

    {# Recipient #}
    <div class="inv-receiver-col">
      {% if owner %}
        <div class="return-address">
          {{ settings.company_name ?? '' }} · {{ settings.company_street ?? '' }} · {{ settings.company_zip ?? '' }} {{ settings.company_city ?? '' }}
        </div>
        <div class="recipient-name">{{ owner.first_name }} {{ owner.last_name }}</div>
        <div class="recipient-address">
          {% if owner.street %}{{ owner.street }}<br>{% endif %}
          {% if owner.zip or owner.city %}{{ owner.zip }} {{ owner.city }}<br>{% endif %}
          {% if owner.country and owner.country != 'DE' %}{{ owner.country }}{% endif %}
        </div>
      {% endif %}
    </div>

    {# Meta #}
    <div class="inv-meta-col">
      <table class="meta-table">
        <tr>
          <td>Rechnungsdatum</td>
          <td>{{ invoice.issue_date|date_de }}</td>
        </tr>
        {% if invoice.due_date %}
        <tr>
          <td>Fällig bis</td>
          <td style="{{ invoice.status == 'overdue' ? 'color:#d32f2f;' : '' }}">{{ invoice.due_date|date_de }}</td>
        </tr>
        {% endif %}
        <tr>
          <td>Rechnungs-Nr.</td>
          <td>{{ invoice.invoice_number }}</td>
        </tr>
        {% if patient %}
        <tr>
          <td>Patient</td>
          <td>{{ patient.name }}</td>
        </tr>
        {% endif %}
        {% if settings.tax_number %}
        <tr>
          <td>Steuer-Nr.</td>
          <td>{{ settings.tax_number }}</td>
        </tr>
        {% endif %}
      </table>
    </div>

  </div>

  {# ── Patient chip (optional) ──────────────────────── #}
  {% if patient %}
  <div class="patient-chip">
    <svg width="11" height="11" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="7" r="4" stroke="#3a5adb" stroke-width="2"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="#3a5adb" stroke-width="2" stroke-linecap="round"/></svg>
    {{ patient.name }}{% if patient.species %} · {{ patient.species }}{% endif %}
  </div>
  {% endif %}

  {# ── Intro text / Subject ─────────────────────────── #}
  <div class="inv-subject">
    Rechnung Nr. {{ invoice.invoice_number }}
    {% if patient %} für {{ patient.name }}{% endif %}
  </div>
  {% if settings.pdf_intro_text %}
  <div class="inv-intro">{{ settings.pdf_intro_text }}</div>
  {% else %}
  <div class="inv-intro">
    für folgende erbrachten Leistungen erlauben wir uns, Ihnen folgenden Betrag in Rechnung zu stellen:
  </div>
  {% endif %}

  {# ── Positions table ──────────────────────────────── #}
  <table class="pos-table">
    <thead>
      <tr>
        <th style="width:40%;text-align:left;">Leistung / Beschreibung</th>
        <th style="width:10%;">Menge</th>
        <th style="width:15%;">Einzelpreis</th>
        <th style="width:10%;">MwSt.</th>
        <th style="width:15%;">Betrag</th>
      </tr>
    </thead>
    <tbody>
      {% for pos in positions %}
      <tr>
        <td>{{ pos.description }}</td>
        <td>{{ pos.quantity|number_format(2, ',', '.') }}</td>
        <td>{{ pos.unit_price|money }}</td>
        <td>{{ pos.tax_rate }}%</td>
        <td><strong>{{ (pos.quantity * pos.unit_price)|money }}</strong></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  {# ── Totals ───────────────────────────────────────── #}
  <div class="totals-wrap">
    <table class="totals-table">
      <tr>
        <td>Nettobetrag</td>
        <td>{{ invoice.total_net|money }}</td>
      </tr>
      <tr>
        <td>Umsatzsteuer</td>
        <td>{{ invoice.total_tax|money }}</td>
      </tr>
      <tr class="total-gross">
        <td>Gesamtbetrag</td>
        <td>{{ invoice.total_gross|money }}</td>
      </tr>
    </table>
  </div>

  {# ── Notes ────────────────────────────────────────── #}
  {% if invoice.notes %}
  <div class="inv-notes">{{ invoice.notes }}</div>
  {% endif %}

  {# ── Closing / Thank-you ──────────────────────────── #}
  {% if settings.pdf_closing_text %}
  <div class="inv-closing">{{ settings.pdf_closing_text }}</div>
  {% else %}
  <div class="inv-closing">
    Bitte überweisen Sie den Gesamtbetrag
    {% if invoice.due_date %}bis zum <strong>{{ invoice.due_date|date_de }}</strong>{% endif %}
    auf das unten angegebene Konto.
    {% if invoice.payment_terms %}<br><em>{{ invoice.payment_terms }}</em>{% endif %}
  </div>
  {% endif %}

  <div class="inv-thankyou">Vielen Dank!</div>

  {# ── Footer bar ───────────────────────────────────── #}
  <div class="inv-footer">
    {# Company #}
    <div class="footer-col">
      <div class="footer-col-label">Absender</div>
      <div class="footer-col-value">
        <strong>{{ settings.company_name ?? '' }}</strong><br>
        {{ settings.company_street ?? '' }}<br>
        {{ settings.company_zip ?? '' }} {{ settings.company_city ?? '' }}
      </div>
    </div>

    {# Contact #}
    {% if settings.company_phone or settings.company_email %}
    <div class="footer-col">
      <div class="footer-col-label">Kontakt</div>
      <div class="footer-col-value">
        {% if settings.company_phone %}Tel: {{ settings.company_phone }}<br>{% endif %}
        {% if settings.company_email %}{{ settings.company_email }}<br>{% endif %}
        {% if settings.company_website %}{{ settings.company_website }}{% endif %}
      </div>
    </div>
    {% endif %}

    {# Bank #}
    {% if settings.bank_iban %}
    <div class="footer-col">
      <div class="footer-col-label">Bankverbindung</div>
      <div class="footer-col-value">
        {% if settings.bank_name %}<strong>{{ settings.bank_name }}</strong><br>{% endif %}
        IBAN: {{ settings.bank_iban }}<br>
        {% if settings.bank_bic %}BIC: {{ settings.bank_bic }}{% endif %}
      </div>
    </div>
    {% endif %}

    {# Tax / Legal #}
    {% if settings.tax_number %}
    <div class="footer-col">
      <div class="footer-col-label">Steuernummer</div>
      <div class="footer-col-value">{{ settings.tax_number }}</div>
    </div>
    {% endif %}
  </div>

</div>{# .a4 #}
</div>{# .paper-wrap #}

</body>
</html>
