                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="reminder-notes">Interne Notiz (optional, erscheint auf dem PDF)</label>
                        <textarea class="form-control" id="reminder-notes" name="notes" rows="2" placeholder="z.B. Telefonisch bereits kontaktiert..."></textarea>
