{# PDF Viewer Modal (global, reused) #}
<div id="pdf-viewer-overlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.9);align-items:center;justify-content:center;flex-direction:column;">
    <div style="position:relative;width:92vw;max-width:1000px;height:90vh;display:flex;flex-direction:column;background:var(--bg-surface,#1a1a2e);border-radius:12px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.7);">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 1rem;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;">
            <span id="pv-filename" style="font-size:0.875rem;font-weight:600;color:#fff;"></span>
            <div style="display:flex;gap:0.5rem;">
                <a id="pv-download" href="" download style="background:rgba(255,255,255,0.12);color:#fff;padding:0.35rem 0.75rem;border-radius:6px;font-size:0.8rem;text-decoration:none;">Herunterladen</a>
                <button id="pv-close" style="background:rgba(255,255,255,0.12);border:none;color:#fff;width:32px;height:32px;border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </button>
            </div>
        </div>
        <iframe id="pv-frame" src="" style="flex:1;border:none;width:100%;" title="PDF Vorschau"></iframe>
    </div>
</div>

<script>
(function () {
    // ── Invoice row click → open modal + lazy load PDF preview ──────
    document.querySelectorAll('.invoice-row').forEach(function (row) {
        row.addEventListener('click', function (e) {
            if (e.target.closest('button, a, form')) return;
            const invoiceId = row.dataset.invoiceId;
            const modalId   = 'modal-invoice-' + invoiceId;

            // Open modal via Bootstrap 5
            const modalEl = document.getElementById(modalId);
            if (modalEl) bootstrap.Modal.getOrCreateInstance(modalEl).show();

            // Lazy-load positions
            const posBox = document.getElementById('positions-' + invoiceId);
            if (posBox && posBox.dataset.loaded !== '1') {
                posBox.dataset.loaded = '1';
                fetch('/rechnungen/' + invoiceId + '/positionen-json')
                    .then(r => r.json())
                    .then(function (data) {
                        if (!data.positions || !data.positions.length) {
                            posBox.innerHTML = '<p class="text-sm text-muted">Keine Positionen.</p>';
                            return;
                        }
                        let html = '<table style="width:100%;border-collapse:collapse;font-size:0.82rem;">';
                        html += '<thead><tr style="border-bottom:1px solid var(--glass-border);">';
                        html += '<th style="text-align:left;padding:4px 6px;color:var(--text-muted);font-weight:500;">Beschreibung</th>';
                        html += '<th style="text-align:right;padding:4px 6px;color:var(--text-muted);font-weight:500;">Menge</th>';
                        html += '<th style="text-align:right;padding:4px 6px;color:var(--text-muted);font-weight:500;">Einzelpreis</th>';
                        html += '<th style="text-align:right;padding:4px 6px;color:var(--text-muted);font-weight:500;">MwSt.</th>';
                        html += '<th style="text-align:right;padding:4px 6px;color:var(--text-muted);font-weight:500;">Gesamt</th>';
                        html += '</tr></thead><tbody>';
                        data.positions.forEach(function (p, i) {
                            const bg = i % 2 === 0 ? 'background:rgba(255,255,255,0.02);' : '';
                            const total = (parseFloat(p.quantity) * parseFloat(p.unit_price)).toFixed(2).replace('.', ',');
                            const price = parseFloat(p.unit_price).toFixed(2).replace('.', ',');
                            const qty   = parseFloat(p.quantity).toFixed(2).replace('.', ',');
                            html += `<tr style="${bg}"><td style="padding:5px 6px;">${p.description}</td><td style="text-align:right;padding:5px 6px;">${qty}</td><td style="text-align:right;padding:5px 6px;">${price} €</td><td style="text-align:right;padding:5px 6px;">${p.tax_rate}%</td><td style="text-align:right;padding:5px 6px;font-weight:600;">${total} €</td></tr>`;
                        });
                        html += '</tbody></table>';
                        posBox.innerHTML = html;
                    })
                    .catch(function () {
                        posBox.innerHTML = '<p class="text-sm text-muted">Positionen konnten nicht geladen werden.</p>';
                    });
            }

            // Lazy-load HTML preview in iframe
            const pdfWrap = document.getElementById('pdf-frame-wrap-' + invoiceId);
            const pdfPlaceholder = document.getElementById('pdf-placeholder-' + invoiceId);
            if (pdfWrap && pdfPlaceholder && !pdfWrap.dataset.loaded) {
                pdfWrap.dataset.loaded = '1';
                const frame = document.createElement('iframe');
                frame.src   = '/rechnungen/' + invoiceId + '/vorschau';
                frame.style.cssText = 'width:100%;height:100%;border:none;display:block;';
                frame.title = 'Rechnungs-Vorschau';
                pdfPlaceholder.remove();
                pdfWrap.appendChild(frame);
            }
        });
    });

    // ── Global PDF preview modal ─────────────────────────────────────
    window.openPdfPreview = function (src, filename) {
        document.getElementById('pv-filename').textContent = filename;
        document.getElementById('pv-download').href = src;
        document.getElementById('pv-download').download = filename;
        document.getElementById('pv-frame').src = src;
        document.getElementById('pdf-viewer-overlay').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    };

    document.getElementById('pv-close').addEventListener('click', function () {
        document.getElementById('pdf-viewer-overlay').style.display = 'none';
        document.getElementById('pv-frame').src = '';
        document.body.style.overflow = '';
    });
    document.getElementById('pdf-viewer-overlay').addEventListener('click', function (e) {
        if (e.target === this) {
            this.style.display = 'none';
            document.getElementById('pv-frame').src = '';
            document.body.style.overflow = '';
        }
    });

    // ── Mahnwesen: open Erinnerung mini-modal ────────────────────────
    window.openReminderModal = function (invoiceId, invoiceNumber) {
        var form = document.getElementById('form-reminder');
        form.action = '/rechnungen/' + invoiceId + '/erinnerung';
        document.getElementById('reminder-invoice-label').textContent = invoiceNumber;
        // Default due date = today + 7 days
        var d = new Date();
        d.setDate(d.getDate() + 7);
        document.getElementById('reminder-due-date').value = d.toISOString().split('T')[0];
        document.getElementById('reminder-notes').value = '';
        bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-reminder')).show();
        loadMahnwesenHistory(invoiceId);
    };

    // ── Mahnwesen: open Mahnung mini-modal ───────────────────────────
    window.openDunningModal = function (invoiceId, invoiceNumber) {
        var form = document.getElementById('form-dunning');
        form.action = '/rechnungen/' + invoiceId + '/mahnung';
        document.getElementById('dunning-invoice-label').textContent = invoiceNumber;
        // Default due date = today + 14 days
        var d = new Date();
        d.setDate(d.getDate() + 14);
        document.getElementById('dunning-due-date').value = d.toISOString().split('T')[0];
        document.getElementById('dunning-fee').value = '5.00';
        document.getElementById('dunning-notes').value = '';
        bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-dunning')).show();
        loadMahnwesenHistory(invoiceId);
    };

    // ── Load reminder/dunning history into invoice modal ─────────────
    function loadMahnwesenHistory(invoiceId) {
        var box = document.getElementById('mahnwesen-history-' + invoiceId);
        if (!box) return;
        if (box.dataset.loaded === '1') return;
        box.dataset.loaded = '1';
        box.innerHTML = '<span style="color:var(--text-muted);">Lade Verlauf…</span>';
        fetch('/api/rechnungen/' + invoiceId + '/mahnwesen', {headers:{'X-Requested-With':'XMLHttpRequest'}})
            .then(function(r){ return r.json(); })
            .then(function(data) {
                if (!data.ok) { box.innerHTML = ''; return; }
                var items = [];
                (data.reminders || []).forEach(function(r) {
                    var date = r.created_at ? r.created_at.substring(0,10).split('-').reverse().join('.') : '';
                    var sent = r.sent_at ? '<span style="color:#22c55e;">✓ gesendet ' + (r.sent_at.substring(0,10).split('-').reverse().join('.')) + '</span>' : '<span style="color:#f59e0b;">nicht gesendet</span>';
                    items.push('<div style="display:flex;align-items:center;gap:0.5rem;padding:0.3rem 0.5rem;border-radius:5px;background:rgba(6,182,212,0.08);margin-bottom:3px;">'
                        + '<svg width="11" height="11" fill="none" viewBox="0 0 24 24"><path stroke="#06b6d4" stroke-width="2" d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg>'
                        + '<span style="color:var(--text-muted);">' + date + '</span>'
                        + '<span style="color:var(--text-primary);flex:1;">Zahlungserinnerung</span>'
                        + sent
                        + '<a href="/mahnwesen/erinnerungen/' + r.id + '/pdf" target="_blank" style="color:var(--accent);font-size:0.72rem;margin-left:4px;">PDF</a>'
                        + '</div>');
                });
                (data.dunnings || []).forEach(function(d) {
                    var date  = d.created_at ? d.created_at.substring(0,10).split('-').reverse().join('.') : '';
                    var sent  = d.sent_at ? '<span style="color:#22c55e;">✓ gesendet ' + (d.sent_at.substring(0,10).split('-').reverse().join('.')) + '</span>' : '<span style="color:#f59e0b;">nicht gesendet</span>';
                    var level = d.level === 1 ? '1. Mahnung' : d.level === 2 ? '2. Mahnung' : 'Letzte Mahnung';
                    items.push('<div style="display:flex;align-items:center;gap:0.5rem;padding:0.3rem 0.5rem;border-radius:5px;background:rgba(245,158,11,0.08);margin-bottom:3px;">'
                        + '<svg width="11" height="11" fill="none" viewBox="0 0 24 24"><path stroke="#f59e0b" stroke-width="2" d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>'
                        + '<span style="color:var(--text-muted);">' + date + '</span>'
                        + '<span style="color:var(--text-primary);flex:1;">' + level + (d.fee > 0 ? ' (+' + parseFloat(d.fee).toFixed(2).replace('.',',') + ' €)' : '') + '</span>'
                        + sent
                        + '<a href="/mahnwesen/mahnungen/' + d.id + '/pdf" target="_blank" style="color:var(--accent);font-size:0.72rem;margin-left:4px;">PDF</a>'
                        + '</div>');
                });
                box.innerHTML = items.length ? items.join('') : '';
            })
            .catch(function(){ box.innerHTML = ''; });
    }

    // Auto-load history when an invoice modal is shown
    document.querySelectorAll('[id^="modal-invoice-"]').forEach(function(modalEl) {
        modalEl.addEventListener('show.bs.modal', function() {
            var invoiceId = modalEl.id.replace('modal-invoice-', '');
            loadMahnwesenHistory(invoiceId);
        });
    });

})();
</script>

{# ── Überfällig-Alert Modal ─────────────────────────────────────── #}
<div class="modal fade" id="modal-overdue-alert" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header" style="background:linear-gradient(135deg,#ef4444,#f59e0b);color:#fff;">
                <div class="d-flex align-items-center gap-2">
                    <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path stroke="#fff" stroke-width="2" d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13" stroke="#fff" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="17" x2="12.01" y2="17" stroke="#fff" stroke-width="2" stroke-linecap="round"/></svg>
                    <strong>Offene Rechnungen – Handlungsbedarf</strong>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div id="overdue-alert-loading" class="text-center p-4 text-muted">Lade offene Rechnungen…</div>
                <div id="overdue-alert-empty" class="text-center p-4 text-success d-none">
                    <svg width="32" height="32" fill="none" viewBox="0 0 24 24" class="mb-2"><circle cx="12" cy="12" r="10" stroke="#22c55e" stroke-width="2"/><path stroke="#22c55e" stroke-width="2" d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <div>Alle Rechnungen sind auf dem aktuellen Stand. 🎉</div>
                </div>
                <div id="overdue-alert-list"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Schließen</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/apexcharts@3/dist/apexcharts.min.js"></script>
<script>
(function () {
    'use strict';

    var isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark'
              || document.documentElement.classList.contains('dark');
    var textColor  = isDark ? '#94a3b8' : '#6b7280';
    var gridColor  = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
    var bgCard     = isDark ? '#1e2a3a' : '#ffffff';

    /* ── Monatsumsatz Balkendiagramm ───────────────────────── */
    var monthlyEl = document.getElementById('inv-chart-monthly');
    if (monthlyEl) {
        var chartLabels = {{ chart_data.labels|json_encode|replace({'</': '<\/'})|raw }};
        var chartPaid   = {{ chart_data.paid|json_encode|replace({'</': '<\/'})|raw }};
        var chartOpen   = {{ chart_data.open|json_encode|replace({'</': '<\/'})|raw }};

        new ApexCharts(monthlyEl, {
            chart: {
                type: 'bar',
                height: 250,
                stacked: false,
                toolbar: { show: false },
                background: 'transparent',
                fontFamily: 'inherit',
                animations: { enabled: true, speed: 400 }
            },
            series: [
                { name: 'Bezahlt', data: chartPaid },
                { name: 'Offen / Überfällig', data: chartOpen }
            ],
            colors: ['#22c55e', '#f59e0b'],
            plotOptions: {
                bar: {
                    borderRadius: 4,
                    columnWidth: '55%',
                    dataLabels: { position: 'top' }
                }
            },
            dataLabels: { enabled: false },
            xaxis: {
                categories: chartLabels,
                labels: { style: { colors: textColor, fontSize: '11px' } },
                axisBorder: { show: false },
                axisTicks: { show: false }
            },
            yaxis: {
                labels: {
                    style: { colors: textColor, fontSize: '11px' },
                    formatter: function (v) {
                        return v >= 1000 ? (v / 1000).toFixed(1) + 'k €' : v.toFixed(0) + ' €';
                    }
                }
            },
            grid: { borderColor: gridColor, strokeDashArray: 4 },
            legend: {
                position: 'top',
                horizontalAlign: 'right',
                labels: { colors: textColor },
                markers: { radius: 4 }
            },
            tooltip: {
                theme: isDark ? 'dark' : 'light',
                y: { formatter: function (v) { return v.toFixed(2).replace('.', ',') + ' €'; } }
            }
        }).render();
    }

    /* ── Status-Verteilung Donut ────────────────────────────── */
    var donutEl = document.getElementById('inv-chart-donut');
    if (donutEl) {
        var paid    = {{ stats.paid_count }};
        var open    = {{ stats.open_count }};
        var overdue = {{ stats.overdue_count }};
        var draft   = {{ stats.draft_count }};
        var total   = paid + open + overdue + draft;

        if (total === 0) {
            donutEl.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:200px;color:var(--text-muted);font-size:.85rem;">Keine Rechnungen</div>';
        } else {
            new ApexCharts(donutEl, {
                chart: {
                    type: 'donut',
                    height: 220,
                    background: 'transparent',
                    fontFamily: 'inherit',
                    animations: { enabled: true, speed: 400 },
                    toolbar: { show: false },
                    events: {
                        dataPointSelection: function (event, chartContext, config) {
                            var statusMap = ['paid', 'open', 'overdue', 'draft'];
                            var s = statusMap[config.dataPointIndex];
                            if (s) { window.location.href = '/rechnungen?status=' + s; }
                        }
                    }
                },
                series: [paid, open, overdue, draft],
                labels: ['Bezahlt', 'Offen', 'Überfällig', 'Entwurf'],
                colors: ['#22c55e', '#f59e0b', '#ef4444', '#94a3b8'],
                dataLabels: {
                    enabled: true,
                    formatter: function (val) { return Math.round(val) + '%'; },
                    style: { fontSize: '11px', colors: ['#fff'] },
                    dropShadow: { enabled: false }
                },
                plotOptions: {
                    pie: {
                        donut: {
                            size: '68%',
                            labels: {
                                show: true,
                                total: {
                                    show: true,
                                    label: 'Gesamt',
                                    color: textColor,
                                    fontSize: '13px',
                                    formatter: function () { return total; }
                                },
                                value: {
                                    color: textColor,
                                    fontSize: '18px',
                                    fontWeight: 700
                                }
                            }
                        }
                    }
                },
                legend: { show: false },
                stroke: { width: 2, colors: [bgCard] },
                tooltip: {
                    theme: isDark ? 'dark' : 'light',
                    y: { formatter: function (v) { return v + ' Rechnung' + (v !== 1 ? 'en' : ''); } }
                }
            }).render();
        }
    }

    /* ── Inline-Status AJAX Dropdown ───────────────────────── */
    var _csrfToken = '{{ csrf_token }}';
    var _statusColors = {
        open:    { bg: '#fef3c7', color: '#92400e', border: '#f59e0b' },
        paid:    { bg: '#dcfce7', color: '#166534', border: '#22c55e' },
        overdue: { bg: '#fee2e2', color: '#991b1b', border: '#ef4444' },
        mahnung: { bg: '#fce7f3', color: '#9d174d', border: '#ec4899' },
        draft:   { bg: '#f1f5f9', color: '#475569', border: '#94a3b8' }
    };

    function applySelectStyle(sel, status) {
        var c = _statusColors[status] || _statusColors['draft'];
        sel.style.background    = c.bg;
        sel.style.color         = c.color;
        sel.style.borderColor   = c.border;
        sel.style.fontWeight    = '600';
    }

    document.querySelectorAll('.invoice-status-select').forEach(function (sel) {
        applySelectStyle(sel, sel.dataset.current);

        sel.addEventListener('change', function () {
            var invoiceId  = sel.dataset.invoiceId;
            var newStatus  = sel.value;
            var prevStatus = sel.dataset.current;

            applySelectStyle(sel, newStatus);
            sel.disabled = true;

            var fd = new FormData();
            fd.append('_csrf_token', _csrfToken);
            fd.append('status', newStatus);

            fetch('/rechnungen/' + invoiceId + '/status-inline', {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: fd
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                sel.disabled = false;
                if (data.ok) {
                    sel.dataset.current = newStatus;
                    var row = sel.closest('tr');
                    if (row) {
                        row.style.transition = 'opacity .25s';
                        row.style.opacity = '0.5';
                        setTimeout(function () { row.style.opacity = '1'; }, 300);
                    }
                    var toast = document.createElement('div');
                    toast.className = 'position-fixed bottom-0 end-0 p-3';
                    toast.style.zIndex = '9999';
                    var statusLabel = { open: 'Offen', paid: 'Bezahlt', overdue: 'Überfällig', mahnung: 'Mahnung', draft: 'Entwurf' };
                    toast.innerHTML = '<div class="toast show align-items-center text-bg-success border-0" role="alert"><div class="d-flex"><div class="toast-body">'
                        + '✅ Status auf <strong>' + (statusLabel[newStatus] || newStatus) + '</strong> geändert'
                        + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" onclick="this.closest(\'div.position-fixed\').remove()"></button></div></div>';
                    document.body.appendChild(toast);
                    setTimeout(function () { toast.remove(); }, 2800);
                } else {
                    sel.value = prevStatus;
                    applySelectStyle(sel, prevStatus);
                    alert('Fehler beim Statusändern: ' + (data.error || ''));
                }
            })
            .catch(function () {
                sel.disabled = false;
                sel.value = prevStatus;
                applySelectStyle(sel, prevStatus);
            });
        });
    });

    /* ── Highlight active KPI card when filtered ─────────────── */
    var currentStatus = '{{ status }}';
    if (currentStatus) {
        document.querySelectorAll('.kpi-filter-card[data-filter-status="' + currentStatus + '"]').forEach(function (el) {
            var card = el.querySelector('.card');
            if (card) card.style.outline = '2px solid var(--bs-primary)';
        });
    }

    /* ── Overdue Alert Modal ────────────────────────────────── */
    var _alertSessionKey = 'overdue_alert_shown_' + new Date().toDateString();
    if (!sessionStorage.getItem(_alertSessionKey)) {
        sessionStorage.setItem(_alertSessionKey, '1');
        setTimeout(function () {
            fetch('/api/mahnwesen/alert', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data.ok || !data.invoices || data.invoices.length === 0) return;
                    renderAlertModal(data.invoices);
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-overdue-alert')).show();
                })
                .catch(function () {});
        }, 1200);
    }

    function renderAlertModal(invoices) {
        var loading = document.getElementById('overdue-alert-loading');
        var empty   = document.getElementById('overdue-alert-empty');
        var list    = document.getElementById('overdue-alert-list');
        if (loading) loading.classList.add('d-none');

        if (!invoices || invoices.length === 0) {
            if (empty) empty.classList.remove('d-none');
            return;
        }

        var html = '<div class="list-group list-group-flush">';
        invoices.forEach(function (inv) {
            var reminderCount = parseInt(inv.reminder_count || 0);
            var dunningCount  = parseInt(inv.dunning_count  || 0);
            var daysOpen      = parseInt(inv.days_open      || 0);
            var isOverdue     = inv.status === 'overdue';

            var statusBadge = isOverdue
                ? '<span class="badge" style="background:#ef4444;color:#fff;">Überfällig</span>'
                : '<span class="badge" style="background:#f59e0b;color:#fff;">Offen</span>';

            var daysLabel = daysOpen === 1
                ? '1 Tag'
                : daysOpen + ' Tage';

            var reminderBadge = reminderCount > 0
                ? '<span class="badge bg-info-subtle text-info ms-1">' + reminderCount + 'x Erinnerung</span>'
                : '';
            var dunningBadge = dunningCount > 0
                ? '<span class="badge bg-warning-subtle text-warning ms-1">' + dunningCount + 'x Mahnung</span>'
                : '';

            /* Action: ≥3 reminders and no dunnings yet → suggest dunning, else → reminder */
            var needsDunning = reminderCount >= 3 && dunningCount < 3;
            var actionBtn = '';
            if (needsDunning) {
                actionBtn = '<button class="btn btn-sm btn-warning alert-send-dunning ms-auto flex-shrink-0" '
                    + 'data-invoice-id="' + inv.id + '" data-invoice-number="' + inv.invoice_number + '" '
                    + 'style="font-size:.75rem;">'
                    + '<svg width="11" height="11" fill="none" viewBox="0 0 24 24" style="margin-right:3px;vertical-align:-1px;"><path stroke="currentColor" stroke-width="2" d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>'
                    + 'Mahnung senden</button>';
            } else if (dunningCount >= 3) {
                actionBtn = '<span class="badge bg-danger ms-auto flex-shrink-0" style="font-size:.72rem;">Letzte Mahnung bereits versendet</span>';
            } else {
                actionBtn = '<button class="btn btn-sm btn-primary alert-send-reminder ms-auto flex-shrink-0" '
                    + 'data-invoice-id="' + inv.id + '" data-invoice-number="' + inv.invoice_number + '" '
                    + 'style="font-size:.75rem;">'
                    + '<svg width="11" height="11" fill="none" viewBox="0 0 24 24" style="margin-right:3px;vertical-align:-1px;"><path stroke="currentColor" stroke-width="2" d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path stroke="currentColor" stroke-width="2" d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>'
                    + 'Erinnerung senden</button>';
            }

            html += '<div class="list-group-item px-3 py-2" id="alert-row-' + inv.id + '">'
                + '<div class="d-flex align-items-center gap-2 flex-wrap">'
                + '<div class="fw-semibold" style="min-width:90px;color:var(--bs-primary);">' + inv.invoice_number + '</div>'
                + statusBadge
                + '<div class="text-muted small flex-fill" style="min-width:120px;">'
                + (inv.owner_name || '—')
                + (inv.patient_name ? ' &bull; ' + inv.patient_name : '')
                + '</div>'
                + '<div class="text-muted small">' + parseFloat(inv.total_gross).toFixed(2).replace('.', ',') + ' €</div>'
                + '<div class="small" style="color:' + (isOverdue ? '#ef4444' : '#f59e0b') + ';">seit ' + daysLabel + '</div>'
                + reminderBadge + dunningBadge
                + actionBtn
                + '</div>'
                + '</div>';
        });
        html += '</div>';
        list.innerHTML = html;

        /* Bind send-reminder buttons */
        list.querySelectorAll('.alert-send-reminder').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var invoiceId     = btn.dataset.invoiceId;
                var invoiceNumber = btn.dataset.invoiceNumber;
                btn.disabled = true;
                btn.textContent = 'Sende…';

                var dueDate = new Date();
                dueDate.setDate(dueDate.getDate() + 7);
                var dueDateStr = dueDate.toISOString().split('T')[0];

                var fd = new FormData();
                fd.append('_csrf_token', _csrfToken);
                fd.append('due_date', dueDateStr);
                fd.append('notes', '');

                fetch('/rechnungen/' + invoiceId + '/erinnerung', {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: fd
                })
                .then(function (r) {
                    var row = document.getElementById('alert-row-' + invoiceId);
                    if (row) {
                        row.innerHTML = '<div class="px-3 py-2 text-success small">✅ Zahlungserinnerung für <strong>' + invoiceNumber + '</strong> gesendet.</div>';
                    }
                })
                .catch(function () {
                    btn.disabled = false;
                    btn.textContent = 'Erinnerung senden';
                });
            });
        });

        /* Bind send-dunning buttons */
        list.querySelectorAll('.alert-send-dunning').forEach(function (btn) {
            btn.addEventListener('click', function () {
                /* Close alert modal and open the proper dunning modal */
                bootstrap.Modal.getInstance(document.getElementById('modal-overdue-alert')).hide();
                var invoiceId     = btn.dataset.invoiceId;
                var invoiceNumber = btn.dataset.invoiceNumber;
                setTimeout(function () {
                    if (typeof openDunningModal === 'function') {
                        openDunningModal(invoiceId, invoiceNumber);
                    }
                }, 350);
            });
        });
    }

    /* Theme-Wechsel: Charts neu rendern wenn Nutzer Theme wechselt */
    var observer = new MutationObserver(function () {
        location.reload();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });

})();
</script>

<style>
@keyframes pulse-open {
    0%, 100% { background-color: transparent; }
    50%       { background-color: rgba(245, 158, 11, 0.10); }
}
@keyframes pulse-overdue {
    0%, 100% { background-color: transparent; }
    50%       { background-color: rgba(239, 68, 68, 0.11); }
}
.row-pulse-open    { animation: pulse-open    3s ease-in-out infinite; }
.row-pulse-overdue { animation: pulse-overdue 2.4s ease-in-out infinite; }
</style>
{% endblock %}
