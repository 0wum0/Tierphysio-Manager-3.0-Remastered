{# ═════════════════════════════════════════════════════
   TAB: HAUSAUFGABEN-TEMPLATES
════════════════════════════════════════════════════ #}
<div class="settings-tab-content" id="tab-hausaufgaben">

    {# Neues Template #}
    <div class="glass-card mb-4">
        <h3 class="section-title">Neues Hausaufgaben-Template</h3>
        <form action="/einstellungen/hausaufgaben-templates" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="form-grid-2 mb-3">
                <div class="form-group">
                    <label class="form-label">Titel *</label>
                    <input type="text" name="title" class="form-control" required placeholder="z.B. Wärmeanwendung">
                </div>
                <div class="form-group">
                    <label class="form-label">Kategorie</label>
                    <select name="category" class="form-control">
                        <option value="bewegung">🏃 Bewegung</option>
                        <option value="dehnung">🤸 Dehnung</option>
                        <option value="massage">💆 Massage</option>
                        <option value="kalt_warm">🌡️ Kalt/Warm</option>
                        <option value="medikamente">💊 Medikamente</option>
                        <option value="fuetterung">🍽️ Fütterung</option>
                        <option value="beobachtung">👁️ Beobachtung</option>
                        <option value="sonstiges" selected>📌 Sonstiges</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Häufigkeit</label>
                    <select name="frequency" class="form-control">
                        <option value="daily">Täglich</option>
                        <option value="twice_daily">2x täglich</option>
                        <option value="three_times_daily">3x täglich</option>
                        <option value="weekly">Wöchentlich</option>
                        <option value="as_needed">Bei Bedarf</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Dauer</label>
                    <div class="flex gap-2">
                        <input type="number" name="duration_value" class="form-control" value="10" min="1" style="width:80px;">
                        <select name="duration_unit" class="form-control">
                            <option value="minutes">Minuten</option>
                            <option value="hours">Stunden</option>
                            <option value="days">Tage</option>
                            <option value="weeks">Wochen</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="form-group mb-3">
                <label class="form-label">Beschreibung / Anleitung *</label>
                <textarea name="description" class="form-control" rows="3" required placeholder="Genaue Anleitung für den Besitzer..."></textarea>
            </div>
            <div class="form-group mb-3">
                <label class="form-label">Therapeuten-Hinweis (intern)</label>
                <textarea name="therapist_notes" class="form-control" rows="2" placeholder="Interne Notiz, erscheint im PDF..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                Template hinzufügen
            </button>
        </form>
    </div>

    {# Liste der Templates #}
    <div class="glass-card">
        <h3 class="section-title">Vorhandene Templates</h3>
        {% if homework_templates is empty %}
            <p style="color:var(--text-muted);font-size:0.875rem;">Noch keine Templates vorhanden. Migration ausführen falls nötig.</p>
        {% else %}
            {% set hw_categories = {
                'bewegung': '🏃 Bewegung', 'dehnung': '🤸 Dehnung', 'massage': '💆 Massage',
                'kalt_warm': '🌡️ Kalt/Warm', 'medikamente': '💊 Medikamente',
                'fuetterung': '🍽️ Fütterung', 'beobachtung': '👁️ Beobachtung', 'sonstiges': '📌 Sonstiges'
            } %}
            {% set hw_frequencies = {
                'daily': 'Täglich', 'twice_daily': '2x täglich', 'three_times_daily': '3x täglich',
                'weekly': 'Wöchentlich', 'as_needed': 'Bei Bedarf'
            } %}
            <div style="display:flex;flex-direction:column;gap:0.75rem;">
                {% for ht in homework_templates %}
                <div class="glass-card" style="padding:1rem;background:var(--glass-bg);">
                    <div class="flex gap-3 items-start" style="flex-wrap:wrap;">
                        <div style="flex-shrink:0;font-size:1.4rem;">{{ ht.category_emoji }}</div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-weight:600;font-size:0.95rem;">{{ ht.title }}</div>
                            <div style="font-size:0.75rem;color:var(--text-muted);margin-top:0.2rem;">
                                {{ hw_categories[ht.category] ?? ht.category }}
                                &nbsp;·&nbsp; {{ hw_frequencies[ht.frequency] ?? ht.frequency }}
                                &nbsp;·&nbsp; {{ ht.duration_value }} {{ ht.duration_unit == 'minutes' ? 'Min' : (ht.duration_unit == 'hours' ? 'Std' : ht.duration_unit) }}
                                &nbsp;·&nbsp;
                                {% if ht.is_active %}
                                    <span style="color:var(--success);">Aktiv</span>
                                {% else %}
                                    <span style="color:var(--text-muted);">Inaktiv</span>
                                {% endif %}
                            </div>
                            {% if ht.description %}
                                <div style="font-size:0.8rem;color:var(--text-secondary);margin-top:0.3rem;">{{ ht.description|slice(0, 120) }}{% if ht.description|length > 120 %}…{% endif %}</div>
                            {% endif %}
                        </div>
                        <div class="flex gap-2" style="flex-shrink:0;">
                            <button class="btn btn-secondary btn-sm" onclick="openEditHT({{ ht|json_encode|e('html_attr') }})">
                                <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                Bearbeiten
                            </button>
                            <form action="/einstellungen/hausaufgaben-templates/{{ ht.id }}/loeschen" method="POST" style="margin:0;" onsubmit="return confirm('Template wirklich löschen?');">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="3 6 5 6 21 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 11v6M14 11v6"/></svg>
                                    Löschen
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

{# Edit-Modal für Hausaufgaben-Template #}
<div class="modal fade" id="modal-edit-ht" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">Hausaufgaben-Template bearbeiten</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="form-edit-ht" method="POST">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="modal-body">
                    <div class="form-grid-2 mb-3">
                        <div class="form-group">
                            <label class="form-label">Titel *</label>
                            <input type="text" id="eht-title" name="title" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Kategorie</label>
                            <select id="eht-category" name="category" class="form-control">
                                <option value="bewegung">🏃 Bewegung</option>
                                <option value="dehnung">🤸 Dehnung</option>
                                <option value="massage">💆 Massage</option>
                                <option value="kalt_warm">🌡️ Kalt/Warm</option>
                                <option value="medikamente">💊 Medikamente</option>
                                <option value="fuetterung">🍽️ Fütterung</option>
                                <option value="beobachtung">👁️ Beobachtung</option>
                                <option value="sonstiges">📌 Sonstiges</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Häufigkeit</label>
                            <select id="eht-frequency" name="frequency" class="form-control">
                                <option value="daily">Täglich</option>
                                <option value="twice_daily">2x täglich</option>
                                <option value="three_times_daily">3x täglich</option>
                                <option value="weekly">Wöchentlich</option>
                                <option value="as_needed">Bei Bedarf</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Dauer</label>
                            <div class="flex gap-2">
                                <input type="number" id="eht-duration-value" name="duration_value" class="form-control" min="1" style="width:80px;">
                                <select id="eht-duration-unit" name="duration_unit" class="form-control">
                                    <option value="minutes">Minuten</option>
                                    <option value="hours">Stunden</option>
                                    <option value="days">Tage</option>
                                    <option value="weeks">Wochen</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Beschreibung / Anleitung *</label>
                        <textarea id="eht-description" name="description" class="form-control" rows="4" required></textarea>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Therapeuten-Hinweis (intern)</label>
                        <textarea id="eht-therapist-notes" name="therapist_notes" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="form-group">
                        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
                            <input type="hidden" name="is_active" value="0">
                            <input type="checkbox" id="eht-active" name="is_active" value="1" style="width:16px;height:16px;">
                            Aktiv (im Dropdown sichtbar)
                        </label>
                    </div>
                </div>
                <div class="flex gap-2 justify-end" style="padding:1rem 1.5rem;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Speichern</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function openEditHT(ht) {
    document.getElementById('eht-title').value = ht.title || '';
    document.getElementById('eht-category').value = ht.category || 'sonstiges';
    document.getElementById('eht-frequency').value = ht.frequency || 'daily';
    document.getElementById('eht-duration-value').value = ht.duration_value || 10;
    document.getElementById('eht-duration-unit').value = ht.duration_unit || 'minutes';
    document.getElementById('eht-description').value = ht.description || '';
    document.getElementById('eht-therapist-notes').value = ht.therapist_notes || '';
    document.getElementById('eht-active').checked = ht.is_active == 1;
    document.getElementById('form-edit-ht').action = '/einstellungen/hausaufgaben-templates/' + ht.id;
    var modal = new bootstrap.Modal(document.getElementById('modal-edit-ht'));
    modal.show();
}
</script>

{# ═════════════════════════════════════════════════════
   TAB: GEBURTSTAG
════════════════════════════════════════════════════ #}
<div class="settings-tab-content" id="tab-geburtstag">
    <form action="/einstellungen" method="POST">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

        <div class="glass-card mb-4">
            <h3 class="section-title mb-3">🎂 Geburtstagsmail</h3>

            <div class="alert mb-4" style="background:rgba(124,46,248,0.12);border:1px solid rgba(180,100,255,0.3);border-radius:10px;padding:1rem 1.25rem;">
                <div class="fw-600 mb-1" style="color:#c8a0ff;">Automatische Geburtstagsmail</div>
                <p class="mb-0" style="font-size:0.85rem;color:rgba(255,255,255,0.7);line-height:1.6;">
                    Wird täglich per Cron-Job aufgerufen und sendet automatisch eine Glückwunschmail an Tierhalter,
                    deren Patient heute Geburtstag hat. Jedes Tier erhält pro Jahr nur eine Mail.
