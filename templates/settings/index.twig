                    <code style="background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:4px;padding:1px 6px;">{{owner_name}}</code>
                    <code style="background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:4px;padding:1px 6px;">{{age}}</code>
