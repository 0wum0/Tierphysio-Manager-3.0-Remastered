<div class="settings-tab-content" id="tab-datenschutz">
    <form action="/einstellungen" method="POST">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <div class="glass-card">
            <h3 class="section-title">Datenschutzerklärung</h3>
            <p class="text-muted" style="font-size:0.82rem;margin-bottom:1rem;">
                Hier kannst du die Datenschutzerklärung anpassen. Sie wird unter <code>/datenschutz</code> angezeigt.
                Verwende die Platzhalter <code>{{company_name}}</code>, <code>{{company_street}}</code>, <code>{{company_zip}}</code>, <code>{{company_city}}</code>, <code>{{company_email}}</code>, <code>{{company_phone}}</code> um deine Firmendaten automatisch einzufügen.
            </p>
            <div class="form-group">
                <label class="form-label">Datenschutzerklärung (Markdown-Format)</label>
                <textarea name="gdpr_text" class="form-control" rows="20" style="font-family:monospace;font-size:0.85rem;line-height:1.6;">{{ settings.gdpr_text ?? '' }}</textarea>
            </div>
            <div style="margin-top:1rem;">
                <a href="/datenschutz" target="_blank" class="btn btn-secondary btn-sm">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    Vorschau in neuem Tab öffnen
                </a>
            </div>
        </div>
        <div class="flex justify-end mt-3">
            <button type="submit" class="btn btn-primary">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/></svg>
                Datenschutzerklärung speichern
            </button>
        </div>
    </form>
</div>

</div>

<script>
function selectPracticeType(type) {
    document.querySelectorAll('input[name="practice_type"]').forEach(function(r) {
        var card = r.closest('label');
        if (r.value === type) {
            r.checked = true;
            card.style.borderColor = 'var(--primary)';
        } else {
            r.checked = false;
            card.style.borderColor = 'var(--glass-border)';
        }
    });
}
</script>
{% endblock %}
