                    <button type="button" class="btn btn-secondary btn-sm" onclick="
                        var chars='ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
                        var t=''; for(var i=0;i<40;i++) t+=chars[Math.floor(Math.random()*chars.length)];
                        document.getElementById('birthday-token-input').value=t;
                        updateBirthdayCronUrl();
                    " style="white-space:nowrap;">🎲 Generieren</button>
                </div>
                <div class="fs-nano text-muted mt-1">Dieser Token schützt den Cron-Endpunkt vor unautorisierten Aufrufen.</div>
            </div>

            <div class="form-group mb-3" id="birthday-cron-url-box" style="{{ (settings.birthday_cron_token ?? '') ? '' : 'display:none;' }}">
                <label class="form-label fw-semibold">Cron-URL <span class="text-muted fw-400">(täglich aufrufen, z.B. via cron-job.org)</span></label>
                <div class="d-flex gap-2 align-items-center">
                    <input type="text" id="birthday-cron-url-display" class="form-control font-monospace" readonly
                           value="{{ app_url }}/cron/geburtstag?token={{ settings.birthday_cron_token ?? '' }}"
                           style="font-size:0.78rem;color:var(--bs-secondary-color);">
                    <button type="button" class="btn btn-secondary btn-sm" style="white-space:nowrap;"
                            onclick="var u=document.getElementById('birthday-cron-url-display');u.select();navigator.clipboard&&navigator.clipboard.writeText(u.value).then(function(){var b=this;},function(){});this.textContent='\u2713 Kopiert';var me=this;setTimeout(function(){me.textContent='\uD83D\uDCCB Kopieren';},1500);">
                        📋 Kopieren
                    </button>
                </div>
                <div class="fs-nano text-muted mt-1">Trage diese URL bei <a href="https://cron-job.org" target="_blank" rel="noopener">cron-job.org</a> als täglichen GET-Aufruf ein (z.B. 08:00 Uhr).</div>
            </div>

        </div>

        <button type="submit" class="btn btn-primary">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" points="17 21 17 13 7 13 7 21"/></svg>
            Alle Templates speichern
        </button>
    </form>

    </div>{# end left #}

    {# ── RIGHT: Live Preview ── #}
    <div style="position:sticky;top:80px;">
        <div class="glass-card">
            <h3 class="section-title mb-3" style="font-size:0.875rem;">
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" class="me-1"><path stroke="currentColor" stroke-width="2" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
                Live-Vorschau
            </h3>
            <div id="email-preview-wrap" style="border-radius:8px;overflow:hidden;border:1px solid var(--bs-border-color);background:#0f0f1a;min-height:420px;">
                <div id="email-preview-frame" style="width:100%;min-height:420px;"></div>
            </div>
            <p class="text-muted mt-2" style="font-size:0.75rem;">Vorschau mit Beispieldaten. Sieht in echten E-Mail-Clients ähnlich aus.</p>
        </div>
    </div>

</div>{# end grid #}

</div>{# end tab #}

<script>
(function() {
'use strict';

var _companyName = {{ (settings.company_name ?? 'Tierphysio Praxis')|json_encode|replace({'</': '<\/'})|raw }};
var _emailDefaults = {
    invoice:  { subject: {{ email_tpl_defaults.invoice_subject|json_encode|replace({'</': '<\/'})|raw }},  body: {{ email_tpl_defaults.invoice_body|json_encode|replace({'</': '<\/'})|raw }} },
    receipt:  { subject: {{ email_tpl_defaults.receipt_subject|json_encode|replace({'</': '<\/'})|raw }},  body: {{ email_tpl_defaults.receipt_body|json_encode|replace({'</': '<\/'})|raw }} },
    reminder: { subject: {{ email_tpl_defaults.reminder_subject|json_encode|replace({'</': '<\/'})|raw }}, body: {{ email_tpl_defaults.reminder_body|json_encode|replace({'</': '<\/'})|raw }} },
    invite:   { subject: {{ email_tpl_defaults.invite_subject|json_encode|replace({'</': '<\/'})|raw }},   body: {{ email_tpl_defaults.invite_body|json_encode|replace({'</': '<\/'})|raw }} },
    birthday: { subject: {{ email_tpl_defaults.birthday_subject|json_encode|replace({'</': '<\/'})|raw }}, body: {{ email_tpl_defaults.birthday_body|json_encode|replace({'</': '<\/'})|raw }} }
};

function resetEmailTpl(tpl) {
    var d = _emailDefaults[tpl];
    if (!d) return;
    if (!confirm('Standard-Text für dieses Template wiederherstellen?')) return;
    var s = document.getElementById('etpl-' + tpl + '-subject');
    var b = document.getElementById('etpl-' + tpl + '-body');
    if (s) { s.value = d.subject; s.dispatchEvent(new Event('input')); }
    if (b) { b.value = d.body;    b.dispatchEvent(new Event('input')); }
}

/* ── Tab Switcher ── */
function initEmailTplTabs() {
    var tplTabs   = document.querySelectorAll('.email-tpl-tab');
    var tplPanels = document.querySelectorAll('.email-tpl-panel');

    if (!tplTabs.length) return;

    function switchTpl(name) {
        tplTabs.forEach(function(b) {
            var active = b.getAttribute('data-tpl') === name;
            b.classList.toggle('btn-primary',   active);
            b.classList.toggle('btn-secondary', !active);
        });
        tplPanels.forEach(function(p) {
            p.style.display = (p.id === 'etpl-' + name) ? '' : 'none';
        });
        updateEmailPreview(name);
    }

    tplTabs.forEach(function(b) {
        b.addEventListener('click', function() {
            switchTpl(b.getAttribute('data-tpl'));
        });
    });

    /* ── Preview ── */
    var previewIcons = {
        invoice:  '\uD83D\uDCC4',
        receipt:  '\u2705',
        reminder: '\uD83D\uDCC5',
        invite:   '\uD83D\uDC3E',
        birthday: '\uD83C\uDF82'
    };

    function esc(s) {
        return String(s || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');
    }

    function buildPreviewHtml(title, bodyText, icon) {
        var body = esc(bodyText).replace(/\n/g, '<br>');
        var ttl  = esc(title);
        var co   = esc(_companyName);
        return '<div style="background:#0f0f1a;padding:24px 12px;font-family:-apple-system,BlinkMacSystemFont,\'Segoe UI\',Roboto,sans-serif;">'
            + '<div style="max-width:520px;margin:0 auto;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:14px;overflow:hidden;">'
            + '<div style="background:linear-gradient(135deg,rgba(79,124,255,0.35),rgba(139,92,246,0.35));padding:26px 32px;text-align:center;">'
            + '<div style="font-size:2rem;margin-bottom:8px;">' + icon + '</div>'
            + '<div style="margin:0;color:#fff;font-size:1.1rem;font-weight:700;line-height:1.3;">' + ttl + '</div>'
            + '<p style="margin:5px 0 0;color:rgba(255,255,255,0.5);font-size:0.75rem;">' + co + '</p>'
            + '</div>'
            + '<div style="padding:24px 28px;color:rgba(255,255,255,0.82);font-size:0.88rem;line-height:1.8;">' + body + '</div>'
            + '<div style="padding:12px 28px 18px;text-align:center;border-top:1px solid rgba(255,255,255,0.08);">'
            + '<span style="color:rgba(255,255,255,0.25);font-size:0.72rem;">' + co + ' &middot; Automatisch generierte Nachricht</span>'
            + '</div>'
            + '</div></div>';
    }

    function updateEmailPreview(tplName) {
        var frame     = document.getElementById('email-preview-frame');
        if (!frame) return;
        var subjectEl = document.getElementById('etpl-' + tplName + '-subject');
        var bodyEl    = document.getElementById('etpl-' + tplName + '-body');
        if (!subjectEl) { frame.innerHTML = ''; return; }
        var subject   = subjectEl.value || '(Kein Betreff)';
        var body      = bodyEl ? bodyEl.value : '(Das Template wird automatisch generiert.)';
        var icon      = previewIcons[tplName] || '\uD83D\uDCE7';
        frame.innerHTML = buildPreviewHtml(subject, body, icon);
    }

    /* live keystroke update */
    ['invoice','receipt','reminder','invite','birthday'].forEach(function(tpl) {
        var s = document.getElementById('etpl-' + tpl + '-subject');
        var b = document.getElementById('etpl-' + tpl + '-body');
        if (s) s.addEventListener('input', function() { updateEmailPreview(tpl); });
        if (b) b.addEventListener('input', function() { updateEmailPreview(tpl); });
    });

    /* Re-render preview when settings tab becomes visible */
    document.addEventListener('settingsTabActivated', function(e) {
        if (e.detail.tab === 'email-templates') {
            var active = document.querySelector('.email-tpl-tab.btn-primary');
            var name   = active ? active.getAttribute('data-tpl') : 'invoice';
            updateEmailPreview(name);
        }
    });

    /* init active tab — but only render preview if already visible */
    var emailTab = document.getElementById('tab-email-templates');
    if (emailTab && emailTab.classList.contains('active')) {
        switchTpl('invoice');
    } else {
        /* just set button states without triggering preview while hidden */
        tplTabs.forEach(function(b) {
            var active = b.getAttribute('data-tpl') === 'invoice';
            b.classList.toggle('btn-primary',   active);
            b.classList.toggle('btn-secondary', !active);
        });
        tplPanels.forEach(function(p) {
            p.style.display = (p.id === 'etpl-invoice') ? '' : 'none';
        });
    }
}

/* ── Platzhalter Clipboard ── */
document.addEventListener('click', function(e) {
    var el = e.target.closest('[data-ph]');
    if (!el) return;
    var ph = el.getAttribute('data-ph');
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(ph).then(function() {
            var orig = el.textContent;
            el.textContent = '\u2713';
            setTimeout(function(){ el.textContent = orig; }, 1000);
        });
    }
});

initEmailTplTabs();

})();
</script>

<script>
function updateBdayCronUrl() {
    var token = (document.getElementById('bday-token-input') || {}).value || '';
    var box   = document.getElementById('bday-cron-url-box');
    var disp  = document.getElementById('bday-cron-url-display');
    if (!box || !disp) return;
    if (token) {
        disp.value = location.protocol + '//' + location.host + '/cron/geburtstag?token=' + token;
        box.style.display = '';
    } else {
        box.style.display = 'none';
    }
}
function updateBirthdayCronUrl() {
    var token = (document.getElementById('birthday-token-input') || {}).value || '';
    var box   = document.getElementById('birthday-cron-url-box');
    var disp  = document.getElementById('birthday-cron-url-display');
    if (!box || !disp) return;
    if (token) {
        disp.value = location.protocol + '//' + location.host + '/cron/geburtstag?token=' + token;
        box.style.display = '';
    } else {
        box.style.display = 'none';
    }
}
</script>

<script>
function openEditTT(tt) {
    document.getElementById('form-edit-tt').action = '/einstellungen/behandlungsarten/' + tt.id;
    document.getElementById('ett-name').value   = tt.name  || '';
    document.getElementById('ett-color').value  = tt.color || '#4f7cff';
    document.getElementById('ett-price').value  = tt.price || '';
    document.getElementById('ett-sort').value   = tt.sort_order || 0;
    document.getElementById('ett-desc').value   = tt.description || '';
    document.getElementById('ett-active').checked = tt.active == 1;
    window.openModal('modal-edit-tt');
}
</script>

