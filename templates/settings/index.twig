                <h3 class="section-title mb-0">🎂 Geburtstagsmail</h3>
                <button type="button" class="btn btn-outline-secondary btn-xs" onclick="resetEmailTpl('birthday')" title="Standard wiederherstellen">↺ Standard</button>
            </div>

            <div class="alert mb-4" style="background:rgba(124,46,248,0.12);border:1px solid rgba(180,100,255,0.3);border-radius:10px;padding:1rem 1.25rem;">
                <div class="fw-600 mb-1" style="color:#c8a0ff;">Automatische Geburtstagsmail</div>
                <p class="mb-2" style="font-size:0.85rem;color:rgba(255,255,255,0.7);line-height:1.6;">
                    Wird täglich per Cron-Job aufgerufen und sendet automatisch eine Glückwunschmail an Tierhalter,
                    deren Patient heute Geburtstag hat. Jedes Tier erhält pro Jahr nur eine Mail.
                </p>
                <p class="mb-0" style="font-size:0.8rem;color:rgba(255,255,255,0.5);">
                    <strong>Cron-Befehl (täglich 08:00 Uhr):</strong><br>
                    <code style="background:rgba(0,0,0,0.3);padding:4px 8px;border-radius:6px;font-size:0.78rem;display:inline-block;margin-top:4px;">
                        0 8 * * * curl -s "{{ app_url }}/cron/geburtstag?token=IHR_TOKEN" &gt; /dev/null
                    </code>
                </p>
            </div>

            <div class="form-group mb-3">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" name="birthday_mail_enabled" value="1" id="birthday-enabled"
                           {{ (settings.birthday_mail_enabled ?? '0') == '1' ? 'checked' : '' }}>
                    <label class="form-check-label fw-500" for="birthday-enabled">
                        Geburtstagsmail aktivieren
                    </label>
                </div>
                <div class="fs-nano text-muted ms-4 mt-1">Wenn deaktiviert, werden keine Geburtstagsmails versendet.</div>
            </div>

            <div class="form-group mb-3">
                <label class="form-label fw-semibold">Betreff</label>
                <input type="text" name="birthday_mail_subject" id="etpl-birthday-subject" class="form-control"
                       value="{{ settings.birthday_mail_subject|default(email_tpl_defaults.birthday_subject) }}">
            </div>

            <div class="form-group mb-3">
                <label class="form-label fw-semibold">Text</label>
                <textarea name="birthday_mail_body" id="etpl-birthday-body" class="form-control" rows="8"
                          style="font-family:monospace;font-size:0.85rem;resize:vertical;">{{ settings.birthday_mail_body|default(email_tpl_defaults.birthday_body) }}</textarea>
            </div>

            <div class="mb-3" style="font-size:0.78rem;color:var(--bs-secondary-color);">
                <strong>Platzhalter im Text:</strong>
                {% for ph in ['{' ~ '{patient_name}}', '{' ~ '{owner_name}}', '{' ~ '{age}}', '{' ~ '{company_name}}'] %}
                <code data-ph="{{ ph }}" style="cursor:pointer;background:var(--bs-tertiary-bg);border:1px solid var(--bs-border-color);border-radius:4px;padding:1px 6px;margin:2px;">{{ ph }}</code>
                {% endfor %}
            </div>

            <div class="form-group mb-3">
                <label class="form-label fw-semibold">Cron-Token <span class="text-muted fw-400">(Sicherheitstoken für den Cron-Aufruf)</span></label>
                <div class="d-flex gap-2">
                    <input type="text" name="birthday_cron_token" class="form-control font-monospace"
                           value="{{ settings.birthday_cron_token ?? '' }}"
                           placeholder="Sicheres zufälliges Token eingeben..."
                           id="birthday-token-input"
