Options -Indexes
RewriteEngine On

# Block direct access to sensitive files and directories
RewriteRule ^(\.env|composer\.(json|lock)|\.git) - [F,L]
RewriteRule ^(app|lang|migrations|templates|plugins)/ - [F,L]

# Serve storage/uploads/ and storage/patients/ directly (images, logos)
RewriteCond %{DOCUMENT_ROOT}/%1 -f
RewriteRule ^(storage/(?:uploads|patients)/.+)$ $1 [L]

# Serve static files from public/ directly
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
RewriteRule ^(.*)$ public/$1 [L]

# Serve directories from public/ directly
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
RewriteRule ^(.*)$ public/$1 [L]

# Everything else → public/index.php (PHP router)
RewriteRule ^(.*)$ public/index.php [QSA,L]
